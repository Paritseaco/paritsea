					flex-direction: column;
					align-items: flex-start;
					justify-content: flex-start;
					gap: var(--spacing-6);
					overflow-y: auto;
					opacity: 0;
					visibility: hidden;
					pointer-events: none;
					transform: translateY(-12px);
					transition:
						opacity var(--transition-base),
						transform var(--transition-base),
						visibility var(--transition-base);
					z-index: 120;
				}

				.site-search {
					display: none;
				}

				.nav-links {
					width: 100%;
					flex-direction: column;
					gap: 0;
					border-top: 1px solid var(--color-border-subtle);
				}

				.nav-links a,
				.nav-admin,
				.nav-language {
					font-size: var(--font-size-lg);
					letter-spacing: 0.005em;
				}

				.nav-links a {
					display: block;
					width: 100%;
					padding: var(--spacing-4) 0;
					border-bottom: 1px solid var(--color-border-subtle);
				}

				/* Mobile accordion — System dropdown */
				.nav-dropdown {
					width: 100%;
				}

				/* Mobile: wrapper spans full row, no border/bg of its own */
				.nav-dropdown-btn {
					width: 100%;
					background: none;
					border-radius: 0;
					border-color: transparent transparent var(--color-border-subtle) transparent;
					border-width: 0 0 1px 0;
				}

				.nav-dropdown:hover .nav-dropdown-btn,
				.nav-dropdown:focus-within .nav-dropdown-btn,
				.nav-dropdown.is-active .nav-dropdown-btn {
					background: none;
					border-color: transparent transparent var(--color-border-subtle) transparent;
				}

				/* Mobile: label takes all available width, chevron at right */
				.nav-dropdown-label {
					flex: 1;
					font-size: var(--font-size-lg);
					letter-spacing: 0.005em;
					padding: var(--spacing-4) 0;
					color: var(--color-text-secondary);
				}

				/* Mobile: chevron button right-side, full height of row */
				.nav-dropdown-chevron-btn {
					padding: var(--spacing-4) var(--spacing-2);
					color: var(--color-text-secondary);
				}

				.nav-dropdown-panel {
					position: static;
					opacity: 1;
					visibility: visible;
					pointer-events: none;
					transform: none;
					box-shadow: none;
					border: none;
					border-radius: 0;
					padding: 0;
					background: transparent;
					max-height: 0;
					overflow: hidden;
					transition: max-height var(--transition-base);
				}

				.nav-dropdown.is-open .nav-dropdown-panel {
					pointer-events: auto;
					max-height: 400px;
				}

				.nav-dropdown-item {
					font-size: var(--font-size-lg);
					letter-spacing: 0.005em;
					padding: var(--spacing-3) var(--spacing-4);
					border-bottom: 1px solid var(--color-border-subtle);
					border-radius: 0;
				}

				.nav-admin {
					padding-top: var(--spacing-1);
				}

				.nav-language {
					width: 100%;
					justify-content: flex-start;
					border: 0;
					height: auto;
					min-height: 44px;
					min-width: 0;
					padding: var(--spacing-2) 0 0;
				}

				body[data-menu-open="true"] {
					overflow: hidden;
				}

				body[data-menu-open="true"] .nav-right {
					opacity: 1;
					visibility: visible;
					pointer-events: auto;
					transform: translateY(0);
				}

				body[data-menu-open="true"] .nav-backdrop {
					display: block;
					position: fixed;
					inset: calc(var(--nav-height) + 1px) 0 0;
					background: color-mix(in srgb, var(--color-text) 8%, transparent);
					border: 0;
					padding: 0;
					margin: 0;
					cursor: pointer;
					z-index: 110;
				}

				body[data-menu-open="true"] .nav-toggle-line:nth-child(1) {
					transform: translateY(5px) rotate(45deg);
				}

				body[data-menu-open="true"] .nav-toggle-line:nth-child(2) {
					opacity: 0;
				}

				body[data-menu-open="true"] .nav-toggle-line:nth-child(3) {
					transform: translateY(-5px) rotate(-45deg);
				}

				.footer-grid {
					grid-template-columns: 1fr;
				}

				.footer-nav {
					display: none;
				}

				.footer-brand {
					grid-column: span 1;
					max-width: none;
				}

				.footer-tagline {
					max-width: 18rem;
					font-size: var(--font-size-xs);
					line-height: 1.6;
				}

				.footer-tagline-full {
					display: none;
				}

				.footer-tagline-short {
					display: inline;
				}

				.footer-bottom {
					flex-direction: column;
					gap: var(--spacing-4);
					text-align: center;
				}
			}
		</style>

		<script>
			// ⌘K / Ctrl+K to focus search
			document.addEventListener("keydown", (e) => {
				if ((e.metaKey || e.ctrlKey) && e.key === "k") {
					e.preventDefault();
					const searchInput = document.querySelector(
						".site-search-input"
					) as HTMLInputElement;
					if (searchInput) {
						searchInput.focus();
					}
				}
			});

			const body = document.body;
			const navToggle = document.querySelector(".nav-toggle");
			const navBackdrop = document.querySelector(".nav-backdrop");
			// Include dropdown labels (nav-dropdown-label) so they close menu on mobile click
			const mobileNavLinks = document.querySelectorAll(".nav-links a, .nav-dropdown-label, .nav-admin");
			const mobileBreakpoint = window.matchMedia("(max-width: 960px)");

			const closeMenu = () => {
				body.removeAttribute("data-menu-open");
				navToggle?.setAttribute("aria-expanded", "false");
				navToggle?.setAttribute("aria-label", "Open navigation menu");
			};

			const openMenu = () => {
				body.setAttribute("data-menu-open", "true");
				navToggle?.setAttribute("aria-expanded", "true");
				navToggle?.setAttribute("aria-label", "Close navigation menu");
			};

			navToggle?.addEventListener("click", () => {
				if (body.getAttribute("data-menu-open") === "true") {
					closeMenu();
				} else {
					openMenu();
				}
			});

			navBackdrop?.addEventListener("click", closeMenu);

			mobileNavLinks.forEach((link) => {
				link.addEventListener("click", () => {
					if (mobileBreakpoint.matches) closeMenu();
				});
			});

			document.addEventListener("keydown", (event) => {
				if (event.key === "Escape") closeMenu();
			});

			mobileBreakpoint.addEventListener("change", (event) => {
				if (!event.matches) closeMenu();
			});

			// ─── Mobile accordion for System dropdown ────────────────────────────
			// Chevron button (▾) toggles the accordion on mobile.
			// Label link navigates to /system and closes menu (handled by mobileNavLinks above).
			// On desktop, the dropdown panel is CSS hover/focus-within — no JS needed.
			const chevronBtns = document.querySelectorAll<HTMLButtonElement>(".nav-dropdown-chevron-btn");

			chevronBtns.forEach((btn) => {
				btn.addEventListener("click", () => {
					const dropdown = btn.closest<HTMLElement>(".nav-dropdown");
					if (!dropdown) return;
					const isOpen = dropdown.classList.toggle("is-open");
					btn.setAttribute("aria-expanded", String(isOpen));
					// Close any other open dropdowns
					chevronBtns.forEach((otherBtn) => {
						if (otherBtn !== btn) {
							const other = otherBtn.closest<HTMLElement>(".nav-dropdown");
							if (other?.classList.contains("is-open")) {
								other.classList.remove("is-open");
								otherBtn.setAttribute("aria-expanded", "false");
							}
						}
					});
				});
			});

			// Close all dropdowns when the mobile menu closes
			const origCloseMenu = closeMenu;
			const closeMenuWithDropdowns = () => {
				origCloseMenu();
				chevronBtns.forEach((btn) => {
					btn.closest<HTMLElement>(".nav-dropdown")?.classList.remove("is-open");
					btn.setAttribute("aria-expanded", "false");
				});
			};

			navBackdrop?.removeEventListener("click", closeMenu);
			navBackdrop?.addEventListener("click", closeMenuWithDropdowns);

			// On mobile: if user taps the System label link, also collapse the accordion
			document.querySelectorAll(".nav-dropdown-label").forEach((label) => {
				label.addEventListener("click", () => {
					const dropdown = label.closest<HTMLElement>(".nav-dropdown");
					if (dropdown && mobileBreakpoint.matches) {
						dropdown.classList.remove("is-open");
						const chevron = dropdown.querySelector<HTMLButtonElement>(".nav-dropdown-chevron-btn");
						chevron?.setAttribute("aria-expanded", "false");
					}
				});
			});
			// ─────────────────────────────────────────────────────────────────────
		</script>
		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>
