---
import { getMenu, getSiteSettings } from "emdash";
import {
	EmDashHead,
	EmDashBodyStart,
	EmDashBodyEnd,
} from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import LiveSearch from "emdash/ui/search";
import { Font } from "astro:assets";
import { resolveBlogSiteIdentity } from "../utils/site-identity";
import {
	alternatePath,
	getAstroLocale,
	localeToHtmlLang,
	localizedPath,
	stripLocalePrefix,
	ui,
} from "../utils/i18n";
import "../styles/theme.css";

interface Props {
	title: string;
	pageTitle?: string | null;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	robots?: string | null;
	type?: "website" | "article";
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	locale?: "th" | "en";
	/** Pass content reference for plugin page contributions on content pages */
	content?: { collection: string; id: string; slug?: string | null };
}

const {
	title,
	pageTitle,
	description,
	image,
	canonical,
	robots,
	type = "website",
	publishedTime,
	modifiedTime,
	author,
	locale: localeProp,
	content,
} = Astro.props;
const locale = localeProp ?? getAstroLocale(Astro);
const copy = ui[locale];
const { siteTitle, siteTagline, siteLogo, siteFavicon } = resolveBlogSiteIdentity(await getSiteSettings());
// If title already includes site title (from getSeoMeta), use as-is
const fullTitle = title.includes(siteTitle) ? title : `${title} — ${siteTitle}`;
const requestPath = Astro.url.searchParams.get("__path") ?? ((Astro.locals.originalPath as string | undefined) ?? Astro.url.pathname);
const canonicalPath = stripLocalePrefix(requestPath);
const resolvedCanonical =
	canonical ??
	new URL(
		requestPath,
		(typeof Astro.site === "string" ? Astro.site : Astro.site?.toString()) ?? Astro.url.origin,
	).toString();
const languageAlternatePath = alternatePath(requestPath, locale);
const thAlternateUrl = new URL(localizedPath(canonicalPath, "th"), Astro.url.origin).toString();
const enAlternateUrl = new URL(localizedPath(canonicalPath, "en"), Astro.url.origin).toString();

// Fetch primary menu defined in seed
const menu = await getMenu("primary");
const navItems = menu?.items.map((item) => ({
	...item,
	label: copy.navLabels[item.label as keyof typeof copy.navLabels] ?? item.label,
	url:
		item.label === "The Doctrine"
			? localizedPath("/the-doctrine", locale)
			: item.label === "Protocols"
				? localizedPath("/protocols", locale)
				: item.label === "Standards"
					? localizedPath("/standards", locale)
						: item.label === "The Method"
							? localizedPath("/the-method", locale)
							: item.label === "Implementations"
								? localizedPath("/implementations", locale)
								: localizedPath(item.url, locale),
}));
const resolvedNavItems = (() => {
	const items = navItems ? [...navItems] : [];
	if (!items.some((item) => stripLocalePrefix(item.url) === "/implementations")) {
		items.push({
			id: "implementations",
			label: copy.navLabels.Implementations,
			url: localizedPath("/implementations", locale),
			target: undefined,
			children: [],
		});
	}
	return items;
})();

// Build public page context for plugin contributions
// SEO data is passed here and rendered securely by EmDashHead
const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: type,
	title: fullTitle,
	pageTitle: pageTitle ?? title,
	description,
	canonical: resolvedCanonical,
	image,
	content,
	seo: { ogImage: image, robots },
	articleMeta: { publishedTime, modifiedTime, author },
	siteName: siteTitle,
});

// Check if user is logged in (for showing admin link)
const isLoggedIn = !!Astro.locals.user;
---

<!doctype html>
<html lang={localeToHtmlLang(locale)}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@400;450;500;600&display=swap" rel="stylesheet" />
		<Font cssVariable="--font-sans" preload />
		<Font cssVariable="--font-mono" />
		<title>{fullTitle}</title>
		<link rel="alternate" hreflang="th" href={thAlternateUrl} />
		<link rel="alternate" hreflang="en" href={enAlternateUrl} />
		<link rel="alternate" hreflang="x-default" href={thAlternateUrl} />
		{siteFavicon && <link rel="icon" href={siteFavicon} />}
		<EmDashHead page={pageCtx} />
		<script is:inline>
			// Apply theme immediately to prevent flash
			(function () {
				var c = document.cookie;
				var i = c.indexOf("theme=");
				var theme = i >= 0 ? c.slice(i + 6).split(";")[0] : null;
				if (theme === "dark" || theme === "light") {
					document.documentElement.classList.add(theme);
				} else if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
					document.documentElement.classList.add("dark");
				}
			})();
		</script>
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />
		<header class="site-header">
			<nav class="nav">
				<a href={localizedPath("/", locale)} class="site-title">
					{siteLogo
						? <img src={siteLogo.url} alt={siteLogo.alt || siteTitle} class="site-logo-img" />
						: siteTitle
					}
				</a>
				<button
					type="button"
					class="nav-toggle"
					aria-expanded="false"
					aria-controls="site-navigation-panel"
					aria-label={copy.menuOpen}
				>
					<span class="nav-toggle-box" aria-hidden="true">
						<span class="nav-toggle-line"></span>
						<span class="nav-toggle-line"></span>
						<span class="nav-toggle-line"></span>
					</span>
				</button>
				<div class="nav-right" id="site-navigation-panel">
					<LiveSearch
						placeholder={copy.search}
						class="site-search"
						inputClass="site-search-input"
						resultsClass="site-search-results"
						resultClass="site-search-result"
						collections={["posts", "pages"]}
					/>
					<div class="nav-links">
						{
							resolvedNavItems.map((item) => (
								<a
									href={item.url}
									target={item.target}
									class={stripLocalePrefix(item.url) === "/the-doctrine" ? "nav-doctrine" : undefined}
								>
									{item.label}
								</a>
							))
						}
					</div>
					{
						isLoggedIn && (
							<a href="/_emdash/admin" class="nav-admin">
								{copy.admin}
							</a>
						)
					}
					<a href={languageAlternatePath} class="nav-language" aria-label={locale === "en" ? "Switch to Thai" : "Switch to English"}>
						{copy.languageSwitch}
					</a>
				</div>
			</nav>
			<button
				type="button"
				class="nav-backdrop"
				aria-label={copy.menuClose}
				tabindex="-1"
			></button>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<div class="footer-inner">
				<div class="footer-grid">
					<div class="footer-brand">
						<a href={localizedPath("/", locale)} class="footer-logo">
							{siteLogo
								? <img src={siteLogo.url} alt={siteLogo.alt || siteTitle} class="footer-logo-img" />
								: siteTitle
							}
						</a>
						<p class="footer-tagline">
							<span class="footer-tagline-full">{siteTagline}</span>
							<span class="footer-tagline-short">{copy.footerTagline}</span>
						</p>
					</div>
					<div class="footer-nav">
						<h4 class="footer-heading">{copy.frameworkLayers}</h4>
						<ul class="footer-links">
							<li><a href={localizedPath("/the-doctrine", locale)}>{copy.navLabels["The Doctrine"]}</a></li>
							<li><a href={localizedPath("/protocols", locale)}>{copy.navLabels.Protocols}</a></li>
							<li><a href={localizedPath("/standards", locale)}>{copy.navLabels.Standards}</a></li>
							<li><a href={localizedPath("/the-method", locale)}>{copy.navLabels["The Method"]}</a></li>
							<li><a href={localizedPath("/implementations", locale)}>{copy.navLabels.Implementations}</a></li>
						</ul>
					</div>
					<div class="footer-nav">
						<h4 class="footer-heading">{copy.legalContact}</h4>
						<ul class="footer-links">
							<li><a href={localizedPath("/licensing", locale)}>{copy.licensing}</a></li>
							<li><a href={localizedPath("/contact", locale)}>{copy.contact}</a></li>
						</ul>
					</div>
				</div>
				<div class="footer-bottom">
					<p class="footer-copyright">
						© Paritsea · <a href={localizedPath("/licensing", locale)}>{copy.licensing}</a>
					</p>
					<div class="theme-switcher">
						<button
							type="button"
							class="theme-btn"
							data-theme="light"
							aria-label={copy.themeLight}
						>
							<svg
								width="16"
								height="16"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								><circle cx="12" cy="12" r="5"></circle><line
									x1="12"
									y1="1"
									x2="12"
									y2="3"></line><line x1="12" y1="21" x2="12" y2="23"
								></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"
								></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"
								></line><line x1="1" y1="12" x2="3" y2="12"></line><line
									x1="21"
									y1="12"
									x2="23"
									y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"
								></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"
								></line></svg
							>
						</button>
						<button
							type="button"
							class="theme-btn"
							data-theme="dark"
							aria-label={copy.themeDark}
						>
							<svg
								width="16"
								height="16"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
								></path></svg
							>
						</button>
						<button
							type="button"
							class="theme-btn"
							data-theme="system"
							aria-label={copy.themeSystem}
						>
							<svg
								width="16"
								height="16"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								><rect x="2" y="3" width="20" height="14" rx="2" ry="2"
								></rect><line x1="8" y1="21" x2="16" y2="21"></line><line
									x1="12"
									y1="17"
									x2="12"
									y2="21"></line></svg
							>
						</button>
					</div>
				</div>
			</div>
		</footer>

		<script>
			// Theme switcher
			const THEME_REGEX = /theme=([^;]+)/;
			const themeBtns =
				document.querySelectorAll<HTMLButtonElement>(".theme-btn");
			const root = document.documentElement;

			function setCookie(
				name: string,
				value: string,
				maxAge: number = 31536000
			) {
				const secure = location.protocol === "https:" ? "; Secure" : "";
				if (value === "") {
					document.cookie = `${name}=; path=/; max-age=0; SameSite=Lax${secure}`;
				} else {
					document.cookie = `${name}=${value}; path=/; max-age=${maxAge}; SameSite=Lax${secure}`;
				}
			}

			function setTheme(theme: string) {
				if (theme === "system") {
					setCookie("theme", "");
					root.classList.remove("light", "dark");
					if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
						root.classList.add("dark");
					}
				} else {
					setCookie("theme", theme);
					root.classList.remove("light", "dark");
					root.classList.add(theme);
				}
				updateActiveBtn(theme);
			}

			function updateActiveBtn(theme: string) {
				themeBtns.forEach((btn) => {
					btn.classList.toggle("active", btn.dataset.theme === theme);
				});
			}

			function getStoredTheme(): string {
				const match = document.cookie.match(THEME_REGEX);
				return match ? match[1] : "system";
			}

			// Initialize
			const storedTheme = getStoredTheme();
			setTheme(storedTheme);

			themeBtns.forEach((btn) => {
				btn.addEventListener("click", () => {
					setTheme(btn.dataset.theme || "system");
				});
			});

			// Listen for system preference changes
			window
				.matchMedia("(prefers-color-scheme: dark)")
				.addEventListener("change", (e) => {
					if (getStoredTheme() === "system") {
						root.classList.toggle("dark", e.matches);
					}
				});
		</script>

		<style is:global>
			/*
			 * Establish layer order: "base" has lower priority than unlayered
			 * styles, so theme.css overrides always win regardless of source
			 * order in the bundled CSS.
			 */
			@layer base;

			@layer base {
				*:where(:not([class*="emdash"]):not([class*="ec-"])),
				*:where(:not([class*="emdash"]):not([class*="ec-"]))::before,
				*:where(:not([class*="emdash"]):not([class*="ec-"]))::after {
					box-sizing: border-box;
				}

				body,
				h1,
				h2,
				h3,
				h4,
				h5,
				h6,
				p,
				ul,
				ol,
				figure,
				blockquote,
				dl,
				dd {
					margin: 0;
				}

				ul,
				ol {
					padding: 0;
				}

				:root {
					/* Colors - Light mode: Warm Cream / Ink */
					--color-bg: #f0ece5;
					--color-bg-subtle: #e8e4dc;
					--color-text: #1c1410;
					--color-text-secondary: #4a3c34;
					--color-muted: #8c7d74;
					--color-border: #cdc8c0;
					--color-border-subtle: #dbd7d0;
					--color-surface: #e8e4dc;
					--color-accent: #1c1410;
					--color-accent-hover: #2e2218;
					--color-on-accent: #f0ece5;
					--color-accent-ring: color-mix(
						in srgb,
						var(--color-accent) 10%,
						transparent
					);
					--color-highlight: #c4bdb4;
					--color-rule: #b8b2aa;
					--color-sand: #c4a882;
					--color-sand-subtle: #ede6da;
					--color-clay: #b8794a;
					--color-sea: #3f5753;

					/* EmDash search theming */
					--emdash-search-bg: var(--color-bg);
					--emdash-search-text: var(--color-text);
					--emdash-search-muted: var(--color-muted);
					--emdash-search-border: var(--color-border);
					--emdash-search-hover: var(--color-surface);
					--emdash-search-highlight: var(--color-text);

					/* Fonts */
					--font-serif: 'Playfair Display', Georgia, serif;
					--font-sans: 'Inter', system-ui, sans-serif;

					/* Type scale */
					--font-size-2xs: 0.6875rem;
					--font-size-xs: 0.75rem;
					--font-size-sm: 0.875rem;
					--font-size-base: 1rem;
					--font-size-lg: 1.125rem;
					--font-size-xl: 1.375rem;
					--font-size-2xl: 1.625rem;
					--font-size-3xl: 2.125rem;
					--font-size-4xl: 2.75rem;
					--font-size-5xl: 3.75rem;

					/* Line heights */
					--leading-tight: 1.1;
					--leading-snug: 1.25;
					--leading-normal: 1.55;
					--leading-relaxed: 1.75;

					/* Spacing */
					--spacing-1: 0.25rem;
					--spacing-2: 0.5rem;
					--spacing-3: 0.75rem;
					--spacing-4: 1rem;
					--spacing-5: 1.25rem;
					--spacing-6: 1.5rem;
					--spacing-7: 1.75rem;
					--spacing-8: 2rem;
					--spacing-10: 2.5rem;
					--spacing-12: 3rem;
					--spacing-16: 4rem;
					--spacing-20: 5rem;
					--spacing-24: 6rem;

					/* Legacy spacing aliases */
					--spacing-xs: var(--spacing-1);
					--spacing-sm: var(--spacing-2);
					--spacing-md: var(--spacing-4);
					--spacing-lg: var(--spacing-6);
					--spacing-xl: var(--spacing-8);
					--spacing-2xl: var(--spacing-12);
					--spacing-3xl: var(--spacing-16);

					/* Layout */
					--content-width: 600px;
					--wide-width: 1100px;
					--max-width: var(--content-width);
					--gutter-width: 200px;
					--radius: 0px;
					--radius-lg: 2px;
					--radius-full: 9999px;

					/* Transitions */
					--transition-fast: 120ms ease;
					--transition-base: 180ms ease;

					/* Nav */
					--nav-height: 64px;

					/* Search */
					--search-input-width: 156px;

					/* Article layout */
					--meta-col-width: 160px;

					/* Avatar sizes */
					--avatar-size-xs: 16px;
					--avatar-size-sm: 18px;
					--avatar-size-md: 22px;
					--avatar-size-lg: 30px;

					/* Letter spacing */
					--tracking-tight: -0.02em;
					--tracking-snug: -0.01em;
					--tracking-normal: 0em;
					--tracking-wide: 0.06em;
					--tracking-wider: 0.1em;
					--tracking-widest: 0.14em;

					/* Tag pill */
					--tag-padding-y: 2px;

					/* Shadows */
					--shadow-dropdown: 0 2px 16px rgba(42, 31, 24, 0.12);
					--shadow-btn-active: none;
				}

				/* Dark mode via system preference */
				@media (prefers-color-scheme: dark) {
					:root:not(.light) {
						--color-bg: #1c1917;
						--color-bg-subtle: #232018;
						--color-text: #f0ebe3;
						--color-text-secondary: #c4b9ae;
						--color-muted: #8c7e74;
						--color-border: #38332e;
						--color-border-subtle: #2c2822;
						--color-surface: #262220;
						--color-accent: #e8dfd4;
						--color-accent-hover: #f0ebe3;
						--color-on-accent: #1c1917;
						--color-highlight: #332e28;
						--color-rule: #3a3530;
						--color-sand: #a8916c;
						--color-sand-subtle: #2a2318;
					}
				}

				/* Explicit dark mode */
				:root.dark {
					--color-bg: #1c1917;
					--color-bg-subtle: #232018;
					--color-text: #f0ebe3;
					--color-text-secondary: #c4b9ae;
					--color-muted: #8c7e74;
					--color-border: #38332e;
					--color-border-subtle: #2c2822;
					--color-surface: #262220;
					--color-accent: #e8dfd4;
					--color-accent-hover: #f0ebe3;
					--color-on-accent: #1c1917;
					--color-highlight: #332e28;
					--color-rule: #3a3530;
					--color-sand: #a8916c;
					--color-sand-subtle: #2a2318;
					--color-clay: #c4865a;
					--color-sea: #5a7d7b;
				}

				html {
					scroll-behavior: smooth;
				}

				body {
					font-family: var(--font-sans);
					font-size: var(--font-size-base);
					line-height: var(--leading-relaxed);
					color: var(--color-text);
					background: var(--color-bg);
					-webkit-font-smoothing: antialiased;
					-moz-osx-font-smoothing: grayscale;
					min-height: 100vh;
				}

				a:where(:not([class*="emdash"]):not([class*="ec-"])) {
					color: inherit;
					text-decoration: none;
					transition: opacity var(--transition-fast);
				}

				a:where(:not([class*="emdash"]):not([class*="ec-"])):hover {
					opacity: 0.65;
				}

				img {
					max-width: 100%;
					height: auto;
					display: block;
				}

				/* Serif headings: Playfair Display for visual identity */
				h1,
				h2,
				h3,
				h4,
				h5,
				h6 {
					font-family: var(--font-serif);
					line-height: var(--leading-tight);
					font-weight: 700;
					letter-spacing: var(--tracking-snug);
					color: var(--color-text);
				}

				h1 {
					font-weight: 700;
					letter-spacing: var(--tracking-tight);
				}

				h2 {
					font-weight: 600;
					font-size: var(--font-size-2xl);
				}

				/* Use sans for UI labels */
				.label,
				.meta,
				.nav-links a,
				.nav-language,
				.footer-heading,
				.section-title {
					font-family: var(--font-sans);
				}

				::selection {
					background: var(--color-highlight);
					color: var(--color-text);
				}

				/* ─── Thai locale typography ─── */
				:lang(th) {
					--font-sans: 'Sarabun', system-ui, sans-serif;
					--font-serif: 'Sarabun', system-ui, sans-serif;
				}

				:lang(th) body {
					font-size: 1.0625rem;   /* Sarabun reads slightly larger than Inter */
					line-height: 1.85;      /* Thai script needs more vertical rhythm */
					letter-spacing: 0;
					word-break: keep-all;   /* prevent break mid-syllable */
				}

				:lang(th) h1,
				:lang(th) h2,
				:lang(th) h3,
				:lang(th) h4,
				:lang(th) h5,
				:lang(th) h6 {
					font-weight: 600;
					letter-spacing: 0;
					line-height: 1.35;
				}

				:lang(th) .hero-statement {
					line-height: 1.25;
				}

				:lang(th) .article-content :global(p),
				:lang(th) .article-content :global(li) {
					letter-spacing: 0;
					line-height: 1.9;
				}
			}
		</style>

		<style>
			/* ─── Header / Nav ─── */
			.site-header {
				position: sticky;
				top: 0;
				z-index: 100;
				background: var(--color-bg);
				border-bottom: 1px solid var(--color-border-subtle);
			}

			.nav {
				display: flex;
				justify-content: space-between;
				align-items: center;
				max-width: var(--wide-width);
				margin: 0 auto;
				padding: 0 var(--spacing-8);
				height: var(--nav-height);
				gap: var(--spacing-6);
			}

			.site-title {
				font-family: var(--font-serif);
				font-size: var(--font-size-lg);
				font-weight: 400;
				color: var(--color-text);
