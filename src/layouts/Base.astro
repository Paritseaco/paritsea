---
import { getMenu, getSiteSettings } from "emdash";
import {
	EmDashHead,
	EmDashBodyStart,
	EmDashBodyEnd,
} from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import LiveSearch from "emdash/ui/search";
import { Font } from "astro:assets";
import { resolveBlogSiteIdentity } from "../utils/site-identity";
import {
	alternatePath,
	getAstroLocale,
	localeToHtmlLang,
	localizedPath,
	stripLocalePrefix,
	ui,
} from "../utils/i18n";
import "../styles/theme.css";

interface Props {
	title: string;
	pageTitle?: string | null;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	robots?: string | null;
	type?: "website" | "article";
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	locale?: "th" | "en";
	structuredData?: Record<string, unknown> | null;
	/** Pass content reference for plugin page contributions on content pages */
	content?: { collection: string; id: string; slug?: string | null };
}

const {
	title,
	pageTitle,
	description,
	image,
	canonical,
	robots,
	type = "website",
	publishedTime,
	modifiedTime,
	author,
	locale: localeProp,
	structuredData: pageStructuredData,
	content,
} = Astro.props;
const locale = localeProp ?? getAstroLocale(Astro);
const copy = ui[locale];
const { siteTitle, siteTagline, siteFavicon } = resolveBlogSiteIdentity(await getSiteSettings());
const brandMark = "/images/logo/paritsea-mark.svg";
const brandFavicon = "/images/logo/paritsea-mark.svg";
const resolvedFavicon = siteFavicon ?? brandFavicon;
// If title already includes site title (from getSeoMeta), use as-is
const fullTitle = title.includes(siteTitle) ? title : `${title} — ${siteTitle}`;
const requestPath = Astro.url.searchParams.get("__path") ?? ((Astro.locals.originalPath as string | undefined) ?? Astro.url.pathname);
const canonicalPath = stripLocalePrefix(requestPath);
const resolvedCanonical =
	canonical ??
	new URL(
		requestPath,
		(typeof Astro.site === "string" ? Astro.site : Astro.site?.toString()) ?? Astro.url.origin,
	).toString();
// SEO-03: fallback OG image for pages without a dedicated featured image
const siteOrigin = (typeof Astro.site === "string" ? Astro.site : Astro.site?.toString())?.replace(/\/$/, "") ?? Astro.url.origin;
const resolvedOgImage = image ?? `${siteOrigin}/images/logo.jpg`;
const resolvedDescription = description ?? siteTagline;
const languageAlternatePath = alternatePath(requestPath, locale);
const thAlternateUrl = new URL(localizedPath(canonicalPath, "th"), Astro.url.origin).toString();
const enAlternateUrl = new URL(localizedPath(canonicalPath, "en"), Astro.url.origin).toString();

// Fetch primary menu defined in seed
const menu = await getMenu("primary");

// Helper: resolve one menu item's label + URL (used recursively for children).
// Return type is explicit to avoid ts(7023)/ts(7024) implicit-any on recursive call.
type ResolvedMenuItem = {
	label: string;
	url: string;
	children: ResolvedMenuItem[];
	[k: string]: unknown;
};

function resolveMenuItem(item: { label?: string; url?: string; children?: unknown[]; [k: string]: unknown }): ResolvedMenuItem {
	return {
		...item,
		label: copy.navLabels[item.label as keyof typeof copy.navLabels] ?? item.label ?? "",
		url: localizedPath(item.url ?? "/", locale),
		children: (item.children ?? []).map((child) =>
			resolveMenuItem(child as typeof item)
		),
	};
}

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const navItems: ResolvedMenuItem[] = (menu?.items ?? []).map((item) => resolveMenuItem(item as any));

const resolvedNavItems = (() => {
	const systemItem = navItems.find((item) => stripLocalePrefix(item.url) === "/system");
	const systemChildren = systemItem?.children?.length
		? systemItem.children
		: [
				{
					label: copy.navLabels.Frameworks ?? copy.navLabels.Framework,
					url: localizedPath("/system/frameworks", locale),
					children: [],
				},
				{
					label: copy.navLabels.Protocols,
					url: localizedPath("/system/protocols", locale),
					children: [],
				},
				{
					label: copy.navLabels.Standards,
					url: localizedPath("/system/standards", locale),
					children: [],
				},
			];
	return [
		{
			id: "lens",
			label: copy.navLabels.Lens ?? "Lens",
			url: localizedPath("/about", locale),
			target: undefined,
			children: [],
		},
		{
			id: "journal",
			label: copy.navLabels.Journal ?? "Journal",
			url: localizedPath("/journal", locale),
			target: undefined,
			children: [],
		},
		{
			id: "system",
			label: copy.navLabels.System ?? "System",
			url: localizedPath("/system", locale),
			target: undefined,
			children: systemChildren,
		},
		{
			id: "ip",
			label: copy.navLabels.IP ?? "IP",
			url: localizedPath("/ip", locale),
			target: undefined,
			children: [],
		},
	] as ResolvedMenuItem[];
})();

// Active-state helper: used to apply nav-framework and system dropdown is-active classes
const currentPath = stripLocalePrefix(Astro.url.pathname);

// Build public page context for plugin contributions
// SEO data is passed here and rendered securely by EmDashHead
const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: type,
	title: fullTitle,
	pageTitle: pageTitle ?? title,
	description,
	canonical: resolvedCanonical,
	image: resolvedOgImage,
	content,
	seo: { ogImage: resolvedOgImage, robots },
	articleMeta: { publishedTime, modifiedTime, author },
	siteName: siteTitle,
});

// Check if user is logged in (for showing admin link)
const isLoggedIn = !!Astro.locals.user;
const defaultStructuredData = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "WebSite",
			"@id": `${siteOrigin}/#website`,
			url: siteOrigin,
			name: siteTitle,
			description: resolvedDescription,
			inLanguage: ["en", "th"],
		},
		{
			"@type": "Person",
			"@id": `${siteOrigin}/about#parit-ritchai`,
			name: "Parit Ritchai",
			url: `${siteOrigin}/about`,
			sameAs: [
				"https://www.youtube.com/@paritsea",
				"https://www.threads.com/@paritsea",
				"https://www.instagram.com/paritsea",
				"https://www.facebook.com/profile.php?id=61588809970162",
				"https://www.linkedin.com/company/paritsea/",
			],
		},
		{
			"@type": "Organization",
			"@id": `${siteOrigin}/#organization`,
			name: "Paritsea",
			url: siteOrigin,
			logo: `${siteOrigin}${brandMark}`,
			sameAs: [
				"https://www.youtube.com/@paritsea",
				"https://www.threads.com/@paritsea",
				"https://www.instagram.com/paritsea",
				"https://www.facebook.com/profile.php?id=61588809970162",
				"https://www.linkedin.com/company/paritsea/",
			],
		},
	],
};
const structuredData = pageStructuredData ?? defaultStructuredData;
---

<!doctype html>
<html lang={localeToHtmlLang(locale)}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;450;500;600&family=JetBrains+Mono:wght@400;500&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&family=Sarabun:wght@300;400;500;600&display=swap" rel="stylesheet" />
		<Font cssVariable="--font-sans" preload />
		<Font cssVariable="--font-mono" />
  <title>{fullTitle}</title>
  <link rel="alternate" hreflang="en" href={enAlternateUrl} />
  <link rel="alternate" hreflang="th" href={thAlternateUrl} />
  <link rel="alternate" hreflang="x-default" href={enAlternateUrl} />
  <link rel="icon" href={resolvedFavicon} type="image/svg+xml" />
  <EmDashHead page={pageCtx} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={resolvedDescription} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
<script is:inline>
			// Apply theme immediately to prevent flash
			(function () {
				var c = document.cookie;
				var i = c.indexOf("theme=");
				var theme = i >= 0 ? c.slice(i + 6).split(";")[0] : null;
				if (theme === "dark" || theme === "light") {
					document.documentElement.classList.add(theme);
				} else if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
					document.documentElement.classList.add("dark");
				}
			})();
		</script>
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />
		<a class="skip-link" href="#main-content">{locale === "th" ? "ข้ามไปยังเนื้อหาหลัก" : "Skip to main content"}</a>
		<header class="site-header">
			<nav class="nav">
				<a href={localizedPath("/", locale)} class="site-title">
					<img src={brandMark} alt="" class="site-logo-mark" aria-hidden="true" />
					<span class="site-logo-word">{siteTitle}</span>
				</a>
				<button
					type="button"
					class="nav-toggle"
					aria-expanded="false"
					aria-controls="site-navigation-panel"
					aria-label={copy.menuOpen}
				>
					<span class="nav-toggle-box" aria-hidden="true">
						<span class="nav-toggle-line"></span>
						<span class="nav-toggle-line"></span>
						<span class="nav-toggle-line"></span>
					</span>
				</button>
				<div class="nav-right" id="site-navigation-panel">
					<LiveSearch
						placeholder={copy.search}
						class="site-search"
						inputClass="site-search-input"
						resultsClass="site-search-results"
						resultClass="site-search-result"
						collections={["posts", "pages"]}
					/>
					<div class="nav-links">
						{resolvedNavItems.map((item) =>
							item.children && item.children.length > 0 ? (
								<div
									class:list={[
										"nav-dropdown",
										{
											"is-active":
												currentPath === stripLocalePrefix(item.url) ||
												currentPath.startsWith(stripLocalePrefix(item.url) + "/"),
										},
									]}
								>
									<div class="nav-dropdown-btn">
										<a
											href={item.url}
											class="nav-dropdown-label"
											aria-current={
												currentPath === stripLocalePrefix(item.url) ||
												currentPath.startsWith(stripLocalePrefix(item.url) + "/")
													? "page"
													: undefined
											}
										>
											{item.label}
										</a>
										<button
											class="nav-dropdown-chevron-btn"
											aria-expanded="false"
											aria-haspopup="true"
											aria-label={`${item.label} — sub-pages`}
										>
											<span class="nav-dropdown-chevron" aria-hidden="true">▾</span>
										</button>
									</div>
									<div class="nav-dropdown-panel" role="menu">
										{item.children.map((child) => (
											<a
												href={child.url}
												role="menuitem"
												class:list={[
													"nav-dropdown-item",
											{ "nav-framework": stripLocalePrefix(child.url) === "/system/frameworks" },
													{ "is-active": currentPath === stripLocalePrefix(child.url) },
												]}
											>
												{child.label}
											</a>
										))}
									</div>
								</div>
							) : (
								<a
									href={item.url}
									target={item.target as "_blank" | "_self" | "_parent" | "_top" | undefined}
									aria-current={
										currentPath === stripLocalePrefix(item.url) ||
										currentPath.startsWith(stripLocalePrefix(item.url) + "/")
											? "page"
											: undefined
									}
								>
									{item.label}
								</a>
							)
						)}
					</div>
					{
						isLoggedIn && (
							<a href="/_emdash/admin" class="nav-admin">
								{copy.admin}
							</a>
						)
					}
					<a href={languageAlternatePath} class="nav-language" aria-label={locale === "en" ? "Switch to Thai" : "Switch to English"}>
						{copy.languageSwitch}
					</a>
				</div>
			</nav>
			<button
				type="button"
				class="nav-backdrop"
				aria-label={copy.menuClose}
				tabindex="-1"
			></button>
		</header>

		<main id="main-content" tabindex="-1">
			<slot />
		</main>

		<footer class="site-footer">
			<div class="footer-inner">
				<div class="footer-grid">
					<div class="footer-brand">
						<a href={localizedPath("/", locale)} class="footer-logo">
							<img src={brandMark} alt="" class="footer-logo-mark" aria-hidden="true" />
							<span>{siteTitle}</span>
						</a>
						<p class="footer-tagline">{copy.footerTagline}</p>
					</div>
					<div class="footer-nav">
						<h4 class="footer-heading">{copy.thoughtPath}</h4>
						<ul class="footer-links">
							<li><a href={localizedPath("/about", locale)}>{copy.navLabels.Lens}</a></li>
							<li><a href={localizedPath("/journal", locale)}>{copy.navLabels.Journal}</a></li>
							<li><a href={localizedPath("/system", locale)}>{copy.navLabels.System}</a></li>
							<li><a href={localizedPath("/ip", locale)}>{copy.navLabels.IP}</a></li>
							<li><a href={localizedPath("/media", locale)}>{copy.navLabels.Media}</a></li>
						</ul>
					</div>
					<div class="footer-nav">
						<h4 class="footer-heading">{copy.frameworkLayers}</h4>
						<ul class="footer-links">
							<li><a href={localizedPath("/system/frameworks", locale)}>{copy.navLabels.Frameworks ?? copy.navLabels.Framework}</a></li>
							<li><a href={localizedPath("/system/protocols", locale)}>{copy.navLabels.Protocols}</a></li>
							<li><a href={localizedPath("/system/standards", locale)}>{copy.navLabels.Standards}</a></li>
						</ul>
					</div>
				<div class="footer-nav">
					<h4 class="footer-heading">{copy.legalContact}</h4>
					<ul class="footer-links">
						<li><a href={localizedPath("/about", locale)}>{copy.about}</a></li>
						<li><a href={localizedPath("/ip/licensing", locale)}>{copy.licensing}</a></li>
						<li><a href={localizedPath("/contact", locale)}>{copy.contact}</a></li>
					</ul>
				</div>
				<div class="footer-nav">
					<h4 class="footer-heading">{locale === "th" ? "บริบทการประยุกต์ใช้" : "Applied context"}</h4>
					<ul class="footer-links">
						<li><a href="https://seocean.co.th" target="_blank" rel="noreferrer">{locale === "th" ? "SE Ocean นำงานบางส่วนไปใช้กับบริบทองค์กร →" : "SE Ocean applies selected work in organizational contexts →"}</a></li>
					</ul>
				</div>
				</div>
				<div class="footer-bottom">
					<p class="footer-copyright">
						© Paritsea · <a href={localizedPath("/ip/licensing", locale)}>{copy.licensing}</a>
					</p>
					<div class="theme-switcher">
						<button
							type="button"
							class="theme-btn"
							data-theme="light"
							aria-label={copy.themeLight}
						>
							<svg
								width="16"
								height="16"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								><circle cx="12" cy="12" r="5"></circle><line
									x1="12"
									y1="1"
									x2="12"
									y2="3"></line><line x1="12" y1="21" x2="12" y2="23"
								></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"
								></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"
								></line><line x1="1" y1="12" x2="3" y2="12"></line><line
									x1="21"
									y1="12"
									x2="23"
									y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"
								></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"
								></line></svg
							>
						</button>
						<button
							type="button"
							class="theme-btn"
							data-theme="dark"
							aria-label={copy.themeDark}
						>
							<svg
								width="16"
								height="16"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
								></path></svg
							>
						</button>
						<button
							type="button"
							class="theme-btn"
							data-theme="system"
							aria-label={copy.themeSystem}
						>
							<svg
								width="16"
								height="16"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								><rect x="2" y="3" width="20" height="14" rx="2" ry="2"
								></rect><line x1="8" y1="21" x2="16" y2="21"></line><line
									x1="12"
									y1="17"
									x2="12"
									y2="21"></line></svg
							>
						</button>
					</div>
				</div>
			</div>
		</footer>

		<script>
			// Theme switcher
			const THEME_REGEX = /theme=([^;]+)/;
			const themeBtns =
				document.querySelectorAll<HTMLButtonElement>(".theme-btn");
			const root = document.documentElement;

			function setCookie(
				name: string,
				value: string,
				maxAge: number = 31536000
			) {
				const secure = location.protocol === "https:" ? "; Secure" : "";
				if (value === "") {
					document.cookie = `${name}=; path=/; max-age=0; SameSite=Lax${secure}`;
				} else {
					document.cookie = `${name}=${value}; path=/; max-age=${maxAge}; SameSite=Lax${secure}`;
				}
			}

			function setTheme(theme: string) {
				if (theme === "system") {
					setCookie("theme", "");
					root.classList.remove("light", "dark");
					if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
						root.classList.add("dark");
					}
				} else {
					setCookie("theme", theme);
					root.classList.remove("light", "dark");
					root.classList.add(theme);
				}
				updateActiveBtn(theme);
			}

			function updateActiveBtn(theme: string) {
				themeBtns.forEach((btn) => {
					btn.classList.toggle("active", btn.dataset.theme === theme);
				});
			}

			function getStoredTheme(): string {
				const match = document.cookie.match(THEME_REGEX);
				return match ? match[1] : "system";
			}

			// Initialize
			const storedTheme = getStoredTheme();
			setTheme(storedTheme);

			themeBtns.forEach((btn) => {
				btn.addEventListener("click", () => {
					setTheme(btn.dataset.theme || "system");
				});
			});

			// Listen for system preference changes
			window
				.matchMedia("(prefers-color-scheme: dark)")
				.addEventListener("change", (e) => {
					if (getStoredTheme() === "system") {
						root.classList.toggle("dark", e.matches);
					}
				});
		</script>

		<style is:global>
			/*
			 * Base reset and structural defaults.
			 * Theme variables (colors, spacing, typography) are defined in theme.css with higher priority.
			 */
			@layer base;

			@layer base {
				*:where(:not([class*="emdash"]):not([class*="ec-"])),
				*:where(:not([class*="emdash"]):not([class*="ec-"]))::before,
				*:where(:not([class*="emdash"]):not([class*="ec-"]))::after {
					box-sizing: border-box;
				}

				body,
				h1,
				h2,
				h3,
				h4,
				h5,
				h6,
				p,
				ul,
				ol,
				figure,
				blockquote,
				dl,
				dd {
					margin: 0;
				}

				ul,
				ol {
					padding: 0;
				}

				/* EmDash search theming from theme vars */
				:root {
					--emdash-search-bg: var(--color-bg);
					--emdash-search-text: var(--color-text);
					--emdash-search-muted: var(--color-muted);
					--emdash-search-border: var(--color-border);
					--emdash-search-hover: var(--color-surface);
					--emdash-search-highlight: var(--color-text);
				}

				html {
					scroll-behavior: smooth;
				}

				body {
					font-family: var(--font-sans);
					font-size: var(--font-size-base);
					line-height: var(--leading-relaxed);
					color: var(--color-text);
					background: var(--color-bg);
					-webkit-font-smoothing: antialiased;
					-moz-osx-font-smoothing: grayscale;
					min-height: 100vh;
				}

				a:where(:not([class*="emdash"]):not([class*="ec-"])) {
					color: inherit;
					text-decoration: none;
					transition: opacity var(--transition-fast);
				}

				a:where(:not([class*="emdash"]):not([class*="ec-"])):hover {
					opacity: 0.65;
				}

				img {
					max-width: 100%;
					height: auto;
					display: block;
				}

				/* Serif headings */
				h1,
				h2,
				h3,
				h4,
				h5,
				h6 {
					font-family: var(--font-serif);
					line-height: var(--leading-tight);
					font-weight: 500;
					letter-spacing: var(--tracking-snug);
					color: var(--color-text);
				}

				h1 {
					font-weight: 500;
					letter-spacing: var(--tracking-tight);
				}

				h2 {
					font-weight: 500;
					font-size: var(--font-size-2xl);
				}

				/* Sans for UI labels */
				.label,
				.meta,
				.nav-links a,
				.nav-language,
				.footer-heading,
				.section-title {
					font-family: var(--font-sans);
				}

				::selection {
					background: var(--color-highlight);
					color: var(--color-text);
				}

				:focus-visible {
					outline: 2px solid var(--color-accent);
					outline-offset: 3px;
				}

				main:focus {
					outline: none;
				}

				/* ─── Thai locale typography ─── */
