---
import { getEmDashCollection, getEntryTerms } from "emdash";
import Base from "../layouts/Base.astro";
import Breadcrumb from "./Breadcrumb.astro";
import UsageGuidance from "./UsageGuidance.astro";
import { isFrameworkPageSlug, resolveFrameworkPage } from "../utils/public-paths";
import { getReadingTime } from "../utils/reading-time";
import {
	formatDateForLocale,
	getAstroLocale,
	localizeEntry,
	localizeTermLabel,
	localizedPath,
	ui,
} from "../utils/i18n";

interface Props {
	slug: "protocols" | "standards" | "the-method";
}

const { slug } = Astro.props;
const locale = getAstroLocale(Astro);
const navLabels = ui[locale].navLabels;

let posts = [];

try {
	({ entries: posts } = await getEmDashCollection("posts", {
		where: { framework_page: slug },
		orderBy: { published_at: "desc" },
	}));
} catch {
	({ entries: posts } = await getEmDashCollection("posts", {
		where: { category: slug },
		orderBy: { published_at: "desc" },
	}));
}

const filteredPosts = await Promise.all(
	posts.map(async (post) => {
		const legacyTerms = await getEntryTerms("posts", post.data.id, "category");
		const frameworkPage = resolveFrameworkPage(
			post.data.framework_page,
			legacyTerms.find((term) => isFrameworkPageSlug(term.slug))?.slug,
		);
		const categories = legacyTerms.filter((term) => !isFrameworkPageSlug(term.slug));
		const bylines = post.data.bylines ?? [];
		return {
			post: localizeEntry(post, "posts", locale),
			frameworkPage,
			cats: (categories.length > 0 ? categories : legacyTerms).map((term) => ({
				...term,
				label: localizeTermLabel(term.label, locale),
			})),
			bylines,
		};
	})
);

const scopedPosts = filteredPosts.filter(({ frameworkPage }) => frameworkPage === slug);

const formatDate = (date: Date) =>
	formatDateForLocale(date, locale);

const isProtocols = slug === "protocols";
const isStandards = slug === "standards";
const isMethod = slug === "the-method";
const pageTitle = isProtocols ? "Protocols — Paritsea" : isStandards ? "Standards — Paritsea" : "Journal — Paritsea";
const pageDescription = locale === "th"
	? isProtocols
		? "Protocols คือเครื่องมืออ้างอิงเชิงโครงสร้างที่สืบเนื่องจาก Framework และออกแบบให้ปรับใช้ข้ามโดเมนได้โดยไม่เสียความหมายต้นทาง"
		: isStandards
			? "Standards นิยามเงื่อนไขที่ตรวจสอบได้ซึ่งสืบเนื่องจาก Protocols เพื่อทำให้ข้อกล่าวอ้างเชิงโครงสร้างประเมินได้จริง"
			: "Journal คือทะเบียนวิเคราะห์ของ Paritsea: บันทึกข้อสังเกตที่ตั้งชื่อแรงตึงเชิงโครงสร้างก่อนกลายเป็น Protocol หรือ Standard"
	: isProtocols
		? "Protocols are public structural instruments derived from the Framework and designed for cross-domain adaptation."
		: isStandards
			? "Standards define verifiable conditions derived from Protocols and make structural claims assessable."
			: "Journal is Paritsea's analytical registry: observations that name structural tension before it becomes protocol or standard.";
const methodFormatLabel = (format: unknown, cats: Array<{ label: string }>) => {
	if (format === "video-reflection") return "Video Reflection";
	if (format === "pattern-brief") return "Pattern Brief";
	if (format === "decision-note") return "Decision Note";
	const labels = cats.map((cat) => cat.label.toLowerCase());
	if (labels.some((label) => label.includes("video") || label.includes("วิดีโอ"))) {
		return "Video Reflection";
	}
	if (labels.some((label) => label.includes("brief"))) {
		return "Pattern Brief";
	}
	return null;
};

const methodStatusLabel = (format: unknown, cats: Array<{ label: string }>) => {
	if (format === "video-reflection") return locale === "th" ? "สังเกตผ่านวิดีโอ" : "Video observation";
	if (format === "pattern-brief") return locale === "th" ? "รูปแบบที่เริ่มซ้ำ" : "Pattern emerging";
	if (format === "decision-note") return locale === "th" ? "บันทึกการตัดสินใจ" : "Decision note";
	const labels = cats.map((cat) => cat.label.toLowerCase());
	if (labels.some((label) => label.includes("structural") || label.includes("แรงตึง"))) {
		return locale === "th" ? "แรงตึงที่ถูกตั้งชื่อ" : "Named tension";
	}
	if (labels.some((label) => label.includes("human") || label.includes("มนุษย์"))) {
		return locale === "th" ? "ต้นทุนมนุษย์ที่ถูกบันทึก" : "Human cost recorded";
	}
	return locale === "th" ? "Observation ต้นทาง" : "Source observation";
};

const copy = locale === "th"
	? {
			referenceLayer: "ชั้นอ้างอิง",
			protocolsDescription:
				"โปรโตคอลคือเครื่องมือเชิงโครงสร้างที่สืบเนื่องจาก Framework แต่ละฉบับนิยามภาระหน้าที่ ขอบเขต และเงื่อนไขความโปร่งใส ที่ปรับใช้ข้ามโดเมนได้โดยไม่เสียความหมายของ Framework",
			standardsDescription:
				"มาตรฐานแปลงภาระหน้าที่ของ Framework ให้เป็นเงื่อนไขที่วัดได้ เมื่อโปรโตคอลกำหนดภาระหน้าที่ มาตรฐานจะนิยามเกณฑ์ที่ทำให้ข้อกล่าวอ้างเชิงโครงสร้างประเมินได้จริง",
			methodDescription:
				"Journal คือ first record ของ Paritsea บันทึกสิ่งที่ Parit เห็นจากสถานการณ์จริง ทั้งแรงตึงเชิงโครงสร้าง ต้นทุนมนุษย์ และ pattern ที่ยังไม่ควรถูกรีบทำให้เป็นกฎ",
			methodSecondary:
				"บันทึกเหล่านี้เป็นพื้นที่ก่อนตกผลึก ไม่ใช่บทความความเห็นและไม่ใช่ social feed เมื่อสิ่งที่เห็นปรากฏซ้ำพอ มันอาจถูกคัดไปเป็น Framework, Protocol, Standard หรือ IP ในอนาคต",
			methodFlowNote:
				"บันทึกเหล่านี้คือการสังเกตที่ถูกตั้งชื่อก่อนจะกลายเป็นกฎ การมองก่อนการจัดโครงสร้าง",
			further: "",
			protocolsPositionNote:
				"โปรโตคอลสืบเนื่องจาก Framework — แต่ละฉบับนิยามภาระหน้าที่ที่ต้องคงอยู่ในทางปฏิบัติเชิงโครงสร้าง",
			standardsPositionNote:
				"มาตรฐานสืบเนื่องจากโปรโตคอล — แต่ละฉบับนิยามเงื่อนไขที่ตรวจสอบได้ เพื่อประเมินภาระหน้าที่ของโปรโตคอล",
			publiclyDocumented: "เผยแพร่แล้ว",
			noProtocols: "ยังไม่มีโปรโตคอลเผยแพร่",
			noStandards: "ยังไม่มีมาตรฐานเผยแพร่",
			noEntries: "ยังไม่มีบันทึก",
			readProtocol: "อ่าน Protocol →",
			readStandard: "อ่านมาตรฐาน →",
			minRead: "นาที",
			aboutProtocols: "เกี่ยวกับโปรโตคอล",
			aboutProtocolsText:
				"โปรโตคอลแต่ละฉบับคือเครื่องมือเชิงโครงสร้างสาธารณะ ไม่ใช่คำแนะนำหรือ best practice แต่นิยามข้อกำหนดที่ระบบต้องผ่านหากต้องการกล่าวอ้างความสอดคล้องภายใต้กรอบ Paritsea",
			derivedFrom: "สืบเนื่องจาก",
			derivedFromText: "โปรโตคอลทั้งหมดรับอำนาจจาก",
			doctrineLink: "Paritsea Framework",
			noContradiction: "และไม่มีโปรโตคอลใดขัดต่อ Framework ฐานรากได้",
			aboutStandards: "เกี่ยวกับมาตรฐาน",
			aboutStandardsText:
				"มาตรฐานแปลงภาระหน้าที่เชิงโครงสร้างให้เป็นเงื่อนไขที่ตรวจสอบได้ ระบุว่าความสอดคล้องมีหน้าตาอย่างไรในทางปฏิบัติ และเปลี่ยนข้อกล่าวอ้างที่เป็นนามธรรมให้เป็นเกณฑ์ที่ทดสอบและนำไปใช้ได้",
			relationship: "ความสัมพันธ์กับโปรโตคอล",
			relationshipText:
				"มาตรฐานทำงานอยู่ใต้โปรโตคอล โปรโตคอลกำหนดภาระหน้าที่ ส่วนมาตรฐานนิยามเกณฑ์ หนึ่งโดเมนโปรโตคอลอาจมีหลายมาตรฐานได้",
			notWhat: "สิ่งที่บันทึกเหล่านี้ไม่ใช่",
			notWhatText:
				"บันทึกเหล่านี้ไม่ใช่คอลัมน์ความเห็น ไม่ใช่ content marketing และไม่ใช่บทวิจารณ์ข่าวอุตสาหกรรม แต่ละบันทึกคือ observation ที่เก็บที่มา น้ำหนัก และบริบทก่อนถูกทำให้เป็นทางการ",
			whatHappens: "บันทึกเหล่านี้จะไปถึงไหน",
			whatHappensText:
				"รูปแบบที่เกิดซ้ำในหลายบันทึกอาจถูกทำให้เป็นโปรโตคอลหรือมาตรฐานในภายหลัง Journal คือที่ที่ปัญหากลายเป็นสิ่งที่อ่านออกได้ ก่อนกลายเป็นสิ่งที่ถูกกำกับ",
			youtubeBridge: "ดูวิดีโอสะท้อนคิดทั้งหมด",
		}
	: {
			referenceLayer: "Reference Layer",
			protocolsDescription:
				"Protocols are formal structural instruments derived from the Framework. They define obligations, boundaries, and transparency conditions that can be adapted across domains without losing Framework meaning.",
			standardsDescription:
				"Standards translate Framework obligations into measurable conditions. Where protocols establish obligations, standards define the thresholds by which structural claims can be meaningfully assessed.",
			methodDescription:
				"Journal is Paritsea's first record. It holds what Parit sees in real situations: structural tension, human cost, and patterns that should not be forced into rules too early.",
			methodSecondary:
				"These entries are pre-crystallization records, not opinion posts or a social feed. When an observation repeats with enough structure, it may later become Framework, Protocol, Standard, or future IP.",
			methodFlowNote:
				"These are observations named before they become governed. Seeing before structuring.",
			further: "",
			protocolsPositionNote:
				"Protocols derive from the Framework. Each defines an obligation — what must hold in structural practice.",
			standardsPositionNote:
				"Standards derive from Protocols. Each defines a verifiable condition — the threshold by which a Protocol's obligation is assessed.",
			publiclyDocumented: "publicly documented",
			noProtocols: "No protocols published yet.",
			noStandards: "No standards published yet.",
			noEntries: "No entries yet.",
			readProtocol: "Read protocol →",
			readStandard: "Read standard →",
			minRead: "min read",
			aboutProtocols: "About Protocols",
			aboutProtocolsText:
				"Each protocol is a public structural instrument. Protocols are not tips, best practices, or style recommendations. They define the requirements a system must satisfy if it is to claim coherence under the Paritsea framework.",
			derivedFrom: "Derived From",
			derivedFromText: "All protocols derive authority from",
			doctrineLink: "Paritsea Framework",
			noContradiction: "No protocol may contradict the foundational Framework.",
			aboutStandards: "About Standards",
			aboutStandardsText:
				"Standards translate structural obligations into verifiable conditions. They specify what coherence looks like in practice, turning abstract claims into criteria that can be tested, interpreted, and implemented.",
			relationship: "Relationship to Protocols",
			relationshipText:
				"Standards operate beneath Protocols. A Protocol establishes the obligation; a Standard defines the threshold. Multiple standards may exist for a single protocol domain.",
			notWhat: "What This Is Not",
			notWhatText:
				"These entries are not opinion columns, content marketing, or industry takes. Each entry preserves origin, weight, and context before anything becomes official.",
			whatHappens: "What Happens to These",
			whatHappensText:
				"Patterns that persist across multiple entries may later be formalised into protocols or standards. Journal is where problems become legible before they become governed.",
			youtubeBridge: "View all video reflections",
		};
---

<Base
	title={pageTitle}
	description={pageDescription}
	locale={locale}
>
	{isProtocols && (
		<div class="index-page">
			<Breadcrumb crumbs={[
				{ label: "System", href: localizedPath("/system", locale) },
				{ label: "Protocols" }
			]} />
			<header class="index-header">
				<div class="index-header-grid">
					<div class="index-header-primary">
						<p class="index-eyebrow">
							{copy.referenceLayer}
							<span class="index-count">{locale === "th" ? `${scopedPosts.length} Protocol ${copy.publiclyDocumented}` : `${scopedPosts.length} protocol${scopedPosts.length === 1 ? "" : "s"} ${copy.publiclyDocumented}`}</span>
						</p>
						<h1 class="index-title">{navLabels.Protocols}</h1>
						<p class="index-position-note">{copy.protocolsPositionNote}</p>
						<p class="index-description">{copy.protocolsDescription}</p>
						{copy.further && <p class="index-meta-further">{copy.further}</p>}
					</div>
					<div class="index-header-aside">
						<div class="aside-block">
							<h3 class="aside-heading">{copy.aboutProtocols}</h3>
							<p class="aside-text">{copy.aboutProtocolsText}</p>
						</div>
						<div class="aside-block">
							<h3 class="aside-heading">{copy.derivedFrom}</h3>
							<p class="aside-text">
								{copy.derivedFromText} <a href={localizedPath("/system/framework", locale)} class="aside-link">{copy.doctrineLink}</a>. {copy.noContradiction}
							</p>
						</div>
					</div>
				</div>
				<UsageGuidance variant="protocols" compact locale={locale} />
			</header>

			<section class="document-registry">
				{scopedPosts.length === 0 ? (
					<p class="registry-empty">{copy.noProtocols}</p>
				) : (
					<div class="document-list">
						{scopedPosts.map(({ post, cats }, i) => (
							<a href={localizedPath(`/system/protocols/${post.id}`, locale)} class="document-card">
								<div class="document-card-index">{String(i + 1).padStart(2, "0")}</div>
								<div class="document-card-body">
									{cats.length > 0 && (
										<div class="document-card-tags">
											{cats.map((c) => <span class="document-tag">{c.label}</span>)}
										</div>
									)}
									<h2 class="document-card-title">{post.data.title}</h2>
									{post.data.excerpt && <p class="document-card-excerpt">{post.data.excerpt}</p>}
									<div class="document-card-footer">
										{post.data.publishedAt && <time class="document-date">{formatDate(post.data.publishedAt)}</time>}
										<span class="document-read">{copy.readProtocol}</span>
									</div>
								</div>
							</a>
						))}
					</div>
				)}
			</section>
		</div>
	)}

	{isStandards && (
		<div class="index-page">
			<Breadcrumb crumbs={[
				{ label: "System", href: localizedPath("/system", locale) },
				{ label: "Standards" }
			]} />
			<header class="index-header">
				<div class="index-header-grid">
					<div class="index-header-primary">
						<p class="index-eyebrow">
							{copy.referenceLayer}
							<span class="index-count">{locale === "th" ? `${scopedPosts.length} มาตรฐาน ${copy.publiclyDocumented}` : `${scopedPosts.length} standard${scopedPosts.length === 1 ? "" : "s"} ${copy.publiclyDocumented}`}</span>
						</p>
						<h1 class="index-title">{navLabels.Standards}</h1>
						<p class="index-position-note">{copy.standardsPositionNote}</p>
						<p class="index-description">{copy.standardsDescription}</p>
						{copy.further && <p class="index-meta-further">{copy.further}</p>}
					</div>
					<div class="index-header-aside">
						<div class="aside-block">
							<h3 class="aside-heading">{copy.aboutStandards}</h3>
							<p class="aside-text">{copy.aboutStandardsText}</p>
						</div>
						<div class="aside-block">
							<h3 class="aside-heading">{copy.relationship}</h3>
							<p class="aside-text">{copy.relationshipText}</p>
						</div>
					</div>
				</div>
				<UsageGuidance variant="standards" compact locale={locale} />
			</header>

			<section class="document-registry">
				{scopedPosts.length === 0 ? (
					<p class="registry-empty">{copy.noStandards}</p>
				) : (
					<div class="document-list">
						{scopedPosts.map(({ post, cats }, i) => (
							<a href={localizedPath(`/system/standards/${post.id}`, locale)} class="document-card">
								<div class="document-card-index">{String(i + 1).padStart(2, "0")}</div>
								<div class="document-card-body">
									{cats.length > 0 && (
										<div class="document-card-tags">
											{cats.map((c) => <span class="document-tag">{c.label}</span>)}
										</div>
									)}
									<h2 class="document-card-title">{post.data.title}</h2>
									{post.data.excerpt && <p class="document-card-excerpt">{post.data.excerpt}</p>}
									<div class="document-card-footer">
										{post.data.publishedAt && <time class="document-date">{formatDate(post.data.publishedAt)}</time>}
										<span class="document-read">{copy.readStandard}</span>
									</div>
								</div>
							</a>
						))}
					</div>
				)}
			</section>
		</div>
	)}

	{isMethod && (
		<div class="index-page">
			<header class="index-header">
				<div class="index-header-grid">
					<div class="index-header-primary">
						<p class="index-eyebrow">
							{locale === "th" ? "ทะเบียนวิเคราะห์" : "Analytical Registry"}
							<span class="index-count">{locale === "th" ? `${scopedPosts.length} บันทึก ${copy.publiclyDocumented}` : `${scopedPosts.length} entr${scopedPosts.length === 1 ? "y" : "ies"} published`}</span>
						</p>
						<h1 class="index-title">{navLabels["The Method"]}</h1>
						<p class="index-description">{copy.methodDescription}</p>
						<p class="index-description-secondary">{copy.methodSecondary}</p>
						<p class="index-meta-further">{copy.methodFlowNote}</p>
					</div>
					<div class="index-header-aside">
						<div class="aside-block">
							<h3 class="aside-heading">{copy.notWhat}</h3>
							<p class="aside-text">{copy.notWhatText}</p>
						</div>
						<div class="aside-block">
							<h3 class="aside-heading">{copy.whatHappens}</h3>
							<p class="aside-text">{copy.whatHappensText}</p>
						</div>
					</div>
				</div>
				<UsageGuidance variant="the-method" compact locale={locale} />
			</header>

			<section class="document-registry">
				{scopedPosts.length === 0 ? (
					<p class="registry-empty">{copy.noEntries}</p>
				) : (
					<div class="document-list">
						{scopedPosts.map(({ post, cats }, i) => (
							<a href={localizedPath(`/journal/${post.id}`, locale)} class="document-card">
								<div class="document-card-index">{String(scopedPosts.length - i).padStart(2, "0")}</div>
								<div class="document-card-body">
									{methodFormatLabel(post.data.format, cats) && (
									<div class="document-card-format">{methodFormatLabel(post.data.format, cats)}</div>
								)}
									<div class="document-card-status">{methodStatusLabel(post.data.format, cats)}</div>
									{cats.length > 0 && (
										<div class="document-card-tags">
											{cats.map((c) => <span class="document-tag">{c.label}</span>)}
										</div>
									)}
									<h2 class="document-card-title">{post.data.title}</h2>
									{post.data.excerpt && <p class="document-card-excerpt">{post.data.excerpt}</p>}
									<div class="document-card-footer">
										{post.data.publishedAt && <time class="document-date">{formatDate(post.data.publishedAt)}</time>}
										<span class="document-read">{getReadingTime(post.data.content)} {copy.minRead}</span>
									</div>
								</div>
							</a>
						))}
					</div>
				)}
			</section>
			<p class="method-youtube-link-wrap">
				<a href="https://www.youtube.com/@paritsea" target="_blank" rel="noreferrer" class="method-youtube-link">
					{copy.youtubeBridge} →
				</a>
			</p>
		</div>
	)}
</Base>

<style>
	/* ─── Page shell ─── */
	.index-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-8) var(--spacing-20);
		position: relative;
	}

	.index-page::before {
		content: "";
		position: absolute;
		inset: 0 0 auto 0;
		height: 300px;
		background: radial-gradient(circle at 8% 0%, color-mix(in srgb, var(--color-accent) 18%, transparent), transparent 60%);
