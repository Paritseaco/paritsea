---
import { getEmDashCollection, getEntryTerms } from "emdash";
import Base from "../layouts/Base.astro";
import Breadcrumb from "./Breadcrumb.astro";
import { isFrameworkPageSlug, resolveFrameworkPage } from "../utils/public-paths";
import { getReadingTime } from "../utils/reading-time";
import {
	formatDateForLocale,
	getAstroLocale,
	localizeEntry,
	localizedPath,
} from "../utils/i18n";
import { localizeRecordValue } from "../utils/intellectual-localization";

interface Props {
	slug: "protocols" | "standards" | "the-method";
}

const { slug } = Astro.props;
const locale = getAstroLocale(Astro);
let result;

try {
	result = await getEmDashCollection("posts", {
		where: { framework_page: slug },
		orderBy: { published_at: "desc" },
	});
} catch {
	result = await getEmDashCollection("posts", {
		where: { category: slug },
		orderBy: { published_at: "desc" },
	});
}

Astro.cache.set(result.cacheHint);

const resolved = await Promise.all(result.entries.map(async (entry) => {
	const terms = await getEntryTerms("posts", entry.data.id, "category");
	const frameworkPage = resolveFrameworkPage(
		entry.data.framework_page,
		terms.find((term) => isFrameworkPageSlug(term.slug))?.slug,
	);
	return {
		entry: localizeEntry(entry, "posts", locale),
		frameworkPage,
	};
}));

const entries = resolved
	.filter(({ frameworkPage }) => frameworkPage === slug)
	.map(({ entry }) => ({
		entry,
		version: entry.data.document_version ?? "",
		status: entry.data.lifecycle_status ?? (slug === "the-method" ? "exploring" : "current"),
		readingTime: getReadingTime(entry.data.content),
	}));
const kind = slug === "the-method" ? "journal" : slug === "protocols" ? "protocol" : "standard";

const copy = locale === "th"
	? {
		journal: {
			pageTitle: "บันทึก — Paritsea",
			role: "คลังข้อสังเกต",
			title: "บันทึก",
			summary: "สิ่งที่ถูกมองเห็นก่อนจะกลายเป็นคำอธิบายที่มั่นคง บันทึกแต่ละชิ้นอาจมีความไม่แน่ใจ เปลี่ยนแปลงได้ และไม่จำเป็นต้องพัฒนาเป็นงานอ้างอิง",
			boundary: "การเผยแพร่ในบันทึกไม่ได้ทำให้งานชิ้นนั้นเป็น Framework, Protocol หรือ Standard โดยอัตโนมัติ",
			empty: "ยังไม่มีบันทึกที่เผยแพร่",
			read: "อ่านบันทึก",
		},
		protocol: {
			pageTitle: "Protocol — Paritsea",
			role: "คลังงานอ้างอิง",
			title: "Protocol",
			summary: "งานที่แปลงหลักการใน Framework ให้เป็นภาระหน้าที่หรือวิธีดำเนินการที่รักษาความหมายต้นทางไว้ได้",
			boundary: "Protocol ไม่ใช่คำแนะนำทั่วไป ทุกฉบับต้องระบุ version, ขอบเขต และ Framework ที่เป็นต้นทาง",
			empty: "ยังไม่มี Protocol ที่เผยแพร่",
			read: "เปิดเอกสาร",
		},
		standard: {
			pageTitle: "Standard — Paritsea",
			role: "คลังเกณฑ์อ้างอิง",
			title: "Standard",
			summary: "เงื่อนไขหรือเกณฑ์ที่ใช้ตรวจว่าภาระหน้าที่ของ Protocol เกิดขึ้นจริงเพียงใด โดยไม่ทำให้บริบทต่างกันถูกบังคับให้เหมือนกัน",
			boundary: "Standard ระบุสิ่งที่ตรวจสอบได้ ไม่ใช่ตรารับรอง และไม่สร้างสถานะ Official Use ด้วยตัวเอง",
			empty: "ยังไม่มี Standard ที่เผยแพร่",
			read: "เปิดเอกสาร",
		},
		count: "งานที่เผยแพร่",
		updated: "ปรับปรุง",
		minutes: "นาที",
		path: "เส้นทางความคิด",
		pathNote: "บันทึกอาจนำไปสู่ Concept และงานอ้างอิง แต่ทุกชิ้นหยุดอยู่ในขั้นที่เหมาะสมได้",
	}
	: {
		journal: {
			pageTitle: "Journal — Paritsea",
			role: "Observation archive",
			title: "Journal",
			summary: "What is seen before it becomes a stable explanation. An entry may remain uncertain, be revised, and never need to become reference work.",
			boundary: "Publication in Journal does not make an entry a Framework, Protocol, or Standard.",
			empty: "No Journal entries have been published.",
			read: "Read entry",
		},
		protocol: {
			pageTitle: "Protocols — Paritsea",
			role: "Reference archive",
			title: "Protocols",
			summary: "Work that translates Framework principles into obligations or methods while preserving the meaning of the source.",
			boundary: "A Protocol is not general advice. Each record must name its version, scope, and source Framework.",
			empty: "No Protocols have been published.",
			read: "Open document",
		},
		standard: {
			pageTitle: "Standards — Paritsea",
			role: "Threshold archive",
			title: "Standards",
			summary: "Conditions used to examine whether a Protocol obligation is present without forcing different contexts into false uniformity.",
			boundary: "A Standard defines what can be examined. It is not a certification mark and does not create Official Use by itself.",
			empty: "No Standards have been published.",
			read: "Open document",
		},
		count: "published works",
		updated: "Updated",
		minutes: "min",
		path: "Thought path",
		pathNote: "Journal may lead to Concepts and reference work, but any work may stop at the stage appropriate to it.",
	};

const current = copy[kind];
const entryPath = (id: string) => kind === "journal"
	? `/journal/${id}`
	: `/system/${kind === "protocol" ? "protocols" : "standards"}/${id}`;
---

<Base title={current.pageTitle} description={current.summary} locale={locale}>
	<main class="experience-page archive-page">
		<Breadcrumb crumbs={[
			{ label: locale === "th" ? "หน้าแรก" : "Home", href: localizedPath("/", locale) },
			...(kind === "journal" ? [] : [{ label: locale === "th" ? "งานอ้างอิง" : "Reference work", href: localizedPath("/system", locale) }]),
			{ label: current.title },
		]} />

		<header class="archive-header">
			<div>
				<p class="experience-label" data-state={kind === "journal" ? "moving" : "governed"}>{current.role}</p>
				<h1 class="experience-title">{current.title}</h1>
				<p class="experience-summary">{current.summary}</p>
			</div>
			<dl class="archive-count">
				<dt>{copy.count}</dt>
				<dd>{String(entries.length).padStart(2, "0")}</dd>
			</dl>
		</header>

		<p class="archive-boundary">{current.boundary}</p>

		<section class="experience-index" aria-label={current.title}>
			{entries.length ? entries.map(({ entry, version, status, readingTime }, index) => (
					<a class="experience-index-row" href={localizedPath(entryPath(entry.id), locale)}>
						<span class="experience-index-number">{String(index + 1).padStart(2, "0")}</span>
						<div class="experience-index-copy">
							<p class="experience-index-meta">{locale === "th" && kind === "journal" ? "บันทึก" : localizeRecordValue(locale, kind)}{version ? ` · v${version}` : ""} · {localizeRecordValue(locale, status)}</p>
							<h2>{entry.data.title}</h2>
							{entry.data.excerpt && <p>{entry.data.excerpt}</p>}
							<div class="archive-row-footer">
								{entry.data.publishedAt && <time>{copy.updated} {formatDateForLocale(entry.data.publishedAt, locale)}</time>}
								<span>{readingTime} {copy.minutes}</span>
								<strong>{current.read} →</strong>
							</div>
						</div>
					</a>
				)) : <div class="experience-empty"><p>{current.empty}</p></div>}
		</section>

		<aside class="archive-path">
			<div>
				<p class="experience-label" data-state="named">{copy.path}</p>
				<p>{copy.pathNote}</p>
			</div>
			<nav aria-label={copy.path}>
				<a href={localizedPath("/journal", locale)}>Journal</a>
				<span aria-hidden="true">→</span>
				<a href={localizedPath("/concepts", locale)}>Concept</a>
				<span aria-hidden="true">→</span>
				<a href={localizedPath("/system", locale)}>Framework · Protocol · Standard</a>
			</nav>
		</aside>
	</main>
</Base>

<style>
	.archive-header { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: var(--spacing-12); align-items: end; padding: var(--spacing-12) 0 var(--spacing-14); border-bottom: 1px solid var(--color-border); }
	.archive-count { min-width: 150px; padding-left: var(--spacing-6); border-left: 1px solid var(--color-border); }
	.archive-count dt { font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--color-muted); text-transform: uppercase; letter-spacing: var(--tracking-wide); }
	.archive-count dd { margin-top: var(--spacing-2); font-family: var(--font-serif); font-size: clamp(3rem, 7vw, 6rem); line-height: .9; color: var(--color-accent); }
	.archive-boundary { max-width: 68ch; padding: var(--spacing-6) 0; color: var(--color-text-secondary); border-bottom: 1px solid var(--color-border-subtle); }
	.archive-page .experience-index-row { grid-template-columns: 5rem minmax(0, 1fr); }
	.archive-page .experience-index-copy h2 { font-family: var(--font-serif); font-size: clamp(1.65rem, 2.6vw, 2.65rem); font-weight: 500; line-height: 1.1; letter-spacing: var(--tracking-snug); text-wrap: balance; }
	.archive-page .experience-index-copy > p { max-width: 58ch; margin-top: var(--spacing-3); line-height: 1.7; color: var(--color-text-secondary); text-wrap: pretty; }
	.archive-row-footer { display: flex; flex-wrap: wrap; gap: var(--spacing-3) var(--spacing-6); margin-top: var(--spacing-5); font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--color-muted); }
	.archive-row-footer strong { margin-left: auto; color: var(--color-accent); font-weight: 500; }
	.archive-path { display: grid; grid-template-columns: minmax(0, .8fr) minmax(0, 1.2fr); gap: var(--spacing-12); margin-top: var(--spacing-20); padding: var(--spacing-8) 0; border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
	.archive-path p:last-child { max-width: 52ch; margin-top: var(--spacing-4); color: var(--color-text-secondary); line-height: 1.7; }
	.archive-path nav { display: flex; flex-wrap: wrap; gap: var(--spacing-3); align-items: center; align-content: center; }
	.archive-path a { text-decoration: underline; text-decoration-color: var(--color-border); text-underline-offset: .25em; }
	:global(:lang(th)) .archive-count dt, :global(:lang(th)) .archive-row-footer { font-family: var(--font-sans); font-size: .875rem; letter-spacing: 0; text-transform: none; }
	:global(:lang(th)) .archive-count dd { font-family: var(--font-sans); font-weight: 300; }
	:global(:lang(th)) .archive-page .experience-index-copy h2 { font-family: var(--font-sans); font-weight: 300; font-style: normal; letter-spacing: 0; line-height: 1.45; }
	:global(:lang(th)) .archive-page .experience-index-copy > p { font-size: 1.0625rem; line-height: 1.9; letter-spacing: 0; word-break: keep-all; }
	:global(:lang(th)) .archive-boundary, :global(:lang(th)) .archive-path p:last-child { font-size: 1.0625rem; line-height: 1.9; letter-spacing: 0; word-break: keep-all; }
	@media (max-width: 700px) { .archive-header, .archive-path, .archive-page .experience-index-row { grid-template-columns: 1fr; } .archive-count { padding: var(--spacing-5) 0 0; border-left: 0; border-top: 1px solid var(--color-border-subtle); } .archive-count dd { font-size: 3.5rem; } .archive-row-footer strong { width: 100%; margin-left: 0; } }
</style>
