---
import { getAstroLocale } from "../utils/i18n";

interface Props {
	role: string;
	eyebrow?: string;
	title: string;
	intro: string;
	count?: number;
	statusLabel?: string;
}

const { role, eyebrow, title, intro, count, statusLabel } = Astro.props;
const locale = getAstroLocale(Astro);
---

<header class="role-header">
	<div class="role-rail" aria-hidden="true"><span></span><i></i></div>
	<div class="role-copy">
		<p class="role-kicker"><span>{role}</span>{eyebrow && <> · {eyebrow}</>}</p>
		<h1>{title}</h1>
		<p class="role-intro">{intro}</p>
		{(typeof count === "number" || statusLabel) && (
			<p class="role-state">
				{typeof count === "number" && <span>{count} {locale === "th" ? "ระเบียน" : "records"}</span>}
				{statusLabel && <span>{statusLabel}</span>}
			</p>
		)}
	</div>
</header>

<style>
	.role-header {
		display: grid;
		grid-template-columns: 18px minmax(0, 880px);
		gap: var(--spacing-6);
		padding: var(--spacing-10) 0 var(--spacing-12);
		border-bottom: 1px solid var(--color-border);
	}

	.role-rail {
		position: relative;
		min-height: 140px;
	}

	.role-rail::before {
		content: "";
		position: absolute;
		left: 8px;
		top: 8px;
		bottom: 8px;
		width: 1px;
		background: var(--color-border);
	}

	.role-rail span,
	.role-rail i {
		position: absolute;
		left: 4px;
		width: 9px;
		height: 9px;
		border: 1px solid var(--color-accent);
		border-radius: 50%;
		background: var(--color-bg);
	}

	.role-rail span { top: 4px; }
	.role-rail i { bottom: 4px; background: var(--color-accent); }

	.role-kicker,
	.role-state {
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
	}

	.role-kicker span { color: var(--color-accent); }

	h1 {
		max-width: 19ch;
		margin-top: var(--spacing-6);
		font-size: clamp(2.5rem, 4.5vw, 4.75rem);
		line-height: 1.04;
		letter-spacing: var(--tracking-tightest);
	}

	.role-intro {
		max-width: 700px;
		margin-top: var(--spacing-8);
		font-family: var(--font-serif);
		font-size: clamp(1.25rem, 2vw, 1.65rem);
		line-height: 1.55;
		color: var(--color-text-secondary);
	}

	.role-state {
		display: flex;
		gap: var(--spacing-6);
		margin-top: var(--spacing-8);
	}

	:global(:lang(th)) .role-kicker,
	:global(:lang(th)) .role-state {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		letter-spacing: 0;
		line-height: 1.55;
		text-transform: none;
	}

	:global(:lang(th)) h1 {
		font-family: var(--font-sans);
		font-weight: 300;
		letter-spacing: 0;
		font-size: clamp(2.25rem, 4vw, 4rem);
		line-height: 1.48;
	}

	:global(:lang(th)) .role-intro {
		font-family: var(--font-sans);
		font-size: clamp(1.125rem, 2vw, 1.4rem);
		line-height: 1.9;
		letter-spacing: 0;
	}

	@media (max-width: 640px) {
		.role-header {
			grid-template-columns: 18px minmax(0, 1fr);
			gap: var(--spacing-4);
			padding: var(--spacing-12) 0;
		}

		.role-rail::before { left: 8px; }
		.role-rail span,
		.role-rail i { left: 4px; }
	}
</style>
