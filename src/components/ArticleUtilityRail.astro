---
import type { SiteLocale } from "../utils/i18n";
import { ui } from "../utils/i18n";

interface BylineCredit {
	byline: {
		displayName: string;
		avatarMediaId?: string | null;
	};
	roleLabel?: string | null;
}

interface Props {
	bylines?: BylineCredit[];
	lastUpdatedLabel?: string | null;
	lastUpdatedIso?: string | null;
	readingTime: number;
	postId: string;
	initialViews: number;
	pageUrl: string;
	locale?: SiteLocale;
}

const {
	bylines = [],
	lastUpdatedLabel = null,
	lastUpdatedIso = null,
	readingTime,
	postId,
	initialViews,
	pageUrl,
	locale = "th",
} = Astro.props;

const labels = ui[locale].labels;
---

<div
	class="article-utility-rail"
	data-article-utility-rail
	data-page-url={pageUrl}
	data-copy-success={labels.copied}
	data-copy-failed={labels.copyFailed}
>
	<div class="article-utility-actions" role="group" aria-label="Page actions">
		<button type="button" class="article-utility-action" data-copy-url>
			<svg viewBox="0 0 24 24" aria-hidden="true">
				<path
					d="M10.5 13.5L13.5 10.5M8.318 15.682l-1.06 1.06a3 3 0 01-4.243-4.242l4.95-4.95a3 3 0 014.243 0l1.06 1.06M15.682 8.318l1.06-1.06a3 3 0 114.243 4.242l-4.95 4.95a3 3 0 01-4.243 0l-1.06-1.06"
					fill="none"
					stroke="currentColor"
					stroke-width="1.75"
					stroke-linecap="round"
					stroke-linejoin="round"
				/>
			</svg>
			<span>{labels.copyUrl}</span>
		</button>
	</div>

	<p class="article-utility-status sr-only" aria-live="polite" data-utility-status></p>

	{
		bylines.length > 0 && (
			<div class="article-utility-block article-utility-block--byline">
				<span class="article-utility-label">
					{bylines.length === 1 ? labels.author : labels.authors}
				</span>
				<div class="article-utility-bylines">
					{bylines.map((credit) => (
						<div class="article-utility-byline">
							{credit.byline.avatarMediaId && (
								<img
									src={`/_emdash/api/media/file/${credit.byline.avatarMediaId}`}
									alt={credit.byline.displayName}
									class="article-utility-avatar"
								/>
							)}
							<div class="article-utility-byline-info">
								<span class="article-utility-byline-name">{credit.byline.displayName}</span>
								{credit.roleLabel && (
									<span class="article-utility-byline-role">{credit.roleLabel}</span>
								)}
							</div>
						</div>
					))}
				</div>
			</div>
		)
	}

	{
		lastUpdatedLabel && (
			<div class="article-utility-block">
				<span class="article-utility-label">{labels.lastUpdated}</span>
				<time class="article-utility-value" datetime={lastUpdatedIso ?? undefined}>
					{lastUpdatedLabel}
				</time>
			</div>
		)
	}

	<div class="article-utility-block">
		<span class="article-utility-label">{labels.readingTime}</span>
		<span class="article-utility-value">{readingTime} {labels.minRead}</span>
	</div>

	<div class="article-utility-block">
		<span class="article-utility-label">{labels.readership}</span>
		<span
			class="article-utility-value"
			id="article-readership"
			data-post-id={postId}
			data-initial-views={initialViews}
		>
			{initialViews} {labels.reads}
		</span>
	</div>
</div>

<script is:inline>
	const copyText = async (text) => {
		if (navigator.clipboard?.writeText) {
			await navigator.clipboard.writeText(text);
			return;
		}

		const textarea = document.createElement("textarea");
		textarea.value = text;
		textarea.setAttribute("readonly", "");
		textarea.style.position = "absolute";
		textarea.style.left = "-9999px";
		document.body.appendChild(textarea);
		textarea.select();
		document.execCommand("copy");
		document.body.removeChild(textarea);
	};

	document.querySelectorAll("[data-article-utility-rail]").forEach((rail) => {
		if (rail.dataset.jsBound === "true") return;
		rail.dataset.jsBound = "true";

		const status = rail.querySelector("[data-utility-status]");
		const copyUrlButton = rail.querySelector("[data-copy-url]");
		const pageUrl = rail.dataset.pageUrl || window.location.href;
		const copySuccess = rail.dataset.copySuccess || "Page URL copied.";
		const copyFailed = rail.dataset.copyFailed || "Could not copy the page URL automatically.";

		copyUrlButton?.addEventListener("click", async () => {
			try {
				await copyText(pageUrl);
				if (status) status.textContent = copySuccess;
			} catch {
				if (status) status.textContent = copyFailed;
			}
		});
	});
</script>

<style>
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.article-utility-rail {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-6);
	}

	.article-utility-actions {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
		padding-bottom: var(--spacing-6);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.article-utility-action {
		display: inline-flex;
		align-items: flex-start;
		gap: var(--spacing-2);
		width: 100%;
		padding: 0;
		border: 0;
		background: transparent;
		color: var(--color-text-secondary);
		font: inherit;
		font-size: var(--font-size-base);
		line-height: 1.45;
		text-align: left;
		cursor: pointer;
		transition: color var(--transition-fast);
	}

	.article-utility-action:hover,
	.article-utility-action:focus-visible {
		color: var(--color-text);
		outline: none;
	}

	.article-utility-action svg {
		width: 1rem;
		height: 1rem;
		flex-shrink: 0;
		margin-top: 0.18rem;
	}

	.article-utility-block {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-1);
	}

	.article-utility-label {
		display: block;
		font-size: var(--font-size-xs);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		color: var(--color-muted);
	}

	.article-utility-value {
		display: block;
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		line-height: 1.6;
	}

	.article-utility-bylines {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2);
	}

	.article-utility-byline {
		display: flex;
		align-items: center;
		gap: var(--spacing-2);
	}

	.article-utility-avatar {
		width: var(--avatar-size-lg);
		height: var(--avatar-size-lg);
		border-radius: 999px;
		object-fit: cover;
	}

	.article-utility-byline-info {
		display: flex;
		flex-direction: column;
		min-width: 0;
	}

	.article-utility-byline-name {
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-text);
	}

	.article-utility-byline-role {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	@media (max-width: 1100px) {
		.article-utility-rail {
			display: grid;
			grid-template-columns: repeat(4, minmax(0, 1fr));
			gap: var(--spacing-4);
			padding-bottom: var(--spacing-5);
			border-bottom: 1px solid var(--color-border-subtle);
		}

		.article-utility-actions {
			padding-bottom: 0;
			border-bottom: 0;
		}

		.article-utility-action {
			font-size: var(--font-size-sm);
		}
	}

	@media (max-width: 720px) {
		.article-utility-rail {
			display: none;
		}
	}
</style>
