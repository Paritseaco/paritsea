---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import PageRoleHeader from "../../components/PageRoleHeader.astro";
import { getAstroLocale, localizeEntry, localizedPath } from "../../utils/i18n";
import { resolvePostPath } from "../../utils/public-paths";

const locale = getAstroLocale(Astro);
const { entries, cacheHint } = await getEmDashCollection("posts", { orderBy: { published_at: "desc" } });
Astro.cache.set(cacheHint);
const works = entries.map((entry) => localizeEntry(entry, "posts", locale));
const intro = locale === "th"
	? "Parit Ritchai เป็นผู้เขียน ผู้ตั้งชื่อ และผู้มีอำนาจตัดสินใจต่อ semantic change ของงานต้นทาง ส่วน Paritsea ทำหน้าที่รักษางานเหล่านั้นเป็น public record ที่มี version และ provenance หน้านี้เป็นระเบียนผู้เขียน ไม่ใช่ portfolio"
	: "Parit Ritchai is the author, namer, and decision authority for semantic change in the source work. Paritsea preserves that work as a versioned public record. This is an author record, not a portfolio.";
---

<Base title="Parit Ritchai — Author record" description={intro} locale={locale}>
	<div class="author-shell">
		<Breadcrumb crumbs={[{ label: "Lens", href: localizedPath("/about", locale) }, { label: "Parit Ritchai" }]} />
		<PageRoleHeader role="Author record" eyebrow="Authorship and change authority" title="Parit Ritchai" intro={intro} count={works.length} statusLabel={locale === "th" ? "ผู้เขียนต้นทาง" : "Source author"} />
		<section class="author-boundary">
			<h2>{locale === "th" ? "สิ่งที่ผูกกับชื่อผู้เขียน" : "What remains attached to the author"}</h2>
			<p>{locale === "th" ? "Observation, judgment, naming และเหตุผลของการเปลี่ยน canonical work ต้องมี attribution ที่ตรวจสอบได้ ขณะเดียวกัน Framework, Protocol และ Standard ต้องอ่านและอ้างอิงได้โดยไม่ต้องซื้อบริการจากผู้เขียน" : "Observation, judgement, naming, and the rationale for changing canonical work remain attributable. Frameworks, Protocols, and Standards must still be readable and citable without purchasing a service from the author."}</p>
		</section>
		<section class="bibliography" aria-labelledby="bibliography-title">
			<h2 id="bibliography-title">{locale === "th" ? "งานที่เผยแพร่" : "Published record"}</h2>
			{works.map((work) => <a href={localizedPath(resolvePostPath(work.id, work.data.framework_page) ?? `/journal/${work.id}`, locale)}><span>{work.data.framework_page}</span><strong>{work.data.title}</strong></a>)}
		</section>
	</div>
</Base>

<style>
	.author-shell { width: var(--wide-width); margin: 0 auto; padding: var(--spacing-8) 0 var(--spacing-24); }
	.author-boundary { display: grid; grid-template-columns: minmax(220px, .6fr) 1.4fr; gap: var(--spacing-12); padding: var(--spacing-16) 0; border-bottom: 1px solid var(--color-border); }
	.author-boundary h2 { font-size: var(--font-size-2xl); }
	.author-boundary p { max-width: 700px; font-family: var(--font-serif); font-size: var(--font-size-xl); line-height: 1.65; }
	.bibliography { padding-top: var(--spacing-12); }
	.bibliography > h2 { margin-bottom: var(--spacing-6); }
	.bibliography a { display: grid; grid-template-columns: 180px 1fr; gap: var(--spacing-6); padding: var(--spacing-5) 0; border-top: 1px solid var(--color-border-subtle); }
	.bibliography span { font-family: var(--font-mono); font-size: var(--font-size-sm); color: var(--color-muted); }
	.bibliography strong { font-family: var(--font-serif); font-size: var(--font-size-xl); font-weight: 500; }
	:global(:lang(th)) .author-boundary p { font-family: var(--font-sans); font-size: 1.0625rem; line-height: 1.9; }
	:global(:lang(th)) .bibliography span { font-family: var(--font-sans); font-size: var(--font-size-sm); letter-spacing: 0; }
	@media (max-width: 700px) { .author-boundary, .bibliography a { grid-template-columns: 1fr; gap: var(--spacing-3); } }
</style>
