---
import { getEmDashCollection, getEntryTerms, getSiteSettings } from "emdash";
import Base from "../layouts/Base.astro";
import {
	isFrameworkPageSlug,
	resolveFrameworkPage,
	resolvePostPath,
} from "../utils/public-paths";
import { resolveBlogSiteIdentity } from "../utils/site-identity";
import {
	formatDateForLocale,
	getAstroLocale,
	localizeEntry,
	localizeTermLabel,
	localizedPath,
	ui,
} from "../utils/i18n";

const locale = getAstroLocale(Astro);
const navLabels = ui[locale].navLabels;

const { entries: posts, cacheHint } = await getEmDashCollection("posts");
const { siteTitle, siteTagline } = resolveBlogSiteIdentity(await getSiteSettings());

Astro.cache.set(cacheHint);

// Specific landmark posts
const doctrinePost = posts.find((p) => p.id === "doctrine");
const stpPost = posts.find((p) => p.id === "stp");
const aslsPost = posts.find((p) => p.id === "asls-01");
const localizedDoctrinePost = doctrinePost ? localizeEntry(doctrinePost, "posts", locale) : null;
const localizedStpPost = stpPost ? localizeEntry(stpPost, "posts", locale) : null;
const localizedAslsPost = aslsPost ? localizeEntry(aslsPost, "posts", locale) : null;

// The Method = recent analytical entries (exclude the 3 landmark posts)
const landmarkIds = new Set(["doctrine", "stp", "asls-01"]);
const methodEntries = (
	await Promise.all(
		posts
			.filter((p) => !landmarkIds.has(p.id))
			.map(async (post) => {
				const legacyTerms = await getEntryTerms("posts", post.data.id, "category");
				const legacyFrameworkPage =
					legacyTerms.find((term) => isFrameworkPageSlug(term.slug))?.slug ?? null;
				return {
					post,
					legacyTerms,
					frameworkPage: resolveFrameworkPage(post.data.framework_page, legacyFrameworkPage),
				};
			}),
	)
)
	.filter((entry) => entry.frameworkPage === "the-method")
	.toSorted((a, b) => {
		const dateA = a.post.data.publishedAt?.getTime() ?? 0;
		const dateB = b.post.data.publishedAt?.getTime() ?? 0;
		return dateB - dateA;
	})
	.slice(0, 4);

const methodEntriesWithTags = await Promise.all(
	methodEntries.map(async ({ post, legacyTerms, frameworkPage }) => {
		const categories = legacyTerms.filter((term) => !isFrameworkPageSlug(term.slug)).length > 0
			? legacyTerms.filter((term) => !isFrameworkPageSlug(term.slug))
			: await getEntryTerms("posts", post.data.id, "category");
		const href =
			resolvePostPath(post.id, frameworkPage, null) ??
			`/the-method/${post.id}`;
		return {
			post: localizeEntry(post, "posts", locale),
			categories: categories.map((category) => ({
				slug: category.slug,
				label: localizeTermLabel(category.label, locale),
			})),
			href: localizedPath(href, locale),
		};
	})
);

function formatDate(date: Date | null | undefined) {
	return formatDateForLocale(date, locale);
}

const home = locale === "th"
	? {
			eyebrow: "กรอบอ้างอิงสาธารณะ",
			// Statement reordered to natural Thai climactic structure
			// — key concept lands at the end, not front-loaded
			statement: "ก่อนจะกระทำได้อย่างชอบธรรม\nโครงสร้างต้องสอดคล้องก่อน",
			// Definition: shorter, more evocative — leads with the core value proposition
			definition:
				"Paritsea ช่วยตั้งชื่อแรงตึงที่ซ่อนอยู่ในโครงสร้าง ก่อนมันจะแข็งตัวกลายเป็นบรรทัดฐาน",
			sub:
				"กรอบอ้างอิงนี้ถูกออกแบบให้ถูกอ้างอิง ดัดแปลง และนำไปใช้ได้ ทั้งในองค์กร ผลิตภัณฑ์ และการตัดสินใจส่วนบุคคล ทุกที่ที่ความชัดเจนเชิงโครงสร้างมีความสำคัญ",
			readDoctrine: "อ่านแก่น",
			viewImplementations: "ดูการประยุกต์ใช้ →",
			referenceNote:
				"แก่น โปรโตคอล มาตรฐาน วิธีวิเคราะห์ และการประยุกต์ใช้ อยู่ในสถาปัตยกรรมอ้างอิงเดียว",
			referenceArchitecture: "สถาปัตยกรรมอ้างอิง",
			methodDesc:
				"บันทึกวิเคราะห์ที่ระบุแรงตึงเชิงโครงสร้าง ก่อนมันจะแข็งตัวกลายเป็นบรรทัดฐาน",
			implementationsDesc:
				"ระบบที่นำตรรกะ Paritsea ไปใช้จริงในสภาพแวดล้อมการทำงาน AgenSea คือการประยุกต์ใช้แรกที่บันทึกไว้ภายใต้ ASLS-01",
			registry: "ทะเบียนวิเคราะห์",
			openMethod: "เปิด The Method →",
			// Quote: punchier, parallel structure — "ปัญหาคือ" restated for rhythm
			quote: "\"ปัญหาไม่ใช่ว่าสิ่งต่างๆ พัง\nปัญหาคือมันทำงานอยู่ — และยังมีบางอย่างผิด\"",
			attr: "— Parit Ritchai, แก่น",
		}
	: {
			eyebrow: "Public Reference Framework",
			statement: "Structural coherence\nis a prerequisite\nfor legitimate action.",
			definition:
				"Paritsea is a public reference framework for naming structural tension, defining legitimacy, and translating doctrine into applied judgment across domains.",
			sub:
				"Designed to be cited, adapted, and implemented in organisations, products, and personal decision-making where structural clarity matters.",
			readDoctrine: "Read the Doctrine",
			viewImplementations: "View Implementations →",
			referenceNote:
				"Doctrine, protocols, standards, analytical method, and applied implementations in one public architecture.",
			referenceArchitecture: "Reference Architecture",
			methodDesc:
				"Analytical entries that identify structural tension before it hardens into normalized practice.",
			implementationsDesc:
				"Applied systems that enforce Paritsea logic in real operating environments. AgenSea is the first documented ASLS-01 implementation.",
			registry: "Analytical Registry",
			openMethod: "Open The Method →",
			quote: "\"The problem is not that things are broken.\nThe problem is that they work — and something is still wrong.\"",
			attr: "— Parit Ritchai, The Doctrine",
		};
---

<Base title={siteTitle} description={siteTagline} locale={locale}>
	<div class="landing">

		{/* ── HERO ── */}
		<section class="hero">
			<div class="hero-container">
				<div class="hero-inner">
					<p class="hero-eyebrow">{home.eyebrow}</p>
					<h1 class="hero-statement">
						{home.statement.split("\n").map((line, index) => (
							<>{index > 0 && <br />}{line}</>
						))}
					</h1>
					<p class="hero-definition">
						{home.definition}
					</p>
					<p class="hero-sub">
						{home.sub}
					</p>
					<div class="hero-actions">
						{doctrinePost && (
							<a href={localizedPath("/the-doctrine", locale)} class="btn-primary">
								{home.readDoctrine}
							</a>
						)}
						<a href={localizedPath("/implementations", locale)} class="btn-ghost">
							{home.viewImplementations}
						</a>
					</div>
					<p class="hero-reference-note">
						{home.referenceNote}
					</p>
				</div>
				<div class="hero-illustration-wrapper">
					{/*
					 * Framework Architecture Diagram
					 * Shows the 5 reference layers of Paritsea.
					 * A wave line (the sea threshold) divides Standards from The Method.
					 * Sand accent (#c4a882) marks the wave and anchor dot — brand colour.
					 */}
					<svg class="hero-illustration" viewBox="0 0 420 560" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
						{/* Outer reference frame */}
						<rect x="10" y="10" width="400" height="540" fill="none" stroke="currentColor" stroke-width="0.75" opacity="0.12"/>

						{/* Left margin rule */}
						<line x1="52" y1="68" x2="52" y2="492" stroke="currentColor" stroke-width="0.75" opacity="0.15"/>

						{/* Subtle vertical grid */}
						<line x1="157" y1="10" x2="157" y2="550" stroke="currentColor" stroke-width="0.4" opacity="0.06"/>
						<line x1="263" y1="10" x2="263" y2="550" stroke="currentColor" stroke-width="0.4" opacity="0.06"/>
						<line x1="369" y1="10" x2="369" y2="550" stroke="currentColor" stroke-width="0.4" opacity="0.06"/>

						{/* ── 01  THE DOCTRINE / แก่น ── */}
						<text x="24" y="75" font-family="ui-monospace,monospace" font-size="9" letter-spacing="0.08em" fill="currentColor" opacity="0.4">01</text>
						<line x1="52" y1="72" x2="400" y2="72" stroke="currentColor" stroke-width="1.75" opacity="0.55"/>
						{/* Anchor dot — structural clarity point */}
						<circle cx="210" cy="72" r="4" fill="currentColor" opacity="0.7"/>

						{/* Connectors from 01 down */}
						<line x1="126" y1="72" x2="126" y2="178" stroke="currentColor" stroke-width="0.6" opacity="0.18"/>
						<line x1="335" y1="72" x2="335" y2="178" stroke="currentColor" stroke-width="0.6" opacity="0.14"/>

						{/* ── 02  PROTOCOLS ── */}
						<text x="24" y="185" font-family="ui-monospace,monospace" font-size="9" letter-spacing="0.08em" fill="currentColor" opacity="0.35">02</text>
						<line x1="52" y1="182" x2="400" y2="182" stroke="currentColor" stroke-width="1.1" opacity="0.38"/>
						<circle cx="126" cy="182" r="2.5" fill="currentColor" opacity="0.45"/>
						<circle cx="335" cy="182" r="2.5" fill="currentColor" opacity="0.38"/>

						<line x1="126" y1="182" x2="210" y2="282" stroke="currentColor" stroke-width="0.5" opacity="0.14"/>
						<line x1="335" y1="182" x2="210" y2="282" stroke="currentColor" stroke-width="0.5" opacity="0.12"/>

						{/* ── 03  STANDARDS ── */}
						<text x="24" y="289" font-family="ui-monospace,monospace" font-size="9" letter-spacing="0.08em" fill="currentColor" opacity="0.32">03</text>
						<line x1="52" y1="286" x2="400" y2="286" stroke="currentColor" stroke-width="1.1" opacity="0.32"/>
						<circle cx="210" cy="286" r="2.5" fill="currentColor" opacity="0.42"/>

						{/* ── SEA WAVE THRESHOLD ── */}
						{/* Wave 1 — primary, sand colour */}
						<path
							d="M52 322 C110 302 150 342 210 322 C270 302 320 342 400 322"
							stroke="#c4a882" stroke-width="1.75" fill="none" opacity="0.85"
						/>
						{/* Wave 2 — secondary, lighter */}
						<path
							d="M52 337 C110 317 150 357 210 337 C270 317 320 357 400 337"
							stroke="#c4a882" stroke-width="1" fill="none" opacity="0.45"
						/>
						{/* Wave anchor dot */}
						<circle cx="210" cy="322" r="3" fill="#c4a882" opacity="0.9"/>

						{/* ── 04  THE METHOD ── */}
						<text x="24" y="390" font-family="ui-monospace,monospace" font-size="9" letter-spacing="0.08em" fill="currentColor" opacity="0.3">04</text>
						<line x1="52" y1="387" x2="400" y2="387" stroke="currentColor" stroke-width="1.1" opacity="0.28"/>
						<circle cx="157" cy="387" r="2" fill="currentColor" opacity="0.32"/>
						<circle cx="335" cy="387" r="2" fill="currentColor" opacity="0.28"/>

						{/* ── 05  IMPLEMENTATIONS ── */}
						<text x="24" y="492" font-family="ui-monospace,monospace" font-size="9" letter-spacing="0.08em" fill="currentColor" opacity="0.25">05</text>
						<line x1="52" y1="489" x2="400" y2="489" stroke="currentColor" stroke-width="1" opacity="0.22"/>
						<circle cx="210" cy="489" r="2.5" fill="currentColor" opacity="0.28"/>
						<circle cx="88" cy="489" r="1.5" fill="currentColor" opacity="0.2"/>
						<circle cx="340" cy="489" r="1.5" fill="currentColor" opacity="0.2"/>
					</svg>
				</div>
			</div>
			<div class="hero-rule" aria-hidden="true">
				<span class="rule-label">{home.referenceArchitecture}</span>
			</div>
		</section>

		{/* ── SYSTEM PILLARS ── */}
		<section class="pillars">
			<header class="section-header">
				<span class="section-eyebrow">{home.referenceArchitecture}</span>
			</header>
			<div class="pillars-grid">

				{localizedDoctrinePost && (
					<a href={localizedPath("/the-doctrine", locale)} class="pillar pillar--doctrine">
						<div class="pillar-index">01</div>
						<div class="pillar-body">
							<h2 class="pillar-title">{navLabels["The Doctrine"]}</h2>
							<p class="pillar-desc">
								{localizedDoctrinePost.data.excerpt ?? "The foundational position from which the rest of the framework derives."}
							</p>
						</div>
						<span class="pillar-arrow">→</span>
					</a>
				)}

				{localizedStpPost && (
					<a href={localizedPath("/protocols/stp", locale)} class="pillar">
						<div class="pillar-index">02</div>
						<div class="pillar-body">
							<h2 class="pillar-title">STP Protocol</h2>
							<p class="pillar-desc">
								{localizedStpPost.data.excerpt ?? "A protocol for structural transition, accountability, and procedural visibility."}
							</p>
						</div>
						<span class="pillar-arrow">→</span>
					</a>
				)}

				{localizedAslsPost && (
					<a href={localizedPath("/standards/asls-01", locale)} class="pillar">
						<div class="pillar-index">03</div>
						<div class="pillar-body">
							<h2 class="pillar-title">ASLS-01 Standard</h2>
							<p class="pillar-desc">
								{localizedAslsPost.data.excerpt ?? "A verifiable standard for assessing structural legitimacy in agency and service-based systems."}
							</p>
						</div>
						<span class="pillar-arrow">→</span>
					</a>
				)}

				<a href={localizedPath("/the-method", locale)} class="pillar pillar--method">
					<div class="pillar-index">04</div>
					<div class="pillar-body">
						<h2 class="pillar-title">{navLabels["The Method"]}</h2>
						<p class="pillar-desc">
							{home.methodDesc}
						</p>
					</div>
					<span class="pillar-arrow">→</span>
				</a>

				<a href={localizedPath("/implementations", locale)} class="pillar">
					<div class="pillar-index">05</div>
					<div class="pillar-body">
						<h2 class="pillar-title">{navLabels.Implementations}</h2>
						<p class="pillar-desc">
							{home.implementationsDesc}
						</p>
					</div>
					<span class="pillar-arrow">→</span>
				</a>

			</div>
		</section>

		{/* ── LATEST ENTRIES ── */}
		{methodEntriesWithTags.length > 0 && (
			<section class="records">
				<header class="section-header">
					<span class="section-eyebrow">{home.registry}</span>
					<a href={localizedPath("/the-method", locale)} class="section-more">{home.openMethod}</a>
				</header>
				<div class="records-list">
					{methodEntriesWithTags.map(({ post, categories, href }, i) => (
						<a href={href} class="record-item">
							<span class="record-num">
								{String(i + 1).padStart(2, "0")}
							</span>
							<div class="record-body">
								<h3 class="record-title">{post.data.title}</h3>
								{post.data.excerpt && (
									<p class="record-excerpt">{post.data.excerpt}</p>
								)}
							</div>
							<div class="record-meta">
								{categories.length > 0 && (
									<span class="record-tag">{categories[0].label}</span>
								)}
								{formatDate(post.data.publishedAt) && (
									<time class="record-date">{formatDate(post.data.publishedAt)}</time>
								)}
							</div>
						</a>
					))}
				</div>
			</section>
		)}

		{/* ── CLOSING STATEMENT ── */}
		<section class="closing">
			<blockquote class="closing-quote">
				{home.quote.split("\n").map((line, index) => (
					<>{index > 0 && <br />}{line}</>
				))}
			</blockquote>
			<p class="closing-attr">{home.attr}</p>
		</section>

	</div>
</Base>

<style>
	/* ─── Wrapper ─── */
	.landing {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 var(--spacing-8) var(--spacing-24);
	}

	/* ─── Section common ─── */
	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding-bottom: var(--spacing-4);
		border-bottom: 1px solid var(--color-border-subtle);
		margin-bottom: var(--spacing-10);
	}

	.section-eyebrow {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-xs);
		font-weight: 500;
		letter-spacing: var(--tracking-widest);
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.section-more {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-xs);
		color: var(--color-text-secondary);
		text-decoration: none;
		letter-spacing: 0.01em;
		transition: color var(--transition-fast);
	}

	.section-more:hover {
		color: var(--color-text);
	}

	/* ─── HERO ─── */
	.hero {
		padding: var(--spacing-20) 0 var(--spacing-24);
		border-bottom: 1px solid var(--color-border-subtle);
		margin-bottom: var(--spacing-20);
	}

	.hero-container {
		display: flex;
		gap: var(--spacing-16);
		align-items: flex-start;
	}

	.hero-inner {
		max-width: 760px;
		flex: 1;
	}

	.hero-illustration-wrapper {
		flex: 0 0 260px;
		align-self: stretch;
		display: flex;
		align-items: flex-start;
		padding-top: var(--spacing-3);
		opacity: 0.75;
		transition: opacity var(--transition-fast);
	}

	.hero:hover .hero-illustration-wrapper {
		opacity: 1;
	}

	.hero-illustration {
		width: 100%;
		height: auto;
		display: block;
		/* Taller viewBox ratio — fill vertical space naturally */
	}

	.hero-eyebrow {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-xs);
		font-weight: 500;
		letter-spacing: var(--tracking-widest);
		text-transform: uppercase;
		color: var(--color-muted);
		margin: 0 0 var(--spacing-6);
	}

	.hero-statement {
		font-family: Georgia, 'Times New Roman', serif;
		font-size: clamp(2rem, 4.5vw, 3.5rem);
		font-weight: 700;
		line-height: 1.06;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin: 0 0 var(--spacing-7);
	}

	.hero-definition {
		font-size: var(--font-size-lg);
		line-height: 1.6;
		color: var(--color-text-secondary);
		max-width: 620px;
		margin: 0 0 var(--spacing-5);
	}

	.hero-sub {
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		max-width: 560px;
		margin: 0 0 var(--spacing-8);
	}

	.br-lg { display: block; }

	.hero-actions {
		display: flex;
		gap: var(--spacing-5);
		align-items: center;
	}

	.hero-reference-note {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-sm);
		line-height: 1.7;
		color: var(--color-muted);
		max-width: 660px;
		margin: var(--spacing-6) 0 0;
	}

	.btn-primary {
		display: inline-block;
		padding: var(--spacing-3) var(--spacing-7);
		background: var(--color-text);
		color: var(--color-bg);
		text-decoration: none;
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-sm);
		font-weight: 500;
		letter-spacing: 0.02em;
		transition: opacity var(--transition-fast);
	}

	.btn-primary:hover {
		opacity: 0.78;
	}

	.btn-ghost {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		text-decoration: none;
		letter-spacing: 0.01em;
		transition: color var(--transition-fast);
	}

	.btn-ghost:hover {
		color: var(--color-text);
	}

	.hero-rule {
		display: flex;
		align-items: center;
		gap: var(--spacing-4);
		margin-top: var(--spacing-14);
	}

	.rule-label {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-xs);
		letter-spacing: var(--tracking-widest);
		text-transform: uppercase;
		color: var(--color-border);
	}

	/* ─── PILLARS ─── */
	.pillars {
		margin-bottom: var(--spacing-20);
	}

	.pillars-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1px;
		background: var(--color-border-subtle);
		border: 1px solid var(--color-border-subtle);
	}

	.pillar {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-5);
		padding: var(--spacing-8) var(--spacing-6) var(--spacing-7);
		background: var(--color-bg);
		text-decoration: none;
		color: inherit;
		transition: background var(--transition-fast), border-left-color var(--transition-fast);
		position: relative;
		border-left: 3px solid transparent;
	}

	.pillar:hover {
		background: var(--color-bg-subtle);
		border-left-color: var(--color-accent);
	}

	.pillar--doctrine {
		background: var(--color-bg-subtle);
	}

	.pillar--doctrine:hover {
		background: var(--color-surface);
