---
import { getEmDashCollection, getSiteSettings } from "emdash";
import Base from "../layouts/Base.astro";
import {
	formatDateForLocale,
	getAstroLocale,
	localizeEntry,
	localizedPath,
} from "../utils/i18n";
import { resolveBlogSiteIdentity } from "../utils/site-identity";

const locale = getAstroLocale(Astro);
const { entries, cacheHint } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
});
const { siteTitle } = resolveBlogSiteIdentity(await getSiteSettings());
Astro.cache.set(cacheHint);

function contentType(entry: (typeof entries)[number]) {
	const data = entry.data as unknown as Record<string, unknown>;
	if (typeof data.content_type === "string" && data.content_type) return data.content_type;
	const family = String(data.framework_page ?? "");
	if (family === "the-method") return "journal";
	if (family === "the-doctrine") return "framework";
	if (family === "protocols") return "protocol";
	if (family === "standards") return "standard";
	return "journal";
}

function workPath(entry: (typeof entries)[number]) {
	const type = contentType(entry);
	if (type === "concept") return `/concepts/${entry.id}`;
	if (type === "framework") return `/system/frameworks/${entry.id === "doctrine" ? "paritsea-framework" : entry.id}`;
	if (type === "protocol") return `/system/protocols/${entry.id}`;
	if (type === "standard") return `/system/standards/${entry.id}`;
	return `/journal/${entry.id}`;
}

const localizedWorks = entries.map((entry) => ({
	original: entry,
	entry: localizeEntry(entry, "posts", locale),
	type: contentType(entry),
	href: localizedPath(workPath(entry), locale),
}));

const journal = localizedWorks.filter((item) => item.type === "journal");
const formalized = localizedWorks.filter((item) => ["framework", "protocol", "standard"].includes(item.type));
const latestJournal = journal.slice(0, 3);
const featuredFormalized = formalized.slice(0, 3);

const counts = {
	journal: journal.length,
	concept: localizedWorks.filter((item) => item.type === "concept").length,
	framework: localizedWorks.filter((item) => item.type === "framework").length,
	protocol: localizedWorks.filter((item) => item.type === "protocol").length,
	standard: localizedWorks.filter((item) => item.type === "standard").length,
};

const copy = locale === "th"
	? {
		pageDescription: "Paritsea บันทึกข้อสังเกตของ Parit Ritchai และเปิดให้เห็นว่าความคิดหนึ่งค่อย ๆ ถูกตั้งชื่อ ทบทวน และพัฒนาเป็นงานอ้างอิงอย่างไร",
		heroLabel: "บันทึกสาธารณะโดย Parit Ritchai",
		heroTitle: "บางอย่างผิดอยู่ ก่อนที่เราจะมีคำเรียกมัน",
		heroSummary: "Paritsea เริ่มจากสิ่งที่ Parit Ritchai เห็นในชีวิต งาน และระบบ จากนั้นจึงบันทึก ตั้งชื่อ และทบทวน บางแนวคิดหยุดอยู่ที่คำถาม บางแนวคิดค่อย ๆ กลายเป็นงานอ้างอิงที่ตรวจสอบที่มาได้",
		primaryAction: "เริ่มจากข้อสังเกต",
		secondaryAction: "ดูงานอ้างอิง",
		mapLabel: "ความคิดหนึ่งอาจเดินทางอย่างไร",
		intentLabel: "เริ่มจากเหตุผลที่มาที่นี่",
		intentTitle: "คุณกำลังพยายามเข้าใจอะไร",
		intentSummary: "ไม่จำเป็นต้องอ่านตามลำดับ เลือกทางเข้าที่ตรงกับคำถามของคุณมากที่สุด",
		intents: [
			{
				index: "01",
				title: "ฉันเห็นบางอย่างซ้ำ ๆ แต่ยังอธิบายไม่ได้",
				body: "เริ่มจาก Journal เพื่ออ่านข้อสังเกตที่ยังไม่ถูกบังคับให้เป็นข้อสรุป",
				href: "/journal",
				link: "อ่านบันทึกต้นทาง",
			},
			{
				index: "02",
				title: "ฉันพบคำของ Paritsea และต้องการรู้ว่ามาจากไหน",
				body: "Concept records เก็บนิยาม ที่มา ความสัมพันธ์ และสิ่งที่แนวคิดนั้นยังไม่ได้พิสูจน์",
				href: "/concepts",
				link: "สำรวจแนวคิด",
			},
			{
				index: "03",
				title: "ฉันต้องการงานที่จัดระบบแล้ว",
				body: "Framework, Protocol และ Standard แสดงข้อเสนอ ภาระหน้าที่ เกณฑ์ และเวอร์ชันที่อ้างอิงได้",
				href: "/system",
				link: "ดูงานอ้างอิง",
			},
			{
				index: "04",
				title: "ฉันต้องการอ้างอิง ดัดแปลง หรือนำงานไปใช้",
				body: "ตรวจขอบเขตการใช้ วิธีระบุที่มา และระเบียนการนำงานไปใช้โดยไม่บิดความหมายต้นทาง",
				href: "/ip",
				link: "ตรวจการใช้และอ้างอิง",
			},
		],
		journalLabel: "คำถามที่กำลังเคลื่อนไหว",
		journalTitle: "สิ่งที่ยังไม่ควรถูกสรุปเร็วเกินไป",
		journalSummary: "Journal รักษาข้อสังเกตและความไม่แน่นอนไว้ก่อน บันทึกแต่ละชิ้นจึงไม่จำเป็นต้องกลายเป็น Framework หรือ Standard",
		openJournal: "ดูบันทึกทั้งหมด",
		formalLabel: "งานที่ผ่านการจัดระบบแล้ว",
		formalTitle: "อ่านได้ อ้างอิงได้ และตรวจที่มาได้",
		formalSummary: "งานกลุ่มนี้ระบุประเภท สถานะ เวอร์ชัน ขอบเขต และเหตุผลของการเปลี่ยนแปลงอย่างชัดเจน",
		openSystem: "ดูงานอ้างอิงทั้งหมด",
		pathLabel: "จากข้อสังเกตสู่งานอ้างอิง",
		pathTitle: "ไม่ใช่ทุกความคิดต้องเดินไปจนสุดทาง",
		pathSummary: "เส้นทางนี้แสดงความสัมพันธ์ ไม่ใช่ลำดับบังคับ งานหนึ่งอาจยังคงเป็นคำถาม หรือย้อนกลับไปแก้ความเข้าใจเดิมเมื่อมีหลักฐานใหม่",
		pathStages: ["ข้อสังเกต", "แนวคิด", "Framework", "Protocol", "Standard"],
		authorLabel: "ใครกำลังพูด",
		authorTitle: "ผู้เขียนต้องมองเห็นได้ แต่ไม่ควรกลบงาน",
		authorBody: "Parit Ritchai เป็นผู้เขียนข้อสังเกต ผู้ตั้งชื่อ และผู้ตัดสินใจเมื่อความหมายของงานต้นทางเปลี่ยน ส่วน Paritsea ทำให้งานเหล่านั้นอ่าน ตรวจสอบ และอ้างอิงได้โดยไม่ต้องกลายเป็นประวัติส่วนตัวหรือข้อเสนอขายบริการ",
		authorLink: "อ่านเรื่องผู้เขียนและขอบเขตของ Paritsea",
		appliedLabel: "เมื่องานถูกนำไปใช้",
		appliedTitle: "การประยุกต์ใช้ไม่เปลี่ยนเจ้าของต้นทาง",
		appliedBody: "SE Ocean อาจตีความและนำงานบางส่วนไปใช้กับบริบทองค์กร งานที่ทำกับลูกค้าเปลี่ยนได้ตามสถานการณ์ แต่ไม่สามารถแก้ความหมายของฉบับอ้างอิงหลักใน Paritsea ได้โดยอัตโนมัติ",
		appliedLink: "ดูบริบทการประยุกต์ใช้ที่ SE Ocean",
		returnLabel: "กลับมาเมื่อความคิดเปลี่ยน",
		returnTitle: "ติดตามงานใหม่และการแก้ไขผ่าน RSS",
		returnBody: "Paritsea ไม่เผยแพร่เพื่อรักษาความถี่ เมื่อมีข้อสังเกตใหม่หรือฉบับอ้างอิงเปลี่ยน การอัปเดตจะกลับมาที่บันทึกต้นทางเสมอ",
		returnLink: "เปิด RSS",
		workType: { journal: "Journal", concept: "Concept", framework: "Framework", protocol: "Protocol", standard: "Standard" } as Record<string, string>,
		status: { exploring: "กำลังสำรวจ", developing: "กำลังพัฒนา", current: "ฉบับปัจจุบัน", superseded: "มีฉบับใหม่กว่า", retired: "ยุติการใช้" } as Record<string, string>,
	}
	: {
		pageDescription: "Paritsea records observations by Parit Ritchai and shows how selected ideas are named, revised, and developed into traceable public work.",
		heroLabel: "A public record by Parit Ritchai",
		heroTitle: "Some things are wrong before we have language for them.",
		heroSummary: "Paritsea begins with what Parit Ritchai notices in life, work, and systems. Observations are recorded, named, and revised. Some remain open questions. Selected ideas become reference work whose source and limits can be inspected.",
		primaryAction: "Start with an observation",
		secondaryAction: "Browse reference work",
		mapLabel: "How an idea may move",
		intentLabel: "Start with what brought you here",
		intentTitle: "What are you trying to understand?",
		intentSummary: "There is no required reading order. Choose the entry point closest to the question you already have.",
		intents: [
			{ index: "01", title: "I keep noticing something I cannot yet explain", body: "Start with Journal for observations that have not been forced into conclusions.", href: "/journal", link: "Read source observations" },
			{ index: "02", title: "I encountered a Paritsea term and need its source", body: "Concept records hold definitions, origin, relationships, and what an idea has not established.", href: "/concepts", link: "Explore concepts" },
			{ index: "03", title: "I need work that has become structured", body: "Frameworks, Protocols, and Standards expose propositions, obligations, thresholds, and referenceable versions.", href: "/system", link: "Browse reference work" },
			{ index: "04", title: "I want to cite, adapt, or use the work", body: "Check attribution, use boundaries, and recorded applications without displacing the source.", href: "/ip", link: "Review use and citation" },
		],
		journalLabel: "Questions in motion",
		journalTitle: "Work that should not be settled too quickly",
		journalSummary: "Journal keeps observation and uncertainty visible. An entry does not need to become a Framework or Standard to remain useful.",
		openJournal: "View all observations",
		formalLabel: "Structured reference work",
		formalTitle: "Readable, citable, and traceable to its source",
		formalSummary: "These works name their type, status, version, scope, and the reason for material change.",
		openSystem: "View all reference work",
		pathLabel: "From observation to reference work",
		pathTitle: "Not every idea has to travel the whole path",
		pathSummary: "This is a relationship map, not a required sequence. Work may remain an open question or return to an earlier stage when new evidence changes the reading.",
		pathStages: ["Observation", "Concept", "Framework", "Protocol", "Standard"],
		authorLabel: "Who is speaking",
		authorTitle: "The author should remain visible without eclipsing the work",
		authorBody: "Parit Ritchai writes the observations, names the patterns, and decides when the meaning of source work changes. Paritsea makes that work readable, inspectable, and citable without turning it into a personal portfolio or service offer.",
		authorLink: "Read about the author and Paritsea's boundary",
		appliedLabel: "When work is applied",
		appliedTitle: "Application does not transfer authority over the source",
		appliedBody: "SE Ocean may interpret and apply selected work in organizational contexts. Client work can change with the situation, but it cannot silently redefine the canonical Paritsea source.",
		appliedLink: "See applied contexts at SE Ocean",
		returnLabel: "Return when the work changes",
		returnTitle: "Follow new work and revisions through RSS",
		returnBody: "Paritsea does not publish to maintain a cadence. When a new observation appears or reference work changes, the update returns to the source record.",
		returnLink: "Open RSS",
		workType: { journal: "Journal", concept: "Concept", framework: "Framework", protocol: "Protocol", standard: "Standard" } as Record<string, string>,
		status: { exploring: "Exploring", developing: "Developing", current: "Current", superseded: "Superseded", retired: "Retired" } as Record<string, string>,
	};

function stageState(type: string) {
	if (type === "journal") return "moving";
	if (type === "concept") return "named";
	return "governed";
}

function statusFor(item: (typeof localizedWorks)[number]) {
	const data = item.original.data as unknown as Record<string, unknown>;
	return String(data.lifecycle_status ?? (item.type === "journal" ? "exploring" : "current"));
}

function versionFor(item: (typeof localizedWorks)[number]) {
	const data = item.original.data as unknown as Record<string, unknown>;
	return String(data.document_version ?? (item.type === "journal" ? "0.1" : "1.0"));
}
---

<Base title={siteTitle} description={copy.pageDescription} locale={locale}>
	<div class="home-page">
		<section class="home-hero" aria-labelledby="home-title">
			<div class="home-hero-copy">
				<p class="experience-label" data-state="moving">{copy.heroLabel}</p>
				<h1 id="home-title" class="experience-title">{copy.heroTitle}</h1>
				<p class="experience-summary">{copy.heroSummary}</p>
				<div class="home-hero-actions">
					<a class="home-primary-link" href={localizedPath("/journal", locale)}>{copy.primaryAction}<span aria-hidden="true">↗</span></a>
					<a class="experience-link" href={localizedPath("/system", locale)}>{copy.secondaryAction}<span aria-hidden="true">→</span></a>
				</div>
			</div>

			<div class="home-trace" aria-label={copy.mapLabel}>
				<p>{copy.mapLabel}</p>
				<ol>
					<li data-state="moving"><span>01</span>{copy.pathStages[0]}</li>
					<li data-state="named"><span>02</span>{copy.pathStages[1]}</li>
					<li data-state="governed"><span>03</span>{copy.pathStages[2]}</li>
				</ol>
				<p class="home-trace-note">{locale === "th" ? "เส้นทางเปิดอยู่ และย้อนกลับได้" : "The path stays open and revisable"}</p>
			</div>
		</section>

		<section class="experience-section home-intents" aria-labelledby="intent-title">
			<div class="experience-section-heading">
				<div>
					<p class="experience-label" data-state="named">{copy.intentLabel}</p>
					<h2 id="intent-title">{copy.intentTitle}</h2>
				</div>
				<p>{copy.intentSummary}</p>
			</div>
			<div class="intent-list">
				{copy.intents.map((intent) => (
					<a href={localizedPath(intent.href, locale)} class="intent-row">
						<span class="intent-index">{intent.index}</span>
						<div>
							<h3>{intent.title}</h3>
							<p>{intent.body}</p>
						</div>
						<span class="intent-link">{intent.link} <i aria-hidden="true">→</i></span>
					</a>
				))}
			</div>
		</section>

		<section class="experience-section" aria-labelledby="journal-title">
			<div class="experience-section-heading">
				<div>
					<p class="experience-label" data-state="moving">{copy.journalLabel}</p>
					<h2 id="journal-title">{copy.journalTitle}</h2>
				</div>
				<div>
					<p>{copy.journalSummary}</p>
					<a class="experience-link" href={localizedPath("/journal", locale)}>{copy.openJournal} <span aria-hidden="true">→</span></a>
				</div>
			</div>
			<div class="experience-index">
				{latestJournal.map((item) => (
					<a class="experience-index-row" href={item.href}>
						<div class="experience-index-meta">
							<span>{copy.workType[item.type]}</span><br />
							{item.original.data.publishedAt && <time>{formatDateForLocale(item.original.data.publishedAt, locale)}</time>}
						</div>
						<div class="experience-index-copy">
							<h3>{item.entry.data.title}</h3>
							{item.entry.data.excerpt && <p>{item.entry.data.excerpt}</p>}
						</div>
						<div class="experience-index-state">{copy.status[statusFor(item)] ?? statusFor(item)}</div>
					</a>
				))}
			</div>
		</section>

		<section class="experience-section" aria-labelledby="formal-title">
			<div class="experience-section-heading">
				<div>
					<p class="experience-label" data-state="governed">{copy.formalLabel}</p>
					<h2 id="formal-title">{copy.formalTitle}</h2>
				</div>
				<div>
					<p>{copy.formalSummary}</p>
					<a class="experience-link" href={localizedPath("/system", locale)}>{copy.openSystem} <span aria-hidden="true">→</span></a>
				</div>
			</div>
			<div class="experience-index">
				{featuredFormalized.map((item) => (
					<a class="experience-index-row" href={item.href}>
						<div class="experience-index-meta">{copy.workType[item.type]}<br />v{versionFor(item)}</div>
						<div class="experience-index-copy">
							<h3>{item.entry.data.title}</h3>
							{item.entry.data.excerpt && <p>{item.entry.data.excerpt}</p>}
						</div>
						<div class="experience-index-state">{copy.status[statusFor(item)] ?? statusFor(item)}</div>
					</a>
				))}
			</div>
		</section>

		<section class="experience-section thought-path" aria-labelledby="path-title">
			<div class="experience-section-heading">
				<div>
					<p class="experience-label" data-state="named">{copy.pathLabel}</p>
					<h2 id="path-title">{copy.pathTitle}</h2>
				</div>
				<p>{copy.pathSummary}</p>
			</div>
			<ol class="thought-path-list">
				{copy.pathStages.map((stage, index) => {
					const keys = ["journal", "concept", "framework", "protocol", "standard"] as const;
					const hrefs = ["/journal", "/concepts", "/system/frameworks", "/system/protocols", "/system/standards"];
					return (
						<li data-state={stageState(keys[index])}>
							<a href={localizedPath(hrefs[index], locale)}>
								<span>{String(index + 1).padStart(2, "0")}</span>
								<strong>{stage}</strong>
								<small>{counts[keys[index]]}</small>
							</a>
						</li>
					);
				})}
			</ol>
		</section>

		<section class="experience-section home-author" aria-labelledby="author-title">
			<div class="experience-note">
				<div>
					<p class="experience-label" data-state="named">{copy.authorLabel}</p>
					<h2 id="author-title">{copy.authorTitle}</h2>
				</div>
				<div>
					<p>{copy.authorBody}</p>
					<a class="experience-link" href={localizedPath("/about", locale)}>{copy.authorLink} <span aria-hidden="true">→</span></a>
				</div>
			</div>
		</section>

		<section class="experience-section home-application" aria-labelledby="applied-title">
			<div class="experience-note" data-context="applied">
				<div>
					<p class="experience-label" data-state="applied">{copy.appliedLabel}</p>
					<h2 id="applied-title">{copy.appliedTitle}</h2>
				</div>
				<div>
					<p>{copy.appliedBody}</p>
					<a class="experience-link" href="https://seocean.co.th" target="_blank" rel="noreferrer">{copy.appliedLink} <span aria-hidden="true">↗</span></a>
				</div>
			</div>
		</section>

		<section class="home-return" aria-labelledby="return-title">
			<p class="experience-label" data-state="moving">{copy.returnLabel}</p>
			<h2 id="return-title">{copy.returnTitle}</h2>
			<p>{copy.returnBody}</p>
			<a class="experience-link" href="/rss.xml">{copy.returnLink} <span aria-hidden="true">↗</span></a>
		</section>
	</div>
</Base>

<style>
	.home-page {
		width: var(--wide-width);
		margin-inline: auto;
		padding-bottom: var(--spacing-24);
	}

	.home-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.25fr) minmax(290px, 0.55fr);
		gap: clamp(var(--spacing-12), 8vw, var(--spacing-32));
		align-items: end;
		min-height: min(780px, calc(100dvh - var(--nav-height)));
		padding-block: clamp(var(--spacing-16), 9vw, var(--spacing-32));
		border-bottom: 1px solid var(--color-border);
	}

	.home-hero-copy .experience-title {
		max-width: 12ch;
	}

	.home-hero-actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--spacing-5) var(--spacing-7);
		margin-top: var(--spacing-10);
	}

	.home-primary-link {
		display: inline-flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--spacing-8);
		min-width: 260px;
		min-height: 52px;
		padding: var(--spacing-3) var(--spacing-5);
		background: var(--color-text);
		color: var(--color-bg);
		text-decoration: none;
		transition: transform var(--transition-base), background var(--transition-base);
	}

	.home-primary-link:hover {
		transform: translateY(-2px);
		background: var(--color-accent);
	}

	.home-trace {
		position: relative;
		padding: var(--spacing-6) 0 var(--spacing-6) var(--spacing-7);
		border-left: 1px solid var(--color-border);
	}

	.home-trace > p:first-child,
	.home-trace-note {
		font-family: var(--font-mono);
