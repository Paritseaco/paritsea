---
import { getEmDashCollection, getEntryTerms, getSiteSettings } from "emdash";
import Base from "../layouts/Base.astro";
import {
	isFrameworkPageSlug,
	resolveFrameworkPage,
	resolvePostPath,
} from "../utils/public-paths";
import { resolveBlogSiteIdentity } from "../utils/site-identity";
import {
	formatDateForLocale,
	getAstroLocale,
	localizeEntry,
	localizeTermLabel,
	localizedPath,
	ui,
} from "../utils/i18n";

const locale = getAstroLocale(Astro);
const copy = ui[locale];
const navLabels = ui[locale].navLabels;

const { entries: posts, cacheHint } = await getEmDashCollection("posts");
const { siteTitle, siteTagline } = resolveBlogSiteIdentity(await getSiteSettings());

Astro.cache.set(cacheHint);

// Specific landmark posts
const doctrinePost = posts.find((p) => p.id === "doctrine");
const stpPost = posts.find((p) => p.id === "stp");
const aslsPost = posts.find((p) => p.id === "asls-01");
const localizedDoctrinePost = doctrinePost ? localizeEntry(doctrinePost, "posts", locale) : null;
const localizedStpPost = stpPost ? localizeEntry(stpPost, "posts", locale) : null;
const localizedAslsPost = aslsPost ? localizeEntry(aslsPost, "posts", locale) : null;

// The Method = recent analytical entries (exclude the 3 landmark posts)
const landmarkIds = new Set(["doctrine", "stp", "asls-01"]);
const methodEntries = (
	await Promise.all(
		posts
			.filter((p) => !landmarkIds.has(p.id))
			.map(async (post) => {
				const legacyTerms = await getEntryTerms("posts", post.data.id, "category");
				const legacyFrameworkPage =
					legacyTerms.find((term) => isFrameworkPageSlug(term.slug))?.slug ?? null;
				return {
					post,
					legacyTerms,
					frameworkPage: resolveFrameworkPage(post.data.framework_page, legacyFrameworkPage),
				};
			}),
	)
)
	.filter((entry) => entry.frameworkPage === "the-method")
	.toSorted((a, b) => {
		const dateA = a.post.data.publishedAt?.getTime() ?? 0;
		const dateB = b.post.data.publishedAt?.getTime() ?? 0;
		return dateB - dateA;
	})
	.slice(0, 4);

const methodEntriesWithTags = await Promise.all(
	methodEntries.map(async ({ post, legacyTerms, frameworkPage }) => {
		const categories = legacyTerms.filter((term) => !isFrameworkPageSlug(term.slug)).length > 0
			? legacyTerms.filter((term) => !isFrameworkPageSlug(term.slug))
			: await getEntryTerms("posts", post.data.id, "category");
		const href =
			resolvePostPath(post.id, frameworkPage, null) ??
			`/the-method/${post.id}`;
		return {
			post: localizeEntry(post, "posts", locale),
			youtubeUrl: typeof post.data.youtube_url === "string" ? post.data.youtube_url : null,
			categories: categories.map((category) => ({
				slug: category.slug,
				label: localizeTermLabel(category.label, locale),
			})),
			href: localizedPath(href, locale),
		};
	})
);

function formatDate(date: Date | null | undefined) {
	return formatDateForLocale(date, locale);
}

const home = locale === "th"
	? {
			eyebrow: "กรอบอ้างอิงสาธารณะ",
			statement: "เมื่อชีวิตกับระบบซับซ้อน\nเราต้องมีภาษาที่ทำให้มันชัด",
			definition:
				"Paritsea คือพื้นที่ที่อ่านชีวิตคนและระบบไปพร้อมกัน แปลงความสับสนให้เป็นโครงสร้างที่นิยามได้ ตัดสินใจได้ และนำไปใช้ได้จริง",
			sub:
				"วิธีทำงานของฉันผสาน intuition + analysis + strategy เพื่ออ่าน pattern อธิบายความซับซ้อน และสร้าง framework ที่ใช้ได้กับคน งาน และธุรกิจ",
			startHere: "เริ่มตรงนี้",
			startHereDesc: "ใหม่ต่อ Paritsea? เริ่มจากแก่นหลัก จากนั้นสำรวจบันทึกวิเคราะห์ หรือดูกระบบที่นำไปใช้จริง",
			methodLabel: "วิธีคิดหลัก",
			methodSummary: "Paritsea มองคน ระบบ โครงสร้าง และความคลุมเครือไปพร้อมกัน — แปลเป็นภาษาทำงานที่ชัดเจน ตั้งชื่อได้ เข้าใจได้ และลงมือทำได้",
			methodDetail:
				"จับสัญญาณที่ยังไม่มีภาษา → แยกโครงสร้างและ pattern → แปลงเป็นคำแนะนำและทิศทางที่ตัดสินใจได้",
			readDoctrine: "อ่านแก่น",
			exploreMethod: "เปิดวิธีวิเคราะห์",
			viewImplementations: "ดูการประยุกต์ใช้",
			methodDesc:
				"บันทึกวิเคราะห์ที่ระบุแรงตึงเชิงโครงสร้าง ก่อนมันจะแข็งตัวกลายเป็นบรรทัดฐาน",
			implementationsDesc:
				"ระบบที่นำตรรกะ Paritsea ไปใช้จริงในสภาพแวดล้อมการทำงาน AgenSea คือการประยุกต์ใช้แรกที่บันทึกไว้ภายใต้ ASLS-01",
			registry: "ทะเบียนวิเคราะห์",
			openMethod: "เปิด The Method →",
			followOn: "ติดตาม",
			quote: "\"ปัญหาไม่ใช่ว่าสิ่งต่างๆ พัง\nปัญหาคือมันทำงานอยู่ — และยังมีบางอย่างผิด\"",
			attr: "— Parit Ritchai, แก่น",
		}
	: {
			eyebrow: "Public Reference Framework",
			statement: "When life and systems are complex,\nwe need language that makes them legible.",
			definition:
				"Paritsea integrates people, systems, structure, and ambiguity into clear working language — so complexity can be named, understood, and acted on.",
			sub:
				"My work combines intuition + analysis + strategy to read patterns, build frameworks, and turn insight into usable direction.",
			startHere: "Start Here",
			startHereDesc: "New to Paritsea? Begin with the foundational position, then explore analytical entries, or see applied systems.",
			methodLabel: "Core Method",
			methodSummary: "Paritsea integrates people, systems, structure, and ambiguity into clear working language — so complexity can be named, understood, and acted on.",
			methodDetail:
				"Transform unarticulated tensions into actionable frameworks through structured observation, pattern recognition, and strategic synthesis.",
			readDoctrine: "Read the Doctrine",
			exploreMethod: "Explore the Method",
			viewImplementations: "View Implementations",
			methodDesc:
				"Analytical entries that identify structural tension before it hardens into normalized practice.",
			implementationsDesc:
				"Applied systems that enforce Paritsea logic in real operating environments. AgenSea is the first documented ASLS-01 implementation.",
			registry: "Analytical Registry",
			openMethod: "Open The Method →",
			followOn: "Follow on",
			quote: "\"The problem is not that things are broken.\nThe problem is that they work — and something is still wrong.\"",
			attr: "— Parit Ritchai, The Doctrine",
		};
---

<Base title={siteTitle} description={siteTagline} locale={locale}>
	<div class="landing">

		{/* ── HERO ── */}
		<section class="hero">
			<div class="hero-content">
				<p class="hero-eyebrow">{home.eyebrow}</p>
				<h1 class="hero-statement">{home.statement.split("\n").map((line, index) => <>{index > 0 && <br />}{line}</>)}</h1>
				<p class="hero-definition">{home.definition}</p>
				
				<div class="hero-actions">
					{doctrinePost && <a href={localizedPath("/the-doctrine", locale)} class="btn-primary">{home.readDoctrine}</a>}
					<a href={localizedPath("/the-method", locale)} class="btn-secondary">{home.exploreMethod}</a>
				</div>
			</div>

			{/* ── AUTHOR CARD ── */}
			<aside class="hero-author">
				<img src="/images/parit-profile.jpg" alt="Parit Ritchai" class="hero-author-img" />
				<div class="hero-author-body">
					<p class="hero-author-name">{copy.authorName}</p>
					<p class="hero-author-role">{copy.authorRole}</p>
					<p class="hero-author-bio">{copy.authorBio}</p>
					<div class="hero-author-links">
						<a href="https://www.instagram.com/paritsea" target="_blank" rel="noreferrer" class="hero-author-link">{copy.socialInstagram}</a>
						<a href="https://www.threads.net/@paritsea" target="_blank" rel="noreferrer" class="hero-author-link">{copy.socialThreads}</a>
						<a href="https://www.youtube.com/@paritsea" target="_blank" rel="noreferrer" class="hero-author-link">{copy.socialYouTube}</a>
						<a href={localizedPath("/about", locale)} class="hero-author-link hero-author-link--about">{copy.about} →</a>
					</div>
				</div>
			</aside>
		</section>

		{/* ── START HERE / PATHWAY ── */}
		<section class="pathway">
			<p class="pathway-label">{copy.startHere}</p>
			<p class="pathway-desc">{copy.startHereDesc}</p>
			<div class="pathway-cards">
				<a href={localizedPath("/the-doctrine", locale)} class="pathway-card">
					<span class="pathway-card-num">01</span>
					<div class="pathway-card-body">
						<h3 class="pathway-card-title">{navLabels["The Doctrine"]}</h3>
						<p class="pathway-card-desc">{locale === "th" ? "รากฐานของกรอบอ้างอิง" : "The foundational position"}</p>
					</div>
				</a>
				<a href={localizedPath("/the-method", locale)} class="pathway-card">
					<span class="pathway-card-num">02</span>
					<div class="pathway-card-body">
						<h3 class="pathway-card-title">{navLabels["The Method"]}</h3>
						<p class="pathway-card-desc">{locale === "th" ? "บันทึกวิเคราะห์" : "Analytical records"}</p>
					</div>
				</a>
				<a href={localizedPath("/implementations", locale)} class="pathway-card">
					<span class="pathway-card-num">03</span>
					<div class="pathway-card-body">
						<h3 class="pathway-card-title">{navLabels.Implementations}</h3>
						<p class="pathway-card-desc">{locale === "th" ? "ระบบที่นำไปใช้จริง" : "Applied systems"}</p>
					</div>
				</a>
			</div>
		</section>

		{/* ── METHOD STRIP ── */}
		<section class="method-strip" aria-label={home.methodLabel}>
			<p class="method-strip-label">{home.methodLabel}</p>
			<p class="method-strip-summary">{home.methodSummary}</p>
			<p class="method-strip-detail">{home.methodDetail}</p>
		</section>

		{/* ── SYSTEM PILLARS ── */}
		<section class="pillars">
			<header class="section-header">
				<span class="section-eyebrow">{locale === "th" ? "สถาปัตยกรรมอ้างอิง" : "Reference Architecture"}</span>
			</header>
			<div class="pillars-grid">

				{localizedDoctrinePost && (
					<a href={localizedPath("/the-doctrine", locale)} class="pillar pillar--doctrine">
						<div class="pillar-index">01</div>
						<div class="pillar-body">
							<h2 class="pillar-title">{navLabels["The Doctrine"]}</h2>
							<p class="pillar-desc">
								{localizedDoctrinePost.data.excerpt ?? "The foundational position from which the rest of the framework derives."}
							</p>
						</div>
						<span class="pillar-arrow">→</span>
					</a>
				)}

				{localizedStpPost && (
					<a href={localizedPath("/protocols/stp", locale)} class="pillar">
						<div class="pillar-index">02</div>
						<div class="pillar-body">
							<h2 class="pillar-title">STP Protocol</h2>
							<p class="pillar-desc">
								{localizedStpPost.data.excerpt ?? "A protocol for structural transition, accountability, and procedural visibility."}
							</p>
						</div>
						<span class="pillar-arrow">→</span>
					</a>
				)}

				{localizedAslsPost && (
					<a href={localizedPath("/standards/asls-01", locale)} class="pillar">
						<div class="pillar-index">03</div>
						<div class="pillar-body">
							<h2 class="pillar-title">ASLS-01 Standard</h2>
							<p class="pillar-desc">
								{localizedAslsPost.data.excerpt ?? "A verifiable standard for assessing structural legitimacy in agency and service-based systems."}
							</p>
						</div>
						<span class="pillar-arrow">→</span>
					</a>
				)}

				<a href={localizedPath("/the-method", locale)} class="pillar pillar--method">
					<div class="pillar-index">04</div>
					<div class="pillar-body">
						<h2 class="pillar-title">{navLabels["The Method"]}</h2>
						<p class="pillar-desc">
							{home.methodDesc}
						</p>
					</div>
					<span class="pillar-arrow">→</span>
				</a>

				<a href={localizedPath("/implementations", locale)} class="pillar">
					<div class="pillar-index">05</div>
					<div class="pillar-body">
						<h2 class="pillar-title">{navLabels.Implementations}</h2>
						<p class="pillar-desc">
							{home.implementationsDesc}
						</p>
					</div>
					<span class="pillar-arrow">→</span>
				</a>

			</div>
		</section>

		{/* ── LATEST ENTRIES ── */}
		{methodEntriesWithTags.length > 0 && (
			<section class="records">
				<header class="section-header">
					<span class="section-eyebrow">{home.registry}</span>
					<a href={localizedPath("/the-method", locale)} class="section-more">{home.openMethod}</a>
				</header>
				<div class="records-list">
					{methodEntriesWithTags.map(({ post, youtubeUrl, categories, href }, i) => (
						<a href={href} class="record-item">
							<span class="record-num">
								{String(i + 1).padStart(2, "0")}
							</span>
							<div class="record-body">
								<h3 class="record-title">{post.data.title}</h3>
								{post.data.excerpt && (
									<p class="record-excerpt">{post.data.excerpt}</p>
								)}
							</div>
							<div class="record-meta">
								{categories.length > 0 && (
									<span class="record-tag">{categories[0].label}</span>
								)}
								{youtubeUrl && (
									<span class="record-tag record-tag-video">{locale === "th" ? "วิดีโอ" : "Video"}</span>
								)}
								{formatDate(post.data.publishedAt) && (
									<time class="record-date">{formatDate(post.data.publishedAt)}</time>
								)}
							</div>
						</a>
					))}
				</div>
			</section>
		)}

		{/* ── SOCIAL / FOLLOW ── */}
		<section class="social-bridge">
			<p class="social-bridge-eyebrow">{locale === "th" ? "เนื้อหาบนสื่ออื่น" : "Across Platforms"}</p>
			<p class="social-bridge-text">{locale === "th" ? "วิดีโอสะท้อนคิดและเนื้อหาสั้นใน knowledge flow เดียวกัน — รูปแบบต่าง แก่นวิเคราะห์เดียวกัน" : "Video reflections and short-form content in the same knowledge flow — different formats, the same analytical spine."}</p>
			<div class="social-bridge-links">
				<a href="https://www.instagram.com/paritsea" target="_blank" rel="noreferrer" class="social-bridge-link">
					Instagram
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
				</a>
				<a href="https://www.youtube.com/@paritsea" target="_blank" rel="noreferrer" class="social-bridge-link">
					YouTube
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.94 2C5.12 20 12 20 12 20s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 8.25 15.5 12 9.75 15.75 9.75 8.25"/></svg>
				</a>
				<a href="https://www.threads.net/@paritsea" target="_blank" rel="noreferrer" class="social-bridge-link">
					Threads
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 12a4 4 0 0 0-8 0 4 4 0 0 0 8 0"/><path d="M12 8v8"/></svg>
				</a>
			</div>
		</section>

		{/* ── CLOSING STATEMENT ── */}
		<section class="closing">
			<blockquote class="closing-quote">
				{home.quote.split("\n").map((line, index) => (
					<>{index > 0 && <br />}{line}</>
				))}
			</blockquote>
			<p class="closing-attr">{home.attr}</p>
		</section>

	</div>
</Base>

<style>
	/* ─── Landing wrapper ─── */
	.landing {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 var(--spacing-8) var(--spacing-24);
	}

	/* ─── HERO ─── */
	.hero {
		display: grid;
		grid-template-columns: 1fr 280px;
		gap: var(--spacing-16);
		padding: 5rem 0 var(--spacing-16);
		align-items: start;
		position: relative;
		border-bottom: 1px solid var(--color-border-subtle);
		margin-bottom: var(--spacing-12);
	}

	.hero-content {
		max-width: 740px;
	}

	.hero-eyebrow {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 600;
		letter-spacing: var(--tracking-widest);
		text-transform: uppercase;
		color: var(--color-accent);
		margin: 0 0 var(--spacing-6);
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
	}

	.hero-eyebrow::before {
		content: "◆";
		font-size: 0.7em;
		color: var(--color-accent);
		opacity: 0.9;
	}

	.hero-statement {
		font-family: var(--font-serif);
		font-size: clamp(2.25rem, 4.5vw, 3.75rem);
		font-weight: 700;
		line-height: 1.08;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin: 0 0 var(--spacing-8);
	}

	.hero-definition {
		font-size: var(--font-size-lg);
		line-height: 1.7;
		color: var(--color-text-secondary);
		max-width: 640px;
		margin: 0 0 var(--spacing-10);
	}

	.hero-actions {
		display: flex;
		gap: var(--spacing-4);
		align-items: center;
	}

	.btn-primary {
		display: inline-block;
		padding: var(--spacing-3) var(--spacing-7);
		background: var(--color-accent);
		color: var(--color-on-accent);
		text-decoration: none;
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 500;
		letter-spacing: 0.02em;
		transition: background var(--transition-fast), transform var(--transition-fast);
	}

	.btn-primary:hover {
		background: var(--color-accent-hover);
		transform: translateY(-1px);
		opacity: 1;
	}

	.btn-secondary {
		display: inline-block;
		padding: var(--spacing-3) var(--spacing-7);
		border: 1px solid var(--color-border);
		color: var(--color-text-secondary);
		text-decoration: none;
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 500;
		letter-spacing: 0.02em;
		transition: border-color var(--transition-fast), color var(--transition-fast), transform var(--transition-fast);
	}

	.btn-secondary:hover {
		border-color: var(--color-accent);
		color: var(--color-text);
		transform: translateY(-1px);
		opacity: 1;
	}

	/* ─── AUTHOR CARD ─── */
	.hero-author {
		background: var(--color-surface);
		padding: var(--spacing-6);
		border: 1px solid var(--color-border-subtle);
		position: sticky;
		top: calc(var(--nav-height) + 2rem);
	}

	.hero-author-img {
		width: 72px;
		height: 72px;
		border-radius: 50%;
		object-fit: cover;
		margin-bottom: var(--spacing-5);
	}

	.hero-author-name {
		font-family: var(--font-serif);
		font-size: var(--font-size-lg);
		font-weight: 700;
		color: var(--color-text);
		margin: 0 0 var(--spacing-2);
	}

	.hero-author-role {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		color: var(--color-accent);
		margin: 0 0 var(--spacing-4);
		letter-spacing: var(--tracking-wide);
	}

	.hero-author-bio {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0 0 var(--spacing-5);
	}

	.hero-author-links {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
	}

	.hero-author-link {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		color: var(--color-text-secondary);
		text-decoration: none;
		padding: var(--spacing-1) var(--spacing-2);
		border: 1px solid var(--color-border-subtle);
		transition: color var(--transition-fast), border-color var(--transition-fast);
	}

	.hero-author-link:hover {
