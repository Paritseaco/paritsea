---
import { getEmDashCollection, getEntryTerms, getSiteSettings } from "emdash";
import Base from "../layouts/Base.astro";
import {
	isFrameworkPageSlug,
	resolveFrameworkPage,
	resolvePostPath,
} from "../utils/public-paths";
import { resolveBlogSiteIdentity } from "../utils/site-identity";
import {
	formatDateForLocale,
	getAstroLocale,
	localizeEntry,
	localizeTermLabel,
	localizedPath,
	ui,
} from "../utils/i18n";

const locale = getAstroLocale(Astro);
const copy = ui[locale];
const navLabels = ui[locale].navLabels;

const { entries: posts, cacheHint } = await getEmDashCollection("posts");
const { siteTitle } = resolveBlogSiteIdentity(await getSiteSettings());

Astro.cache.set(cacheHint);

// Specific landmark posts
const doctrinePost = posts.find((p) => p.id === "doctrine");

// The Method = recent analytical entries (exclude the 3 landmark posts)
const landmarkIds = new Set(["doctrine", "stp", "asls-01"]);
const methodEntries = (
	await Promise.all(
		posts
			.filter((p) => !landmarkIds.has(p.id))
			.map(async (post) => {
				const legacyTerms = await getEntryTerms("posts", post.data.id, "category");
				const legacyFrameworkPage =
					legacyTerms.find((term) => isFrameworkPageSlug(term.slug))?.slug ?? null;
				return {
					post,
					legacyTerms,
					frameworkPage: resolveFrameworkPage(post.data.framework_page, legacyFrameworkPage),
				};
			}),
	)
)
	.filter((entry) => entry.frameworkPage === "the-method")
	.toSorted((a, b) => {
		const dateA = a.post.data.publishedAt?.getTime() ?? 0;
		const dateB = b.post.data.publishedAt?.getTime() ?? 0;
		return dateB - dateA;
	})
	.slice(0, 4);

const methodEntriesWithTags = await Promise.all(
	methodEntries.map(async ({ post, legacyTerms, frameworkPage }) => {
		const categories = legacyTerms.filter((term) => !isFrameworkPageSlug(term.slug)).length > 0
			? legacyTerms.filter((term) => !isFrameworkPageSlug(term.slug))
			: await getEntryTerms("posts", post.data.id, "category");
		const href =
			resolvePostPath(post.id, frameworkPage, null) ??
			`/journal/${post.id}`;
		return {
			post: localizeEntry(post, "posts", locale),
			youtubeUrl: typeof post.data.youtube_url === "string" ? post.data.youtube_url : null,
			categories: categories.map((category) => ({
				slug: category.slug,
				label: localizeTermLabel(category.label, locale),
			})),
			href: localizedPath(href, locale),
		};
	})
);

function formatDate(date: Date | null | undefined) {
	return formatDateForLocale(date, locale);
}

// ─── Fetch latest YouTube videos from RSS ───
interface YouTubeVideo {
	id: string;
	title: string;
	published: string;
}
let youtubeVideos: YouTubeVideo[] = [];
try {
	const rssUrl = "https://www.youtube.com/feeds/videos.xml?channel_id=UCAbKE9k4l5OYlKnZXzEPhbA";
	const res = await fetch(rssUrl);
	const xml = await res.text();
	// Simple XML parsing — extract entries
	const entries = xml.split("<entry>").slice(1);
	youtubeVideos = entries.slice(0, 4).map((entry) => {
		const idMatch = entry.match(/<yt:videoId>([^<]+)<\/yt:videoId>/);
		const titleMatch = entry.match(/<title>([^<]+)<\/title>/);
		const pubMatch = entry.match(/<published>([^<]+)<\/published>/);
		return {
			id: idMatch?.[1] ?? "",
			title: titleMatch?.[1] ?? "",
			published: pubMatch?.[1] ?? "",
		};
	}).filter((v) => v.id);
} catch {
	// Silent fail — YouTube section just won't render
}

const home = locale === "th"
	? {
			// ── HERO ──
			eyebrow: "Paritsea",
			headlineLine1: "วิธีมองโลก",
			headlineLine2: "ที่เริ่มจากการสังเกตจริง",
			headlineLine3: "ก่อนตกผลึกเป็นระบบ",
			heroSub: "Paritsea คือพื้นที่ของสายตา แนวคิด และบันทึกของ Parit Ritchai\nสิ่งที่เห็นจากสถานการณ์จริงจะถูกบันทึกใน Journal ก่อน\nเมื่อรูปแบบซ้ำพอ จึงตกผลึกเป็น Framework, Protocols, Standards และ IP ที่ใช้อย่างเป็นทางการได้",
			readDoctrine: "เข้าใจ System",
			exploreMethod: "อ่าน Journal",
			viewImplementations: "ดู Media",

			// ── WHAT PARITSEA COVERS ──
			topicsLabel: "เส้นทางของความคิด",
			topicLife: "Lens",
			topicLifeDesc: "สายตาของ Parit ที่อ่านคนและระบบไปพร้อมกัน จากสถานการณ์จริง ไม่ใช่จากทฤษฎีลอยตัว",
			topicWork: "Journal",
			topicWorkDesc: "บันทึกแรกของสิ่งที่เห็น แรงตึง ต้นทุนมนุษย์ และรูปแบบที่ยังไม่ถูกทำให้เป็นกฎ",
			topicHuman: "System",
			topicHumanDesc: "ชั้นที่รูปแบบซ้ำถูกตกผลึกเป็น Framework, Protocols และ Standards ที่อ้างอิงได้",
			topicGrowth: "IP & Official Use",
			topicGrowthDesc: "เงื่อนไขการอ้างอิง ดัดแปลง ขอสิทธิ์ และนำไปใช้เชิงพาณิชย์โดยไม่บิดความหมายต้นทาง",

			// ── WORLDVIEW ──
			worldviewLabel: "Paritsea ทำงานอย่างไร",
			worldviewHeadline: "สิ่งที่ตกผลึกแล้วไม่ได้เกิดขึ้นก่อน สิ่งที่เห็นต่างหากเกิดขึ้นก่อน",
			worldviewBody1: "Paritsea เริ่มจากการมองสถานการณ์จริงให้ชัดพอจะตั้งชื่อได้ Journal จึงเป็นต้นน้ำ ไม่ใช่พื้นที่เสริม มันเก็บ observation ก่อนที่ observation จะกลายเป็นโครงสร้าง",
			worldviewBody2: "เมื่อรูปแบบเดิมปรากฏซ้ำพอ มันจึงถูกแยกชั้นเป็น System: Framework ให้ฐานคิด Protocols กำหนดภาระหน้าที่ Standards ทำให้ตรวจสอบได้ และ Licensing กำหนดการใช้ที่ไม่บิดเบือน",
			worldviewBody3: "",
			worldviewCoda: "Paritsea จึงเป็นทั้งพื้นที่คิด พื้นที่บันทึก และพื้นที่อ้างอิง\nไม่ใช่ service funnel และไม่ใช่คลังบทความทั่วไป",

			// ── START HERE ──
			startHere: "เริ่มตรงนี้",
			startHereDesc: "ใหม่ต่อ Paritsea? เริ่มจาก Lens เพื่อรู้ว่าสายตานี้มาจากไหน จากนั้นอ่าน Journal แล้วค่อยเข้า System และ IP",

			// ── REGISTRY ──
			registry: "Journal",
			openMethod: "สำรวจ Journal →",

			// ── ABOUT ──
			aboutLabel: "Lens",
			aboutHeadline1: "Paritsea มีผู้ถือสายตา",
			aboutHeadline2: "แต่ไม่ได้เป็น portfolio ส่วนตัว",
			aboutBody: "Paritsea คือระบบความคิดที่ Parit Ritchai สร้างจากการสังเกตชีวิต งาน องค์กร ความสัมพันธ์ และสถานการณ์ที่คนจำนวนมากรู้สึกได้ แต่ยังตั้งชื่อไม่ได้",
			aboutInsight: "ตัวตนของ Parit สำคัญเพราะเป็นที่มาของสายตา แต่สิ่งที่ถูกสร้างไว้ต้องอ่าน อ้างอิง และนำไปใช้ได้โดยไม่ต้องกลายเป็นบริการรับจ้างของตัวบุคคล",

			// ── ECOSYSTEM ──
			ecosystemLabel: "ติดตามแนวคิดจาก Paritsea",
			ecosystemYoutube: "YouTube",
			ecosystemYoutubeDesc: "มุมมองเชิงลึกทั้งภาษาไทยและอังกฤษ",
			ecosystemThreads: "Threads",
			ecosystemThreadsDesc: "มุมมองสั้น ๆ ที่คมและชวนคิด",
			ecosystemInstagram: "Instagram",
			ecosystemInstagramDesc: "สำหรับ international audience และ visual thoughts",
			ecosystemFacebook: "Facebook",
			ecosystemFacebookDesc: "อัปเดต บทความ และความคิดเห็นจาก Paritsea",
			ecosystemLine: "LINE Group",
			ecosystemLineDesc: "พูดคุย แลกเปลี่ยน และติดตาม session",
			ecosystemSession: "Linkedin",
			ecosystemSessionDesc: "ติดตามแนวคิดและมุมมองจาก Paritsea",

			followOn: "ติดตาม",

			// ── CLOSING ── / ── VIDEO / QUOTE ──
			videoEyebrow: "วิดีโอล่าสุด",
			videoCTA: "ดูช่อง YouTube →",
			quote: "\"ปัญหาของปัญหาไม่ใช่เพราะแค่มันเป็นปัญหา\nแต่คือวิธีรับมือและจัดการกับปัญหานั้นต่างหาก\nที่ทำให้ทิศทางของปัญหานั้นต่างออกไป\"",
			attr: "— ปาริศ ฤทธิ์ชัย",
		}
	: {
			// ── HERO ──
			eyebrow: "Paritsea",
			headlineLine1: "A way of seeing",
			headlineLine2: "that begins in real situations",
			headlineLine3: "before it becomes system",
			heroSub: "Paritsea is the public home of Parit Ritchai's lens, notes, and thinking system.\nWhat is observed in real situations is first recorded in Journal.\nWhen patterns repeat, they crystallize into Framework, Protocols, Standards, and future IP for official use.",
			readDoctrine: "Understand System",
			exploreMethod: "Read Journal",
			viewImplementations: "View Media",

			// ── WHAT PARITSEA COVERS ──
			topicsLabel: "The path of an idea",
			topicLife: "Lens",
			topicLifeDesc: "Parit's way of reading people and systems together from real situations, not detached theory.",
			topicWork: "Journal",
			topicWorkDesc: "The first record of observations, tensions, human cost, and patterns not yet governed.",
			topicHuman: "System",
			topicHumanDesc: "The layer where recurring patterns crystallize into Framework, Protocols, and Standards.",
			topicGrowth: "IP & Official Use",
			topicGrowthDesc: "Boundaries for citation, adaptation, permission, licensing, and official commercial use.",

			// ── WORLDVIEW ──
			worldviewLabel: "How Paritsea works",
			worldviewHeadline: "The crystallized system does not come first. The seeing comes first.",
			worldviewBody1: "Paritsea begins by staying with real situations long enough to name what is happening. Journal is therefore the source layer, not a supporting blog. It records observation before observation becomes structure.",
			worldviewBody2: "When patterns repeat, they move into System: Framework defines the root, Protocols establish obligations, Standards make conditions verifiable, and Licensing governs use without distortion.",
			worldviewBody3: "",
			worldviewCoda: "Paritsea is a thinking space, a public record, and a reference layer.\nIt is not a service funnel and not a generic blog.",

			// ── START HERE ──
			startHere: "Start Here",
			startHereDesc: "New to Paritsea? Start with the Lens, then read Journal, understand System, and review IP boundaries.",

			// ── REGISTRY ──
			registry: "Journal",
			openMethod: "Explore Journal →",

			// ── ABOUT ──
			aboutLabel: "Lens",
			aboutHeadline1: "Paritsea has a lens-holder",
			aboutHeadline2: "but it is not a personal portfolio",
			aboutBody: "Paritsea is a thinking system Parit Ritchai built from observing life, work, organizations, relationships, and situations many people feel but cannot yet name.",
			aboutInsight: "Parit's presence matters because it explains the origin of the lens. The work itself still needs to be readable, citable, and usable without becoming a personal service business.",

			// ── ECOSYSTEM ──
			ecosystemLabel: "Follow Paritsea Across Platforms",
			ecosystemYoutube: "YouTube",
			ecosystemYoutubeDesc: "Deep perspectives in both Thai and English",
			ecosystemThreads: "Threads",
			ecosystemThreadsDesc: "Short, sharp thoughts",
			ecosystemInstagram: "Instagram",
			ecosystemInstagramDesc: "For international audience and visual thoughts",
			ecosystemFacebook: "Facebook",
			ecosystemFacebookDesc: "Updates, posts, and ideas from Paritsea",
			ecosystemLine: "LINE Group",
			ecosystemLineDesc: "Chat, share, and follow sessions",
			ecosystemSession: "Linkedin",
			ecosystemSessionDesc: "Follow ideas and perspectives from Paritsea",

			followOn: "Follow on",

			// ── CLOSING ── / ── VIDEO / QUOTE ──
			videoEyebrow: "Latest Videos",
			videoCTA: "View YouTube Channel →",
			quote: "\"The problem with problems isn't just that they are problems,\nbut how they are dealt with,\nthat's what makes them turn out differently.\"",
			attr: "— Parit Ritchai",
	};

const homeDescription = locale === "th"
	? "Paritsea คือ living thought system ของ Parit Ritchai: เริ่มจาก Lens และ Journal ก่อนตกผลึกเป็น Framework, Protocols, Standards และ IP สำหรับการใช้ที่เป็นทางการ"
	: "Paritsea is Parit Ritchai's living thought system: a lens and journal that crystallize into Framework, Protocols, Standards, and future IP for official use.";
---

<Base title={siteTitle} description={homeDescription} locale={locale}>
	<div class="landing">

		{/* ── HERO ── */}
		<section class="hero">
			<div class="hero-content">
				<p class="hero-eyebrow">{home.eyebrow}</p>
				<h1 class="hero-statement">
					{home.headlineLine1}<br />
					{home.headlineLine2}<br />
					{home.headlineLine3}
				</h1>
				<p class="hero-sub">{home.heroSub.split("\n").map((line, index) => <>{index > 0 && <br />}{line}</>)}</p>

				<div class="hero-actions">
					{doctrinePost && <a href={localizedPath("/system", locale)} class="btn-primary">{home.readDoctrine}</a>}
					<a href={localizedPath("/journal", locale)} class="btn-secondary">{home.exploreMethod}</a>
					<a href={localizedPath("/media", locale)} class="btn-text">{home.viewImplementations}</a>
				</div>

				<div class="hero-credit">
					<img src="/images/parit-profile.jpg" alt="" class="hero-credit-img" />
					<span class="hero-credit-name">{copy.authorName}</span>
					<span class="hero-credit-sep">·</span>
					<a href={localizedPath("/about", locale)} class="hero-credit-about">{copy.about} →</a>
				</div>
			</div>

			<aside class="hero-map">
				<p class="hero-map-label">{locale === "th" ? "เส้นทางความคิด" : "Thought path"}</p>
				<ul class="hero-map-list">
					<li class="hero-map-item">
						<a href={localizedPath("/about", locale)} class="hero-map-link">
							<span class="hero-map-num">01</span>
							<span class="hero-map-name">{navLabels.Lens}</span>
						</a>
					</li>
					<li class="hero-map-item">
						<a href={localizedPath("/journal", locale)} class="hero-map-link">
							<span class="hero-map-num">02</span>
							<span class="hero-map-name">{navLabels.Journal}</span>
						</a>
					</li>
					<li class="hero-map-item">
						<a href={localizedPath("/system", locale)} class="hero-map-link">
							<span class="hero-map-num">03</span>
							<span class="hero-map-name">{navLabels.System}</span>
						</a>
					</li>
					<li class="hero-map-item">
						<a href={localizedPath("/licensing", locale)} class="hero-map-link">
							<span class="hero-map-num">04</span>
							<span class="hero-map-name">{navLabels.IP}</span>
						</a>
					</li>
					<li class="hero-map-item">
						<a href={localizedPath("/media", locale)} class="hero-map-link">
							<span class="hero-map-num">05</span>
							<span class="hero-map-name">{navLabels.Media}</span>
						</a>
					</li>
				</ul>
			</aside>
		</section>

		{/* ── WORLDVIEW ── */}
		<section class="worldview">
			<div class="worldview-content">
				<p class="worldview-eyebrow">{home.worldviewLabel}</p>
				<h2 class="worldview-headline">{home.worldviewHeadline}</h2>
				<div class="worldview-body">
					<p>{home.worldviewBody1}</p>
					<p>{home.worldviewBody2}</p>
					{home.worldviewBody3 && <p>{home.worldviewBody3}</p>}
				</div>
				<p class="worldview-coda">{home.worldviewCoda.split("\n").map((line, index) => <>{index > 0 && <br />}{line}</>)}</p>
			</div>
		</section>

		<section class="lens-panel">
			<div class="lens-panel-copy">
				<p class="lens-eyebrow">{home.aboutLabel}</p>
				<h2 class="lens-title">
					{home.aboutHeadline1}<br />
					{home.aboutHeadline2}
				</h2>
				<p>{home.aboutBody}</p>
				<p>{home.aboutInsight}</p>
				<a href={localizedPath("/about", locale)} class="lens-link">{copy.about} →</a>
			</div>
			<div class="lens-panel-source">
				<img src="/images/parit-profile.jpg" alt={copy.authorName} class="lens-portrait" />
				<div class="lens-source-note">
					<span>{copy.authorName}</span>
					<p>{copy.authorRole}</p>
				</div>
			</div>
		</section>

		{/* ── WHAT PARITSEA COVERS ── */}
		<section class="topics">
			<p class="topics-eyebrow">{home.topicsLabel}</p>
			<div class="topics-grid">
				<div class="topic-card">
					<h3 class="topic-card-title">{home.topicLife}</h3>
					<p class="topic-card-desc">{home.topicLifeDesc}</p>
				</div>
				<div class="topic-card">
					<h3 class="topic-card-title">{home.topicWork}</h3>
					<p class="topic-card-desc">{home.topicWorkDesc}</p>
				</div>
				<div class="topic-card">
					<h3 class="topic-card-title">{home.topicHuman}</h3>
					<p class="topic-card-desc">{home.topicHumanDesc}</p>
				</div>
				<div class="topic-card">
					<h3 class="topic-card-title">{home.topicGrowth}</h3>
					<p class="topic-card-desc">{home.topicGrowthDesc}</p>
				</div>
			</div>
		</section>

		{/* ── LATEST ENTRIES ── */}
		{methodEntriesWithTags.length > 0 && (
			<section class="records">
				<header class="section-header">
					<span class="section-eyebrow">{home.registry}</span>
					<a href={localizedPath("/journal", locale)} class="section-more">{home.openMethod}</a>
				</header>
				<div class="records-list">
					{methodEntriesWithTags.map(({ post, youtubeUrl, categories, href }, i) => (
						<a href={href} class="record-item">
							<span class="record-num">
								{String(i + 1).padStart(2, "0")}
							</span>
							<div class="record-body">
								<h3 class="record-title">{post.data.title}</h3>
								{post.data.excerpt && (
									<p class="record-excerpt">{post.data.excerpt}</p>
								)}
							</div>
							<div class="record-meta">
								{categories.length > 0 && (
									<span class="record-tag">{categories[0].label}</span>
								)}
								{youtubeUrl && (
									<span class="record-tag record-tag-video">{locale === "th" ? "วิดีโอ" : "Video"}</span>
								)}
								{formatDate(post.data.publishedAt) && (
									<time class="record-date">{formatDate(post.data.publishedAt)}</time>
								)}
							</div>
						</a>
					))}
				</div>
			</section>
		)}

		{/* ── YOUTUBE VIDEOS ── */}
		{youtubeVideos.length > 0 && (
			<section class="videos">
				<header class="section-header">
					<span class="section-eyebrow">{home.videoEyebrow}</span>
					<a href="https://www.youtube.com/@paritsea" target="_blank" rel="noreferrer" class="section-more">{home.videoCTA}</a>
				</header>
				<div class="videos-grid">
					{youtubeVideos.map((video) => (
						<a
							href={`https://www.youtube.com/watch?v=${video.id}`}
							target="_blank"
							rel="noreferrer"
							class="video-card"
						>
							<div class="video-thumb-wrap">
								<img
									src={`https://i3.ytimg.com/vi/${video.id}/hqdefault.jpg`}
									alt={video.title}
									class="video-thumb"
									loading="lazy"
								/>
								<span class="video-play-icon">
									<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="8,5 19,12 8,19"/></svg>
								</span>
							</div>
							<p class="video-title">{video.title}</p>
						</a>
					))}
				</div>
			</section>
		)}

		{/* ── ECOSYSTEM ── */}
		<section class="ecosystem">
			<p class="ecosystem-eyebrow">{home.ecosystemLabel}</p>
			<div class="ecosystem-grid">
				<a href="https://www.youtube.com/@paritsea" target="_blank" rel="noreferrer" class="ecosystem-card">
					<h3 class="ecosystem-card-title">{home.ecosystemYoutube}</h3>
					<p class="ecosystem-card-desc">{home.ecosystemYoutubeDesc}</p>
				</a>
				<a href="https://www.threads.com/@paritsea" target="_blank" rel="noreferrer" class="ecosystem-card">
					<h3 class="ecosystem-card-title">{home.ecosystemThreads}</h3>
