---
import { getEmDashCollection, getEntryTerms, getSiteSettings } from "emdash";
import Base from "../layouts/Base.astro";
import { getReadingTime } from "../utils/reading-time";
import { resolveBlogSiteIdentity } from "../utils/site-identity";

const { entries: posts, cacheHint } = await getEmDashCollection("posts");
const { siteTitle, siteTagline } = resolveBlogSiteIdentity(await getSiteSettings());

Astro.cache.set(cacheHint);

// Specific landmark posts
const doctrinePost = posts.find((p) => p.id === "doctrine");
const stpPost = posts.find((p) => p.id === "stp");
const aslsPost = posts.find((p) => p.id === "asls-01");

// The Method = recent records (exclude the 3 landmark posts)
const landmarkIds = new Set(["doctrine", "stp", "asls-01"]);
const records = posts
	.filter((p) => !landmarkIds.has(p.id))
	.toSorted((a, b) => {
		const dateA = a.data.publishedAt?.getTime() ?? 0;
		const dateB = b.data.publishedAt?.getTime() ?? 0;
		return dateB - dateA;
	})
	.slice(0, 4);

// Fetch tags for records
const recordsWithTags = await Promise.all(
	records.map(async (post) => {
		const tags = await getEntryTerms("posts", post.data.id, "tag");
		return {
			post,
			tags: tags.map((t) => ({ slug: t.slug, label: t.label })),
		};
	})
);

function formatDate(date: Date | null | undefined) {
	if (!date) return null;
	return date.toLocaleDateString("en-US", {
		year: "numeric",
		month: "short",
		day: "numeric",
	});
}
---

<Base title={siteTitle} description={siteTagline}>
	<div class="landing">

		{/* ── HERO ── */}
		<section class="hero">
			<div class="hero-inner">
				<p class="hero-eyebrow">Paritsea</p>
				<h1 class="hero-statement">
					Structural coherence<br />is a prerequisite<br />for legitimate action.
				</h1>
				<p class="hero-sub">
					A working framework for seeing clearly inside complex systems —<br class="br-lg" />
					where tension is visible, cost is named, and method is precise.
				</p>
				<div class="hero-actions">
					{doctrinePost && (
						<a href={`/posts/${doctrinePost.id}`} class="btn-primary">
							Read the Doctrine
						</a>
					)}
					<a href="/posts" class="btn-ghost">
						All records →
					</a>
				</div>
			</div>
			<div class="hero-rule" aria-hidden="true">
				<span class="rule-label">est. 2024</span>
			</div>
		</section>

		{/* ── SYSTEM PILLARS ── */}
		<section class="pillars">
			<header class="section-header">
				<span class="section-eyebrow">The Framework</span>
			</header>
			<div class="pillars-grid">

				{doctrinePost && (
					<a href={`/posts/${doctrinePost.id}`} class="pillar pillar--doctrine">
						<div class="pillar-index">01</div>
						<div class="pillar-body">
							<h2 class="pillar-title">The Doctrine</h2>
							<p class="pillar-desc">
								{doctrinePost.data.excerpt ?? "The foundational principles that define what this framework stands for and why."}
							</p>
						</div>
						<span class="pillar-arrow">→</span>
					</a>
				)}

				{stpPost && (
					<a href={`/posts/${stpPost.id}`} class="pillar">
						<div class="pillar-index">02</div>
						<div class="pillar-body">
							<h2 class="pillar-title">STP Protocol</h2>
							<p class="pillar-desc">
								{stpPost.data.excerpt ?? "A structured protocol for navigating system transitions with precision and accountability."}
							</p>
						</div>
						<span class="pillar-arrow">→</span>
					</a>
				)}

				{aslsPost && (
					<a href={`/posts/${aslsPost.id}`} class="pillar">
						<div class="pillar-index">03</div>
						<div class="pillar-body">
							<h2 class="pillar-title">ASLS-01 Standard</h2>
							<p class="pillar-desc">
								{aslsPost.data.excerpt ?? "The standard for defining, measuring, and communicating structural legitimacy in systems."}
							</p>
						</div>
						<span class="pillar-arrow">→</span>
					</a>
				)}

				<a href="/posts" class="pillar pillar--method">
					<div class="pillar-index">04</div>
					<div class="pillar-body">
						<h2 class="pillar-title">The Method</h2>
						<p class="pillar-desc">
							Field records — observations of where structural incoherence becomes real cost.
						</p>
					</div>
					<span class="pillar-arrow">→</span>
				</a>

			</div>
		</section>

		{/* ── RECENT RECORDS ── */}
		{recordsWithTags.length > 0 && (
			<section class="records">
				<header class="section-header">
					<span class="section-eyebrow">Recent Records</span>
					<a href="/posts" class="section-more">View all →</a>
				</header>
				<div class="records-list">
					{recordsWithTags.map(({ post, tags }, i) => (
						<a href={`/posts/${post.id}`} class="record-item">
							<span class="record-num">
								{String(i + 1).padStart(2, "0")}
							</span>
							<div class="record-body">
								<h3 class="record-title">{post.data.title}</h3>
								{post.data.excerpt && (
									<p class="record-excerpt">{post.data.excerpt}</p>
								)}
							</div>
							<div class="record-meta">
								{tags.length > 0 && (
									<span class="record-tag">{tags[0].label}</span>
								)}
								{formatDate(post.data.publishedAt) && (
									<time class="record-date">{formatDate(post.data.publishedAt)}</time>
								)}
							</div>
						</a>
					))}
				</div>
			</section>
		)}

		{/* ── CLOSING STATEMENT ── */}
		<section class="closing">
			<blockquote class="closing-quote">
				"The problem is not that things are broken.<br />
				The problem is that they work — and something is still wrong."
			</blockquote>
			<p class="closing-attr">— Parit Ritchai, The Doctrine</p>
		</section>

	</div>
</Base>

<style>
	/* ─── Wrapper ─── */
	.landing {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 var(--spacing-8) var(--spacing-24);
	}

	/* ─── Section common ─── */
	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding-bottom: var(--spacing-4);
		border-bottom: 1px solid var(--color-border-subtle);
		margin-bottom: var(--spacing-10);
	}

	.section-eyebrow {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-xs);
		font-weight: 500;
		letter-spacing: var(--tracking-widest);
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.section-more {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-xs);
		color: var(--color-text-secondary);
		text-decoration: none;
		letter-spacing: 0.01em;
		transition: color var(--transition-fast);
	}

	.section-more:hover {
		color: var(--color-text);
	}

	/* ─── HERO ─── */
	.hero {
		padding: var(--spacing-20) 0 var(--spacing-24);
		border-bottom: 1px solid var(--color-border-subtle);
		margin-bottom: var(--spacing-20);
	}

	.hero-inner {
		max-width: 760px;
	}

	.hero-eyebrow {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-xs);
		font-weight: 500;
		letter-spacing: var(--tracking-widest);
		text-transform: uppercase;
		color: var(--color-muted);
		margin: 0 0 var(--spacing-6);
	}

	.hero-statement {
		font-family: Georgia, 'Times New Roman', serif;
		font-size: clamp(2rem, 4.5vw, 3.5rem);
		font-weight: 700;
		line-height: 1.06;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin: 0 0 var(--spacing-7);
	}

	.hero-sub {
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		max-width: 560px;
		margin: 0 0 var(--spacing-10);
	}

	.br-lg { display: block; }

	.hero-actions {
		display: flex;
		gap: var(--spacing-5);
		align-items: center;
	}

	.btn-primary {
		display: inline-block;
		padding: var(--spacing-3) var(--spacing-7);
		background: var(--color-text);
		color: var(--color-bg);
		text-decoration: none;
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-sm);
		font-weight: 500;
		letter-spacing: 0.02em;
		transition: opacity var(--transition-fast);
	}

	.btn-primary:hover {
		opacity: 0.78;
	}

	.btn-ghost {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		text-decoration: none;
		letter-spacing: 0.01em;
		transition: color var(--transition-fast);
	}

	.btn-ghost:hover {
		color: var(--color-text);
	}

	.hero-rule {
		display: flex;
		align-items: center;
		gap: var(--spacing-4);
		margin-top: var(--spacing-14);
	}

	.rule-label {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-2xs);
		letter-spacing: var(--tracking-widest);
		text-transform: uppercase;
		color: var(--color-border);
	}

	/* ─── PILLARS ─── */
	.pillars {
		margin-bottom: var(--spacing-20);
	}

	.pillars-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1px;
		background: var(--color-border-subtle);
		border: 1px solid var(--color-border-subtle);
	}

	.pillar {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-5);
		padding: var(--spacing-8) var(--spacing-6) var(--spacing-7);
		background: var(--color-bg);
		text-decoration: none;
		color: inherit;
		transition: background var(--transition-fast);
		position: relative;
	}

	.pillar:hover {
		background: var(--color-bg-subtle);
	}

	.pillar--doctrine {
		background: var(--color-bg-subtle);
	}

	.pillar--doctrine:hover {
		background: var(--color-surface);
	}

	.pillar-index {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-2xs);
		letter-spacing: var(--tracking-widest);
		color: var(--color-border);
		font-weight: 500;
	}

	.pillar-body {
		flex: 1;
	}

	.pillar-title {
		font-family: Georgia, 'Times New Roman', serif;
		font-size: var(--font-size-lg);
		font-weight: 700;
		line-height: 1.2;
		color: var(--color-text);
		margin: 0 0 var(--spacing-3);
	}

	.pillar-desc {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-sm);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.pillar-arrow {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		align-self: flex-end;
		transition: transform var(--transition-fast), color var(--transition-fast);
	}

	.pillar:hover .pillar-arrow {
		transform: translateX(3px);
		color: var(--color-text-secondary);
	}

	/* ─── RECORDS ─── */
	.records {
		margin-bottom: var(--spacing-20);
	}

	.records-list {
		display: flex;
		flex-direction: column;
	}

	.record-item {
		display: grid;
		grid-template-columns: 2.5rem 1fr auto;
		gap: var(--spacing-6);
		align-items: start;
		padding: var(--spacing-6) 0;
		border-bottom: 1px solid var(--color-border-subtle);
		text-decoration: none;
		color: inherit;
		transition: background var(--transition-fast);
	}

	.record-item:first-child {
		border-top: none;
	}

	.record-item:hover .record-title {
		opacity: 0.6;
	}

	.record-num {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-xs);
		color: var(--color-border);
		letter-spacing: var(--tracking-wide);
		padding-top: 3px;
	}

	.record-body {
		flex: 1;
	}

	.record-title {
		font-family: Georgia, 'Times New Roman', serif;
		font-size: var(--font-size-xl);
		font-weight: 700;
		line-height: 1.2;
		color: var(--color-text);
		margin: 0 0 var(--spacing-2);
		transition: opacity var(--transition-fast);
	}

	.record-excerpt {
		font-size: var(--font-size-sm);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.record-meta {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: var(--spacing-2);
		min-width: 100px;
		padding-top: 3px;
	}

	.record-tag {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-2xs);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		color: var(--color-muted);
		white-space: nowrap;
	}

	.record-date {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		white-space: nowrap;
	}

	/* ─── CLOSING ─── */
	.closing {
		padding: var(--spacing-16) 0 var(--spacing-8);
		border-top: 1px solid var(--color-border-subtle);
		max-width: 680px;
	}

	.closing-quote {
		font-family: Georgia, 'Times New Roman', serif;
		font-size: var(--font-size-xl);
		font-style: italic;
		line-height: 1.6;
		color: var(--color-text-secondary);
		margin: 0 0 var(--spacing-4);
		border: none;
		padding: 0;
	}

	.closing-attr {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-xs);
		letter-spacing: var(--tracking-wide);
		color: var(--color-muted);
		margin: 0;
	}

	/* ─── Responsive ─── */
	@media (max-width: 1024px) {
		.pillars-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.hero-statement {
			font-size: clamp(1.75rem, 4vw, 2.625rem);
		}
	}

	@media (max-width: 768px) {
		.landing {
			padding: 0 var(--spacing-5) var(--spacing-16);
		}

		.hero {
			padding: var(--spacing-14) 0 var(--spacing-16);
		}

		.hero-rule {
			display: none;
		}

		.record-item {
			grid-template-columns: 2rem 1fr;
			grid-template-rows: auto auto;
		}

		.record-meta {
			grid-column: 2;
			flex-direction: row;
			align-items: center;
			justify-content: flex-start;
			min-width: unset;
			padding-top: var(--spacing-2);
		}
	}

	@media (max-width: 600px) {
		.pillars-grid {
			grid-template-columns: 1fr;
		}

		.hero-statement {
			font-size: var(--font-size-2xl);
		}

		.hero-actions {
			flex-direction: column;
			align-items: flex-start;
		}

		.br-lg { display: none; }
	}
</style>
