---
import { getEmDashCollection, getEntryTerms, getSiteSettings } from "emdash";
import Base from "../layouts/Base.astro";
import {
	isFrameworkPageSlug,
	resolveFrameworkPage,
	resolvePostPath,
} from "../utils/public-paths";
import { resolveBlogSiteIdentity } from "../utils/site-identity";
import {
	formatDateForLocale,
	getAstroLocale,
	localizeEntry,
	localizeTermLabel,
	localizedPath,
	ui,
} from "../utils/i18n";

const locale = getAstroLocale(Astro);
const copy = ui[locale];
const navLabels = ui[locale].navLabels;

const { entries: posts, cacheHint } = await getEmDashCollection("posts");
const { siteTitle } = resolveBlogSiteIdentity(await getSiteSettings());

Astro.cache.set(cacheHint);

// Specific landmark posts
const doctrinePost = posts.find((p) => p.id === "doctrine");

// The Method = recent analytical entries (exclude the 3 landmark posts)
const landmarkIds = new Set(["doctrine", "stp", "asls-01"]);
const methodEntries = (
	await Promise.all(
		posts
			.filter((p) => !landmarkIds.has(p.id))
			.map(async (post) => {
				const legacyTerms = await getEntryTerms("posts", post.data.id, "category");
				const legacyFrameworkPage =
					legacyTerms.find((term) => isFrameworkPageSlug(term.slug))?.slug ?? null;
				return {
					post,
					legacyTerms,
					frameworkPage: resolveFrameworkPage(post.data.framework_page, legacyFrameworkPage),
				};
			}),
	)
)
	.filter((entry) => entry.frameworkPage === "the-method")
	.toSorted((a, b) => {
		const dateA = a.post.data.publishedAt?.getTime() ?? 0;
		const dateB = b.post.data.publishedAt?.getTime() ?? 0;
		return dateB - dateA;
	})
	.slice(0, 4);

const methodEntriesWithTags = await Promise.all(
	methodEntries.map(async ({ post, legacyTerms, frameworkPage }) => {
		const categories = legacyTerms.filter((term) => !isFrameworkPageSlug(term.slug)).length > 0
			? legacyTerms.filter((term) => !isFrameworkPageSlug(term.slug))
			: await getEntryTerms("posts", post.data.id, "category");
		const href =
			resolvePostPath(post.id, frameworkPage, null) ??
			`/journal/${post.id}`;
		return {
			post: localizeEntry(post, "posts", locale),
			youtubeUrl: typeof post.data.youtube_url === "string" ? post.data.youtube_url : null,
			categories: categories.map((category) => ({
				slug: category.slug,
				label: localizeTermLabel(category.label, locale),
			})),
			href: localizedPath(href, locale),
		};
	})
);

function formatDate(date: Date | null | undefined) {
	return formatDateForLocale(date, locale);
}

// ─── Fetch latest YouTube videos from RSS ───
interface YouTubeVideo {
	id: string;
	title: string;
	published: string;
}
let youtubeVideos: YouTubeVideo[] = [];
try {
	const rssUrl = "https://www.youtube.com/feeds/videos.xml?channel_id=UCAbKE9k4l5OYlKnZXzEPhbA";
	const res = await fetch(rssUrl);
	const xml = await res.text();
	// Simple XML parsing — extract entries
	const entries = xml.split("<entry>").slice(1);
	youtubeVideos = entries.slice(0, 4).map((entry) => {
		const idMatch = entry.match(/<yt:videoId>([^<]+)<\/yt:videoId>/);
		const titleMatch = entry.match(/<title>([^<]+)<\/title>/);
		const pubMatch = entry.match(/<published>([^<]+)<\/published>/);
		return {
			id: idMatch?.[1] ?? "",
			title: titleMatch?.[1] ?? "",
			published: pubMatch?.[1] ?? "",
		};
	}).filter((v) => v.id);
} catch {
	// Silent fail — YouTube section just won't render
}

const home = locale === "th"
	? {
			// ── HERO ──
			eyebrow: "Paritsea",
			headlineLine1: "แหล่งอ้างอิงต้นทาง",
			headlineLine2: "ของ Framework, Protocols,",
			headlineLine3: "Standards และ IP ของ Paritsea",
			heroSub: "Paritsea คือพื้นที่บันทึกแนวคิดต้นฉบับ Framework, Protocol, Standard และสถานะการนำไปใช้จริง\nไม่ใช่เว็บไซต์ขายบริการ แต่เป็นชั้นอ้างอิงของระบบความคิด\nที่ผู้อื่นสามารถอ่าน อ้างถึง ดัดแปลง หรือขออนุญาตนำไปใช้ได้อย่างไม่บิดเบือน",
			readDoctrine: "อ่าน Framework",
			exploreMethod: "สำรวจ Journal",
			viewImplementations: "ดูการนำไปปรับใช้จริง",

			// ── WHAT PARITSEA COVERS ──
			topicsLabel: "สิ่งที่ Paritsea รับผิดชอบ",
			topicLife: "Framework ต้นทาง",
			topicLifeDesc: "ฐานความคิดที่กำหนดความหมาย ขอบเขต และเงื่อนไขของความสอดคล้องเชิงโครงสร้าง",
			topicWork: "Protocols & Standards",
			topicWorkDesc: "เครื่องมืออ้างอิงที่แปลง Framework ให้เป็นภาระหน้าที่ เกณฑ์ และเงื่อนไขที่ตรวจสอบได้",
			topicHuman: "Journal Observations",
			topicHumanDesc: "บันทึกสิ่งที่มองเห็นก่อนถูกทำให้เป็นระบบ เพื่อให้ปัญหา รูปแบบ และต้นทุนมนุษย์อ่านออกได้",
			topicGrowth: "Use, Citation & IP",
			topicGrowthDesc: "เงื่อนไขการอ้างอิง การดัดแปลง สิทธิการใช้ และสถานะ implementation อย่างเป็นทางการ",

			// ── WORLDVIEW ──
			worldviewLabel: "ทำไมต้องมีแหล่งอ้างอิงนี้",
			worldviewHeadline: "แนวคิดจะเดินทางได้อย่างซื่อสัตย์ ก็ต่อเมื่อที่มา ขอบเขต และสิทธิการใช้ชัดเจน",
			worldviewBody1: "Paritsea แยกชั้นต้นฉบับออกจากการนำไปใช้เชิงพาณิชย์ เพื่อให้ Framework, Protocols และ Standards ถูกอ่านจากแหล่งที่ไม่ถูกแรงจูงใจทางบริการกลืนความหมาย",
			worldviewBody2: "เมื่อแนวคิดถูกอ้าง แปล ดัดแปลง หรือแปลงเป็นระบบ ผู้อ่านควรเห็นได้ว่าอะไรคือข้อความต้นทาง อะไรคือ adaptation และอะไรต้องได้รับอนุญาตก่อนใช้อย่างเป็นทางการ",
			worldviewBody3: "",
			worldviewCoda: "Paritsea จึงทำหน้าที่เป็น source-of-truth:\nเก็บต้นฉบับ ชี้ขอบเขต และป้องกันการนำความคิดไปใช้จนเสียความหมาย",

			// ── START HERE ──
			startHere: "เริ่มตรงนี้",
			startHereDesc: "ใหม่ต่อ Paritsea? เริ่มจาก Framework เพื่อเข้าใจวิธีคิดที่เห็นทั้งคนและระบบ จากนั้นสำรวจ Journal หรือดู Implementation",

			// ── REGISTRY ──
			registry: "Journal",
			openMethod: "สำรวจ Journal →",

			// ── ABOUT ──
			aboutLabel: "เกี่ยวกับ Paritsea",
			aboutHeadline1: "ไม่ใช่แค่การแชร์ความรู้",
			aboutHeadline2: "แต่คือการเข้าใจโลกอย่างลึกซึ้ง",
			aboutBody: "Paritsea เกิดจากการผสมกันของ การมองเชิงระบบ ความเข้าใจมนุษย์ ประสบการณ์ชีวิตจริง ธุรกิจ องค์กร และการทำงานร่วมกับคน และการตั้งคำถามกับสิ่งที่คนส่วนใหญ่มองข้าม",
			aboutInsight: "หลายเรื่องในโลกไม่ได้ซับซ้อนเพราะมันยาก แต่ซับซ้อนเพราะคนมองแค่บางมิติ Paritsea จึงพยายามเชื่อมสิ่งเหล่านั้นเข้าด้วยกัน เพื่อให้เราเข้าใจทั้งโลก และตัวเอง ได้ชัดขึ้น",

			// ── ECOSYSTEM ──
			ecosystemLabel: "ติดตามแนวคิดจาก Paritsea",
			ecosystemYoutube: "YouTube",
			ecosystemYoutubeDesc: "มุมมองเชิงลึกทั้งภาษาไทยและอังกฤษ",
			ecosystemThreads: "Threads",
			ecosystemThreadsDesc: "มุมมองสั้น ๆ ที่คมและชวนคิด",
			ecosystemInstagram: "Instagram",
			ecosystemInstagramDesc: "สำหรับ international audience และ visual thoughts",
			ecosystemFacebook: "Facebook",
			ecosystemFacebookDesc: "อัปเดต บทความ และความคิดเห็นจาก Paritsea",
			ecosystemLine: "LINE Group",
			ecosystemLineDesc: "พูดคุย แลกเปลี่ยน และติดตาม session",
			ecosystemSession: "Linkedin",
			ecosystemSessionDesc: "ติดตามแนวคิดและมุมมองจาก Paritsea",

			followOn: "ติดตาม",

			// ── CLOSING ── / ── VIDEO / QUOTE ──
			videoEyebrow: "วิดีโอล่าสุด",
			videoCTA: "ดูช่อง YouTube →",
			quote: "\"ปัญหาของปัญหาไม่ใช่เพราะแค่มันเป็นปัญหา\nแต่คือวิธีรับมือและจัดการกับปัญหานั้นต่างหาก\nที่ทำให้ทิศทางของปัญหานั้นต่างออกไป\"",
			attr: "— ปาริศ ฤทธิ์ชัย",
		}
	: {
			// ── HERO ──
			eyebrow: "Paritsea",
			headlineLine1: "The source of record",
			headlineLine2: "for Paritsea frameworks,",
			headlineLine3: "protocols, standards, and IP",
			heroSub: "Paritsea publishes the original thinking behind its Framework, Protocols, Standards, and implementation records. It is not a service website. It is the reference layer for concepts that may later be cited, adapted, licensed, or translated into practice elsewhere.",
			readDoctrine: "Read Framework",
			exploreMethod: "Explore Journal",
			viewImplementations: "View Implementations",

			// ── WHAT PARITSEA COVERS ──
			topicsLabel: "What Paritsea Is Responsible For",
			topicLife: "Original Framework",
			topicLifeDesc: "The root position that defines structural coherence, legitimacy, and the boundaries of the system.",
			topicWork: "Protocols & Standards",
			topicWorkDesc: "Reference instruments that translate the Framework into obligations, thresholds, and verifiable conditions.",
			topicHuman: "Journal Observations",
			topicHumanDesc: "Named observations before they become governed, preserving patterns, tensions, and human cost.",
			topicGrowth: "Use, Citation & IP",
			topicGrowthDesc: "Rules for attribution, adaptation, commercial use, and official implementation status.",

			// ── WORLDVIEW ──
			worldviewLabel: "Why this reference exists",
			worldviewHeadline: "Ideas can travel honestly only when their source, boundaries, and use are clear.",
			worldviewBody1: "Paritsea keeps the original reference layer separate from commercial service expression so the Framework, Protocols, and Standards can be read without being absorbed by a service incentive.",
			worldviewBody2: "When an idea is cited, translated, adapted, or implemented, readers should be able to distinguish the source text, the adaptation, and the use that requires permission.",
			worldviewBody3: "",
			worldviewCoda: "This site preserves the source:\nthe original system, its governed instruments, and the public record around their use.",

			// ── START HERE ──
			startHere: "Start Here",
			startHereDesc: "New to Paritsea? Start with the foundational position to understand a method that reads people and systems together, then explore analytical entries or see applied systems.",

			// ── REGISTRY ──
			registry: "Journal",
			openMethod: "Explore Journal →",

			// ── ABOUT ──
			aboutLabel: "About Paritsea",
			aboutHeadline1: "Not just sharing knowledge",
			aboutHeadline2: "But understanding the world more deeply",
			aboutBody: "Paritsea is born from the combination of systems thinking, deep human understanding, real-life experience, business and organizations, working with people, and questioning what most people overlook.",
			aboutInsight: "Many things aren't complex because they're hard — they're complex because people only look at one dimension. Paritsea tries to connect them, so we can understand both the world and ourselves more clearly.",

			// ── ECOSYSTEM ──
			ecosystemLabel: "Follow Paritsea Across Platforms",
			ecosystemYoutube: "YouTube",
			ecosystemYoutubeDesc: "Deep perspectives in both Thai and English",
			ecosystemThreads: "Threads",
			ecosystemThreadsDesc: "Short, sharp thoughts",
			ecosystemInstagram: "Instagram",
			ecosystemInstagramDesc: "For international audience and visual thoughts",
			ecosystemFacebook: "Facebook",
			ecosystemFacebookDesc: "Updates, posts, and ideas from Paritsea",
			ecosystemLine: "LINE Group",
			ecosystemLineDesc: "Chat, share, and follow sessions",
			ecosystemSession: "Linkedin",
			ecosystemSessionDesc: "Follow ideas and perspectives from Paritsea",

			followOn: "Follow on",

			// ── CLOSING ── / ── VIDEO / QUOTE ──
			videoEyebrow: "Latest Videos",
			videoCTA: "View YouTube Channel →",
			quote: "\"The problem with problems isn't just that they are problems,\nbut how they are dealt with,\nthat's what makes them turn out differently.\"",
			attr: "— Parit Ritchai",
	};

const homeDescription = locale === "th"
	? "Paritsea คือแหล่งอ้างอิงต้นทางของ Framework, Protocols, Standards และ IP ไม่ใช่เว็บไซต์ขายบริการ แต่เป็นชั้นอ้างอิงสำหรับการอ่าน อ้างถึง ดัดแปลง ขอสิทธิการใช้ และนำไปใช้จริง"
	: "Paritsea is the source of record for its Framework, Protocols, Standards, and IP: a public reference layer for reading, citation, adaptation, licensing, and implementation.";
---

<Base title={siteTitle} description={homeDescription} locale={locale}>
	<div class="landing">

		{/* ── HERO ── */}
		<section class="hero">
			<div class="hero-content">
				<p class="hero-eyebrow">{home.eyebrow}</p>
				<h1 class="hero-statement">
					{home.headlineLine1}<br />
					{home.headlineLine2}<br />
					{home.headlineLine3}
				</h1>
				<p class="hero-sub">{home.heroSub.split("\n").map((line, index) => <>{index > 0 && <br />}{line}</>)}</p>

				<div class="hero-actions">
					{doctrinePost && <a href={localizedPath("/system/framework", locale)} class="btn-primary">{home.readDoctrine}</a>}
					<a href={localizedPath("/journal", locale)} class="btn-secondary">{home.exploreMethod}</a>
				</div>

				<div class="hero-credit">
					<img src="/images/parit-profile.jpg" alt="" class="hero-credit-img" />
					<span class="hero-credit-name">{copy.authorName}</span>
					<span class="hero-credit-sep">·</span>
					<a href={localizedPath("/about", locale)} class="hero-credit-about">{copy.about} →</a>
				</div>
			</div>

			<aside class="hero-map">
				<p class="hero-map-label">{locale === "th" ? "กรอบอ้างอิง" : "The Framework"}</p>
				<ul class="hero-map-list">
					<li class="hero-map-item">
						<a href={localizedPath("/system/framework", locale)} class="hero-map-link">
							<span class="hero-map-num">01</span>
							<span class="hero-map-name">{navLabels.Framework}</span>
						</a>
					</li>
					<li class="hero-map-item">
						<a href={localizedPath("/journal", locale)} class="hero-map-link">
							<span class="hero-map-num">02</span>
							<span class="hero-map-name">{navLabels.Journal}</span>
						</a>
					</li>
					<li class="hero-map-item">
						<a href={localizedPath("/implementation", locale)} class="hero-map-link">
							<span class="hero-map-num">03</span>
							<span class="hero-map-name">{navLabels.Implementation}</span>
						</a>
					</li>
				</ul>
			</aside>
		</section>

		{/* ── WORLDVIEW ── */}
		<section class="worldview">
			<div class="worldview-content">
				<p class="worldview-eyebrow">{home.worldviewLabel}</p>
				<h2 class="worldview-headline">{home.worldviewHeadline}</h2>
				<div class="worldview-body">
					<p>{home.worldviewBody1}</p>
					<p>{home.worldviewBody2}</p>
					{home.worldviewBody3 && <p>{home.worldviewBody3}</p>}
				</div>
				<p class="worldview-coda">{home.worldviewCoda.split("\n").map((line, index) => <>{index > 0 && <br />}{line}</>)}</p>
			</div>
		</section>

		{/* ── WHAT PARITSEA COVERS ── */}
		<section class="topics">
			<p class="topics-eyebrow">{home.topicsLabel}</p>
			<div class="topics-grid">
				<div class="topic-card">
					<h3 class="topic-card-title">{home.topicLife}</h3>
					<p class="topic-card-desc">{home.topicLifeDesc}</p>
				</div>
				<div class="topic-card">
					<h3 class="topic-card-title">{home.topicWork}</h3>
					<p class="topic-card-desc">{home.topicWorkDesc}</p>
				</div>
				<div class="topic-card">
					<h3 class="topic-card-title">{home.topicHuman}</h3>
					<p class="topic-card-desc">{home.topicHumanDesc}</p>
				</div>
				<div class="topic-card">
					<h3 class="topic-card-title">{home.topicGrowth}</h3>
					<p class="topic-card-desc">{home.topicGrowthDesc}</p>
				</div>
			</div>
		</section>

		{/* ── LATEST ENTRIES ── */}
		{methodEntriesWithTags.length > 0 && (
			<section class="records">
				<header class="section-header">
					<span class="section-eyebrow">{home.registry}</span>
					<a href={localizedPath("/journal", locale)} class="section-more">{home.openMethod}</a>
				</header>
				<div class="records-list">
					{methodEntriesWithTags.map(({ post, youtubeUrl, categories, href }, i) => (
						<a href={href} class="record-item">
							<span class="record-num">
								{String(i + 1).padStart(2, "0")}
							</span>
							<div class="record-body">
								<h3 class="record-title">{post.data.title}</h3>
								{post.data.excerpt && (
									<p class="record-excerpt">{post.data.excerpt}</p>
								)}
							</div>
							<div class="record-meta">
								{categories.length > 0 && (
									<span class="record-tag">{categories[0].label}</span>
								)}
								{youtubeUrl && (
									<span class="record-tag record-tag-video">{locale === "th" ? "วิดีโอ" : "Video"}</span>
								)}
								{formatDate(post.data.publishedAt) && (
									<time class="record-date">{formatDate(post.data.publishedAt)}</time>
								)}
							</div>
						</a>
					))}
				</div>
			</section>
		)}

		{/* ── YOUTUBE VIDEOS ── */}
		{youtubeVideos.length > 0 && (
			<section class="videos">
				<header class="section-header">
					<span class="section-eyebrow">{home.videoEyebrow}</span>
					<a href="https://www.youtube.com/@paritsea" target="_blank" rel="noreferrer" class="section-more">{home.videoCTA}</a>
				</header>
				<div class="videos-grid">
					{youtubeVideos.map((video) => (
						<a
							href={`https://www.youtube.com/watch?v=${video.id}`}
							target="_blank"
							rel="noreferrer"
							class="video-card"
						>
							<div class="video-thumb-wrap">
								<img
									src={`https://i3.ytimg.com/vi/${video.id}/hqdefault.jpg`}
									alt={video.title}
									class="video-thumb"
									loading="lazy"
								/>
								<span class="video-play-icon">
									<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="8,5 19,12 8,19"/></svg>
								</span>
							</div>
							<p class="video-title">{video.title}</p>
						</a>
					))}
				</div>
			</section>
		)}

		{/* ── ECOSYSTEM ── */}
		<section class="ecosystem">
			<p class="ecosystem-eyebrow">{home.ecosystemLabel}</p>
			<div class="ecosystem-grid">
				<a href="https://www.youtube.com/@paritsea" target="_blank" rel="noreferrer" class="ecosystem-card">
					<h3 class="ecosystem-card-title">{home.ecosystemYoutube}</h3>
					<p class="ecosystem-card-desc">{home.ecosystemYoutubeDesc}</p>
				</a>
				<a href="https://www.threads.com/@paritsea" target="_blank" rel="noreferrer" class="ecosystem-card">
					<h3 class="ecosystem-card-title">{home.ecosystemThreads}</h3>
					<p class="ecosystem-card-desc">{home.ecosystemThreadsDesc}</p>
				</a>
				<a href="https://www.instagram.com/paritsea" target="_blank" rel="noreferrer" class="ecosystem-card">
					<h3 class="ecosystem-card-title">{home.ecosystemInstagram}</h3>
					<p class="ecosystem-card-desc">{home.ecosystemInstagramDesc}</p>
				</a>
