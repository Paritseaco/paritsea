---
import { getEmDashCollection, getEntryTerms, getSiteSettings } from "emdash";
import { Image } from "emdash/ui";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import { getReadingTime } from "../utils/reading-time";
import { resolveBlogSiteIdentity } from "../utils/site-identity";

const { entries: posts, cacheHint } = await getEmDashCollection("posts");
const { siteTitle, siteTagline } = resolveBlogSiteIdentity(await getSiteSettings());

Astro.cache.set(cacheHint);

const sortedPosts = posts.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});

// Find the first post with a featured image for the hero
const featuredPost = sortedPosts.find((p) => p.data.featured_image);
const featuredIndex = featuredPost ? sortedPosts.indexOf(featuredPost) : -1;

// If no featured image, use the first post anyway
const heroPost = featuredPost ?? sortedPosts[0] ?? null;
const heroIndex = heroPost ? sortedPosts.indexOf(heroPost) : -1;

// Get remaining posts (exclude hero)
const gridPosts = sortedPosts.filter((_, i) => i !== heroIndex).slice(0, 6);

const totalShown = (heroPost ? 1 : 0) + gridPosts.length;
const hasMorePosts = sortedPosts.length > totalShown;

// Fetch tags for hero post
let heroTags: Array<{ slug: string; label: string }> = [];
const heroBylines = heroPost?.data.bylines ?? [];
if (heroPost) {
	const tags = await getEntryTerms("posts", heroPost.data.id, "tag");
	heroTags = tags.map((t) => ({ slug: t.slug, label: t.label }));
}

// Fetch tags for grid posts
const gridPostsWithTags = await Promise.all(
	gridPosts.map(async (post) => {
		const tags = await getEntryTerms("posts", post.data.id, "tag");
		const bylines = post.data.bylines ?? [];
		return {
			post,
			tags: tags.map((t) => ({ slug: t.slug, label: t.label })),
			bylines,
		};
	})
);

function formatDate(date: Date | null | undefined) {
	if (!date) return null;
	return date.toLocaleDateString("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	});
}
---

<Base title={siteTitle} description={siteTagline}>
	{
		posts.length === 0 ? (
			<section class="empty-state">
				<p class="empty-eyebrow">No entries yet</p>
				<h2>Begin the work.</h2>
				<a href="/_emdash/admin/content/posts/new" class="btn">
					Create an entry
				</a>
			</section>
		) : (
			<div class="home">

				{/* Site header strip — tagline */}
				<div class="home-intro">
					<p class="home-tagline">{siteTagline}</p>
				</div>

				{/* Hero: Featured entry */}
				{heroPost && (
					<section class="hero">
						{heroTags.length > 0 && (
							<div class="hero-eyebrow">
								{heroTags.slice(0,2).map((tag) => (
									<a href={`/tag/${tag.slug}`} class="eyebrow-tag">
										{tag.label}
									</a>
								))}
							</div>
						)}

						<a href={`/posts/${heroPost.id}`} class="hero-title-link">
							<h1 class="hero-title">{heroPost.data.title}</h1>
						</a>

						{heroPost.data.excerpt && (
							<p class="hero-excerpt">{heroPost.data.excerpt}</p>
						)}

						<div class="hero-meta">
							{heroBylines.length > 0 && (
								<span class="hero-byline">
									{heroBylines.slice(0, 2).map((credit, i) => (
										<>
											{i > 0 && <span class="sep">&amp;</span>}
											<span>{credit.byline.displayName}</span>
										</>
									))}
								</span>
							)}
							{heroBylines.length > 0 && formatDate(heroPost.data.publishedAt) && (
								<span class="sep">·</span>
							)}
							{formatDate(heroPost.data.publishedAt) && (
								<time>{formatDate(heroPost.data.publishedAt)}</time>
							)}
							<span class="sep">·</span>
							<span>{getReadingTime(heroPost.data.content)} min read</span>
						</div>

						{heroPost.data.featured_image && (
							<a href={`/posts/${heroPost.id}`} class="hero-image-link">
								<figure class="hero-image">
									<Image image={heroPost.data.featured_image} />
								</figure>
							</a>
						)}
					</section>
				)}

				{/* Grid of remaining entries */}
				{gridPostsWithTags.length > 0 && (
					<section class="index-section">
						<header class="index-header">
							<span class="index-label">Recent entries</span>
							{hasMorePosts && (
								<a href="/posts" class="index-all">
									All entries <span aria-hidden="true">→</span>
								</a>
							)}
						</header>

						<div class="posts-grid">
							{gridPostsWithTags.map(({ post, tags, bylines }) => (
								<PostCard
									title={post.data.title ?? "Untitled"}
									excerpt={post.data.excerpt}
									featuredImage={post.data.featured_image}
									href={`/posts/${post.id}`}
									date={post.data.publishedAt ?? undefined}
									readingTime={getReadingTime(post.data.content)}
									tags={tags}
									bylines={bylines}
								/>
							))}
						</div>
					</section>
				)}
			</div>
		)
	}
</Base>

<style>
	/* ─── Home wrapper ─── */
	.home {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 var(--spacing-8) var(--spacing-24);
	}

	/* ─── Intro strip ─── */
	.home-intro {
		padding: var(--spacing-10) 0 var(--spacing-12);
		border-bottom: 1px solid var(--color-border-subtle);
		margin-bottom: var(--spacing-16);
	}

	.home-tagline {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-xs);
		font-weight: 500;
		letter-spacing: var(--tracking-widest);
		text-transform: uppercase;
		color: var(--color-muted);
		margin: 0;
	}

	/* ─── Hero ─── */
	.hero {
		display: grid;
		grid-template-columns: 1fr 1fr;
		grid-template-rows: auto auto auto auto;
		column-gap: var(--spacing-16);
		row-gap: var(--spacing-5);
		align-items: start;
		padding-bottom: var(--spacing-20);
		margin-bottom: var(--spacing-20);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	/* Eyebrow: col 1, row 1 */
	.hero-eyebrow {
		grid-column: 1;
		grid-row: 1;
		display: flex;
		gap: var(--spacing-3);
	}

	.eyebrow-tag {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-xs);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		color: var(--color-muted);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.eyebrow-tag:hover {
		color: var(--color-text-secondary);
		opacity: 1;
	}

	/* Title: col 1, row 2 */
	.hero-title-link {
		grid-column: 1;
		grid-row: 2;
		text-decoration: none;
		color: inherit;
		display: block;
	}

	.hero-title {
		font-family: Georgia, 'Times New Roman', serif;
		font-size: clamp(1.875rem, 3.5vw, var(--font-size-4xl));
		font-weight: 700;
		line-height: 1.08;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin: 0;
		transition: opacity var(--transition-fast);
	}

	.hero-title-link:hover .hero-title {
		opacity: 0.6;
	}

	/* Excerpt: col 1, row 3 */
	.hero-excerpt {
		grid-column: 1;
		grid-row: 3;
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		max-width: 480px;
		margin: 0;
	}

	/* Meta: col 1, row 4 */
	.hero-meta {
		grid-column: 1;
		grid-row: 4;
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		align-self: end;
	}

	.hero-byline {
		display: flex;
		gap: var(--spacing-1);
		color: var(--color-text-secondary);
	}

	.sep {
		color: var(--color-border);
	}

	/* Image: col 2, all rows */
	.hero-image-link {
		grid-column: 2;
		grid-row: 1 / 5;
		display: block;
		overflow: hidden;
		align-self: stretch;
	}

	.hero-image {
		width: 100%;
		height: 100%;
		overflow: hidden;
		background: var(--color-surface);
		margin: 0;
	}

	.hero-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		aspect-ratio: 4 / 3;
		transition: transform 0.7s ease;
		filter: grayscale(8%);
	}

	.hero-image-link:hover .hero-image img {
		transform: scale(1.03);
	}

	/* ─── Index section ─── */
	.index-section {
		/* no extra top margin — hero-bottom handles it */
	}

	.index-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding-bottom: var(--spacing-4);
		border-bottom: 1px solid var(--color-border-subtle);
		margin-bottom: var(--spacing-10);
	}

	.index-label {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-xs);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: var(--tracking-widest);
		color: var(--color-muted);
	}

	.index-all {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-xs);
		color: var(--color-text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast);
		letter-spacing: 0.01em;
	}

	.index-all:hover {
		color: var(--color-text);
		opacity: 1;
	}

	/* ─── Posts Grid ─── */
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-12) var(--spacing-8);
	}

	/* ─── Empty State ─── */
	.empty-state {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: var(--spacing-4);
		padding: var(--spacing-24) var(--spacing-8);
		max-width: 560px;
		margin: 0 auto;
	}

	.empty-eyebrow {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-xs);
		font-weight: 500;
		letter-spacing: var(--tracking-widest);
		text-transform: uppercase;
		color: var(--color-muted);
		margin: 0;
	}

	.empty-state h2 {
		font-family: Georgia, 'Times New Roman', serif;
		font-size: var(--font-size-3xl);
		font-weight: 700;
		line-height: var(--leading-tight);
		margin: 0;
	}

	.btn {
		display: inline-block;
		margin-top: var(--spacing-2);
		padding: var(--spacing-2) var(--spacing-6);
		background: var(--color-text);
		color: var(--color-bg);
		text-decoration: none;
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: var(--font-size-sm);
		font-weight: 500;
		letter-spacing: 0.02em;
		transition: opacity var(--transition-fast);
	}

	.btn:hover {
		opacity: 0.75;
	}

	/* ─── Responsive ─── */
	@media (max-width: 1024px) {
		.hero {
			grid-template-columns: 1fr;
			grid-template-rows: auto;
			gap: var(--spacing-5);
		}

		.hero-eyebrow { grid-column: 1; grid-row: 1; }
		.hero-title-link { grid-column: 1; grid-row: 2; }
		.hero-excerpt { grid-column: 1; grid-row: 3; }
		.hero-image-link {
			grid-column: 1;
			grid-row: 5;
		}
		.hero-meta { grid-column: 1; grid-row: 4; }

		.hero-image img {
			aspect-ratio: 16 / 7;
			height: auto;
		}

		.posts-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 768px) {
		.home {
			padding: 0 var(--spacing-5) var(--spacing-16);
		}

		.home-intro {
			padding: var(--spacing-8) 0 var(--spacing-10);
			margin-bottom: var(--spacing-12);
		}

		.hero {
			padding-bottom: var(--spacing-14);
			margin-bottom: var(--spacing-14);
		}

		.hero-title {
			font-size: var(--font-size-3xl);
		}

		.hero-image img {
			aspect-ratio: 16 / 9;
		}
	}

	@media (max-width: 600px) {
		.posts-grid {
			grid-template-columns: 1fr;
			gap: var(--spacing-10);
		}

		.hero-title {
			font-size: var(--font-size-2xl);
		}
	}
</style>
