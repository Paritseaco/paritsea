---
import {
	getEmDashEntry,
	getEmDashCollection,
	getEntryTerms,
	getSeoMeta,
	decodeSlug,
	getSiteSettings,
} from "emdash";
import {
	Image,
	PortableText,
} from "emdash/ui";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import ArticleUtilityRail from "../components/ArticleUtilityRail.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import DocumentRecordMeta from "../components/DocumentRecordMeta.astro";
import { getDirectPostBySlug } from "../utils/direct-post";
import {
	frameworkPageFromSegment,
	isFrameworkPageSlug,
	resolveFrameworkPage,
	resolvePostPath,
} from "../utils/public-paths";
import { getReadingTime } from "../utils/reading-time";
import { resolveBlogSiteIdentity } from "../utils/site-identity";
import { incrementPostViews } from "../utils/view-count";
import {
	localizeAppliedContext,
	localizeRecordMetadata,
	localizeRecordValue,
} from "../utils/intellectual-localization";
import {
	formatDateForLocale,
	getAstroLocale,
	localizeEntry,
	localizeTermLabel,
	localizedPath,
	ui,
} from "../utils/i18n";

const locale = getAstroLocale(Astro);
const copy = ui[locale];
const labels = ui[locale].labels;

// Catch-all: last path segment is the post slug; the leading segment(s) are the
// public URL prefix (e.g. "journal", "system/protocols") → reverse-map to taxonomy key.
const pathParam = Astro.params.path ?? "";
const segments = pathParam.split("/").filter(Boolean);
const rawSlug = segments.pop() ?? "";
const publicSegment = segments.join("/");
const taxonomySlug = frameworkPageFromSegment(publicSegment);
if (!taxonomySlug) return new Response(locale === "th" ? "ไม่พบหน้า" : "Not found", { status: 404 });

const decodedSlug = decodeSlug(rawSlug);
if (!decodedSlug) return new Response(locale === "th" ? "ไม่พบหน้า" : "Not found", { status: 404 });
const slug = taxonomySlug === "the-doctrine" && decodedSlug === "paritsea-framework"
	? "doctrine"
	: decodedSlug;

const { entry: emdashPost, cacheHint } = await getEmDashEntry("posts", slug);
const matchingEntry =
	emdashPost && resolveFrameworkPage(emdashPost.data.framework_page) === taxonomySlug
		? emdashPost
		: null;
let rawPost = matchingEntry;
if (!rawPost) {
	try {
		rawPost = await getDirectPostBySlug(slug, taxonomySlug) as typeof rawPost;
	} catch {
		rawPost = null;
	}
}
if (!rawPost) return new Response(locale === "th" ? "ไม่พบหน้า" : "Not found", { status: 404 });
const post = localizeEntry(rawPost, "posts", locale);

if (cacheHint) {
	Astro.cache.set(cacheHint);
}

// Get featured image URL for OG fallback
// The image may have src (external) or meta.storageKey (local)
function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	// Check for direct src
	if (typeof image.src === "string" && image.src) {
		return image.src.startsWith("http")
			? image.src
			: `${Astro.url.origin}${image.src}`;
	}
	// Build from storageKey for local images
	const meta = image.meta as Record<string, unknown> | undefined;
	const storageKey =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);
	if (storageKey) {
		return `${Astro.url.origin}/_emdash/api/media/file/${storageKey}`;
	}
	return undefined;
}
const featuredImageUrl = getImageUrl(post.data.featured_image);
const { siteTitle } = resolveBlogSiteIdentity(await getSiteSettings());

// Generate SEO meta from content
const seo = getSeoMeta(post, {
	siteTitle,
	siteUrl: Astro.site?.origin ?? Astro.url.origin,
	path: localizedPath(resolvePostPath(slug, post.data.framework_page, taxonomySlug) ?? `/${publicSegment}/${slug}`, locale),
	defaultOgImage: featuredImageUrl,
});

// Content categories are the visible classification layer.
const categories = await getEntryTerms("posts", post.data.id, "category");
const frameworkPage = resolveFrameworkPage(post.data.framework_page, taxonomySlug);
const isProtocol = frameworkPage === "protocols";
const isStandard = frameworkPage === "standards";
const isDoctrine = frameworkPage === "the-doctrine";
const isRecord = frameworkPage === "the-method";
const isImplementation = frameworkPage === "implementations";
const recordCategoryLabel = categories[0]?.label ? localizeTermLabel(categories[0].label, locale) : null;
const contentFormat = typeof post.data.format === "string" ? post.data.format : null;
const youtubeUrl = typeof post.data.youtube_url === "string" ? post.data.youtube_url : null;
const formatLabel = contentFormat === "video-reflection"
	? "Video Reflection"
	: contentFormat === "pattern-brief"
		? "Pattern Brief"
		: contentFormat === "decision-note"
			? "Decision Note"
			: null;
const docBadge = isRecord
	? recordCategoryLabel ?? ui[locale].navLabels["The Method"]
	: isProtocol
		? labels.protocol
		: isStandard
			? labels.standard
			: isImplementation
				? labels.implementation
			: isDoctrine
				? labels.doctrine
				: null;
// Bylines are already hydrated by getEmDashEntry
const bylines = post.data.bylines ?? [];

// Get reading time
const readingTime = getReadingTime(post.data.content);
const initialViews = await incrementPostViews(post.data.id, { unique: false });

// Relationship-driven navigation. CMS records win; explicit provenance fallbacks
// preserve the current STP/ASLS and Journal chain until relationships are migrated.
let relationshipTargetIds: string[] = [];
try {
	const relationshipResult = await getEmDashCollection("relationships", { where: { source_work: post.data.id } });
	relationshipTargetIds = relationshipResult.entries
		.map((entry) => String((entry.data as unknown as Record<string, unknown>).target_work ?? ""))
		.filter(Boolean);
} catch {
	relationshipTargetIds = [];
}
const fallbackRelationshipSlugs: Record<string, string[]> = {
	stp: ["doctrine", "aesthetic-transparency"],
	"asls-01": ["stp"],
	"aesthetic-transparency": ["stp"],
};
const { entries: recentPosts } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: 24,
});
const fallbackSlugs = fallbackRelationshipSlugs[slug] ?? [];
const otherPosts = recentPosts
	.filter((candidate) => candidate.id !== post.id)
	.filter((candidate) => relationshipTargetIds.includes(candidate.data.id) || fallbackSlugs.includes(candidate.id))
	.slice(0, 3);

// Fetch categories for related posts (bylines are already hydrated by getEmDashCollection)
const otherPostsWithTags = await Promise.all(
	otherPosts.map(async (p) => {
		const localizedPost = localizeEntry(p, "posts", locale);
		const postCategories = await getEntryTerms("posts", p.data.id, "category");
		const relatedFrameworkPage = resolveFrameworkPage(
			p.data.framework_page,
			postCategories.find((term) => isFrameworkPageSlug(term.slug))?.slug,
		);
		const visibleCategories = postCategories.filter((term) => !isFrameworkPageSlug(term.slug));
		const postBylines = p.data.bylines ?? [];
		const href =
			resolvePostPath(p.id, relatedFrameworkPage, null) ??
			`/journal/${p.id}`;
		return {
			post: localizedPost,
			cats: (visibleCategories.length > 0 ? visibleCategories : postCategories).map((term) => ({
				...term,
				label: localizeTermLabel(term.label, locale),
			})),
			bylines: postBylines,
			href: localizedPath(href, locale),
		};
	})
);

const lastUpdated = post.data.updatedAt ?? post.data.publishedAt ?? null;
const lastUpdatedLabel = formatDateForLocale(lastUpdated, locale);

// Phase 5 — contextual tails
const postDataUntyped = post.data as unknown as Record<string, unknown>;
const fallbackRecord = (() => {
	if (isDoctrine) return {
		type: "Framework", stage: "formalized", status: "current", version: "1.1",
		provenance: "Authored by Parit Ritchai from recurring observations about structural coherence and legitimacy; revision 1.1 replaces absolute immutability with explicit, attributable, versioned change governance.",
		scope: "A canonical lens for examining structural coherence and legitimacy. It does not determine moral virtue, commercial success, or universal applicability.",
		nonClaims: "This Framework is not a regulator, certification, audit result, or permission for an applied interpreter to alter the canonical source.",
	};
	if (isProtocol) return {
		type: "Protocol", stage: "formalized", status: "current", version: "1.0",
		provenance: locale === "th" ? "สืบเนื่องจาก Paritsea Framework และ observation เรื่อง aesthetic transparency" : "Derived from the Paritsea Framework and the Journal observation on aesthetic transparency.",
		scope: locale === "th" ? "กำหนด obligation ด้านความโปร่งใสเชิงโครงสร้าง โดยต้องอ่านร่วมกับ scope ในเอกสาร" : "Defines obligations for structural transparency and must be read with the scope stated in the document.",
		nonClaims: locale === "th" ? "ไม่ใช่ certification, audit result หรือคำกล่าวอ้างว่าใช้ได้กับทุกองค์กร" : "It is not certification, an audit result, or a claim of universal applicability.",
	};
	if (isStandard) return {
		type: "Standard", stage: "formalized", status: "current", version: "1.0",
		provenance: locale === "th" ? "สืบเนื่องจาก Structural Transparency Protocol (STP) v1.0" : "Derived from Structural Transparency Protocol (STP) v1.0.",
		scope: locale === "th" ? "ระบุ threshold ที่ใช้ประเมิน obligation ของ Protocol ในขอบเขตที่เอกสารกำหนด" : "Defines thresholds for assessing Protocol obligations within the stated scope.",
		nonClaims: locale === "th" ? "ไม่สร้าง certification หรือ endorsement โดยตัวมันเอง" : "It does not create certification or endorsement by itself.",
	};
	return {
		type: "Journal", stage: "observation", status: "exploring", version: "1.0",
		provenance: locale === "th" ? "ข้อสังเกตที่เขียนโดย Parit Ritchai และเก็บใน Journal ก่อนการ formalize" : "An observation authored by Parit Ritchai and preserved in Journal before formalization.",
		scope: locale === "th" ? "บันทึกสิ่งที่เห็น การตีความ และคำถามจากบริบทที่ระบุในเนื้อหา" : "Records what was seen, interpreted, and questioned in the context named by the entry.",
		nonClaims: locale === "th" ? "การเผยแพร่ยังไม่ทำให้งานชิ้นนี้เป็น Framework, Protocol หรือ Standard" : "Publication does not make this entry a Framework, Protocol, or Standard.",
	};
})();
const contentType = String(postDataUntyped.content_type ?? fallbackRecord.type);
const intellectualStage = String(postDataUntyped.intellectual_stage ?? fallbackRecord.stage);
const lifecycleStatus = String(postDataUntyped.lifecycle_status ?? fallbackRecord.status);
const documentVersion = isDoctrine
	? "1.1"
	: String(postDataUntyped.document_version ?? fallbackRecord.version);
const localizedRecordMetadata = localizeRecordMetadata(locale, slug, contentType, {
	provenance: String(postDataUntyped.provenance_summary ?? fallbackRecord.provenance),
	scope: String(postDataUntyped.scope_note ?? fallbackRecord.scope),
	nonClaims: String(postDataUntyped.non_claims ?? fallbackRecord.nonClaims),
});
const provenanceSummary = localizedRecordMetadata.provenance;
const scopeNote = localizedRecordMetadata.scope;
const nonClaims = localizedRecordMetadata.nonClaims;
const lastReviewedValue = postDataUntyped.last_reviewed_at instanceof Date
	? formatDateForLocale(postDataUntyped.last_reviewed_at, locale)
	: lastUpdatedLabel;
const systemBridgeUrl = typeof postDataUntyped.system_bridge_url === "string"
	? postDataUntyped.system_bridge_url
	: null;
const protocolUrl = typeof postDataUntyped.protocol_url === "string"
	? postDataUntyped.protocol_url
	: null;

type AppliedContext = { title: string; url: string; summary: string; type: string };
let appliedContexts: AppliedContext[] = [];
try {
	const result = await getEmDashCollection("applied_contexts", { where: { related_work: post.data.id } });
	appliedContexts = result.entries
		.map((entry) => entry.data as unknown as Record<string, unknown>)
		.filter((data) => data.disclosure_status === "reviewed-public")
		.map((data) => localizeAppliedContext(locale, { title: String(data.title ?? "Applied context"), url: String(data.public_url ?? ""), summary: String(data.context_summary ?? ""), type: String(data.context_type ?? "field-evidence") }))
		.filter((context) => context.url.startsWith("https://"));
} catch {
	appliedContexts = [];
}

if (appliedContexts.length === 0) {
	const fallbackApplied: Record<string, AppliedContext> = {
		"when-the-tool-was-not-the-problem": { title: "Tools accelerate confusion", url: "https://seocean.co.th/problems/tools-accelerate-confusion", summary: "A related organizational problem context maintained by SE Ocean.", type: "se-ocean-problem" },
		"on-automation-that-still-requires-fear": { title: "Tools accelerate confusion", url: "https://seocean.co.th/problems/tools-accelerate-confusion", summary: "A related organizational problem context maintained by SE Ocean.", type: "se-ocean-problem" },
		"when-monitoring-becomes-emotional-labour": { title: "Invisible fixers hold the system", url: "https://seocean.co.th/problems/invisible-fixers-hold-system", summary: "A related organizational problem context maintained by SE Ocean.", type: "se-ocean-problem" },
	};
	if (fallbackApplied[slug]) appliedContexts = [localizeAppliedContext(locale, fallbackApplied[slug])];
}

const breadcrumbCrumbs = isRecord
	? [{ label: locale === "th" ? "บันทึก" : "Journal", href: localizedPath("/journal", locale) }, { label: post.data.title }]
	: isDoctrine
		? [{ label: locale === "th" ? "งานอ้างอิง" : "Reference work", href: localizedPath("/system", locale) }, { label: "Framework", href: localizedPath("/system/frameworks", locale) }, { label: post.data.title }]
	: isProtocol
		? [{ label: locale === "th" ? "งานอ้างอิง" : "Reference work", href: localizedPath("/system", locale) }, { label: "Protocol", href: localizedPath("/system/protocols", locale) }, { label: post.data.title }]
		: isStandard
			? [{ label: locale === "th" ? "งานอ้างอิง" : "Reference work", href: localizedPath("/system", locale) }, { label: "Standard", href: localizedPath("/system/standards", locale) }, { label: post.data.title }]
			: [{ label: locale === "th" ? "หน้าแรก" : "Home", href: localizedPath("/", locale) }, { label: post.data.title }];

const documentStructuredData = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": isRecord ? "Article" : "DigitalDocument",
			"@id": `${seo.canonical}#work`,
			name: post.data.title,
			description: post.data.excerpt,
			url: seo.canonical,
			version: documentVersion,
			datePublished: post.data.publishedAt?.toISOString(),
			dateModified: post.data.updatedAt.toISOString(),
			creator: { "@type": "Person", name: "Parit Ritchai", url: `${Astro.url.origin}${localizedPath("/author/parit-ritchai", locale)}` },
			publisher: { "@type": "Organization", name: "Paritsea", url: Astro.url.origin },
			usageInfo: `${Astro.url.origin}${localizedPath("/ip/licensing", locale)}`,
			inLanguage: locale,
		},
		{
			"@type": "BreadcrumbList",
			itemListElement: breadcrumbCrumbs.map((crumb, index) => ({ "@type": "ListItem", position: index + 1, name: crumb.label, item: crumb.href ? `${Astro.url.origin}${crumb.href}` : seo.canonical })),
		},
	],
};

const lateralPosts = otherPosts
	.filter((p) => resolveFrameworkPage(p.data.framework_page) === "the-method")
	.slice(0, 2)
	.map((p) => ({
		post: localizeEntry(p, "posts", locale),
		href: localizedPath(resolvePostPath(p.id, "the-method", null) ?? `/journal/${p.id}`, locale),
	}));
---

<Base
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description}
	image={seo.ogImage}
	canonical={seo.canonical}
	robots={seo.robots}
	type="article"
	publishedTime={post.data.publishedAt?.toISOString() ?? null}
	modifiedTime={post.data.updatedAt.toISOString()}
	locale={locale}
	structuredData={documentStructuredData}
	content={{ collection: "posts", id: post.data.id, slug }}
>
	<div class="article-breadcrumb"><Breadcrumb crumbs={breadcrumbCrumbs} /></div>
	<article class="article">
		{post.data.featured_image && (
			<figure class="article-hero" {...post.edit.featured_image}>
				<Image image={post.data.featured_image} />
				<figcaption>{locale === "th" ? "ภาพหรือเอกสารต้นทางที่เผยแพร่พร้อมระเบียนนี้" : "Source image or document artifact published with this record"}</figcaption>
			</figure>
		)}

		{/* Three-column layout */}
		<div class="article-grid">
			{/* Left gutter: Meta information */}
			<aside class="article-meta-col">
				<div class="meta-sticky">
					<ArticleUtilityRail
						bylines={bylines}
						lastUpdatedLabel={lastUpdatedLabel}
						lastUpdatedIso={lastUpdated?.toISOString() ?? null}
						readingTime={readingTime}
						postId={post.data.id}
						initialViews={initialViews.viewCount}
						pageUrl={seo.canonical ?? Astro.url.toString()}
						locale={locale}
					/>
				</div>
			</aside>

			{/* Main content */}
			<div class={`article-main${isDoctrine ? ' article-main--doctrine' : ''}`}>
				<header class="article-header">
					<p class="experience-label" data-state={isRecord ? "moving" : "governed"}>
						{isRecord ? (locale === "th" ? "บันทึกฉบับเต็ม" : "Full Journal entry") : `${localizeRecordValue(locale, contentType)} · ${localizeRecordValue(locale, lifecycleStatus)}`}
					</p>
					{isDoctrine && (
						<div class="doctrine-authority">
							<p class="doctrine-authority-label">{labels.constitutionalDocument}</p>
							<p class="doctrine-authority-statement">{labels.doctrineNotice}</p>
						</div>
					)}
					{docBadge && (
						<div class={`article-doc-badge${isDoctrine ? ' article-doc-badge--doctrine' : ''}`}>
							{isDoctrine ? labels.constitutionalDoctrine : docBadge}
						</div>
					)}
					{isRecord && formatLabel && (
						<div class="article-context-strip">
							<span class="article-context-format">{formatLabel}</span>
							{youtubeUrl && (
								<a href={youtubeUrl} target="_blank" rel="noreferrer" class="article-context-link">
									{locale === "th" ? "เปิดบน YouTube" : "Open on YouTube"} →
								</a>
							)}
						</div>
					)}
					<div class="article-meta">
						{
							bylines.length > 0 && (
								<>
									<span class="article-meta-byline">
										{bylines.map((credit, i) => (
											<>
												{i > 0 && ", "}
												{credit.byline.displayName}
											</>
										))}
									</span>
									<span class="meta-dot" />
								</>
							)
						}
						{lastUpdatedLabel && (
							<>
								<time datetime={lastUpdated?.toISOString() ?? undefined}>
									{labels.lastUpdated} {lastUpdatedLabel}
								</time>
								<span class="meta-dot" />
							</>
						)}
						<span>{readingTime} {labels.minRead}</span>
					</div>
					<h1 class="article-title" {...post.edit.title}>{post.data.title}</h1>
					{
						post.data.excerpt && (
							<p class="article-excerpt" {...post.edit.excerpt}>{post.data.excerpt}</p>
						)
					}
					</header>

				<DocumentRecordMeta
					locale={locale}
					contentType={contentType}
					stage={intellectualStage}
					status={lifecycleStatus}
					version={documentVersion}
					provenance={provenanceSummary}
					scope={scopeNote}
					nonClaims={nonClaims}
					lastReviewed={lastReviewedValue}
				/>

				<div class={`article-content ${post.data.excerpt ? 'has-excerpt' : ''}`}>
					<PortableText value={post.data.content} />
				</div>

				{/* ── REFERENCE NOTE ── */}
				{frameworkPage && (
					<aside class="article-reference-note">
						<p class="article-reference-note-text">
							{locale === "th"
								? "สามารถอ้างอิงและนำแนวคิดนี้ไปต่อยอดได้ เมื่อให้เครดิตและลิงก์กลับมายัง Paritsea"
								: "You may reference, cite, and build on these ideas with attribution and a link back to Paritsea."}
							<a href={localizedPath("/ip/licensing", locale)} class="article-reference-note-link">
								{locale === "th" ? "อ่านนโยบาย →" : "Read policy →"}
							</a>
						</p>
					</aside>
				)}

				{appliedContexts.length > 0 && (
					<aside class="applied-context" aria-labelledby="applied-context-title">
						<p class="applied-context-label">{locale === "th" ? "บริบทการประยุกต์ใช้ภายนอก" : "External applied context"}</p>
						<h2 id="applied-context-title">{locale === "th" ? "แนวคิดนี้ปรากฏในงานองค์กรอย่างไร" : "Where this idea appears in organizational work"}</h2>
						{appliedContexts.map((context) => <a href={context.url} target="_blank" rel="noreferrer"><strong>{context.title}</strong><span>{locale === "th" ? "ดูบริบทที่ SE Ocean ดูแล โดยไม่เปลี่ยน canonical source →" : "View the context maintained by SE Ocean without changing the canonical source →"}</span></a>)}
					</aside>
				)}

				{/* ── VIDEO EMBED ── */}
				{youtubeUrl && (
					<div class="article-video-embed">
						<div class="article-video-embed-inner">
							<iframe 
								src={youtubeUrl.replace("watch?v=", "embed/").replace("youtu.be/", "youtube.com/embed/")} 
								title={post.data.title}
								allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
								allowfullscreen
								class="article-video-iframe"
							></iframe>
						</div>
						<p class="article-video-caption">
							{locale === "th" ? "Video Reflection — อยู่ใน knowledge flow เดียวกับบทความนี้" : "Video Reflection — part of the same knowledge flow as this entry"}
						</p>
					</div>
				)}

				{/* ── JOURNAL TAIL (MD-06 + MD-07) ── */}
				{isRecord && (
					<div class="article-tail">
						{systemBridgeUrl && (
							<div class="article-tail-bridge">
								<a href={localizedPath(systemBridgeUrl, locale)} class="article-tail-bridge-link">
									{locale === "th" ? "รูปแบบที่อยู่เบื้องหลังนี้ →" : "The pattern behind this →"}
								</a>
							</div>
						)}
						{lateralPosts.length > 0 && (
							<div class="article-tail-lateral">
								<p class="article-tail-lateral-label">
									{locale === "th" ? "บันทึกที่เกี่ยวข้อง" : "Related entries"}
								</p>
								<ul class="article-tail-lateral-list">
									{lateralPosts.map(({ post: p, href }) => (
										<li>
											<a href={href} class="article-tail-lateral-link">{p.data.title}</a>
										</li>
									))}
								</ul>
							</div>
						)}
					</div>
				)}

				{/* ── IMPLEMENTATION TAIL (MD-08) ── */}
				{isImplementation && protocolUrl && (
					<div class="article-tail">
						<div class="article-tail-bridge">
							<a href={localizedPath(protocolUrl, locale)} class="article-tail-bridge-link">
								{locale === "th" ? "กฎที่อยู่เบื้องหลังนี้ →" : "The rule behind this →"}
