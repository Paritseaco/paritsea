---
import {
	getEmDashEntry,
	getEmDashCollection,
	getEntryTerms,
	getSeoMeta,
	decodeSlug,
	getSiteSettings,
} from "emdash";
import {
	Image,
	PortableText,
	Comments,
	CommentForm,
	WidgetArea,
} from "emdash/ui";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import ArticleUtilityRail from "../components/ArticleUtilityRail.astro";
import { getDirectPostBySlug } from "../utils/direct-post";
import {
	frameworkPageFromSegment,
	isFrameworkPageSlug,
	resolveFrameworkPage,
	resolvePostPath,
} from "../utils/public-paths";
import { getReadingTime } from "../utils/reading-time";
import { resolveBlogSiteIdentity } from "../utils/site-identity";
import { incrementPostViews } from "../utils/view-count";
import {
	formatDateForLocale,
	getAstroLocale,
	localizeEntry,
	localizeTermLabel,
	localizedPath,
	ui,
} from "../utils/i18n";

const locale = getAstroLocale(Astro);
const copy = ui[locale];
const labels = ui[locale].labels;

// Catch-all: last path segment is the post slug; the leading segment(s) are the
// public URL prefix (e.g. "journal", "system/protocols") → reverse-map to taxonomy key.
const pathParam = Astro.params.path ?? "";
const segments = pathParam.split("/").filter(Boolean);
const rawSlug = segments.pop() ?? "";
const publicSegment = segments.join("/");
const taxonomySlug = frameworkPageFromSegment(publicSegment);
if (!taxonomySlug || taxonomySlug === "the-doctrine") return Astro.redirect("/404");

const slug = decodeSlug(rawSlug);
if (!slug) return Astro.redirect("/404");

const { entry: emdashPost, cacheHint } = await getEmDashEntry("posts", slug);
const matchingEntry =
	emdashPost && resolveFrameworkPage(emdashPost.data.framework_page) === taxonomySlug
		? emdashPost
		: null;
let rawPost = matchingEntry;
if (!rawPost) {
	try {
		rawPost = await getDirectPostBySlug(slug, taxonomySlug) as typeof rawPost;
	} catch {
		rawPost = null;
	}
}
if (!rawPost) return Astro.redirect("/404");
const post = localizeEntry(rawPost, "posts", locale);

if (cacheHint) {
	Astro.cache.set(cacheHint);
}

// Get featured image URL for OG fallback
// The image may have src (external) or meta.storageKey (local)
function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	// Check for direct src
	if (typeof image.src === "string" && image.src) {
		return image.src.startsWith("http")
			? image.src
			: `${Astro.url.origin}${image.src}`;
	}
	// Build from storageKey for local images
	const meta = image.meta as Record<string, unknown> | undefined;
	const storageKey =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);
	if (storageKey) {
		return `${Astro.url.origin}/_emdash/api/media/file/${storageKey}`;
	}
	return undefined;
}
const featuredImageUrl = getImageUrl(post.data.featured_image);
const { siteTitle } = resolveBlogSiteIdentity(await getSiteSettings());

// Generate SEO meta from content
const seo = getSeoMeta(post, {
	siteTitle,
	siteUrl: Astro.site?.origin ?? Astro.url.origin,
	path: localizedPath(resolvePostPath(slug, post.data.framework_page, taxonomySlug) ?? `/${publicSegment}/${slug}`, locale),
	defaultOgImage: featuredImageUrl,
});

// Content categories are the visible classification layer.
const categories = await getEntryTerms("posts", post.data.id, "category");
const frameworkPage = resolveFrameworkPage(post.data.framework_page, taxonomySlug);
const isProtocol = frameworkPage === "protocols";
const isStandard = frameworkPage === "standards";
const isDoctrine = frameworkPage === "the-doctrine";
const isRecord = frameworkPage === "the-method";
const isImplementation = frameworkPage === "implementations";
const recordCategoryLabel = categories[0]?.label ? localizeTermLabel(categories[0].label, locale) : null;
const contentFormat = typeof post.data.format === "string" ? post.data.format : null;
const youtubeUrl = typeof post.data.youtube_url === "string" ? post.data.youtube_url : null;
const formatLabel = contentFormat === "video-reflection"
	? "Video Reflection"
	: contentFormat === "pattern-brief"
		? "Pattern Brief"
		: contentFormat === "decision-note"
			? "Decision Note"
			: null;
const docBadge = isRecord
	? recordCategoryLabel ?? ui[locale].navLabels["The Method"]
	: isProtocol
		? labels.protocol
		: isStandard
			? labels.standard
			: isImplementation
				? labels.implementation
			: isDoctrine
				? labels.doctrine
				: null;
const articleContext = locale === "th"
	? isRecord
		? {
				kicker: "ต้นทางของระบบ",
				title: "Journal บันทึกสิ่งที่เห็นก่อนจะถูกทำให้เป็น Framework, Protocol หรือ Standard",
				body: "หน้านี้คือ first record ของ observation, tension หรือ pattern จากสถานการณ์จริง ยังไม่ใช่เอกสารกำกับ แต่เป็นหลักฐานของวิธีคิดที่อาจตกผลึกในภายหลัง",
			}
		: isProtocol
			? {
					kicker: "ชั้นข้อกำหนด",
					title: "Protocol คือ obligation ที่สืบมาจาก Framework",
					body: "หน้านี้ไม่ใช่บทความความเห็น แต่เป็นข้อกำหนดที่ทำให้ Framework มีผลในทางปฏิบัติ และต้องไม่ขัดกับรากฐานที่ไม่เปลี่ยนรูป",
				}
			: isStandard
				? {
						kicker: "ชั้นเกณฑ์ตรวจสอบ",
						title: "Standard คือ threshold ที่ทำให้ Protocol ตรวจสอบได้",
						body: "หน้านี้วางเกณฑ์เพื่อดูว่าข้อกำหนดของ Protocol เกิดขึ้นจริงหรือไม่ ไม่ใช่ service offer และไม่ใช่ certification โดยตัวมันเอง",
					}
				: isImplementation
					? {
							kicker: "ตัวอย่างการใช้",
							title: "Implementation คือบันทึกการแปลแนวคิดไปใช้จริง ไม่ใช่ชั้นต้นทางของ Paritsea",
							body: "หน้าประเภทนี้เป็นหลักฐานรองของการใช้งานในโลกจริง ชั้นต้นทางยังคงอยู่ที่ Lens, Journal, System และ IP / Official Use",
						}
					: null
	: isRecord
		? {
				kicker: "System origin",
				title: "Journal records what is seen before it becomes Framework, Protocol, or Standard.",
				body: "This page is a first record of an observation, tension, or pattern from real situations. It is not yet a governed instrument; it is evidence of thinking that may crystallize later.",
			}
		: isProtocol
			? {
					kicker: "Obligation layer",
					title: "A Protocol is an obligation derived from the Framework.",
					body: "This is not an opinion essay. It is a governed requirement that gives the Framework practical force without contradicting the immutable root.",
				}
			: isStandard
				? {
						kicker: "Verification layer",
						title: "A Standard is a threshold that makes a Protocol verifiable.",
						body: "This page defines criteria for whether Protocol obligations hold in practice. It is not a service offer and does not create certification by itself.",
					}
				: isImplementation
					? {
							kicker: "Applied record",
							title: "Implementation documents applied use; it is not Paritsea's source layer.",
							body: "Implementation pages are secondary evidence of real-world application. The source remains Lens, Journal, System, and IP / Official Use.",
						}
					: null;

// Bylines are already hydrated by getEmDashEntry
const bylines = post.data.bylines ?? [];

// Get reading time
const readingTime = getReadingTime(post.data.content);
const initialViews = await incrementPostViews(post.data.id, { unique: false });

// Get other posts for "More posts" section.
// Fetch a few extra in case the current post is among them
const { entries: recentPosts } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: 4,
});
const otherPosts = recentPosts.filter((p) => p.id !== post.id).slice(0, 3);

// Fetch categories for related posts (bylines are already hydrated by getEmDashCollection)
const otherPostsWithTags = await Promise.all(
	otherPosts.map(async (p) => {
		const localizedPost = localizeEntry(p, "posts", locale);
		const postCategories = await getEntryTerms("posts", p.data.id, "category");
		const relatedFrameworkPage = resolveFrameworkPage(
			p.data.framework_page,
			postCategories.find((term) => isFrameworkPageSlug(term.slug))?.slug,
		);
		const visibleCategories = postCategories.filter((term) => !isFrameworkPageSlug(term.slug));
		const postBylines = p.data.bylines ?? [];
		const href =
			resolvePostPath(p.id, relatedFrameworkPage, null) ??
			`/journal/${p.id}`;
		return {
			post: localizedPost,
			cats: (visibleCategories.length > 0 ? visibleCategories : postCategories).map((term) => ({
				...term,
				label: localizeTermLabel(term.label, locale),
			})),
			bylines: postBylines,
			href: localizedPath(href, locale),
		};
	})
);

const lastUpdated = post.data.updatedAt ?? post.data.publishedAt ?? null;
const lastUpdatedLabel = formatDateForLocale(lastUpdated, locale);

// Phase 5 — contextual tails
const postDataUntyped = post.data as unknown as Record<string, unknown>;
const systemBridgeUrl = typeof postDataUntyped.system_bridge_url === "string"
	? postDataUntyped.system_bridge_url
	: null;
const protocolUrl = typeof postDataUntyped.protocol_url === "string"
	? postDataUntyped.protocol_url
	: null;

// MD-07: latest 2 Journal entries (the-method), excluding current post
const { entries: allRecentPosts } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: 10,
});
const lateralPosts = allRecentPosts
	.filter((p) => p.id !== post.id && resolveFrameworkPage(p.data.framework_page) === "the-method")
	.slice(0, 2)
	.map((p) => ({
		post: localizeEntry(p, "posts", locale),
		href: localizedPath(resolvePostPath(p.id, "the-method", null) ?? `/journal/${p.id}`, locale),
	}));
---

<Base
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description}
	image={seo.ogImage}
	canonical={seo.canonical}
	robots={seo.robots}
	type="article"
	publishedTime={post.data.publishedAt?.toISOString() ?? null}
	modifiedTime={post.data.updatedAt.toISOString()}
	locale={locale}
	content={{ collection: "posts", id: post.data.id, slug }}
>
	<article class="article">
		{/* Hero: Full-width featured image or geometric illustration */}
		<div class="article-hero">
			{
				post.data.featured_image ? (
					<div {...post.edit.featured_image}>
						<Image image={post.data.featured_image} />
					</div>
				) : (
					<svg class="article-hero-illustration" viewBox="0 0 800 200" xmlns="http://www.w3.org/2000/svg">
						<!-- vertical grid lines -->
						<line x1="0"   y1="0" x2="0"   y2="200" stroke="currentColor" stroke-width="0.5" opacity="0.08" />
						<line x1="80"  y1="0" x2="80"  y2="200" stroke="currentColor" stroke-width="0.5" opacity="0.08" />
						<line x1="160" y1="0" x2="160" y2="200" stroke="currentColor" stroke-width="0.5" opacity="0.08" />
						<line x1="240" y1="0" x2="240" y2="200" stroke="currentColor" stroke-width="0.5" opacity="0.08" />
						<line x1="320" y1="0" x2="320" y2="200" stroke="currentColor" stroke-width="0.5" opacity="0.08" />
						<line x1="400" y1="0" x2="400" y2="200" stroke="currentColor" stroke-width="0.5" opacity="0.08" />
						<line x1="480" y1="0" x2="480" y2="200" stroke="currentColor" stroke-width="0.5" opacity="0.08" />
						<line x1="560" y1="0" x2="560" y2="200" stroke="currentColor" stroke-width="0.5" opacity="0.08" />
						<line x1="640" y1="0" x2="640" y2="200" stroke="currentColor" stroke-width="0.5" opacity="0.08" />
						<line x1="720" y1="0" x2="720" y2="200" stroke="currentColor" stroke-width="0.5" opacity="0.08" />
						<line x1="800" y1="0" x2="800" y2="200" stroke="currentColor" stroke-width="0.5" opacity="0.08" />
						<!-- horizontal grid lines -->
						<line x1="0" y1="0"   x2="800" y2="0"   stroke="currentColor" stroke-width="0.5" opacity="0.08" />
						<line x1="0" y1="40"  x2="800" y2="40"  stroke="currentColor" stroke-width="0.5" opacity="0.08" />
						<line x1="0" y1="80"  x2="800" y2="80"  stroke="currentColor" stroke-width="0.5" opacity="0.08" />
						<line x1="0" y1="120" x2="800" y2="120" stroke="currentColor" stroke-width="0.5" opacity="0.08" />
						<line x1="0" y1="160" x2="800" y2="160" stroke="currentColor" stroke-width="0.5" opacity="0.08" />
						<line x1="0" y1="200" x2="800" y2="200" stroke="currentColor" stroke-width="0.5" opacity="0.08" />
						<!-- nodes -->
						<circle cx="80"  cy="40"  r="3.5" fill="currentColor" opacity="0.55" />
						<circle cx="240" cy="80"  r="2.5" fill="currentColor" opacity="0.35" />
						<circle cx="400" cy="40"  r="4"   fill="currentColor" opacity="0.65" />
						<circle cx="560" cy="120" r="3"   fill="currentColor" opacity="0.4"  />
						<circle cx="720" cy="80"  r="3.5" fill="currentColor" opacity="0.5"  />
						<circle cx="160" cy="160" r="2.5" fill="currentColor" opacity="0.3"  />
						<circle cx="400" cy="160" r="3"   fill="currentColor" opacity="0.45" />
						<circle cx="640" cy="160" r="2.5" fill="currentColor" opacity="0.35" />
						<!-- connecting paths -->
						<line x1="80"  y1="40"  x2="240" y2="80"  stroke="currentColor" stroke-width="1" opacity="0.18" />
						<line x1="240" y1="80"  x2="400" y2="40"  stroke="currentColor" stroke-width="1" opacity="0.18" />
						<line x1="400" y1="40"  x2="560" y2="120" stroke="currentColor" stroke-width="1" opacity="0.15" />
						<line x1="560" y1="120" x2="720" y2="80"  stroke="currentColor" stroke-width="1" opacity="0.15" />
						<line x1="80"  y1="40"  x2="160" y2="160" stroke="currentColor" stroke-width="1" opacity="0.12" />
						<line x1="400" y1="40"  x2="400" y2="160" stroke="currentColor" stroke-width="1" opacity="0.12" />
						<line x1="720" y1="80"  x2="640" y2="160" stroke="currentColor" stroke-width="1" opacity="0.12" />
					</svg>
				)
			}
		</div>

		{/* Three-column layout */}
		<div class="article-grid">
			{/* Left gutter: Meta information */}
			<aside class="article-meta-col">
				<div class="meta-sticky">
					<ArticleUtilityRail
						bylines={bylines}
						lastUpdatedLabel={lastUpdatedLabel}
						lastUpdatedIso={lastUpdated?.toISOString() ?? null}
						readingTime={readingTime}
						postId={post.data.id}
						initialViews={initialViews.viewCount}
						pageUrl={seo.canonical ?? Astro.url.toString()}
						locale={locale}
					/>
				</div>
			</aside>

			{/* Main content */}
			<div class={`article-main${isDoctrine ? ' article-main--doctrine' : ''}`}>
				<header class="article-header">
					{isDoctrine && (
						<div class="doctrine-authority">
							<p class="doctrine-authority-label">{labels.constitutionalDocument}</p>
							<p class="doctrine-authority-statement">{labels.doctrineNotice}</p>
						</div>
					)}
					{docBadge && (
						<div class={`article-doc-badge${isDoctrine ? ' article-doc-badge--doctrine' : ''}`}>
							{isDoctrine ? labels.constitutionalDoctrine : docBadge}
						</div>
					)}
					{isRecord && formatLabel && (
						<div class="article-context-strip">
							<span class="article-context-format">{formatLabel}</span>
							{youtubeUrl && (
								<a href={youtubeUrl} target="_blank" rel="noreferrer" class="article-context-link">
									{locale === "th" ? "เปิดบน YouTube" : "Open on YouTube"} →
								</a>
							)}
						</div>
					)}
					<div class="article-meta">
						{
							bylines.length > 0 && (
								<>
									<span class="article-meta-byline">
										{bylines.map((credit, i) => (
											<>
												{i > 0 && ", "}
												{credit.byline.displayName}
											</>
										))}
									</span>
									<span class="meta-dot" />
								</>
							)
						}
						{lastUpdatedLabel && (
							<>
								<time datetime={lastUpdated?.toISOString() ?? undefined}>
									{labels.lastUpdated} {lastUpdatedLabel}
								</time>
								<span class="meta-dot" />
							</>
						)}
						<span>{readingTime} {labels.minRead}</span>
					</div>
					<h1 class="article-title" {...post.edit.title}>{post.data.title}</h1>
					{
						post.data.excerpt && (
							<p class="article-excerpt" {...post.edit.excerpt}>{post.data.excerpt}</p>
						)
					}
					{articleContext && (
						<aside class="article-context-panel">
							<p class="article-context-kicker">{articleContext.kicker}</p>
							<h2 class="article-context-title">{articleContext.title}</h2>
							<p class="article-context-body">{articleContext.body}</p>
						</aside>
					)}
					</header>

				<div class={`article-content ${post.data.excerpt ? 'has-excerpt' : ''}`}>
					<PortableText value={post.data.content} />
				</div>

				{/* ── REFERENCE NOTE ── */}
				{frameworkPage && (
					<aside class="article-reference-note">
						<p class="article-reference-note-text">
							{locale === "th"
								? "สามารถอ้างอิงและนำแนวคิดนี้ไปต่อยอดได้ เมื่อให้เครดิตและลิงก์กลับมายัง Paritsea"
								: "You may reference, cite, and build on these ideas with attribution and a link back to Paritsea."}
							<a href={localizedPath("/licensing", locale)} class="article-reference-note-link">
								{locale === "th" ? "อ่านนโยบาย →" : "Read policy →"}
							</a>
						</p>
					</aside>
				)}

				{/* ── VIDEO EMBED ── */}
				{youtubeUrl && (
					<div class="article-video-embed">
						<div class="article-video-embed-inner">
							<iframe 
								src={youtubeUrl.replace("watch?v=", "embed/").replace("youtu.be/", "youtube.com/embed/")} 
								title={post.data.title}
								frameborder="0"
								allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
								allowfullscreen
								class="article-video-iframe"
							></iframe>
						</div>
						<p class="article-video-caption">
							{locale === "th" ? "Video Reflection — อยู่ใน knowledge flow เดียวกับบทความนี้" : "Video Reflection — part of the same knowledge flow as this entry"}
						</p>
					</div>
				)}

				{/* ── JOURNAL TAIL (MD-06 + MD-07) ── */}
				{isRecord && (
					<div class="article-tail">
						{systemBridgeUrl && (
							<div class="article-tail-bridge">
								<a href={localizedPath(systemBridgeUrl, locale)} class="article-tail-bridge-link">
									{locale === "th" ? "รูปแบบที่อยู่เบื้องหลังนี้ →" : "The pattern behind this →"}
								</a>
							</div>
						)}
						{lateralPosts.length > 0 && (
							<div class="article-tail-lateral">
								<p class="article-tail-lateral-label">
									{locale === "th" ? "บันทึกที่เกี่ยวข้อง" : "Related entries"}
								</p>
								<ul class="article-tail-lateral-list">
									{lateralPosts.map(({ post: p, href }) => (
										<li>
											<a href={href} class="article-tail-lateral-link">{p.data.title}</a>
										</li>
									))}
								</ul>
							</div>
						)}
					</div>
				)}

				{/* ── IMPLEMENTATION TAIL (MD-08) ── */}
				{isImplementation && protocolUrl && (
					<div class="article-tail">
						<div class="article-tail-bridge">
							<a href={localizedPath(protocolUrl, locale)} class="article-tail-bridge-link">
								{locale === "th" ? "กฎที่อยู่เบื้องหลังนี้ →" : "The rule behind this →"}
							</a>
						</div>
					</div>
				)}

				{/* ── AUTHOR CARD ── */}
				<div class="article-author-card">
					<img src="/images/parit-profile.jpg" alt="Parit Ritchai" class="article-author-card-img" />
					<div class="article-author-card-body">
						<p class="article-author-card-name">{copy.authorName}</p>
						<p class="article-author-card-role">{copy.authorRole}</p>
						<p class="article-author-card-bio">{copy.authorBio}</p>
						<div class="article-author-card-links">
							<a href="https://www.instagram.com/paritsea" target="_blank" rel="noreferrer">{copy.socialInstagram}</a>
							<a href="https://www.threads.net/@paritsea" target="_blank" rel="noreferrer">{copy.socialThreads}</a>
							<a href="https://www.youtube.com/@paritsea" target="_blank" rel="noreferrer">{copy.socialYouTube}</a>
							<a href={localizedPath("/about", locale)}>{copy.about} →</a>
						</div>
					</div>
				</div>

				<div class="article-comments">
					<Comments collection="posts" contentId={post.data.id} threaded />
					<CommentForm collection="posts" contentId={post.data.id} />
				</div>
			</div>

			{/* Right gutter: TOC + Sidebar widgets */}
			<aside class="article-sidebar">
				<div class="sidebar-sticky">
					<nav class="toc" aria-label={labels.onThisPage}>
						<h4 class="toc-title">{labels.onThisPage}</h4>
						<div class="toc-content" id="toc-content">
							<!-- Populated by JS -->
						</div>
					</nav>
					<div class="sidebar-widgets">
						<WidgetArea name="sidebar" />
					</div>
				</div>
			</aside>
		</div>
	</article>

	{
		otherPostsWithTags.length > 0 && (
			<section class="more-posts">
				<div class="more-inner">
					<h2 class="more-title">{labels.continueReading}</h2>
					<div class="more-grid">
						{otherPostsWithTags.map(
							({ post: p, cats: postCats, bylines: postBylines, href }) => (
								<PostCard
									title={p.data.title}
									excerpt={p.data.excerpt}
									featuredImage={p.data.featured_image}
									href={href}
									date={p.data.publishedAt ?? undefined}
									readingTime={getReadingTime(p.data.content)}
									tags={postCats.map((c) => ({ slug: c.slug, label: c.label }))}
									bylines={postBylines}
									locale={locale}
								/>
							)
						)}
					</div>
				</div>
			</section>
		)
	}

	<script>
		// Build table of contents from h2/h3 headings
		function buildToc() {
			const content = document.querySelector(".article-content");
			const tocContainer = document.getElementById("toc-content");
			if (!content || !tocContainer) return;

			const headings = content.querySelectorAll("h2, h3");
			if (headings.length === 0) {
				// Hide TOC if no headings
				const toc = document.querySelector(".toc") as HTMLElement | null;
				if (toc) toc.style.display = "none";
				return;
			}

			const list = document.createElement("ul");
			list.className = "toc-list";

			headings.forEach((heading, index) => {
				// Add ID if missing
				if (!heading.id) {
					heading.id = `heading-${index}`;
				}

				const li = document.createElement("li");
				li.className =
					heading.tagName === "H3" ? "toc-item toc-item--nested" : "toc-item";

				const link = document.createElement("a");
				link.href = `#${heading.id}`;
				link.className = "toc-link";
				link.textContent = heading.textContent;

				li.appendChild(link);
				list.appendChild(li);
			});

			tocContainer.appendChild(list);

			// Highlight current section on scroll
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						const id = entry.target.id;
						const link = tocContainer.querySelector(`a[href="#${id}"]`);
						if (link) {
							if (entry.isIntersecting) {
								tocContainer
									.querySelectorAll(".toc-link")
									.forEach((l) => l.classList.remove("active"));
								link.classList.add("active");
							}
						}
					});
				},
				{ rootMargin: "-80px 0px -80% 0px" }
			);

			headings.forEach((heading) => observer.observe(heading));
		}

		buildToc();
	</script>
</Base>

