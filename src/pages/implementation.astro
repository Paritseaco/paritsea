---
import Base from "../layouts/Base.astro";
import UsageGuidance from "../components/UsageGuidance.astro";
import { getAstroLocale, localizedPath, ui } from "../utils/i18n";

const locale = getAstroLocale(Astro);
const navLabels = ui[locale].navLabels;

const copy = locale === "th"
	? {
			title: navLabels.Implementations,
			description:
				"การนำไปปรับใช้จริงคือชั้นปฏิบัติของ Paritsea: ระบบที่บันทึกไว้ ซึ่งทำให้หลักการ โปรโตคอล และมาตรฐานกลายเป็นพฤติกรรมจริงในการทำงาน",
			eyebrow: "ชั้นอ้างอิงเชิงปฏิบัติ",
			intro:
				"Paritsea ถูกออกแบบให้เดินทางออกจากข้อความ การนำไปปรับใช้จริงคือระบบ ผลิตภัณฑ์ และสภาพแวดล้อมการทำงาน ที่ทำให้หลักการ โปรโตคอล และมาตรฐานกลายเป็นพฤติกรรมที่สังเกตได้จริง",
			secondary:
				"การนำไปปรับใช้จริงจะนับว่าผ่าน เมื่อใช้ Paritsea อย่างซื่อตรงพอที่ยังอ่านออกว่าเป็นวัตถุอ้างอิง ไม่ใช่แค่ภาษาการตลาดหรือ compliance เชิงภาพลักษณ์",
			integrationNote:
				"ชั้นนี้อยู่ภายใต้ Framework โปรโตคอล และมาตรฐาน",
			publiclyDocumented: "เผยแพร่แล้ว",
			open: "เปิดดูการนำไปปรับใช้จริง →",
			methodLink: "เปิด Journal",
			youtubeLink: "ดู YouTube Reflections",
			qualification: "เกณฑ์การนับ",
			qualificationText:
				"การนำไปปรับใช้จริงต้องนำ Paritsea ไปใช้ในเชิงโครงสร้าง ไม่ใช่เชิงตกแต่ง กรอบอ้างอิงต้องกำหนดพฤติกรรมของผลิตภัณฑ์ ตรรกะความรับผิด และ trust surface ที่ผู้อ่านตรวจสอบได้อย่างมีความหมาย",
			integrity: "ความสมบูรณ์ของการอ้างอิง",
			integrityText:
				"การนำไปปรับใช้จริงต้องไม่แปลงมาตรฐานให้กลายเป็นระบบรีวิว star rating leaderboard sponsored discovery หรือการเปิด raw score การนำไปใช้ต้องรักษาความหมายเชิงโครงสร้าง ไม่ใช่จำลองภาพของมัน",
			current: "สถานะปัจจุบัน",
			currentTextBefore: "AgenSea คือการนำไปปรับใช้จริงแรกที่บันทึกไว้ อยู่ระหว่างพัฒนา prototype โดยใช้",
			currentTextAfter: "เป็นชั้นความโปร่งใสและความรับผิดเชิงโครงสร้าง",
			items: [
				{
					name: "AgenSea",
					status: "Provisional — กำลังพัฒนา prototype",
					label: "ASLS-01 v1.1 implementation",
					description:
						"แพลตฟอร์มความโปร่งใสเชิงโครงสร้างสำหรับงานเอเจนซี-ลูกค้า อยู่ระหว่างพัฒนา prototype เพื่อทำให้สิ่งที่มองไม่เห็นจากภายนอกกลายเป็นสิ่งที่ตรวจสอบได้ — ชื่อเสียงสอดคล้องกับผลงานจริงหรือไม่ ความสามารถที่อ้างว่ามีมีอยู่จริงหรือไม่ และมีผลประโยชน์ทับซ้อนที่ไม่ถูกเปิดเผยหรือไม่",
					href: "https://agensea-flame.vercel.app/",
					notes: [
						"ใช้ความชอบธรรมเชิงโครงสร้างแทนสัญญาณชื่อเสียง",
						"แปลง ASLS เป็น trust surface ที่มนุษย์อ่านได้ แทนการเปิด raw score",
						"แยก structural scoring ออกจาก operational trust signals อย่างชัดเจน",
					],
				},
			],
		}
	: {
			title: "Implementation",
			description:
				"Implementation is the applied layer of Paritsea: documented systems that apply the Framework, Protocols, and Standards in real environments.",
			eyebrow: "Applied Reference Layer",
			intro:
				"Paritsea is intended to travel beyond text. Implementation covers the systems, products, and operating environments where the Framework, Protocols, and Standards become real operating behaviour.",
			secondary:
				"An implementation qualifies when it applies Paritsea faithfully enough to remain legible as a reference object, not merely as branded product language or cosmetic compliance.",
			integrationNote:
				"Governed by the Framework, Protocols, and Standards.",
			publiclyDocumented: "publicly documented",
			open: "Open implementation →",
			methodLink: "Open Journal",
			youtubeLink: "View YouTube reflections",
			qualification: "Qualification Rule",
			qualificationText:
				"An implementation must apply Paritsea structurally, not cosmetically. The framework has to shape product behaviour, accountability logic, and reader-visible trust surfaces in ways others can meaningfully inspect.",
			integrity: "Reference Integrity",
			integrityText:
				"Implementations must not convert standards into review systems, star ratings, leaderboard mechanics, sponsored discovery, or raw score exposure. Application has to preserve structural meaning, not simulate it.",
			current: "Current Reading",
			currentTextBefore: "AgenSea is the first documented implementation. In prototype development, structurally applying",
			currentTextAfter: "as its transparency and accountability layer.",
			items: [
				{
					name: "AgenSea",
					status: "Provisional — prototype",
					label: "ASLS-01 v1.1 implementation",
					description:
						"Structural transparency platform for agency-client work, in prototype development. Built to make structurally invisible problems legible: whether agency reputation maps to documented performance, whether stated specialist capacity is real, and whether undisclosed conflicts of interest exist with competitors.",
					href: "https://agensea-flame.vercel.app/",
					notes: [
						"Implements structural legitimacy rather than reputation signals.",
						"Translates ASLS into human-readable trust surfaces instead of exposing raw scores.",
						"Treats structural scoring and operational trust signals as distinct layers.",
					],
				},
			],
		};
---

<Base
	title={copy.title}
	description={copy.description}
	locale={locale}
>
	<div class="implementations-page">
		<header class="page-header">
			<div class="page-header-inner">
				<p class="page-eyebrow">{copy.eyebrow}</p>
				<h1 class="page-title">{copy.title}</h1>
				<p class="page-description">
					{copy.intro}
				</p>
				<p class="page-description-secondary">
					{copy.secondary}
				</p>
				<p class="page-meta-note">
					{copy.items.length} {copy.items.length === 1 ? "implementation" : "implementations"} {copy.publiclyDocumented}
				</p>
				<p class="page-description-secondary">{copy.integrationNote}</p>
				<div class="page-cross-links">
					<a href={localizedPath("/journal", locale)} class="page-cross-link">{copy.methodLink} →</a>
					<a href="https://www.youtube.com/@paritsea" target="_blank" rel="noreferrer" class="page-cross-link">{copy.youtubeLink} →</a>
				</div>
				<UsageGuidance variant="implementations" compact locale={locale} />
			</div>
		</header>

		<section class="implementation-list" aria-label="Implementation registry">
			{copy.items.map((implementation, index) => (
				<article class="implementation-card">
					<div class="implementation-index">{String(index + 1).padStart(2, "0")}</div>
					<div class="implementation-body">
						<div class="implementation-meta">
							<span class="implementation-label">{implementation.label}</span>
							<span class="implementation-status">{implementation.status}</span>
						</div>
						<h2 class="implementation-title">{implementation.name}</h2>
						<p class="implementation-description">{implementation.description}</p>
						<ul class="implementation-notes">
							{implementation.notes.map((note) => (
								<li>{note}</li>
							))}
						</ul>
						<a
							href={implementation.href}
							class="implementation-link"
							target="_blank"
							rel="noreferrer"
						>
							{copy.open}
						</a>
					</div>
				</article>
			))}
		</section>

		<aside class="page-aside">
			<div class="aside-block">
				<h2 class="aside-heading">{copy.qualification}</h2>
				<p class="aside-text">
					{copy.qualificationText}
				</p>
			</div>
			<div class="aside-block">
				<h2 class="aside-heading">{copy.integrity}</h2>
				<p class="aside-text">
					{copy.integrityText}
				</p>
			</div>
			<div class="aside-block">
				<h2 class="aside-heading">{copy.current}</h2>
				<p class="aside-text">
					{copy.currentTextBefore} <a href={localizedPath("/system/standards/asls-01", locale)} class="aside-link">ASLS-01</a> {copy.currentTextAfter}
				</p>
			</div>
		</aside>
	</div>
</Base>

<style>
	.implementations-page {
		max-width: 1200px;
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-8) var(--spacing-20);
		display: grid;
		grid-template-columns: minmax(0, 1fr) 280px;
		gap: 0 var(--spacing-16);
		align-items: start;
		position: relative;
	}

	.implementations-page::before {
		content: "";
		position: absolute;
		inset: 0 0 auto 0;
		height: 280px;
		background: radial-gradient(circle at 12% 0%, color-mix(in srgb, var(--color-accent) 16%, transparent), transparent 58%);
		pointer-events: none;
	}

	.page-header {
		grid-column: 1 / -1;
		padding-bottom: var(--spacing-12);
		border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 30%, var(--color-border));
		margin-bottom: var(--spacing-12);
		position: relative;
		z-index: 1;
	}

	.page-header-inner {
		max-width: 760px;
	}

	.page-eyebrow,
	.aside-heading,
	.implementation-label,
	.implementation-status {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		text-transform: uppercase;
		letter-spacing: var(--tracking-widest);
		color: var(--color-muted);
	}

	.page-title,
	.implementation-title {
		font-family: var(--font-serif);
		letter-spacing: -0.03em;
	}

	.page-title {
		font-size: clamp(3rem, 7vw, 5rem);
		line-height: 0.95;
		margin: 0 0 var(--spacing-5);
	}

	.page-description,
	.page-description-secondary,
	.page-meta-note,
	.implementation-description,
	.implementation-notes,
	.aside-text {
		font-family: var(--font-sans);
		color: var(--color-text-secondary);
		line-height: var(--leading-relaxed);
	}

	.page-description-secondary {
		margin-top: var(--spacing-4);
	}

	.page-meta-note {
		margin-top: var(--spacing-5);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}

	.page-cross-links {
		display: flex;
		gap: var(--spacing-5);
		flex-wrap: wrap;
		margin: var(--spacing-4) 0 var(--spacing-2);
	}

	.page-cross-link {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-text);
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	.implementation-list {
		display: grid;
		gap: var(--spacing-5);
	}

	.implementation-card {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: var(--spacing-5);
		padding: var(--spacing-5) 0;
		border-top: 1px solid color-mix(in srgb, var(--color-accent) 20%, var(--color-border));
		border-left: 3px solid transparent;
		padding-left: var(--spacing-3);
		border-radius: var(--radius-sm);
		transition: border-left-color var(--transition-fast), background var(--transition-fast);
	}

	.implementation-card:hover {
		border-left-color: var(--color-accent);
		background: color-mix(in srgb, var(--color-surface) 68%, transparent);
	}

	.implementation-index {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		padding-top: 0.3rem;
	}

	.implementation-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-bottom: var(--spacing-2);
	}

	.implementation-title {
		font-size: clamp(1.6rem, 3vw, 2.4rem);
		line-height: 1.04;
		margin: 0 0 var(--spacing-3);
	}

	.implementation-description {
		margin: 0 0 var(--spacing-4);
	}

	.implementation-notes {
		margin: 0 0 var(--spacing-5);
		padding-left: 1.2rem;
	}

	.implementation-notes li + li {
		margin-top: 0.5rem;
	}

	.implementation-link,
	.aside-link {
		font-family: var(--font-sans);
		color: var(--color-text);
		text-decoration: none;
	}

	.implementation-link:hover,
	.aside-link:hover {
		opacity: 0.68;
	}

	.page-aside {
		display: grid;
		gap: var(--spacing-6);
		position: sticky;
		top: calc(var(--nav-height) + var(--spacing-6));
	}

	.aside-block {
		padding-top: var(--spacing-4);
		border-top: 1px solid color-mix(in srgb, var(--color-accent) 22%, var(--color-border));
	}

	.aside-heading {
		color: var(--color-text);
		margin: 0 0 var(--spacing-3);
	}

	@media (max-width: 960px) {
		.implementations-page {
			grid-template-columns: 1fr;
			padding: var(--spacing-10) var(--spacing-5) var(--spacing-14);
		}

		.page-aside {
			position: static;
			margin-top: var(--spacing-8);
		}
	}
</style>
