---
import Base from "../../layouts/Base.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { getAstroLocale, localizedPath } from "../../utils/i18n";

const locale = getAstroLocale(Astro);
const copy = locale === "th" ? {
	title: "การใช้และอ้างอิง — Paritsea",
	role: "ศูนย์รวมขอบเขตการใช้",
	headline: "เปิดให้อ่าน ไม่ได้แปลว่าไม่มีขอบเขต",
	summary: "พื้นที่นี้อธิบายวิธีอ้าง สอน ดัดแปลง และนำงานของ Paritsea ไปใช้ รวมถึงระเบียนการใช้ที่มีสถานะชัดเจน ไม่ใช่หน้าขายสิทธิ์หรือช่องทางรับงาน",
	items: [
		{ number: "01", state: "ข้อกำหนด", title: "การใช้และการอ้างอิง", body: "แยกสิ่งที่ทำได้ด้วยการให้ที่มา สิ่งที่ต้องขออนุญาต และสิ่งที่ไม่ควรอ้างว่าเป็นงานต้นฉบับ", href: "/ip/licensing", action: "อ่านขอบเขตการใช้" },
		{ number: "02", state: "ระเบียน", title: "Official Use", body: "ตรวจสถานะ version, scope และผู้ดำเนินการของการใช้ที่ถูกบันทึกไว้ โดยไม่ตีความเป็น certification เกินกว่าข้อมูลจริง", href: "/ip/official-use", action: "เปิดระเบียน" },
	],
	independent: "ความเป็นอิสระโดยเจตนา",
	independentTitle: "การใช้จริงไม่ทำให้ตลาดเป็นผู้ตัดสินต้นทาง",
	independentBody: "Paritsea ไม่ขายบริการและไม่ปรับข้อสรุปเพื่อ conversion งานอาจถูกนำไปใช้เชิงพาณิชย์โดยผู้ประยุกต์ แต่ provenance, version และ change authority ของฉบับต้นทางยังอยู่ที่นี่",
} : {
	title: "Use and citation — Paritsea",
	role: "Hub for use boundaries",
	headline: "Open to read does not mean without boundaries",
	summary: "This hub explains how Paritsea work may be cited, taught, adapted, and applied, and records uses with explicit status. It is not a rights storefront or a route to commission work.",
	items: [
		{ number: "01", state: "Terms", title: "Use and citation", body: "Distinguish what attribution permits, what needs separate permission, and what must not be represented as the source work.", href: "/ip/licensing", action: "Read use boundaries" },
		{ number: "02", state: "Registry", title: "Official Use", body: "Inspect version, scope, and implementer records without treating an entry as certification beyond what the record states.", href: "/ip/official-use", action: "Open registry" },
	],
	independent: "Independent by design",
	independentTitle: "Use in practice does not let the market decide the source",
	independentBody: "Paritsea does not sell services or optimize conclusions for conversion. Work may be applied commercially by an interpreter, while provenance, version, and change authority for the source remain here.",
};
---

<Base title={copy.title} description={copy.summary} locale={locale}>
	<main class="experience-page ip-page">
		<Breadcrumb crumbs={[{ label: locale === "th" ? "หน้าแรก" : "Home", href: localizedPath("/", locale) }, { label: locale === "th" ? "การใช้และอ้างอิง" : "Use and citation" }]} />
		<header class="ip-header"><p class="experience-label" data-state="governed">{copy.role}</p><h1 class="experience-title">{copy.headline}</h1><p class="experience-summary">{copy.summary}</p></header>

		<section class="experience-index ip-index">
			{copy.items.map((item) => (
				<a class="experience-index-row" href={localizedPath(item.href, locale)}>
					<span class="experience-index-meta">{item.number} · {item.state}</span>
					<div class="experience-index-copy"><h3>{item.title}</h3><p>{item.body}</p></div>
					<span class="experience-index-state">{item.action} →</span>
				</a>
			))}
		</section>

		<section class="experience-section">
			<div class="experience-note"><div><p class="experience-label" data-state="moving">{copy.independent}</p><h2>{copy.independentTitle}</h2></div><p>{copy.independentBody}</p></div>
		</section>
	</main>
</Base>

<style>
	.ip-header { max-width: 1080px; padding: var(--spacing-12) 0 var(--spacing-16); border-bottom: 1px solid var(--color-border); }
	.ip-index { margin-top: var(--spacing-10); }
</style>
