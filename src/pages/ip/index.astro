---
import Base from "../../layouts/Base.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import PageRoleHeader from "../../components/PageRoleHeader.astro";
import { getAstroLocale, localizedPath } from "../../utils/i18n";

const locale = getAstroLocale(Astro);
const intro = locale === "th"
	? "ศูนย์รวมขอบเขตการใช้ สิทธิ์การอ้างอิง และระเบียน Official Use ของงานที่ Paritsea รักษาไว้ หน้านี้ไม่ใช่ service catalogue และการมีชื่ออยู่ในระบบไม่ได้สร้าง certification โดยอัตโนมัติ"
	: "The hub for use boundaries, citation terms, and Official Use records for work stewarded by Paritsea. This is not a service catalogue, and appearing here does not create certification by default.";
---

<Base title="IP and Official Use" description={intro} locale={locale}>
	<div class="ip-shell">
		<Breadcrumb crumbs={[{ label: locale === "th" ? "หน้าแรก" : "Home", href: localizedPath("/", locale) }, { label: "IP" }]} />
		<PageRoleHeader role="Hub" eyebrow="Use boundaries and public stewardship" title="IP & Official Use" intro={intro} statusLabel={locale === "th" ? "ไม่ใช่ commercial intake" : "Not a commercial intake path"} />
		<section class="ip-grid">
			<a href={localizedPath("/ip/licensing", locale)}>
				<span>01 · Policy</span>
				<h2>{locale === "th" ? "สิทธิ์การใช้และการอ้างอิง" : "Licensing and use"}</h2>
				<p>{locale === "th" ? "ตรวจว่าอะไรอ่าน อ้าง สอน หรือดัดแปลงได้ และอะไรต้องได้รับอนุญาตแยก" : "Check what may be read, cited, taught, or adapted, and what requires separate permission."}</p>
			</a>
			<a href={localizedPath("/ip/official-use", locale)}>
				<span>02 · Registry</span>
				<h2>Official Use</h2>
				<p>{locale === "th" ? "ดูระเบียนการนำงานไปใช้ พร้อมสถานะ version, scope และผู้ดำเนินการ" : "Review application records with their status, version, scope, and implementer."}</p>
			</a>
		</section>
		<aside class="independence-note">
			<h2>{locale === "th" ? "ความเป็นอิสระโดยเจตนา" : "Independent by design"}</h2>
			<p>{locale === "th" ? "Paritsea ไม่ขายบริการหรือปรับข้อสรุปเพื่อ conversion หน้าที่ของมันคือรักษาต้นทาง provenance และขอบเขตการใช้ การที่บางแนวคิดถูกนำไปใช้เชิงพาณิชย์ที่อื่นไม่ได้เปลี่ยนผู้กำกับต้นทาง" : "Paritsea does not sell services or optimize conclusions for conversion. Its role is to preserve the source, provenance, and use boundaries. Commercial application elsewhere does not transfer stewardship of the source."}</p>
		</aside>
	</div>
</Base>

<style>
	.ip-shell { width: var(--wide-width); margin: 0 auto; padding: var(--spacing-8) 0 var(--spacing-24); }
	.ip-grid { display: grid; grid-template-columns: repeat(2, 1fr); margin-top: var(--spacing-12); border-top: 1px solid var(--color-border); }
	.ip-grid a { min-height: 300px; padding: var(--spacing-8); border-right: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
	.ip-grid a:last-child { border-right: 0; }
	.ip-grid span { font-family: var(--font-mono); font-size: var(--font-size-sm); color: var(--color-accent); }
	.ip-grid h2 { margin-top: var(--spacing-12); font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 500; }
	.ip-grid p { max-width: 50ch; margin-top: var(--spacing-5); color: var(--color-text-secondary); }
	.independence-note { display: grid; grid-template-columns: .7fr 1.3fr; gap: var(--spacing-12); padding: var(--spacing-16) 0; border-bottom: 1px solid var(--color-border); }
	.independence-note p { max-width: 700px; font-family: var(--font-serif); font-size: var(--font-size-xl); line-height: 1.65; }
	:global(:lang(th)) .ip-grid span { font-family: var(--font-sans); font-size: var(--font-size-sm); letter-spacing: 0; }
	:global(:lang(th)) .ip-grid p, :global(:lang(th)) .independence-note p { font-family: var(--font-sans); font-size: 1.0625rem; line-height: 1.9; letter-spacing: 0; }
	@media (max-width: 700px) { .ip-grid, .independence-note { grid-template-columns: 1fr; } .ip-grid a { border-right: 0; min-height: 0; } }
</style>
