---
import { getEmDashCollection } from "emdash";
import Base from "../../../layouts/Base.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import PageRoleHeader from "../../../components/PageRoleHeader.astro";
import { getAstroLocale, localizedPath } from "../../../utils/i18n";

const locale = getAstroLocale(Astro);
let records: Array<{ id: string; title: string; implementer: string; status: string; version: string; scope: string }> = [];
try {
	const result = await getEmDashCollection("official_uses");
	Astro.cache.set(result.cacheHint);
	records = result.entries.map((entry) => {
		const data = entry.data as unknown as Record<string, unknown>;
		return { id: entry.id, title: String(data.title ?? entry.id), implementer: String(data.implementer ?? "—"), status: String(data.use_status ?? "provisional"), version: String(data.implementation_version ?? "—"), scope: String(data.scope_note ?? "") };
	});
} catch {
	// Schema is additive; preserve a trustworthy public fallback until local/remote D1 is migrated.
}
if (!records.some((record) => record.id === "agensea")) records.push({ id: "agensea", title: "AgenSea", implementer: "Parit Ritchai", status: "provisional", version: "prototype", scope: locale === "th" ? "ต้นแบบที่สำรวจการใช้แนวคิดบางส่วน ยังไม่ใช่ certification หรือหลักฐานว่า Framework ใช้ได้กับทุกบริบท" : "A prototype exploring selected ideas; not certification or evidence of universal applicability." });
const intro = locale === "th" ? "Archive ของการนำงาน Paritsea ไปใช้ที่ถูกบันทึกอย่างชัดเจน สถานะ provisional หมายถึงยังอยู่ระหว่างพัฒนา ไม่ใช่ endorsement หรือ certification" : "An archive of explicitly recorded uses of Paritsea work. Provisional means still developing; it is not endorsement or certification.";
---

<Base title="Official Use" description={intro} locale={locale}>
	<div class="registry-shell">
		<Breadcrumb crumbs={[{ label: "IP", href: localizedPath("/ip", locale) }, { label: "Official Use" }]} />
		<PageRoleHeader role="Registry" eyebrow="Recorded application, not certification" title="Official Use" intro={intro} count={records.length} statusLabel={locale === "th" ? "ทุกระเบียนระบุสถานะและขอบเขต" : "Every record names its status and scope"} />
		<section class="registry-list">
			{records.map((record) => <a href={localizedPath(`/ip/official-use/${record.id}`, locale)} class="registry-row"><span>{record.status}</span><h2>{record.title}</h2><p>{record.scope}</p><small>{record.implementer} · {record.version}</small></a>)}
		</section>
	</div>
</Base>

<style>
	.registry-shell { width: var(--wide-width); margin: 0 auto; padding: var(--spacing-8) 0 var(--spacing-24); }
	.registry-list { margin-top: var(--spacing-12); border-top: 1px solid var(--color-border); }
	.registry-row { display: grid; grid-template-columns: 140px minmax(180px, .7fr) 1.3fr 180px; gap: var(--spacing-8); padding: var(--spacing-8) 0; border-bottom: 1px solid var(--color-border); align-items: start; }
	.registry-row > span, .registry-row small { font-family: var(--font-mono); font-size: var(--font-size-sm); color: var(--color-muted); }
	.registry-row > span { color: var(--color-accent); }
	.registry-row h2 { font-size: var(--font-size-2xl); }
	.registry-row p { color: var(--color-text-secondary); }
	:global(:lang(th)) .registry-row > span, :global(:lang(th)) .registry-row small { font-family: var(--font-sans); font-size: var(--font-size-sm); letter-spacing: 0; line-height: 1.55; }
	:global(:lang(th)) .registry-row p { font-size: 1.0625rem; line-height: 1.85; }
	@media (max-width: 860px) { .registry-row { grid-template-columns: 1fr; gap: var(--spacing-3); } }
</style>
