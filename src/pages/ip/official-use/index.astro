---
import { getEmDashCollection } from "emdash";
import Base from "../../../layouts/Base.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import { getAstroLocale, localizedPath } from "../../../utils/i18n";
import { localizeRecordValue } from "../../../utils/intellectual-localization";

const locale = getAstroLocale(Astro);
const result = await getEmDashCollection("official_uses");
Astro.cache.set(result.cacheHint);
const records = result.entries.map((entry) => ({
	id: entry.id,
	title: entry.data.title,
	implementer: entry.data.implementer,
	status: localizeRecordValue(locale, entry.data.use_status),
	version: localizeRecordValue(locale, entry.data.implementation_version ?? "—"),
	scope: locale === "th" && entry.id === "agensea"
		? "ต้นแบบที่สำรวจแนวคิดบางส่วนของ Paritsea ระเบียนนี้ไม่ใช่การรับรอง การสนับสนุน หรือหลักฐานว่าสามารถใช้ได้กับทุกบริบท"
		: entry.data.scope_note ?? "",
}));
const copy = locale === "th" ? {
	title: "Official Use — Paritsea", role: "ระเบียนการใช้", headline: "การใช้ที่ถูกบันทึก ไม่ใช่ตรารับรอง", summary: "ระเบียนนี้แสดงว่าใครนำงานใดไปใช้ ภายใต้ version, scope และสถานะอะไร คำว่า provisional หมายถึงยังอยู่ระหว่างพัฒนา และการปรากฏในหน้านี้ไม่ได้สร้าง certification หรือ endorsement", count: "ระเบียนที่เผยแพร่", empty: "ยังไม่มีระเบียนที่เผยแพร่",
} : {
	title: "Official Use — Paritsea", role: "Use registry", headline: "Recorded use, not a certification mark", summary: "This registry states who applied which work, under what version, scope, and status. Provisional means still developing. Appearance here does not create certification or endorsement.", count: "published records", empty: "No use records have been published.",
};
---
<Base title={copy.title} description={copy.summary} locale={locale}>
	<main class="experience-page use-registry">
		<Breadcrumb crumbs={[{ label: locale === "th" ? "การใช้และอ้างอิง" : "Use and citation", href: localizedPath("/ip", locale) }, { label: locale === "th" ? "ระเบียนการใช้ (Official Use)" : "Official Use" }]} />
		<header><div><p class="experience-label" data-state="applied">{copy.role}</p><h1 class="experience-title">{copy.headline}</h1><p class="experience-summary">{copy.summary}</p></div><dl><dt>{copy.count}</dt><dd>{String(records.length).padStart(2, "0")}</dd></dl></header>
		<section class="experience-index">
			{records.length ? records.map((record, index) => <a class="experience-index-row" href={localizedPath(`/ip/official-use/${record.id}`, locale)}><span class="experience-index-meta">{String(index + 1).padStart(2, "0")} · {record.status}</span><div class="experience-index-copy"><h3>{record.title}</h3><p>{record.scope}</p></div><span class="experience-index-state">{record.implementer}<br />{record.version} →</span></a>) : <p class="use-empty">{copy.empty}</p>}
		</section>
	</main>
</Base>
<style>
	.use-registry header { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: var(--spacing-12); align-items: end; padding: var(--spacing-12) 0 var(--spacing-16); border-bottom: 1px solid var(--color-border); }
	.use-registry dl { min-width: 170px; padding-left: var(--spacing-6); border-left: 1px solid var(--color-applied); }
	.use-registry dt { font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--color-muted); text-transform: uppercase; letter-spacing: var(--tracking-wide); }
	.use-registry dd { margin-top: var(--spacing-2); font-family: var(--font-serif); font-size: clamp(2.2rem, 4vw, 3.75rem); line-height: 1; color: var(--color-applied); }
	.use-empty { padding: var(--spacing-10) 0; color: var(--color-muted); }
	:global(:lang(th)) .use-registry dt { font-family: var(--font-sans); font-size: .875rem; text-transform: none; letter-spacing: 0; }
	:global(:lang(th)) .use-registry dd { font-family: var(--font-sans); font-weight: 300; }
	@media (max-width: 700px) { .use-registry header { grid-template-columns: 1fr; } .use-registry dl { padding: var(--spacing-5) 0 0; border: 0; border-top: 1px solid var(--color-applied); } }
</style>
