---
import { getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../../../layouts/Base.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import DocumentRecordMeta from "../../../components/DocumentRecordMeta.astro";
import { getAstroLocale, localizedPath } from "../../../utils/i18n";

const locale = getAstroLocale(Astro);
const slug = Astro.params.slug ?? "";
let cmsEntry: Awaited<ReturnType<typeof getEmDashEntry<"official_uses">>>["entry"] = null;
try { const result = await getEmDashEntry("official_uses", slug); cmsEntry = result.entry; Astro.cache.set(result.cacheHint); } catch { cmsEntry = null; }
if (!cmsEntry && slug !== "agensea") return new Response("Not found", { status: 404 });
const data = (cmsEntry?.data ?? {}) as unknown as Record<string, unknown>;
const title = String(data.title ?? "AgenSea");
const status = String(data.use_status ?? "provisional");
const version = String(data.implementation_version ?? "prototype");
const scope = String(data.scope_note ?? (locale === "th" ? "ต้นแบบที่สำรวจการใช้แนวคิดบางส่วนในระบบ agent ยังไม่ใช่ certification หรือหลักฐานว่าแนวคิดใช้ได้กับทุกบริบท" : "A prototype exploring selected ideas in an agent system; not certification or evidence of universal applicability."));
---

<Base title={`${title} — Official Use`} description={scope} locale={locale} type="article">
	<article class="use-record">
		<Breadcrumb crumbs={[{ label: "IP", href: localizedPath("/ip", locale) }, { label: "Official Use", href: localizedPath("/ip/official-use", locale) }, { label: title }]} />
		<p class="role">Official Use · Full record</p>
		<h1>{title}</h1>
		<p class="lead">{scope}</p>
		<DocumentRecordMeta locale={locale} contentType="Official Use" stage="application record" status={status} version={version} provenance={locale === "th" ? "บันทึกโดย Paritsea จากต้นแบบที่ Parit Ritchai พัฒนา ข้อมูลนี้ไม่ใช่ client case" : "Recorded by Paritsea from a prototype developed by Parit Ritchai. This is not a client case."} scope={scope} nonClaims={locale === "th" ? "ไม่สร้าง endorsement, certification หรือสิทธิ์ในการเปลี่ยน canonical source" : "Does not create endorsement, certification, or authority to alter the canonical source."} />
		{cmsEntry && Array.isArray(data.public_note) ? <div class="article-content"><PortableText value={data.public_note as never} /></div> : <div class="article-content"><h2>{locale === "th" ? "สถานะปัจจุบัน" : "Current state"}</h2><p>{locale === "th" ? "ระเบียนนี้ยังเป็น provisional งานที่เผยแพร่มีไว้เพื่อแสดงขอบเขตและที่มาของการทดลอง ไม่ใช่เพื่อกล่าวอ้างผลลัพธ์หรือชักชวนให้ซื้อบริการ" : "This record remains provisional. It is published to show the scope and provenance of the experiment, not to claim outcomes or invite a service purchase."}</p></div>}
	</article>
</Base>

<style>
	.use-record { width: min(var(--content-width), calc(100vw - 32px)); margin: 0 auto; padding: var(--spacing-8) 0 var(--spacing-24); }
	.role { margin-top: var(--spacing-14); font-family: var(--font-mono); font-size: var(--font-size-sm); color: var(--color-accent); }
	h1 { margin-top: var(--spacing-5); font-size: clamp(3rem, 8vw, 6rem); font-weight: 500; }
	.lead { margin-top: var(--spacing-6); font-family: var(--font-serif); font-size: var(--font-size-xl); line-height: 1.6; color: var(--color-text-secondary); }
	.article-content { font-size: var(--font-size-lg); line-height: 1.75; }
	.article-content h2 { margin: var(--spacing-10) 0 var(--spacing-4); }
	:global(:lang(th)) .role { font-family: var(--font-sans); font-size: var(--font-size-sm); letter-spacing: 0; }
	:global(:lang(th)) .lead, :global(:lang(th)) .article-content { font-family: var(--font-sans); font-size: 1.0625rem; line-height: 1.9; letter-spacing: 0; }
</style>
