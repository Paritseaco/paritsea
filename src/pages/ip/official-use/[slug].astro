---
import { getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../../../layouts/Base.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import DocumentRecordMeta from "../../../components/DocumentRecordMeta.astro";
import { getAstroLocale, localizedPath } from "../../../utils/i18n";
import { localizeRecordValue } from "../../../utils/intellectual-localization";

const locale = getAstroLocale(Astro);
const slug = Astro.params.slug ?? "";
let cmsEntry: Awaited<ReturnType<typeof getEmDashEntry<"official_uses">>>["entry"] = null;
try { const result = await getEmDashEntry("official_uses", slug); cmsEntry = result.entry; Astro.cache.set(result.cacheHint); } catch { cmsEntry = null; }
if (!cmsEntry) return new Response("Not found", { status: 404 });
const data = cmsEntry.data;
const title = data.title;
const status = localizeRecordValue(locale, data.use_status);
const version = localizeRecordValue(locale, data.implementation_version ?? "—");
const scope = locale === "th" && slug === "agensea"
	? "ต้นแบบที่สำรวจแนวคิดบางส่วนของ Paritsea ระเบียนนี้ไม่ใช่การรับรอง การสนับสนุน หรือหลักฐานว่าสามารถใช้ได้กับทุกบริบท"
	: data.scope_note ?? (locale === "th" ? "ระเบียนนี้ยังไม่มีคำอธิบายขอบเขตภาษาไทย" : "No public scope note is available for this record.");
---

<Base title={`${title} — Official Use`} description={scope} locale={locale} type="article">
	<article class="use-record">
		<Breadcrumb crumbs={[{ label: "IP", href: localizedPath("/ip", locale) }, { label: locale === "th" ? "ระเบียนการใช้ (Official Use)" : "Official Use", href: localizedPath("/ip/official-use", locale) }, { label: title }]} />
		<p class="role">{locale === "th" ? "ระเบียนการใช้ · ระเบียนฉบับเต็ม" : "Official Use · Full record"}</p>
		<h1>{title}</h1>
		<p class="lead">{scope}</p>
		<DocumentRecordMeta locale={locale} contentType="Official Use" stage="application record" status={status} version={version} provenance={locale === "th" ? "Paritsea บันทึกจากต้นแบบที่ฉันพัฒนาขึ้น ข้อมูลนี้ไม่ใช่กรณีศึกษาของลูกค้า" : "Recorded by Paritsea from a prototype developed by Parit Ritchai. This is not a client case."} scope={scope} nonClaims={locale === "th" ? "ระเบียนนี้ไม่ใช่การรับรอง ไม่ได้แปลว่าสนับสนุน และไม่ให้สิทธิ์เปลี่ยนงานต้นทาง" : "Does not create endorsement, certification, or authority to alter the canonical source."} />
		{locale === "th" && slug === "agensea"
			? <div class="article-content"><h2>สถานะปัจจุบัน</h2><p>AgenSea ถูกบันทึกในฐานะการสำรวจชั่วคราว การอยู่ในระเบียนนี้มีไว้เพื่อบอกความสัมพันธ์และขอบเขต ไม่ได้ทำให้การนำไปใช้นี้เป็นฉบับสมบูรณ์หรือเป็นต้นทาง canonical</p></div>
			: Array.isArray(data.public_note) ? <div class="article-content"><PortableText value={data.public_note} /></div> : <div class="article-content"><h2>{locale === "th" ? "สถานะปัจจุบัน" : "Current state"}</h2><p>{locale === "th" ? "ระเบียนนี้ยังเป็นสถานะชั่วคราว งานที่เผยแพร่มีไว้เพื่อแสดงขอบเขตและที่มาของการทดลอง ไม่ใช่เพื่อกล่าวอ้างผลลัพธ์หรือชักชวนให้ซื้อบริการ" : "This record remains provisional. It is published to show the scope and provenance of the experiment, not to claim outcomes or invite a service purchase."}</p></div>}
	</article>
</Base>

<style>
	.use-record { width: min(var(--content-width), calc(100vw - 32px)); margin: 0 auto; padding: var(--spacing-8) 0 var(--spacing-24); }
	.role { margin-top: var(--spacing-14); font-family: var(--font-mono); font-size: var(--font-size-sm); color: var(--color-accent); }
	h1 { margin-top: var(--spacing-5); font-size: clamp(2.5rem, 6vw, 4.75rem); font-weight: 500; }
	.lead { margin-top: var(--spacing-6); font-family: var(--font-serif); font-size: var(--font-size-xl); line-height: 1.6; color: var(--color-text-secondary); }
	.article-content { font-size: var(--font-size-lg); line-height: 1.75; }
	.article-content h2 { margin: var(--spacing-10) 0 var(--spacing-4); }
	:global(:lang(th)) .role { font-family: var(--font-sans); font-size: var(--font-size-sm); letter-spacing: 0; }
	:global(:lang(th)) .lead, :global(:lang(th)) .article-content { font-family: var(--font-sans); font-size: 1.0625rem; line-height: 1.9; letter-spacing: 0; }
	:global(:lang(th)) h1 { font-family: var(--font-sans); font-size: clamp(2.1rem, 6vw, 3.8rem); font-weight: 300; line-height: 1.48; letter-spacing: 0; word-break: keep-all; }
</style>
