---
import { getEmDashEntry, decodeSlug } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";
import { getAstroLocale, localizeEntry, localizedPath, ui } from "../utils/i18n";

const slug = decodeSlug(Astro.params.page_slug);
const locale = getAstroLocale(Astro);

if (!slug) {
	return Astro.redirect("/404");
}

// Only handle known page slugs — avoid conflicting with other routes
const KNOWN_PAGE_SLUGS = ["licensing", "contact", "about"];
if (!KNOWN_PAGE_SLUGS.includes(slug)) {
	return Astro.redirect("/404");
}

const isLicensingPage = slug === "licensing";
const isContactPage = slug === "contact";
const isAboutPage = slug === "about";

// About page content is fully hardcoded — skip CMS fetch
let rawPage = null;
let cacheHint = null;
if (!isAboutPage) {
	const result = await getEmDashEntry("pages", slug);
	rawPage = result.entry;
	cacheHint = result.cacheHint;
}

if (!isAboutPage && !rawPage) {
	return Astro.redirect("/404");
}

const page = rawPage ? localizeEntry(rawPage, "pages", locale) : null;

if (cacheHint) {
	Astro.cache.set(cacheHint);
}

const copy = ui[locale];

const aboutContent = locale === "th" ? {
	title: "เกี่ยวกับ Paritsea",
	eyebrow: "สายตานี้มาจากไหน",
	heroHeadline: "สายตานี้ไม่ได้มาจากการเรียน\nมันมาจากบางอย่างที่เกิดขึ้น\nที่ทำให้การมองข้ามสิ่งต่างๆ เป็นไปไม่ได้อีก",
	heroBody: "ไม่ใช่มุมมองที่เกิดจากทฤษฎีหรือการศึกษา สิ่งที่อยู่ที่นี่ก่อตัวขึ้นจากการผ่านชีวิตบางอย่าง — และจากสิ่งที่ตกผลึกออกมาในช่วงเวลาที่ตามมา",
	bioSection: {
		name: "ปาริศ ฤทธิ์ชัย",
		title: "ผู้สร้างแนวคิด Paritsea",
		body: "ตอนอายุใกล้ 30 ฉันอยู่ในจุดที่ดูเหมือนประสบความสำเร็จจากภายนอก\nอาชีพที่สร้างมาจนเป็นที่ยอมรับระดับโลก ความสัมพันธ์ที่ดูถูกต้องในทุกมุม เมืองที่คุ้นเคย\nแล้วสามสิ่งก็พังพร้อมกัน — ความสัมพันธ์ บริษัทที่รับผิดชอบ และเมืองที่ย้ายไปเพื่อทั้งสองอย่าง\nฉันแบกทุกอย่างไว้คนเดียว — นานกว่าที่จะไหว\n\nช่วงเวลาหลายเดือนหลังจากนั้นคือที่ที่สายตานี้ก่อตัวขึ้นจริงๆ\nไม่ใช่จากการศึกษา แต่จากการอยู่กับสิ่งที่เกิดขึ้น รวมถึงส่วนที่เจ็บปวดและเป็นของฉันด้วย\nสิ่งที่ชัดขึ้นไม่ใช่ insight แบบนามธรรม\nมันคือการมองเห็น — แบบที่ก่อตัวได้เมื่อการอ่านผิวเผินล้มเหลวซ้ำแล้วซ้ำเล่าจากข้างใน\n\nมีช่วงหนึ่งที่ฉันจำได้ — เพิ่งกลับมากรุงเทพโดยไม่มีอะไรเลย ไปพักกับรุ่นน้องคนหนึ่ง\nเขาทำน้ำแข็งไว้ให้เพราะสังเกตว่าฉันกินน้ำแข็งตลอด โดยไม่ต้องบอก\nฉันร้องไห้ สิ่งเล็กน้อยที่ไม่ต้องขอนั้นแสดงให้ฉันเห็นสิ่งที่ความสัมพันธ์ทั้งชีวิตไม่เคยมีให้\nการถูกมองเห็นมันไม่ยาก แค่มันไม่มีอยู่ที่นั่น\n\nต่อมา ในองค์กรแห่งหนึ่งที่ฉันเข้าไปช่วย\nฉันเจอรูปแบบเดิมในระดับโครงสร้าง — คนที่มองไม่เห็นในระบบที่พวกเขาทำงานอยู่\nระบบไม่สามารถตั้งชื่อสิ่งที่เกิดขึ้นกับพวกเขาได้\nฉันทำได้ ฉันตั้งชื่อมัน วางความจริงเอาไว้ แล้วก็ออกมา",
	},
	sections: [
		{
			title: "สิ่งที่ฉันพบซ้ำๆ",
			content: "คุณไม่สามารถมองโครงสร้างได้ชัดโดยไม่เห็นคนที่ขับเคลื่อนมัน และคุณไม่สามารถเข้าใจสิ่งที่คนกำลังทำโดยไม่เข้าใจน้ำหนักของโครงสร้างที่กำลังกดทับเขา มันคือปัญหาเดียวกัน\n\nฉันพบสิ่งนี้ครั้งแรกในระบบครอบครัวของตัวเอง โครงสร้างที่ผู้ใหญ่มีสิทธิ์ตัดสินซึ่งปิดปากเด็ก — และยังเป็นสิ่งที่ปกป้องมรดกจากพ่อแม่ที่คงเผาทิ้งไปแล้ว โครงสร้างเดิมมีทั้งความผิดพลาดและการปกป้องอยู่พร้อมกัน ไม่สามารถแก้สิ่งหนึ่งโดยไม่รื้ออีกสิ่งหนึ่ง บางครั้งไม่มีอะไรต้องแก้ บางครั้งสิ่งที่จำเป็นคือการมองเห็นทั้งสองด้านพร้อมกัน\n\nนี่คือเหตุผลที่ Paritsea อ่านทั้งสองอย่างพร้อมกัน ไม่ใช่ในฐานะวิธีการ แต่ในฐานะสิ่งที่ค้นพบ — เมื่อพยายามแยกพวกมันออกจากกัน คุณจะหยุดเห็นทั้งคู่อย่างชัดเจน",
		},
		{
			title: "สิ่งที่มองเห็น",
			content: "สิ่งที่ฉันพบซ้ำๆ ในหลายบริบท คือรูปแบบเดิม — สิ่งที่กำลังขับเคลื่อนสถานการณ์อยู่จริงๆ มองไม่เห็นสำหรับคนที่อยู่ข้างใน ไม่ใช่เพราะถูกซ่อนไว้โดยตั้งใจ แต่เพราะมันไม่เคยถูกยอมรับว่ามีอยู่จริง\n\nนั่นคือที่ที่สิ่งนี้เริ่มต้น — จากสิ่งที่ไม่เคยถูกตั้งชื่อ",
		},
		{
			title: "เปิดให้ใช้งานฟรี",
			content: "แนวคิดเหล่านี้มีไว้เพื่อใช้ เหตุผลที่เปิดเป็นเรื่องของโครงสร้าง — การเก็บ Paritsea ไว้นอกระบบแรงจูงใจของที่ปรึกษาที่รับเงินช่วยให้สายตายังคงซื่อสัตย์\n\nมีเงื่อนไขบางประการสำหรับการนำไปใช้เชิงพาณิชย์",
			linkText: "ดูเงื่อนไขการใช้งาน →",
			linkUrl: "/licensing",
		},
	],
	ctaLead: "เริ่มจากที่ Paritsea เริ่ม",
	ctaDoctrine: "อ่าน Framework",
	ctaMethod: "หรือสำรวจ Journal",
	ctaContact: "หรือถ้าอยากคุยกัน เขียนหาได้ที่ hello@paritsea.co",
	bio: "ติดตาม @paritsea บน YouTube, Instagram และ Threads",
} : {
	title: "About Paritsea",
	eyebrow: "Where this lens comes from",
	heroHeadline: "I didn't learn to see this way.\nSomething happened\nthat made looking past things impossible.",
	heroBody: "Not a perspective built from theory or study. What's here was formed from living through something — and from what crystallized in the time that followed.",
	bioSection: {
		name: "Parit Ritchai",
		title: "Creator of Paritsea",
		body: "At around 30, I had reached a point that looked like success from the outside.\nA career I'd built to global recognition, a relationship that looked right from every angle, a city I knew.\nThen three things broke at once: the relationship, the company I'd taken on, the city I'd moved to for both of them.\nI carried all of it alone — longer than was possible.\n\nThe months that followed were where this lens actually formed.\nNot from study. From staying with what had happened, including the parts that were ugly and mine.\nWhat became clear wasn't insight in the abstract.\nIt was sight — the kind that forms when surface readings fail repeatedly, from the inside.\n\nOne moment I carry: newly back in Bangkok with nothing, staying with a junior friend.\nHe had made ice ready because he'd noticed I always ate it.\nI cried. That small, unasked thing showed me what an entire relationship had never provided.\nBeing seen isn't complicated. It just wasn't there.\n\nLater, inside an organization I was brought in to help,\nI found the same pattern at a structural scale: people invisible to the system they worked in.\nThe system couldn't name what was happening to them.\nI could. I named it, placed what I saw, and left.",
	},
	sections: [
		{
			title: "What I kept finding",
			content: "You cannot see a structure clearly without seeing the humans driving it. And you cannot see what a human is doing without understanding the structural load they're carrying. They are the same problem.\n\nI found this first in my own family. A veto structure that silenced children — and also protected the inheritance their parents would have burned. The same structure held both wrong and protection simultaneously. You cannot fix one without dismantling the other. Sometimes neither needs fixing. Sometimes only seeing both dimensions at once is what's needed.\n\nThis is why Paritsea reads both. Not as a methodology. As a finding: when you try to separate them, you stop seeing either one clearly.",
		},
		{
			title: "What this sees",
			content: "What I kept finding, across contexts, was the same pattern: the thing actually driving a situation was invisible to the people inside it. Not hidden deliberately. Simply never acknowledged to exist.\n\nThat is where this starts — with what was never named.",
		},
		{
			title: "Open to use",
			content: "These ideas exist to be used. The reason they're open is structural: keeping Paritsea outside the incentive structures of paid advice keeps the lens honest.\n\nSome conditions apply for commercial use.",
			linkText: "View licensing terms →",
			linkUrl: "/licensing",
		},
	],
	ctaLead: "Start where Paritsea starts",
	ctaDoctrine: "Read Framework",
	ctaMethod: "Or Explore Journal",
	ctaContact: "Or write to us at hello@paritsea.co",
	bio: "Follow @paritsea on YouTube, Instagram and Threads",
};

const licensingSummary = locale === "th"
	? [
			"คุณสามารถอ่าน อ้างถึง สอน และดัดแปลง Paritsea แบบไม่ใช่เชิงพาณิชย์ได้เมื่อให้เครดิต",
			"การนำไปใช้เชิงพาณิชย์ certification หรือการบังคับใช้เป็นผลิตภัณฑ์ต้องได้รับอนุญาต",
			"การใช้ Paritsea ไม่ได้ทำให้เกิด endorsement, certification หรือสถานะ implementation อย่างเป็นทางการ",
		]
	: [
			"You may read, cite, teach, and non-commercially adapt Paritsea with attribution.",
			"Commercial implementation, certification, or productised enforcement requires permission.",
			"Using Paritsea does not create endorsement, certification, or official implementation status.",
		];

const licensingAllowed = locale === "th" ? [
	"อ้าง Paritsea ใน essay, lecture, strategy document และ research",
	"ใช้กรอบนี้ภายในบริษัท งาน domain practice หรือการตัดสินใจส่วนบุคคล",
	"อภิปราย สอน หรือแปลแนวคิดโดยให้เครดิตและลิงก์กลับมายัง Paritsea",
	"ดัดแปลงแนวคิดเพื่อการเรียนรู้ การวิเคราะห์ หรือการใช้งานภายในแบบไม่ใช่เชิงพาณิชย์",
] : [
	"Cite Paritsea in essays, lectures, strategy documents, and research.",
	"Use the framework internally in a company, domain practice, or personal decision-making.",
	"Discuss, teach, or translate the concepts with attribution and a link back to Paritsea.",
	"Adapt the concepts for non-commercial learning, analysis, or internal operational use.",
];

const licensingPermission = locale === "th" ? [
	"ฝัง Paritsea logic ลงในผลิตภัณฑ์ ซอฟต์แวร์ บริการ หรือระบบที่สร้างรายได้",
	"ให้บริการ audit, certification, trust mark, rating หรือ compliance โดยอ้างสิ่งที่สืบเนื่องจาก Paritsea",
	"ทำการตลาดระบบว่าเป็น official Paritsea implementation โดยไม่มีข้อตกลงแยก",
	"ใช้มาตรฐาน Paritsea เป็นชั้นบังคับใช้เชิงพาณิชย์ต่อสาธารณะโดยไม่ได้รับอนุญาต",
] : [
	"Embedding Paritsea logic into paid products, software, services, or revenue-generating systems.",
	"Offering audits, certifications, trust marks, ratings, or compliance services under Paritsea-derived claims.",
	"Marketing a system as an official Paritsea implementation without separate agreement.",
	"Using Paritsea standards as a public commercial enforcement layer without permission.",
];

const licensingForbiddenClaims = locale === "th" ? [
	"อ้าง certification, endorsement, partnership หรือ institutional affiliation โดยไม่มีอนุญาตชัดเจน",
	"นำเสนอ adaptation เป็น Framework โปรโตคอล มาตรฐาน หรือ implementation อย่างเป็นทางการของ Paritsea",
	"ใช้ชื่อ อัตลักษณ์ หรือแบรนด์ Paritsea เพื่อสื่อถึงอำนาจที่คุณไม่ได้รับ",
] : [
	"Claiming certification, endorsement, partnership, or institutional affiliation without explicit authorisation.",
	"Presenting an adaptation as official Paritsea Framework, protocol, standard, or implementation.",
	"Using the Paritsea name, identity, or branding to imply authority you have not been granted.",
];

const licensingFaq = locale === "th" ? [
	{
		question: "ฉันใช้ Paritsea ในบริษัทหรือชีวิตส่วนตัวได้ไหม",
		answer:
			"ได้ การใช้ภายใน การศึกษา การวิเคราะห์ และการดัดแปลงแบบไม่ใช่เชิงพาณิชย์ทำได้ ตราบเท่าที่ไม่สื่อว่าได้รับ endorsement หรือเป็น official implementation",
	},
	{
		question: "ฉันเขียน สอน หรือพูดต่อสาธารณะเกี่ยวกับ Paritsea ได้ไหม",
		answer: "ได้ การอ้างอิง อภิปราย สอน และ commentary ต่อสาธารณะทำได้เมื่อให้เครดิต",
	},
	{
		question: "ฉันสร้างผลิตภัณฑ์หรือบริการแบบเสียเงินจากกรอบนี้ได้ไหม",
		answer:
			"ไม่ได้หากไม่มีอนุญาต การนำไปใช้เชิงพาณิชย์ การบังคับใช้แบบเสียเงิน certification หรือ platformisation ต้องมีข้อตกลงแยก",
	},
	{
		question: "ถ้าฉันดัดแปลง จะทำให้ระบบของฉันเป็น official implementation ไหม",
		answer:
			"ไม่ใช่ การดัดแปลงหมายถึงคุณใช้กรอบนี้ในบริบทของคุณเอง สถานะ official implementation เป็นเรื่องแยกและต้องถูกบันทึกโดย Paritsea อย่างชัดเจน",
	},
	{
		question: "ฉันใช้ชื่อหรือแบรนด์ Paritsea บน material ของฉันได้ไหม",
		answer:
			"คุณอ้างชื่อ Paritsea เพื่อให้เครดิตได้ แต่ห้ามใช้ในลักษณะที่สื่อถึง endorsement, certification, partnership หรือสถานะ official",
	},
] : [
	{
		question: "Can I use Paritsea inside my company or in my own life?",
		answer:
			"Yes. Internal use, study, analysis, and non-commercial adaptation are allowed as long as you do not imply endorsement or official implementation status.",
	},
	{
		question: "Can I write, teach, or speak publicly about Paritsea?",
		answer:
			"Yes. Public reference, discussion, teaching, and commentary are allowed with attribution.",
	},
	{
		question: "Can I build a paid product or service from it?",
		answer:
			"Not without permission. Commercial implementation, paid enforcement, certification, or platformisation requires separate agreement.",
	},
	{
		question: "If I adapt it, does that make my system an official implementation?",
		answer:
			"No. Adaptation means you are using the framework in your own context. Official implementation status is separate and must be explicitly documented by Paritsea.",
	},
	{
		question: "Can I use the Paritsea name or branding on my materials?",
		answer:
			"You may reference Paritsea by name for attribution, but not in ways that imply endorsement, certification, partnership, or official status.",
	},
];

const contactSummary = locale === "th" ? [
	"ใช้อีเมลนี้สำหรับเรื่องสิทธิการใช้ การขออนุญาต คำถามเรื่อง implementation และ correspondence จริงจังเกี่ยวกับกรอบอ้างอิง",
	"ข้อความจะได้รับการพิจารณาอย่างรอบคอบ แต่การตอบกลับไม่รับประกันและขึ้นอยู่กับดุลยพินิจ",
	"โปรดอ้างหน้าที่เกี่ยวข้อง โปรโตคอล มาตรฐาน หรือ implementation เมื่อเขียนเข้ามา",
] : [
	"Use this address for licensing, permissions, implementation enquiries, and serious framework correspondence.",
	"Messages are reviewed carefully, but response is discretionary and not guaranteed.",
	"Reference the relevant page, protocol, standard, or implementation when writing in.",
];

const contactUseCases = locale === "th" ? [
	"คำถามเรื่อง commercial licensing หรือ implementation",
	"คำถามเรื่อง permission, attribution หรือ official use",
	"correspondence เชิงบรรณาธิการ สถาบัน หรือ research อย่างจริงจัง",
	"คำขอเกี่ยวกับ implementation ที่บันทึกไว้หรือการนำกรอบไปใช้",
] : [
	"Commercial licensing or implementation enquiries",
	"Questions about permissions, attribution, or official use",
	"Serious editorial, institutional, or research correspondence",
	"Requests related to documented implementations or framework adoption",
];

const contactNotFor = locale === "th" ? [
	"การโปรโมตทั่วไปหรือ mass marketing",
	"คำขอ endorsement, certification หรือ affiliation โดยไม่มีฐานมาก่อน",
	"support request ที่ไม่เกี่ยวกับกรอบ Paritsea หรือ implementation ที่เผยแพร่",
] : [
	"General promotional outreach or mass marketing",
	"Requests for endorsement, certification, or affiliation without prior basis",
	"Support requests unrelated to Paritsea's framework or published implementations",
];
---

<Base
	title={isAboutPage ? aboutContent.title : page!.data.title}
	locale={locale}
	content={isAboutPage ? undefined : { collection: "pages", id: page!.data.id, slug }}
>
	<article class="page-article">
		{!isAboutPage && (
			<header class="page-header">
				<h1 class="page-title">{page!.data.title}</h1>
			</header>
		)}

		{
			isLicensingPage ? (
				<>
					<section class="policy-callout">
