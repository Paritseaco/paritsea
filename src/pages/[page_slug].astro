---
import { getEmDashEntry, decodeSlug } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";
import { getAstroLocale, localizeEntry, localizedPath } from "../utils/i18n";

const slug = decodeSlug(Astro.params.page_slug);
const locale = getAstroLocale(Astro);

if (!slug) {
	return new Response(locale === "th" ? "ไม่พบหน้า" : "Not found", { status: 404 });
}

// Only handle known page slugs — avoid conflicting with other routes
const KNOWN_PAGE_SLUGS = ["licensing", "ip", "contact", "about"];
if (!KNOWN_PAGE_SLUGS.includes(slug)) {
	return new Response(locale === "th" ? "ไม่พบหน้า" : "Not found", { status: 404 });
}

if (slug === "ip") {
	return Astro.redirect(localizedPath("/ip", locale), 301);
}

const isLicensingPage = slug === "licensing";
const isContactPage = slug === "contact";
const isAboutPage = slug === "about";

// About page content is fully hardcoded — skip CMS fetch
let rawPage = null;
let cacheHint = null;
if (!isAboutPage) {
	const result = await getEmDashEntry("pages", slug);
	rawPage = result.entry;
	cacheHint = result.cacheHint;
}

if (!isAboutPage && !rawPage) {
	return new Response(locale === "th" ? "ไม่พบหน้า" : "Not found", { status: 404 });
}

const page = rawPage ? localizeEntry(rawPage, "pages", locale) : null;

if (cacheHint) {
	Astro.cache.set(cacheHint);
}

const aboutContent = locale === "th" ? {
	title: "เกี่ยวกับ Paritsea",
	eyebrow: "สายตานี้มาจากไหน",
	heroHeadline: "สายตานี้ไม่ได้มาจากการเรียน\nมันมาจากบางอย่างที่เกิดขึ้น\nที่ทำให้การมองข้ามสิ่งต่างๆ เป็นไปไม่ได้อีก",
	heroBody: "ไม่ใช่มุมมองที่เกิดจากทฤษฎีหรือการศึกษา สิ่งที่อยู่ที่นี่ก่อตัวขึ้นจากการผ่านสิ่งต่างๆ มา — และจากสิ่งที่ตกผลึกในช่วงเวลาที่ตามมา",
	bioSection: {
		name: "ปาริศ ฤทธิ์ชัย",
		title: "ผู้สร้างแนวคิด Paritsea",
		body: "สายตานี้เกิดจากการใช้ชีวิต ไม่ใช่การศึกษา มันเริ่มก่อตัวตอนที่การมองแบบผิวเผินใช้ไม่ได้อีกต่อไป\n\nมีช่วงหนึ่งที่ฉันพบว่า สิ่งที่ดูดีจากภายนอก กับสิ่งที่เกิดขึ้นจริงข้างใน ไม่ได้ตรงกัน การอยู่กับความไม่ตรงกันนั้นโดยไม่เบือนหนี — คือจุดเริ่มต้นของสิ่งที่เรียกว่า Paritsea ทุกวันนี้\n\nเมื่อเวลาผ่านไป รูปแบบเดิมปรากฏซ้ำในหลายบริบท ไม่ว่าจะในความสัมพันธ์ส่วนตัวหรือในองค์กร:\nสิ่งที่ขับเคลื่อนสถานการณ์จริงๆ มองไม่เห็นสำหรับคนที่อยู่ข้างใน\nไม่ใช่เพราะถูกซ่อน แต่เพราะไม่เคยถูกตั้งชื่อ\n\nParitsea เกิดขึ้นมาเพื่อตั้งชื่อสิ่งเหล่านั้น\n\nในองค์กรแห่งหนึ่งที่ฉันเข้าไปช่วย ฉันพบรูปแบบเดิมในระดับโครงสร้าง\nคนที่มองไม่เห็นในระบบที่พวกเขาทำงานอยู่ ระบบไม่สามารถตั้งชื่อสิ่งที่เกิดขึ้นกับพวกเขาได้\nฉันทำได้ ฉันตั้งชื่อมัน วางความจริงเอาไว้ แล้วก็ออกมา\n\nรูปแบบเดิมนี้เองที่พัฒนาไปเป็น Framework, Protocol และ Standard —\nไม่ใช่เพราะฉันอยากสร้างระบบอ้างอิง แต่เพราะสิ่งที่เห็นถูกบันทึกและถูกทำให้อ้างอิงได้\n\nโครงสร้างของ Paritsea — Lens, Journal, System และ IP / Official Use —\nสะท้อนวิธีที่ฉันมองและทำงานจริง: เห็นก่อน บันทึกก่อน ตั้งชื่อก่อน แล้วค่อยทำให้เป็นระบบ\nหลังจากนั้นจึงกำหนดเงื่อนไขการอ้างอิง ดัดแปลง และใช้อย่างเป็นทางการ",
	},
	sections: [
		{
			title: "ใครกำลังพูด และอะไรดำเนินต่อได้โดยไม่ขึ้นกับบุคคล",
			content: "Journal ใช้ first-person voice เพราะ observation และ judgment ต้องผูกกับผู้เขียนอย่างตรวจสอบได้ เมื่อแนวคิดถูกทำให้เป็น Framework, Protocol หรือ Standard ภาษาเปลี่ยนเป็น governed editorial voice: Parit Ritchai ยังเป็นผู้เขียนและผู้อนุมัติ semantic change ส่วน Paritsea รักษา version, provenance, scope และประวัติการเปลี่ยนแปลง\n\nโครงสร้างนี้รักษาลายเซ็นของผู้เขียนโดยไม่ทำให้งานกลายเป็น portfolio และทำให้ผู้อื่นอ่าน อ้างอิง หรือประยุกต์งานได้โดยไม่ต้องซื้อบริการจากตัวบุคคล",
			linkText: "ดูระเบียนผู้เขียน →",
			linkUrl: "/author/parit-ritchai",
		},
		{
			title: "วิธีที่ Paritsea อ่าน",
			content: "Paritsea อ่านคนและระบบไปพร้อมกัน เพราะสองสิ่งนี้แยกจากกันไม่ได้\n\nคุณไม่สามารถมองโครงสร้างได้ชัดโดยไม่เห็นคนที่ขับเคลื่อนมัน และคุณไม่สามารถเข้าใจสิ่งที่คนกำลังทำโดยไม่เข้าใจน้ำหนักของโครงสร้างที่กดทับเขา\n\nถ้าฉันต้องบอกว่าอะไรคือสิ่งที่พบซ้ำมากที่สุดในทุกบริบทที่ผ่านมา —\nนั่นคือ: สิ่งที่ขับเคลื่อนสถานการณ์จริงๆ มักมองไม่เห็นสำหรับคนที่อยู่ข้างใน\n\nครอบครัว องค์กร ความสัมพันธ์ ทุกที่มีสิ่งที่ไม่เคยถูกตั้งชื่อ\nพอไม่ถูกตั้งชื่อ มันก็ไม่ถูกแก้ ไม่ถูกพูดถึง ไม่ถูกมองเห็น\n\nParitsea ตั้งชื่อสิ่งเหล่านั้น\n\nเมื่อตั้งชื่อแล้ว อะไรจะเกิดตามมา — ไม่ว่าจะเป็นการเปลี่ยนแปลงหรือไม่ —\nเป็นเรื่องของผู้ที่ได้รับชื่อนั้น\nเพราะบางครั้งสิ่งที่จำเป็นไม่ใช่การแก้ไข แต่คือการที่บางสิ่งถูกมองเห็นในที่สุด",
		},
		{
			title: "จากบันทึกสู่ IP",
			content: "Paritsea ไม่ได้เริ่มจากความคิดที่ตกผลึกแล้ว มันเริ่มจาก Journal — การบันทึกสิ่งที่เห็นจากสถานการณ์จริงก่อน\n\nเมื่อรูปแบบบางอย่างปรากฏซ้ำพอ มันจึงถูกคัดไปเป็น Framework, Protocol หรือ Standard และในอนาคตอาจกลายเป็น IP ที่ผู้อื่นขอใช้ เช่าใช้ หรือได้รับอนุญาตอย่างเป็นทางการได้\n\nการอ้างอิง การศึกษา และการปรับใช้ภายในเปิดให้ทำได้ แต่การนำไปใช้เชิงพาณิชย์หรือกล่าวอ้างสถานะ official ต้องอยู่ภายใต้เงื่อนไขสิทธิการใช้",
			linkText: "ดูเงื่อนไขการใช้งาน →",
			linkUrl: "/ip/licensing",
		},
	],
	ctaLead: "เริ่มจากที่ Paritsea เริ่ม",
	ctaDoctrine: "อ่าน Framework",
	ctaMethod: "หรือสำรวจ Journal",
	ctaContact: "หรือถ้าอยากคุยกัน เขียนหาได้ที่ hello@paritsea.co",
	bio: "ติดตาม @paritsea บน YouTube, Instagram และ Threads",
} : {
	title: "About Paritsea",
	eyebrow: "Where this lens comes from",
	heroHeadline: "I didn't learn to see this way.\nSomething happened\nthat made looking past things impossible.",
	heroBody: "Not a perspective built from theory or study. What's here crystallised from going through things — and from what formed in the time that followed.",
	bioSection: {
		name: "Parit Ritchai",
		title: "Creator of Paritsea",
		body: "This lens came from living, not studying. It began forming when surface-level reading stopped working.\n\nAt one point, I found that what looked good from the outside and what was actually happening inside did not match. Staying with that mismatch without looking away — that was the beginning of what is now Paritsea.\n\nOver time, the same pattern appeared across different contexts: the thing actually driving a situation was invisible to the people inside it.\nNot because it was hidden. Because it was never named.\n\nParitsea exists to name those things.\n\nInside an organization I was brought in to help, I found the same pattern at a structural scale. People invisible to the system they worked in. The system couldn't name what was happening to them. I could. I named it, placed what I saw, and left.\n\nThat pattern became Framework, Protocol, and Standard —\nnot because I set out to build a reference system, but because what was seen got recorded and made referencable.\n\nThe structure of Paritsea — Lens, Journal, System, and IP / Official Use —\nreflects how I actually see and work: observe first, record first, name first, then structure.\nAfter that, define the terms for citation, adaptation, and official use.",
	},
	sections: [
		{
			title: "Who is speaking, and what can continue beyond the person",
			content: "Journal uses first person because observation and judgement must remain attributable. When a work becomes a Framework, Protocol, or Standard, its voice becomes governed and editorial: Parit Ritchai remains the author and approves semantic change, while Paritsea preserves version, provenance, scope, and history.\n\nThis keeps the author's signature visible without turning the work into a portfolio. It also lets other people read, cite, and apply the work without purchasing a personal service.",
			linkText: "View the author record →",
			linkUrl: "/author/parit-ritchai",
		},
		{
			title: "How Paritsea reads",
			content: "Paritsea reads people and systems together because they cannot be separated.\n\nYou cannot see a structure clearly without seeing the humans driving it. And you cannot understand what a human is doing without understanding the weight of the structure on them.\n\nIf I had to name what I have found most consistently across every context I've been in:\nit is that the thing driving a situation is invisible to the people inside it.\n\nFamilies, organisations, relationships — every setting has things that were never named.\nUnnamed, they remain unaddressed, unspoken, unseen.\n\nParitsea names them.\n\nWhat happens after — whether change follows or not — belongs to whoever received the name.\nBecause sometimes what is needed is not a fix. It is that something is finally seen.",
		},
		{
			title: "From record to IP",
			content: "Paritsea does not begin with crystallized ideas. It begins in Journal — the act of recording what is seen in real situations first.\n\nWhen a pattern repeats with enough structure, it can be selected into Framework, Protocol, or Standard. Over time, some of this may become IP that others can request, license, or use officially.\n\nReference, study, and internal adaptation are open. Commercial use or claims of official status follow the licensing policy.",
			linkText: "View licensing terms →",
			linkUrl: "/ip/licensing",
		},
	],
	ctaLead: "Start where Paritsea starts",
	ctaDoctrine: "Read Framework",
	ctaMethod: "Or Explore Journal",
	ctaContact: "Or write to us at hello@paritsea.co",
	bio: "Follow @paritsea on YouTube, Instagram and Threads",
};

const licensingSummary = locale === "th"
	? [
			"คุณสามารถอ่าน อ้างถึง สอน และดัดแปลง Paritsea แบบไม่ใช่เชิงพาณิชย์ได้เมื่อให้เครดิต",
			"การนำไปใช้เชิงพาณิชย์ certification หรือการบังคับใช้เป็นผลิตภัณฑ์ต้องได้รับอนุญาต",
			"การใช้ Paritsea ไม่ได้ทำให้เกิด endorsement, certification หรือสถานะ implementation อย่างเป็นทางการ",
		]
	: [
			"You may read, cite, teach, and non-commercially adapt Paritsea with attribution.",
			"Commercial implementation, certification, or productised enforcement requires permission.",
			"Using Paritsea does not create endorsement, certification, or official implementation status.",
		];

const licensingAllowed = locale === "th" ? [
	"อ้าง Paritsea ใน essay, lecture, strategy document และ research",
	"ใช้กรอบนี้ภายในบริษัท งาน domain practice หรือการตัดสินใจส่วนบุคคล",
	"อภิปราย สอน หรือแปลแนวคิดโดยให้เครดิตและลิงก์กลับมายัง Paritsea",
	"ดัดแปลงแนวคิดเพื่อการเรียนรู้ การวิเคราะห์ หรือการใช้งานภายในแบบไม่ใช่เชิงพาณิชย์",
] : [
	"Cite Paritsea in essays, lectures, strategy documents, and research.",
	"Use the framework internally in a company, domain practice, or personal decision-making.",
	"Discuss, teach, or translate the concepts with attribution and a link back to Paritsea.",
	"Adapt the concepts for non-commercial learning, analysis, or internal operational use.",
];

const licensingPermission = locale === "th" ? [
	"ฝัง Paritsea logic ลงในผลิตภัณฑ์ ซอฟต์แวร์ บริการ หรือระบบที่สร้างรายได้",
	"ให้บริการ audit, certification, trust mark, rating หรือ compliance โดยอ้างสิ่งที่สืบเนื่องจาก Paritsea",
	"ทำการตลาดระบบว่าเป็น official Paritsea implementation โดยไม่มีข้อตกลงแยก",
	"ใช้มาตรฐาน Paritsea เป็นชั้นบังคับใช้เชิงพาณิชย์ต่อสาธารณะโดยไม่ได้รับอนุญาต",
] : [
	"Embedding Paritsea logic into paid products, software, services, or revenue-generating systems.",
	"Offering audits, certifications, trust marks, ratings, or compliance services under Paritsea-derived claims.",
	"Marketing a system as an official Paritsea implementation without separate agreement.",
	"Using Paritsea standards as a public commercial enforcement layer without permission.",
];

const licensingForbiddenClaims = locale === "th" ? [
	"อ้าง certification, endorsement, partnership หรือ institutional affiliation โดยไม่มีอนุญาตชัดเจน",
	"นำเสนอ adaptation เป็น Framework โปรโตคอล มาตรฐาน หรือ implementation อย่างเป็นทางการของ Paritsea",
	"ใช้ชื่อ อัตลักษณ์ หรือแบรนด์ Paritsea เพื่อสื่อถึงอำนาจที่คุณไม่ได้รับ",
] : [
	"Claiming certification, endorsement, partnership, or institutional affiliation without explicit authorisation.",
	"Presenting an adaptation as official Paritsea Framework, protocol, standard, or implementation.",
	"Using the Paritsea name, identity, or branding to imply authority you have not been granted.",
];

const licensingUsePath = locale === "th" ? [
	{
		name: "Cite",
		body: "อ้างถึง Paritsea พร้อมเครดิตและลิงก์กลับมายังหน้าต้นทาง ใช้ได้กับบทความ lecture research และเอกสารภายใน",
	},
	{
		name: "Adapt",
		body: "ดัดแปลงแนวคิดเพื่อการเรียนรู้ การวิเคราะห์ หรือบริบทภายในได้ แต่ต้องไม่นำเสนอว่าเป็น Paritsea official text",
	},
	{
		name: "Internal use",
		body: "ใช้เป็นกรอบคิดภายในชีวิต งาน ทีม หรือองค์กรได้โดยไม่ต้องขออนุญาต ตราบเท่าที่ไม่เกิดรายได้จากการบังคับใช้หรือ certification",
	},
	{
		name: "Commercial licensing",
		body: "การฝัง logic ของ Paritsea ในผลิตภัณฑ์ บริการ ซอฟต์แวร์ audit หรือระบบที่สร้างรายได้ ต้องได้รับอนุญาตแยก",
	},
	{
		name: "Official implementation",
		body: "สถานะ official เกิดขึ้นเฉพาะเมื่อ Paritsea บันทึกหรือยอมรับอย่างชัดเจน การใช้งานทั่วไปไม่ทำให้เกิด endorsement",
	},
] : [
	{
		name: "Cite",
		body: "Reference Paritsea with attribution and a link to the source page. Suitable for essays, lectures, research, and internal documents.",
	},
	{
		name: "Adapt",
		body: "Adapt concepts for learning, analysis, or internal contexts, but do not present the adaptation as official Paritsea text.",
	},
	{
		name: "Internal use",
		body: "Use Paritsea as a thinking framework in life, work, teams, or organizations without permission, as long as it is not monetized enforcement or certification.",
	},
	{
		name: "Commercial licensing",
		body: "Embedding Paritsea logic into products, services, software, audits, or revenue-generating systems requires separate permission.",
	},
	{
		name: "Official implementation",
		body: "Official status exists only when Paritsea explicitly records or recognizes the implementation. Ordinary use does not create endorsement.",
