---
import { getEmDashEntry, decodeSlug } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";
import { getAstroLocale, localizeEntry, localizedPath, ui } from "../utils/i18n";

const slug = decodeSlug(Astro.params.page_slug);
const locale = getAstroLocale(Astro);

if (!slug) {
	return Astro.redirect("/404");
}

// Only handle known page slugs — avoid conflicting with other routes
const KNOWN_PAGE_SLUGS = ["licensing", "contact", "about"];
if (!KNOWN_PAGE_SLUGS.includes(slug)) {
	return Astro.redirect("/404");
}

const isLicensingPage = slug === "licensing";
const isContactPage = slug === "contact";
const isAboutPage = slug === "about";

// About page content is fully hardcoded — skip CMS fetch
let rawPage = null;
let cacheHint = null;
if (!isAboutPage) {
	const result = await getEmDashEntry("pages", slug);
	rawPage = result.entry;
	cacheHint = result.cacheHint;
}

if (!isAboutPage && !rawPage) {
	return Astro.redirect("/404");
}

const page = rawPage ? localizeEntry(rawPage, "pages", locale) : null;

if (cacheHint) {
	Astro.cache.set(cacheHint);
}

const copy = ui[locale];

const aboutContent = locale === "th" ? {
	title: "เกี่ยวกับ Paritsea",
	eyebrow: "เบื้องหลังวิธีคิด",
	heroHeadline: "วิธีคิดที่เข้าใจทั้ง \"ความซับซ้อนของโลก\"\nและความรู้สึกของคน\nไม่ได้เกิดจากทฤษฎี แต่เกิดจากชีวิตจริง",
	heroBody: "Paritsea คือวิธีคิดที่อ่านคนและระบบไปพร้อมกัน\nเกิดจากประสบการณ์จริงข้ามธุรกิจ องค์กร และความสัมพันธ์ของมนุษย์\nไม่ใช่ abstract แต่เป็นวิธีที่ถอดโครงสร้างความซับซ้อนให้เห็นทั้งคน ระบบ และแรงตึงที่ซ่อนอยู่ โดยไม่ละสายตาจากมนุษย์ที่อยู่ข้างใน",
	sections: [
		{
			title: "คำถามที่เริ่มต้นทุกอย่าง",
			content: "Paritsea เริ่มจากคำถามเดิมที่วนเวียนอยู่ในการทำงานกับคนหลายบทบาท\nไม่ว่าจะเป็นองค์กร ทีม ความสัมพันธ์ หรือชีวิตส่วนตัว\n\nจากคนที่แบกทั้งองค์กรไว้บนบ่าโดยไม่มีใครเห็น\nไปจนถึงคนที่เก่งที่สุดในทีมแต่กำลังจะหมดไฟโดยที่ระบบไม่สนใจ\n\nจากองค์กรที่ strategy ดูดีแต่ทุกคนรู้ว่ามันใช้ไม่ได้จริง\nไปจนถึงความสัมพันธ์ที่พัง — ไม่ใช่เพราะใครเลว\nแต่เพราะไม่มีใครเข้าใจว่าอะไรเกิดขึ้นจริง\n\nจากคนที่เริ่มต้นใหม่แล้วกลัวซ้ำรอยเดิม\nไปจนถึงคนที่ประสบความสำเร็จแต่ไม่เข้าใจว่าทำไมยังว่างเปล่า\n\nคำถามเดิมที่กลับมาทุกครั้งคือ:\n\"ทำไมระบบถึงออกแบบมาเพื่อให้คนรับผิดชอบผลลัพธ์ แต่ไม่เคยรับผิดชอบมนุษย์ที่อยู่ข้างใน?\"\n\nParitsea คือความพยายามที่จะตอบคำถามนี้\nไม่ใช่ด้วยทฤษฎีใหม่ แต่ด้วยภาษาที่ทำให้สิ่งที่มองไม่เห็นถูกตั้งชื่อได้",
		},
		{
			title: "ชีวิต งาน ความสัมพันธ์ และการเติบโต ไม่เคยแยกจากกัน",
			content: "สิ่งที่ไม่คาดคิดที่สุดในการสร้าง Paritsea คือการค้นพบว่า\nปัญหาในชีวิต งาน ความสัมพันธ์ และการเติบโต มีโครงสร้างเดียวกัน\n\nผู้นำที่ไม่ไว้ใจให้ใครตัดสินใจแทน\nคู่รักที่กลัวการเปิดใจเพราะเคยถูกทำร้าย\nคนที่เริ่มต้นใหม่แล้วกลัวซ้ำรอยเดิม\nและระบบที่ออกแบบมาให้พึ่งพามนุษย์คนเดียว\nคือปรากฏการณ์เดียวกัน แค่อยู่คนละ domain\n\nเมื่อเห็นแบบนี้แล้ว การแยก \"เรื่องงาน\" ออกจาก \"เรื่องชีวิต\"\nหรือแยก \"ระบบ\" ออกจาก \"มนุษย์\" จึงเป็นสิ่งที่ทำไม่ได้อีกต่อไป\n\nParitsea ไม่ได้แค่เชื่อมมิติเหล่านี้เข้าด้วยกัน\nแต่มันเปิดให้เห็นว่าทุกอย่างเชื่อมกันมาตลอด\nแค่เราไม่เคยมองเห็น",
		},
		{
			title: "คนที่มองเห็นก่อนใคร",
			content: "Paritsea เกิดจาก Parit Ritchai คนเดียว\nไม่ใช่ collective ไม่ใช่ community project\nเป็นระบบความคิดที่เกิดจากคนคนเดียวที่ใช้เวลาหลายปี\nในการสังเกต สัมผัส และเชื่อมโยงสิ่งที่คนส่วนใหญ่มองข้าม\n\nเขาไม่ได้มองว่าตัวเองเป็น guru หรือ thought leader\nแต่มองว่าสิ่งที่ทำคือการ \"ตั้งชื่อ\" ให้กับสิ่งที่คนรู้สึกแต่พูดไม่ออก\n\nทำไมคนเก่งที่สุดในทีมถึงหมดไฟ\nทำไมองค์กรที่ดูดีจากข้างนอกถึงรู้สึกผิดจากข้างใน\nทำไมความสัมพันธ์ที่ดีถึงยังมีบางอย่างขาดอยู่\n\nคำถามเหล่านี้ไม่ได้มาจากห้องเรียน\nแต่มาจากห้องประชุม จากบทสนทนา จากความสัมพันธ์จริง\nที่เห็นว่า \"ระบบ\" กับ \"คน\" ไม่เคยแยกจากกัน\nแค่เราไม่เคยมีภาษาที่ชัดพอจะพูดเรื่องนี้ได้ตรง ๆ\n\nParitsea คือภาษานั้น\nสร้างขึ้นมาเพื่อให้สิ่งที่มองไม่เห็น ถูกตั้งชื่อได้\nและสิ่งที่ถูกตั้งชื่อแล้ว ถูกจัดการได้อย่างแท้จริง",
		},
		{
			title: "Paritsea ทำอะไรให้คุณ",
			content: "Paritsea เปิดให้ทุกคนเข้าถึงได้\nเพราะความเชื่อว่าวิธีคิดที่แข็งแรงที่สุดคือวิธีคิดที่ถูกทดสอบในที่แจ้ง\n\nคุณไม่จำเป็นต้องเป็น CEO นักจิตวิทยา หรือนักปรัชญา\nเพื่อใช้ Paritsea คุณแค่ต้องการ\n— ความตั้งใจที่จะมองสิ่งที่คนส่วนใหญ่มองข้าม\n— ความกล้าที่จะตั้งคำถามกับสิ่งที่ถูกทำให้เป็นปกติ\n— และพื้นที่ในการสังเกต โดยไม่ต้องรีบตัดสิน",
		},
