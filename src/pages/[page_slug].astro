const licensingFaq = locale === "th" ? [
	{
		question: "ฉันใช้ Paritsea ในบริษัทหรือชีวิตส่วนตัวได้ไหม",
		answer:
			"ได้ การใช้ภายใน การศึกษา การวิเคราะห์ และการดัดแปลงแบบไม่ใช่เชิงพาณิชย์ทำได้ ตราบเท่าที่ไม่สื่อว่าได้รับ endorsement หรือเป็น official implementation",
	},
	{
		question: "ฉันเขียน สอน หรือพูดต่อสาธารณะเกี่ยวกับ Paritsea ได้ไหม",
		answer: "ได้ การอ้างอิง อภิปราย สอน และ commentary ต่อสาธารณะทำได้เมื่อให้เครดิต",
	},
	{
		question: "ฉันสร้างผลิตภัณฑ์หรือบริการแบบเสียเงินจากกรอบนี้ได้ไหม",
		answer:
			"ไม่ได้หากไม่มีอนุญาต การนำไปใช้เชิงพาณิชย์ การบังคับใช้แบบเสียเงิน certification หรือ platformisation ต้องมีข้อตกลงแยก",
	},
	{
		question: "ถ้าฉันดัดแปลง จะทำให้ระบบของฉันเป็น official implementation ไหม",
		answer:
			"ไม่ใช่ การดัดแปลงหมายถึงคุณใช้กรอบนี้ในบริบทของคุณเอง สถานะ official implementation เป็นเรื่องแยกและต้องถูกบันทึกโดย Paritsea อย่างชัดเจน",
	},
	{
		question: "ฉันใช้ชื่อหรือแบรนด์ Paritsea บน material ของฉันได้ไหม",
		answer:
			"คุณอ้างชื่อ Paritsea เพื่อให้เครดิตได้ แต่ห้ามใช้ในลักษณะที่สื่อถึง endorsement, certification, partnership หรือสถานะ official",
	},
] : [
	{
		question: "Can I use Paritsea inside my company or in my own life?",
		answer:
			"Yes. Internal use, study, analysis, and non-commercial adaptation are allowed as long as you do not imply endorsement or official implementation status.",
	},
	{
		question: "Can I write, teach, or speak publicly about Paritsea?",
		answer:
			"Yes. Public reference, discussion, teaching, and commentary are allowed with attribution.",
	},
	{
		question: "Can I build a paid product or service from it?",
		answer:
			"Not without permission. Commercial implementation, paid enforcement, certification, or platformisation requires separate agreement.",
	},
	{
		question: "If I adapt it, does that make my system an official implementation?",
		answer:
			"No. Adaptation means you are using the framework in your own context. Official implementation status is separate and must be explicitly documented by Paritsea.",
	},
	{
		question: "Can I use the Paritsea name or branding on my materials?",
		answer:
			"You may reference Paritsea by name for attribution, but not in ways that imply endorsement, certification, partnership, or official status.",
	},
];

const contactSummary = locale === "th" ? [
	"ใช้อีเมลนี้สำหรับเรื่องสิทธิการใช้ การขออนุญาต คำถามเรื่อง implementation และ correspondence จริงจังเกี่ยวกับกรอบอ้างอิง",
	"ข้อความจะได้รับการพิจารณาอย่างรอบคอบ แต่การตอบกลับไม่รับประกันและขึ้นอยู่กับดุลยพินิจ",
	"โปรดอ้างหน้าที่เกี่ยวข้อง โปรโตคอล มาตรฐาน หรือ implementation เมื่อเขียนเข้ามา",
] : [
	"Use this address for licensing, permissions, implementation enquiries, and serious framework correspondence.",
	"Messages are reviewed carefully, but response is discretionary and not guaranteed.",
	"Reference the relevant page, protocol, standard, or implementation when writing in.",
];

const contactUseCases = locale === "th" ? [
	"คำถามเรื่อง commercial licensing หรือ implementation",
	"คำถามเรื่อง permission, attribution หรือ official use",
	"correspondence เชิงบรรณาธิการ สถาบัน หรือ research อย่างจริงจัง",
	"คำขอเกี่ยวกับ implementation ที่บันทึกไว้หรือการนำกรอบไปใช้",
] : [
	"Commercial licensing or implementation enquiries",
	"Questions about permissions, attribution, or official use",
	"Serious editorial, institutional, or research correspondence",
	"Requests related to documented implementations or framework adoption",
];

const contactNotFor = locale === "th" ? [
	"การโปรโมตทั่วไปหรือ mass marketing",
	"คำขอ endorsement, certification หรือ affiliation โดยไม่มีฐานมาก่อน",
	"support request ที่ไม่เกี่ยวกับกรอบ Paritsea หรือ implementation ที่เผยแพร่",
] : [
	"General promotional outreach or mass marketing",
	"Requests for endorsement, certification, or affiliation without prior basis",
	"Support requests unrelated to Paritsea's framework or published implementations",
];

const pageDescription = isAboutPage
	? locale === "th"
		? "ที่มาของ Paritsea วิธีที่กรอบนี้อ่านคนและระบบ และเหตุผลที่แนวคิดเปิดให้อ้างอิงโดยไม่กลายเป็นเว็บไซต์บริการ"
		: "The origin of Paritsea, how it reads people and systems together, and why the reference layer remains open without becoming a service site."
	: isLicensingPage
		? locale === "th"
			? "นโยบายการอ้างอิง การดัดแปลง สิทธิการใช้เชิงพาณิชย์ และสถานะ official implementation ของ Paritsea"
			: "Paritsea policy for citation, adaptation, commercial use, and official implementation status."
		: isContactPage
			? locale === "th"
				? "ช่องทางติดต่อ Paritsea สำหรับสิทธิการใช้ การอ้างอิง implementation และ correspondence จริงจังเกี่ยวกับกรอบอ้างอิง"
				: "Contact Paritsea about licensing, reference use, implementation status, and serious framework correspondence."
			: null;
---

<Base
	title={isAboutPage ? aboutContent.title : page!.data.title}
	description={pageDescription}
	locale={locale}
	content={isAboutPage ? undefined : { collection: "pages", id: page!.data.id, slug }}
>
	<article class="page-article">
		{!isAboutPage && (
			<header class="page-header">
				<h1 class="page-title">{page!.data.title}</h1>
			</header>
		)}

		{
			isLicensingPage ? (
				<>
					<section class="policy-callout">
						<p class="policy-eyebrow">{locale === "th" ? "สรุปภาษาตรง" : "Plain-language summary"}</p>
						<h2 class="policy-callout-title">{locale === "th" ? "Paritsea เปิดให้อ้างอิงและดัดแปลงได้ แต่ไม่เปิดให้ทำ certification, endorsement หรือ enforcement เชิงพาณิชย์โดยไม่ได้รับอนุญาต" : "Paritsea is open for reference and adaptation, but not for unauthorised certification, endorsement, or commercial enforcement."}</h2>
						<ul class="policy-summary-list">
							{licensingSummary.map((item) => (
								<li>{item}</li>
							))}
						</ul>
					</section>

					<div class="page-content policy-content">
						<section class="policy-section">
							<h2>{locale === "th" ? "สิ่งที่คุณทำได้" : "What You May Do"}</h2>
							<ul>
								{licensingAllowed.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</section>

						<section class="policy-section">
							<h2>{locale === "th" ? "สิ่งที่ต้องขออนุญาต" : "What Requires Permission"}</h2>
							<ul>
								{licensingPermission.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</section>

						<section class="policy-section">
							<h2>{locale === "th" ? "สิ่งที่ห้ามกล่าวอ้าง" : "What You Must Not Claim"}</h2>
							<ul>
								{licensingForbiddenClaims.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</section>

						<section class="policy-section">
							<h2>{locale === "th" ? "ตัวอย่างการให้เครดิต" : "Attribution Example"}</h2>
							<p>{locale === "th" ? "รูปแบบสั้นที่แนะนำ:" : "Recommended short form:"}</p>
							<p class="policy-quote">Based on Paritsea by Parit Ritchai, <a href="https://paritsea.co">paritsea.co</a>.</p>
							<p>{locale === "th" ? "รูปแบบยาวที่แนะนำ:" : "Recommended extended form:"}</p>
							<p class="policy-quote">Adapted from Paritsea, a public reference framework by Parit Ritchai, available at <a href="https://paritsea.co">paritsea.co</a>.</p>
						</section>

						<section class="policy-section">
							<h2>{locale === "th" ? "Adaptation กับ Official Implementation" : "Adaptation vs Official Implementation"}</h2>
							<p><strong>Adaptation</strong> {locale === "th" ? "หมายถึงการใช้แนวคิด Paritsea ในบริบท องค์กร โดเมน หรือชีวิตของคุณเอง ซึ่งอนุญาตภายใต้เงื่อนไขสิทธิการใช้" : "means you are using Paritsea concepts in your own context, organisation, domain, or life. This is allowed within the licensing terms."}</p>
							<p><strong>Official Implementation</strong> {locale === "th" ? "หมายถึงระบบที่ถูกบันทึกหรือยอมรับโดย Paritsea อย่างชัดเจนว่าเป็น implementation ของกรอบนี้ การดัดแปลงเพียงอย่างเดียวไม่ทำให้เกิดสถานะ official" : "means a system has been explicitly documented or recognised by Paritsea as an implementation of the framework. Adaptation alone does not create official status."}</p>
						</section>

						<section class="policy-section policy-section--full">
							<h2>{locale === "th" ? "เส้นทางการใช้อย่างถูกต้อง" : "Use Path"}</h2>
							<p class="policy-faq-intro">{locale === "th" ? "Paritsea เปิดให้แนวคิดเดินทางได้ แต่แต่ละระดับมีขอบเขตต่างกัน" : "Paritsea lets ideas travel, but each level has a different boundary."}</p>
							<div class="policy-path-grid">
								{licensingUsePath.map((item) => (
									<div class="policy-path-item">
										<h3>{item.name}</h3>
										<p>{item.body}</p>
									</div>
								))}
							</div>
						</section>

						<section class="policy-section policy-section--full policy-seocean">
							<h2>{locale === "th" ? "ความสัมพันธ์กับ SE Ocean" : "Relationship to SE Ocean"}</h2>
							<p>{locale === "th" ? "Paritsea เป็นพื้นที่กำเนิดและรักษางานความคิดต้นทาง ส่วน SE Ocean อาจตีความและนำงานบางส่วนไปใช้กับบริบทองค์กรอย่างรับผิดชอบ" : "Paritsea originates and preserves the intellectual source. SE Ocean may interpret and apply selected work in accountable organizational contexts."}</p>
							<p>{locale === "th" ? "การนำไปใช้ไม่ได้เปลี่ยนเจ้าของหรือผู้กำกับต้นทาง และ SE Ocean ไม่มีสิทธิ์เปลี่ยน canonical version โดยอัตโนมัติ" : "Application does not transfer ownership or stewardship of the source, and SE Ocean does not gain authority to alter a canonical version automatically."}</p>
							<a href="https://seocean.co.th" target="_blank" rel="noreferrer">{locale === "th" ? "ดูบริบทการประยุกต์ใช้ที่ SE Ocean →" : "See applied contexts at SE Ocean →"}</a>
						</section>

						<section class="policy-section">
							<h2>{locale === "th" ? "การใช้ชื่อและแบรนด์" : "Brand and Name Use"}</h2>
							<p>{locale === "th" ? "คุณสามารถอ้างชื่อ Paritsea เพื่อให้เครดิตและอภิปรายได้ แต่ห้ามใช้ชื่อ อัตลักษณ์ หรือแบรนด์ Paritsea เพื่อสื่อถึง partnership, certification, endorsement หรืออำนาจทางการโดยไม่ได้รับอนุญาต" : "You may reference the Paritsea name for attribution and discussion. You may not use the Paritsea name, identity, or branding to imply partnership, certification, endorsement, or formal authority without permission."}</p>
						</section>

						<section class="policy-section">
							<h2>{locale === "th" ? "คำถามที่พบบ่อย" : "Frequently Asked Questions"}</h2>
							<p class="policy-faq-intro">{locale === "th" ? "คำถามทั่วไปเกี่ยวกับการอ้างอิง การดัดแปลง และการนำ Paritsea ไปใช้" : "Common questions about referencing, adapting, and implementing Paritsea."}</p>
							<div class="policy-faq" role="list">
								{licensingFaq.map((item) => (
									<details class="policy-faq-item" role="listitem">
										<summary class="policy-faq-question">{item.question}</summary>
										<div class="policy-faq-answer">
											<p>{item.answer}</p>
										</div>
									</details>
								))}
							</div>
						</section>

						<section class="policy-section policy-section--full">
							<h2>{locale === "th" ? "นโยบายอย่างเป็นทางการ" : "Formal Policy"}</h2>
							<PortableText value={page!.data.content} />
						</section>
					</div>
				</>
			) : isContactPage ? (
				<>
					<section class="policy-callout">
						<p class="policy-eyebrow">{locale === "th" ? "การติดต่อ" : "Correspondence"}</p>
						<h2 class="policy-callout-title">{locale === "th" ? "Paritsea เปิดรับการติดต่ออย่างจริงจังเกี่ยวกับสิทธิการใช้ implementation และการใช้กรอบนี้ต่อสาธารณะ" : "Paritsea welcomes serious correspondence about licensing, implementation, and the public use of the framework."}</h2>
						<ul class="policy-summary-list">
							{contactSummary.map((item) => (
								<li>{item}</li>
							))}
						</ul>
					</section>

					<div class="page-content policy-content">
						<section class="policy-section">
							<h2>{locale === "th" ? "ช่องทางหลัก" : "Primary Contact"}</h2>
							<p class="policy-quote"><a href="mailto:hello@paritsea.co">hello@paritsea.co</a></p>
							<p>{locale === "th" ? "โปรดใส่บริบท ลิงก์ และชั้นของกรอบอ้างอิงที่เกี่ยวข้องเมื่อเป็นไปได้ เพื่อให้ประเมินคำถามได้แม่นยำ" : "Include context, links, and the relevant framework layer where possible so the enquiry can be assessed accurately."}</p>
						</section>

						<section class="policy-section">
							<h2>{locale === "th" ? "เหมาะสำหรับ" : "Best Used For"}</h2>
							<ul>
								{contactUseCases.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</section>

						<section class="policy-section">
							<h2>{locale === "th" ? "ไม่เหมาะสำหรับ" : "Not Intended For"}</h2>
							<ul>
								{contactNotFor.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</section>

						<section class="policy-section">
							<h2>{locale === "th" ? "ก่อนเขียนถึงเรา" : "Before You Write"}</h2>
							<p>{locale === "th" ? "หากคำถามของคุณเกี่ยวกับการอ้างอิง การดัดแปลง การให้เครดิต หรือสถานะ Official Use โปรดอ่าน " : "If your question is about reference, adaptation, attribution, or Official Use status, please review the "}<a href={localizedPath("/ip/licensing", locale)}>{locale === "th" ? "นโยบายสิทธิการใช้" : "licensing and use policy"}</a>{locale === "th" ? " ก่อน คำถามทั่วไปจำนวนมากมีคำตอบอยู่ที่นั่น" : " first. Many common questions are answered there."}</p>
						</section>

						<section class="policy-section policy-section--full">
							<h2>{locale === "th" ? "บันทึกการติดต่อที่เผยแพร่" : "Published Contact Note"}</h2>
							<PortableText value={page!.data.content} />
						</section>
					</div>
				</>
			) : isAboutPage ? (
				<div class="about-page">
					{/* ── Hero ── */}
					<header class="about-hero">
						<p class="about-eyebrow">{aboutContent.eyebrow}</p>
						<h1 class="about-hero-headline">
							{aboutContent.heroHeadline.split("\n").map((line, index) => (
								<>{index > 0 && <br />}{line}</>
							))}
						</h1>
						<p class="about-hero-body">
							{aboutContent.heroBody.split("\n").map((line, index) => (
								<>{index > 0 && <br />}{line}</>
							))}
						</p>
					</header>

					{/* ── Founder Bio ── */}
					<div class="about-founder">
						<img src="/images/parit-profile.jpg" alt={aboutContent.bioSection.name} class="about-founder-img" />
						<div class="about-founder-body">
							<p class="about-founder-name">{aboutContent.bioSection.name}</p>
							<p class="about-founder-title">{aboutContent.bioSection.title}</p>
							<p class="about-founder-text">
								{aboutContent.bioSection.body.split("\n").map((line, i) => (
									<>{i > 0 && <br />}{line}</>
								))}
							</p>
							<a
								href="https://th.linkedin.com/in/parit-ritchai"
								target="_blank"
								rel="noopener noreferrer"
								class="about-founder-linkedin"
								aria-label="Parit Ritchai on LinkedIn"
							>
								<svg class="about-founder-li-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
									<path d="M17.04 17.043h-2.962v-4.64c0-1.107-.023-2.531-1.544-2.531-1.544 0-1.78 1.204-1.78 2.449v4.722H7.793V7.5h2.844v1.3h.039c.397-.75 1.364-1.54 2.808-1.54 3.001 0 3.556 1.974 3.556 4.542v6.241zM4.447 6.194a1.72 1.72 0 01-1.718-1.72 1.72 1.72 0 011.718-1.72c.948 0 1.718.77 1.718 1.72s-.77 1.72-1.718 1.72zm1.484 10.85H2.96V7.5h2.972v9.543zM18.52 0H1.476C.66 0 0 .645 0 1.44v17.12C0 19.355.66 20 1.476 20H18.52c.816 0 1.48-.645 1.48-1.44V1.44C20 .644 19.336 0 18.52 0z"/>
								</svg>
								<span>LinkedIn</span>
							</a>
						</div>
					</div>

					{/* ── Sections ── */}
					<div class="about-sections">
						{aboutContent.sections.map((section) => (
							<section class="about-section">
								<h2 class="about-section-title">{section.title}</h2>
								<div class="about-section-text">
									{section.content.split("\n\n").map((paragraph) => (
										<p>
											{paragraph.split("\n").map((line, lineIndex) => (
												<>{lineIndex > 0 && <br />}{line}</>
											))}
										</p>
									))}
								</div>
								{section.linkText && section.linkUrl && (
									<a href={localizedPath(section.linkUrl, locale)} class="about-section-link">
										{section.linkText}
									</a>
								)}
							</section>
						))}
					</div>

					{/* ── CTA ── */}
					<footer class="about-cta">
						<p class="about-cta-lead">{aboutContent.ctaLead}</p>
						<div class="about-cta-actions">
							<a href={localizedPath("/system/frameworks/paritsea-framework", locale)} class="about-cta-btn about-cta-btn--primary">{aboutContent.ctaDoctrine}</a>
							<a href={localizedPath("/journal", locale)} class="about-cta-btn about-cta-btn--secondary">{aboutContent.ctaMethod}</a>
						</div>
						<p class="about-cta-contact">
							{aboutContent.ctaContact.split("hello@paritsea.co").map((part, i) => (
								<>{i > 0 && <a href="mailto:hello@paritsea.co">hello@paritsea.co</a>}{part}</>
							))}
						</p>
					</footer>

					{/* ── Social links ── */}
					<p class="about-social">{aboutContent.bio}</p>
				</div>
			) : (
				<div class="page-content">
					<PortableText value={page!.data.content} />
				</div>
			)
		}
	</article>
</Base>

<style>
	.page-article {
		max-width: 720px;
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-6) var(--spacing-20);
	}

	.page-header {
		margin-bottom: var(--spacing-10);
		padding-bottom: var(--spacing-8);
		border-bottom: 1px solid var(--color-border);
	}

	.page-title {
		font-family: var(--font-serif);
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 700;
		line-height: 1.15;
		letter-spacing: -0.02em;
	}

	.page-content :global(p) {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin-bottom: 1.25em;
	}

	.page-content :global(strong) {
		color: var(--color-text);
		font-weight: 600;
	}

	.page-content :global(h2) {
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
		font-weight: 600;
		color: var(--color-text);
		margin-top: 2.5em;
		margin-bottom: 0.75em;
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border-subtle);
	}

	.page-content :global(h3) {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		font-weight: 600;
		color: var(--color-text);
		margin-top: 1.75em;
		margin-bottom: 0.5em;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		font-size: var(--font-size-xs);
	}

	.page-content :global(a) {
		color: var(--color-accent);
		text-decoration: none;
	}

	.page-content :global(a:hover) {
		text-decoration: underline;
	}

	.page-content :global(ul),
	.page-content :global(ol) {
		margin-bottom: 1.25em;
		padding-left: var(--spacing-5);
	}

	.page-content :global(li) {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		color: var(--color-text-secondary);
		margin-bottom: 0.35em;
