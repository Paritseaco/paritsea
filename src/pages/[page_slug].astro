---

<Base
	title={isAboutPage ? aboutContent.title : page.data.title}
	locale={locale}
	content={isAboutPage ? undefined : { collection: "pages", id: page.data.id, slug }}
>
	<article class="page-article">
		{!isAboutPage && (
			<header class="page-header">
				<h1 class="page-title">{page.data.title}</h1>
			</header>
		)}

		{
			isLicensingPage ? (
				<>
					<section class="policy-callout">
						<p class="policy-eyebrow">{locale === "th" ? "สรุปภาษาตรง" : "Plain-language summary"}</p>
						<h2 class="policy-callout-title">{locale === "th" ? "Paritsea เปิดให้อ้างอิงและดัดแปลงได้ แต่ไม่เปิดให้ทำ certification, endorsement หรือ enforcement เชิงพาณิชย์โดยไม่ได้รับอนุญาต" : "Paritsea is open for reference and adaptation, but not for unauthorised certification, endorsement, or commercial enforcement."}</h2>
						<ul class="policy-summary-list">
							{licensingSummary.map((item) => (
								<li>{item}</li>
							))}
						</ul>
					</section>

					<div class="page-content policy-content">
						<section class="policy-section">
							<h2>{locale === "th" ? "สิ่งที่คุณทำได้" : "What You May Do"}</h2>
							<ul>
								{licensingAllowed.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</section>

						<section class="policy-section">
							<h2>{locale === "th" ? "สิ่งที่ต้องขออนุญาต" : "What Requires Permission"}</h2>
							<ul>
								{licensingPermission.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</section>

						<section class="policy-section">
							<h2>{locale === "th" ? "สิ่งที่ห้ามกล่าวอ้าง" : "What You Must Not Claim"}</h2>
							<ul>
								{licensingForbiddenClaims.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</section>

						<section class="policy-section">
							<h2>{locale === "th" ? "ตัวอย่างการให้เครดิต" : "Attribution Example"}</h2>
							<p>{locale === "th" ? "รูปแบบสั้นที่แนะนำ:" : "Recommended short form:"}</p>
							<p class="policy-quote">Based on Paritsea by Parit Ritchai, <a href="https://paritsea.co">paritsea.co</a>.</p>
							<p>{locale === "th" ? "รูปแบบยาวที่แนะนำ:" : "Recommended extended form:"}</p>
							<p class="policy-quote">Adapted from Paritsea, a public reference framework by Parit Ritchai, available at <a href="https://paritsea.co">paritsea.co</a>.</p>
						</section>

						<section class="policy-section">
							<h2>{locale === "th" ? "Adaptation กับ Official Implementation" : "Adaptation vs Official Implementation"}</h2>
							<p><strong>Adaptation</strong> {locale === "th" ? "หมายถึงการใช้แนวคิด Paritsea ในบริบท องค์กร โดเมน หรือชีวิตของคุณเอง ซึ่งอนุญาตภายใต้เงื่อนไขสิทธิการใช้" : "means you are using Paritsea concepts in your own context, organisation, domain, or life. This is allowed within the licensing terms."}</p>
							<p><strong>Official Implementation</strong> {locale === "th" ? "หมายถึงระบบที่ถูกบันทึกหรือยอมรับโดย Paritsea อย่างชัดเจนว่าเป็น implementation ของกรอบนี้ การดัดแปลงเพียงอย่างเดียวไม่ทำให้เกิดสถานะ official" : "means a system has been explicitly documented or recognised by Paritsea as an implementation of the framework. Adaptation alone does not create official status."}</p>
						</section>

						<section class="policy-section">
							<h2>{locale === "th" ? "การใช้ชื่อและแบรนด์" : "Brand and Name Use"}</h2>
							<p>{locale === "th" ? "คุณสามารถอ้างชื่อ Paritsea เพื่อให้เครดิตและอภิปรายได้ แต่ห้ามใช้ชื่อ อัตลักษณ์ หรือแบรนด์ Paritsea เพื่อสื่อถึง partnership, certification, endorsement หรืออำนาจทางการโดยไม่ได้รับอนุญาต" : "You may reference the Paritsea name for attribution and discussion. You may not use the Paritsea name, identity, or branding to imply partnership, certification, endorsement, or formal authority without permission."}</p>
						</section>

						<section class="policy-section">
							<h2>{locale === "th" ? "คำถามที่พบบ่อย" : "Frequently Asked Questions"}</h2>
							<p class="policy-faq-intro">{locale === "th" ? "คำถามทั่วไปเกี่ยวกับการอ้างอิง การดัดแปลง และการนำ Paritsea ไปใช้" : "Common questions about referencing, adapting, and implementing Paritsea."}</p>
							<div class="policy-faq" role="list">
								{licensingFaq.map((item) => (
									<details class="policy-faq-item" role="listitem">
										<summary class="policy-faq-question">{item.question}</summary>
										<div class="policy-faq-answer">
											<p>{item.answer}</p>
										</div>
									</details>
								))}
							</div>
						</section>

						<section class="policy-section policy-section--full">
							<h2>{locale === "th" ? "นโยบายอย่างเป็นทางการ" : "Formal Policy"}</h2>
							<PortableText value={page.data.content} />
						</section>
					</div>
				</>
			) : isContactPage ? (
				<>
					<section class="policy-callout">
						<p class="policy-eyebrow">{locale === "th" ? "การติดต่อ" : "Correspondence"}</p>
						<h2 class="policy-callout-title">{locale === "th" ? "Paritsea เปิดรับการติดต่ออย่างจริงจังเกี่ยวกับสิทธิการใช้ implementation และการใช้กรอบนี้ต่อสาธารณะ" : "Paritsea welcomes serious correspondence about licensing, implementation, and the public use of the framework."}</h2>
						<ul class="policy-summary-list">
							{contactSummary.map((item) => (
								<li>{item}</li>
							))}
						</ul>
					</section>

					<div class="page-content policy-content">
						<section class="policy-section">
							<h2>{locale === "th" ? "ช่องทางหลัก" : "Primary Contact"}</h2>
							<p class="policy-quote"><a href="mailto:hello@paritsea.co">hello@paritsea.co</a></p>
							<p>{locale === "th" ? "โปรดใส่บริบท ลิงก์ และชั้นของกรอบอ้างอิงที่เกี่ยวข้องเมื่อเป็นไปได้ เพื่อให้ประเมินคำถามได้แม่นยำ" : "Include context, links, and the relevant framework layer where possible so the enquiry can be assessed accurately."}</p>
						</section>

						<section class="policy-section">
							<h2>{locale === "th" ? "เหมาะสำหรับ" : "Best Used For"}</h2>
							<ul>
								{contactUseCases.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</section>

						<section class="policy-section">
							<h2>{locale === "th" ? "ไม่เหมาะสำหรับ" : "Not Intended For"}</h2>
							<ul>
								{contactNotFor.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</section>

						<section class="policy-section">
							<h2>{locale === "th" ? "ก่อนเขียนถึงเรา" : "Before You Write"}</h2>
							<p>{locale === "th" ? "หากคำถามของคุณเกี่ยวกับการอ้างอิง การดัดแปลง การให้เครดิต หรือสถานะ official implementation โปรดอ่าน " : "If your question is about reference, adaptation, attribution, or official implementation status, please review the "}<a href={localizedPath("/licensing", locale)}>{locale === "th" ? "นโยบายสิทธิการใช้" : "licensing and use policy"}</a>{locale === "th" ? " ก่อน คำถามทั่วไปจำนวนมากมีคำตอบอยู่ที่นั่น" : " first. Many common questions are answered there."}</p>
						</section>

						<section class="policy-section policy-section--full">
							<h2>{locale === "th" ? "บันทึกการติดต่อที่เผยแพร่" : "Published Contact Note"}</h2>
							<PortableText value={page.data.content} />
						</section>
					</div>
				</>
			) : isAboutPage ? (
				<div class="about-page">
					{/* ── Hero ── */}
					<header class="about-hero">
						<p class="about-eyebrow">{aboutContent.eyebrow}</p>
						<h1 class="about-hero-headline">
							{aboutContent.heroHeadline.split("\n").map((line, index) => (
								<>{index > 0 && <br />}{line}</>
							))}
						</h1>
						<p class="about-hero-body">
							{aboutContent.heroBody.split("\n").map((line, index) => (
								<>{index > 0 && <br />}{line}</>
							))}
						</p>
					</header>

					{/* ── Sections ── */}
					<div class="about-sections">
						{aboutContent.sections.map((section) => (
							<section class="about-section">
								<h2 class="about-section-title">{section.title}</h2>
								<div class="about-section-text">
									{section.content.split("\n\n").map((paragraph, index) => (
										<p key={index}>
											{paragraph.split("\n").map((line, lineIndex) => (
												<>{lineIndex > 0 && <br />}{line}</>
											))}
										</p>
									))}
								</div>
							</section>
						))}
					</div>

					{/* ── CTA ── */}
					<footer class="about-cta">
						<p class="about-cta-lead">{locale === "th" ? "พร้อมที่จะเริ่มมองโลกแบบนี้หรือยัง" : "Ready to start seeing this way?"}</p>
						<div class="about-cta-actions">
							<a href={localizedPath("/the-doctrine", locale)} class="about-cta-btn about-cta-btn--primary">{aboutContent.ctaDoctrine}</a>
							<a href={localizedPath("/the-method", locale)} class="about-cta-btn about-cta-btn--secondary">{aboutContent.ctaMethod}</a>
						</div>
						<p class="about-cta-contact">
							{aboutContent.ctaContact.split("hello@paritsea.co").map((part, i) => (
								<>{i > 0 && <a href="mailto:hello@paritsea.co">hello@paritsea.co</a>}{part}</>
							))}
						</p>
					</footer>

					{/* ── Bio (minimal) ── */}
					<div class="about-bio">
						{aboutContent.bio.split("\n").map((line, index) => (
							<>{index > 0 && <br />}{line}</>
						))}
					</div>
				</div>
			) : (
				<div class="page-content">
					<PortableText value={page.data.content} />
				</div>
			)
		}
	</article>
</Base>

<style>
	.page-article {
		max-width: 720px;
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-6) var(--spacing-20);
	}

	.page-header {
		margin-bottom: var(--spacing-10);
		padding-bottom: var(--spacing-8);
		border-bottom: 1px solid var(--color-border);
	}

	.page-title {
		font-family: var(--font-serif);
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 700;
		line-height: 1.15;
		letter-spacing: -0.02em;
	}

	.page-content :global(p) {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin-bottom: 1.25em;
	}

	.page-content :global(strong) {
		color: var(--color-text);
		font-weight: 600;
	}

	.page-content :global(h2) {
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
		font-weight: 600;
		color: var(--color-text);
		margin-top: 2.5em;
		margin-bottom: 0.75em;
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border-subtle);
	}

	.page-content :global(h3) {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		font-weight: 600;
		color: var(--color-text);
		margin-top: 1.75em;
		margin-bottom: 0.5em;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		font-size: var(--font-size-xs);
	}

	.page-content :global(a) {
		color: var(--color-accent);
		text-decoration: none;
	}

	.page-content :global(a:hover) {
		text-decoration: underline;
	}

	.page-content :global(ul),
	.page-content :global(ol) {
		margin-bottom: 1.25em;
		padding-left: var(--spacing-5);
	}

	.page-content :global(li) {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		color: var(--color-text-secondary);
		margin-bottom: 0.35em;
		line-height: var(--leading-relaxed);
	}

	.policy-callout {
		padding: var(--spacing-6);
		border: 1px solid var(--color-border-subtle);
		background: color-mix(in srgb, var(--color-bg-subtle) 50%, transparent);
		margin-bottom: var(--spacing-10);
	}

	.policy-eyebrow {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: var(--tracking-widest);
		color: var(--color-muted);
		margin: 0 0 var(--spacing-3);
	}

	.policy-callout-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-2xl);
		line-height: 1.2;
		margin: 0 0 var(--spacing-4);
	}

	.policy-summary-list {
		margin: 0;
		padding-left: 1.1rem;
	}

	.policy-summary-list li {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin-bottom: var(--spacing-2);
	}

	.policy-content {
		display: grid;
		gap: var(--spacing-2);
	}

	.policy-section {
		margin-bottom: var(--spacing-6);
	}

	.policy-quote {
		padding: var(--spacing-4);
		border-left: 2px solid var(--color-border);
		background: color-mix(in srgb, var(--color-bg-subtle) 40%, transparent);
	}

	.policy-faq {
		display: grid;
		gap: var(--spacing-3);
	}

	.policy-faq-intro {
		margin-bottom: var(--spacing-4);
	}

	.policy-faq-item {
		border-top: 1px solid var(--color-border-subtle);
		padding-top: var(--spacing-3);
	}

	.policy-faq-item:last-child {
		border-bottom: 1px solid var(--color-border-subtle);
		padding-bottom: var(--spacing-3);
	}

	.policy-faq-question {
		list-style: none;
		cursor: pointer;
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 600;
		line-height: 1.5;
		color: var(--color-text);
		padding-right: var(--spacing-8);
		position: relative;
	}

	.policy-faq-question::-webkit-details-marker {
		display: none;
	}

	.policy-faq-question::after {
		content: "+";
		position: absolute;
		right: 0;
		top: 0;
		font-size: var(--font-size-lg);
		font-weight: 400;
		color: var(--color-muted);
		line-height: 1;
	}

	.policy-faq-item[open] .policy-faq-question::after {
		content: "−";
		color: var(--color-text);
	}

	.policy-faq-answer {
		padding-top: var(--spacing-3);
	}

	.policy-faq-answer p {
		margin: 0;
	}

	.policy-section--full {
		margin-top: var(--spacing-8);
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border);
	}

	/* ─── About Page ─── */
	.about-page {
		max-width: 680px;
	}

	/* Hero */
	.about-hero {
		padding-bottom: var(--spacing-10);
		border-bottom: 1px solid var(--color-border-subtle);
		margin-bottom: var(--spacing-10);
	}

	.about-eyebrow {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 600;
		letter-spacing: var(--tracking-widest);
		text-transform: uppercase;
		color: var(--color-accent);
		margin: 0 0 var(--spacing-6);
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
	}

	.about-eyebrow::before {
		content: "◆";
		font-size: 0.7em;
		color: var(--color-accent);
		opacity: 0.9;
	}

	.about-hero-headline {
		font-family: var(--font-serif);
		font-size: clamp(1.75rem, 4vw, 2.75rem);
		font-weight: 700;
		line-height: 1.2;
		letter-spacing: var(--tracking-tight);
		color: var(--color-text);
		margin: 0 0 var(--spacing-6);
	}

	.about-hero-body {
		font-family: var(--font-sans);
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
	}

	/* Sections */
	.about-sections {
		display: grid;
		gap: var(--spacing-8);
	}

	.about-section {
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border-subtle);
	}

	.about-section-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
		font-weight: 600;
		color: var(--color-text);
		margin: 0 0 var(--spacing-4);
		letter-spacing: var(--tracking-snug);
	}

	.about-section-text {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
	}

	.about-section-text p {
		margin: 0 0 1.25em;
	}

	.about-section-text p:last-child {
		margin-bottom: 0;
	}

	/* CTA */
	.about-cta {
		margin-top: var(--spacing-12);
		padding-top: var(--spacing-8);
		border-top: 1px solid var(--color-border-subtle);
	}

	.about-cta-lead {
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
		font-weight: 600;
		color: var(--color-text);
		margin: 0 0 var(--spacing-5);
		letter-spacing: var(--tracking-snug);
	}

	.about-cta-actions {
		display: flex;
		gap: var(--spacing-4);
		align-items: center;
		margin-bottom: var(--spacing-5);
	}

	.about-cta-btn {
		display: inline-block;
		padding: var(--spacing-3) var(--spacing-7);
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 500;
		letter-spacing: 0.02em;
		text-decoration: none;
		transition: all var(--transition-fast);
	}

	.about-cta-btn--primary {
		background: var(--color-accent);
		color: var(--color-on-accent);
	}

	.about-cta-btn--primary:hover {
		background: var(--color-accent-hover);
		transform: translateY(-1px);
		opacity: 1;
	}

	.about-cta-btn--secondary {
		border: 1px solid var(--color-border);
		color: var(--color-text-secondary);
	}

	.about-cta-btn--secondary:hover {
		border-color: var(--color-accent);
		color: var(--color-text);
		transform: translateY(-1px);
		opacity: 1;
	}

	.about-cta-contact {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		margin: 0;
	}

	.about-cta-contact a {
		color: var(--color-accent);
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.about-cta-contact a:hover {
		opacity: 1;
	}

	/* Bio (minimal, at bottom) */
	.about-bio {
		margin-top: var(--spacing-10);
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border-subtle);
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		line-height: var(--leading-relaxed);
		color: var(--color-muted);
	}

	@media (max-width: 600px) {
		.page-article {
			padding: var(--spacing-8) var(--spacing-4) var(--spacing-12);
		}

		.about-hero-headline {
			font-size: var(--font-size-xl);
		}

		.about-cta-actions {
			flex-direction: column;
			align-items: stretch;
		}

		.about-cta-btn {
			text-align: center;
		}
	}
