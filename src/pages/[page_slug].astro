---
import { getEmDashEntry, decodeSlug } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";

const slug = decodeSlug(Astro.params.page_slug);

if (!slug) {
	return Astro.redirect("/404");
}

// Only handle known page slugs — avoid conflicting with other routes
const KNOWN_PAGE_SLUGS = ["licensing", "contact"];
if (!KNOWN_PAGE_SLUGS.includes(slug)) {
	return Astro.redirect("/404");
}

const { entry: page, cacheHint } = await getEmDashEntry("pages", slug);

if (!page) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);
---

<Base
	title={page.data.title}
	content={{ collection: "pages", id: page.data.id, slug }}
>
	<article class="page-article">
		<header class="page-header">
			<h1 class="page-title" {...page.edit.title}>{page.data.title}</h1>
		</header>

		<div class="page-content">
			<PortableText value={page.data.content} />
		</div>
	</article>
</Base>

<style>
	.page-article {
		max-width: 720px;
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-6) var(--spacing-20);
	}

	.page-header {
		margin-bottom: var(--spacing-10);
		padding-bottom: var(--spacing-8);
		border-bottom: 1px solid var(--color-border);
	}

	.page-title {
		font-family: var(--font-serif);
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 700;
		line-height: 1.15;
		letter-spacing: -0.02em;
	}

	.page-content :global(p) {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin-bottom: 1.25em;
	}

	.page-content :global(strong) {
		color: var(--color-text);
		font-weight: 600;
	}

	.page-content :global(h2) {
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
		font-weight: 600;
		color: var(--color-text);
		margin-top: 2.5em;
		margin-bottom: 0.75em;
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border-subtle);
	}

	.page-content :global(h3) {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		font-weight: 600;
		color: var(--color-text);
		margin-top: 1.75em;
		margin-bottom: 0.5em;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		font-size: var(--font-size-xs);
	}

	.page-content :global(a) {
		color: var(--color-accent);
		text-decoration: none;
	}

	.page-content :global(a:hover) {
		text-decoration: underline;
	}

	.page-content :global(ul),
	.page-content :global(ol) {
		margin-bottom: 1.25em;
		padding-left: var(--spacing-5);
	}

	.page-content :global(li) {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		color: var(--color-text-secondary);
		margin-bottom: 0.35em;
		line-height: var(--leading-relaxed);
	}

	@media (max-width: 600px) {
		.page-article {
			padding: var(--spacing-8) var(--spacing-4) var(--spacing-12);
		}
	}
</style>
