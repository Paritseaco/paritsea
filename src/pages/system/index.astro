---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { getAstroLocale, localizedPath } from "../../utils/i18n";

const locale = getAstroLocale(Astro);
const { entries, cacheHint } = await getEmDashCollection("posts");
Astro.cache.set(cacheHint);

const count = (type: string) => entries.filter((entry) => entry.data.content_type === type).length;
const layers = locale === "th"
	? [
		{ number: "01", state: "จัดระบบแล้ว", name: "Framework", count: count("framework"), href: "/system/frameworks", description: "โครงสร้างที่จัดความสัมพันธ์ของแนวคิด หลักการ และข้อจำกัดให้เป็นระบบเดียวกัน" },
		{ number: "02", state: "นำไปดำเนินการได้", name: "Protocol", count: count("protocol"), href: "/system/protocols", description: "ภาระหน้าที่หรือวิธีดำเนินการที่สืบจาก Framework และต้องรักษาความหมายต้นทาง" },
		{ number: "03", state: "ตรวจสอบได้", name: "Standard", count: count("standard"), href: "/system/standards", description: "เงื่อนไขที่ใช้ตรวจว่าภาระหน้าที่ของ Protocol เกิดขึ้นจริงภายในขอบเขตที่ระบุ" },
	]
	: [
		{ number: "01", state: "Structured", name: "Frameworks", count: count("framework"), href: "/system/frameworks", description: "Structures that organise concepts, principles, and constraints into a coherent reference." },
		{ number: "02", state: "Operable", name: "Protocols", count: count("protocol"), href: "/system/protocols", description: "Obligations or methods derived from a Framework while preserving the meaning of the source." },
		{ number: "03", state: "Verifiable", name: "Standards", count: count("standard"), href: "/system/standards", description: "Conditions used to examine whether a Protocol obligation is present within its stated scope." },
	];

const copy = locale === "th" ? {
	title: "งานอ้างอิง — Paritsea",
	role: "ศูนย์รวมงานที่จัดระบบแล้ว",
	headline: "เมื่อข้อสังเกตต้องรับผิดชอบมากกว่าการเป็นข้อสังเกต",
	summary: "พื้นที่นี้รวม Framework, Protocol และ Standard ที่มีสถานะ เวอร์ชัน ที่มา และขอบเขตชัดเจน งานเหล่านี้อ่านเพื่ออ้าง ตรวจสอบ หรือประยุกต์ภายใต้เงื่อนไขของแต่ละฉบับ",
	choose: "เลือกตามบทบาทของงาน",
	chooseNote: "ทั้งสามประเภทไม่ใช่ระดับคุณค่าที่สูงขึ้นตามลำดับ แต่ตอบคำถามคนละแบบ",
	path: "งานเกิดขึ้นอย่างไร",
	pathTitle: "เส้นทางนี้เป็นแผนที่ ไม่ใช่สายพาน",
	pathBody: "บันทึกหนึ่งชิ้นอาจหยุดอยู่ใน Journal รูปแบบหนึ่งอาจถูกตั้งชื่อเป็น Concept โดยไม่กลายเป็น Framework และ Standard จะเกิดขึ้นต่อเมื่อมีสิ่งที่ควรตรวจจริง การ formalize คือการเพิ่มภาระความรับผิดชอบ ไม่ใช่การประกาศว่างานสำคัญกว่าเดิม",
	boundary: "ขอบเขต",
	boundaryTitle: "เอกสารอ้างอิงไม่ใช่บริการ",
	boundaryBody: "Paritsea รักษาฉบับต้นทางและประวัติการเปลี่ยนแปลง การนำงานไปใช้กับองค์กรอยู่ในบริบทของผู้ประยุกต์ และไม่แก้ canonical record โดยอัตโนมัติ",
	useLink: "ตรวจวิธีใช้และอ้างอิง",
} : {
	title: "Reference work — Paritsea",
	role: "Hub for structured work",
	headline: "When an observation must carry more responsibility than observation alone",
	summary: "This hub holds Frameworks, Protocols, and Standards with explicit status, version, provenance, and scope. They are read to cite, examine, or apply under the conditions of each record.",
	choose: "Choose by the role of the work",
	chooseNote: "The three types are not ascending levels of value. They answer different questions.",
	path: "How work develops",
	pathTitle: "The path is a map, not a production line",
	pathBody: "A Journal entry may remain a Journal entry. A pattern may become a Concept without becoming a Framework. A Standard only emerges when something genuinely needs to be examined. Formalising adds responsibility; it does not declare the work more important.",
	boundary: "Boundary",
	boundaryTitle: "Reference work is not a service",
	boundaryBody: "Paritsea keeps the source record and its history of change. Organizational application belongs to the interpreter's context and does not automatically revise the canonical record.",
	useLink: "Review use and citation",
};
---

<Base title={copy.title} description={copy.summary} locale={locale}>
	<main class="experience-page system-page">
		<Breadcrumb crumbs={[{ label: locale === "th" ? "หน้าแรก" : "Home", href: localizedPath("/", locale) }, { label: locale === "th" ? "งานอ้างอิง" : "Reference work" }]} />
		<header class="system-intro">
			<p class="experience-label" data-state="governed">{copy.role}</p>
			<h1 class="experience-title">{copy.headline}</h1>
			<p class="experience-summary">{copy.summary}</p>
		</header>

		<section class="experience-section" aria-labelledby="layers-title">
			<div class="experience-section-heading">
				<h2 id="layers-title">{copy.choose}</h2>
				<p>{copy.chooseNote}</p>
			</div>
			<div class="experience-index">
				{layers.map((layer) => (
					<a class="experience-index-row" href={localizedPath(layer.href, locale)}>
						<span class="experience-index-meta">{layer.number} · {layer.state}</span>
						<div class="experience-index-copy">
							<h3>{layer.name}</h3>
							<p>{layer.description}</p>
						</div>
						<span class="experience-index-state">{String(layer.count).padStart(2, "0")} {locale === "th" ? "งาน" : "works"} →</span>
					</a>
				))}
			</div>
		</section>

		<section class="experience-section system-path" aria-labelledby="path-title">
			<div>
				<p class="experience-label" data-state="moving">{copy.path}</p>
				<h2 id="path-title">{copy.pathTitle}</h2>
				<p>{copy.pathBody}</p>
			</div>
			<ol aria-label={copy.path}>
				{["Journal", "Concept", "Framework", "Protocol", "Standard"].map((label, index) => (
					<li data-state={index === 0 ? "open" : index === 1 ? "named" : "governed"}><span>{String(index + 1).padStart(2, "0")}</span>{label}</li>
				))}
			</ol>
		</section>

		<section class="experience-section">
			<div class="experience-note">
				<div><p class="experience-label" data-state="governed">{copy.boundary}</p><h2>{copy.boundaryTitle}</h2></div>
				<div><p>{copy.boundaryBody}</p><a class="experience-link" href={localizedPath("/ip", locale)}>{copy.useLink} <span aria-hidden="true">→</span></a></div>
			</div>
		</section>
	</main>
</Base>

<style>
	.system-intro { max-width: 1080px; padding: var(--spacing-12) 0 var(--spacing-16); border-bottom: 1px solid var(--color-border); }
	.system-path { display: grid; grid-template-columns: minmax(0, .8fr) minmax(320px, 1.2fr); gap: clamp(var(--spacing-10), 8vw, var(--spacing-24)); }
	.system-path h2 { max-width: 14ch; margin-top: var(--spacing-5); font-family: var(--font-serif); font-size: clamp(2.2rem, 4vw, 4rem); font-weight: 500; line-height: 1.05; }
	.system-path > div > p:last-child { max-width: 56ch; margin-top: var(--spacing-6); color: var(--color-text-secondary); line-height: 1.75; }
	.system-path ol { list-style: none; align-self: start; border-top: 1px solid var(--color-border); }
	.system-path li { position: relative; display: grid; grid-template-columns: 4rem 1fr; padding: var(--spacing-5) 0; border-bottom: 1px solid var(--color-border-subtle); font-family: var(--font-serif); font-size: var(--font-size-2xl); }
	.system-path li::after { content: ""; position: absolute; right: 0; top: 50%; width: 8px; height: 8px; border: 1px solid var(--color-muted); border-radius: 50%; }
	.system-path li[data-state="named"]::after { background: color-mix(in srgb, var(--color-accent) 28%, transparent); border-color: var(--color-accent); }
	.system-path li[data-state="governed"]::after { background: var(--color-accent); border-color: var(--color-accent); }
	.system-path li span { font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--color-muted); }
	:global(:lang(th)) .system-path h2, :global(:lang(th)) .system-path li { font-family: var(--font-sans); font-weight: 300; letter-spacing: 0; line-height: 1.45; }
	:global(:lang(th)) .system-path > div > p:last-child { font-size: 1.0625rem; line-height: 1.9; letter-spacing: 0; word-break: keep-all; }
	:global(:lang(th)) .system-path li span { font-family: var(--font-sans); font-size: .875rem; letter-spacing: 0; }
	@media (max-width: 800px) { .system-path { grid-template-columns: 1fr; } }
</style>
