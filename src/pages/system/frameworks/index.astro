---
import { getEmDashCollection } from "emdash";
import Base from "../../../layouts/Base.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import { getAstroLocale, localizeEntry, localizedPath } from "../../../utils/i18n";
import { localizeRecordValue } from "../../../utils/intellectual-localization";

const locale = getAstroLocale(Astro);
const { entries, cacheHint } = await getEmDashCollection("posts", { where: { framework_page: "the-doctrine" } });
Astro.cache.set(cacheHint);
const works = entries.map((entry) => localizeEntry(entry, "posts", locale));
const copy = locale === "th" ? {
	title: "Framework — Paritsea", role: "ศูนย์รวม Framework", headline: "โครงสร้างที่ทำให้แนวคิดหลายส่วนรับผิดชอบต่อกัน", summary: "Framework จัดความสัมพันธ์ระหว่างแนวคิด หลักการ และข้อจำกัดให้เป็นระบบที่อ้างอิงได้ แต่ไม่ใช่คำตอบสำเร็จรูป ทุกฉบับต้องระบุขอบเขต เวอร์ชัน ที่มา และสิ่งที่ยังไม่ยืนยัน", count: "Framework ที่เผยแพร่", open: "เปิดเอกสารฉบับเต็ม",
} : {
	title: "Frameworks — Paritsea", role: "Framework hub", headline: "Structures that make related ideas accountable to one another", summary: "A Framework organises concepts, principles, and constraints into a citable system. It is not a universal answer. Every record must state its scope, version, provenance, and what it does not establish.", count: "published Frameworks", open: "Open full document",
};
---
<Base title={copy.title} description={copy.summary} locale={locale}>
	<main class="experience-page framework-hub">
		<Breadcrumb crumbs={[{ label: locale === "th" ? "งานอ้างอิง" : "Reference work", href: localizedPath("/system", locale) }, { label: "Framework" }]} />
		<header><div><p class="experience-label" data-state="governed">{copy.role}</p><h1 class="experience-title">{copy.headline}</h1><p class="experience-summary">{copy.summary}</p></div><dl><dt>{copy.count}</dt><dd>{String(works.length).padStart(2, "0")}</dd></dl></header>
		<section class="experience-index">
			{works.map((work, index) => <a class="experience-index-row" href={localizedPath("/system/frameworks/paritsea-framework", locale)}><span class="experience-index-meta">{String(index + 1).padStart(2, "0")} · Framework</span><div class="experience-index-copy"><h3>{work.data.title}</h3>{work.data.excerpt && <p>{work.data.excerpt}</p>}</div><span class="experience-index-state">v{work.id === "doctrine" ? "1.1" : work.data.document_version ?? "1.0"} · {localizeRecordValue(locale, work.data.lifecycle_status ?? "current")}<br />{copy.open} →</span></a>)}
		</section>
	</main>
</Base>
<style>
	.framework-hub header { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: var(--spacing-12); align-items: end; padding: var(--spacing-12) 0 var(--spacing-16); border-bottom: 1px solid var(--color-border); }
	.framework-hub dl { min-width: 170px; padding-left: var(--spacing-6); border-left: 1px solid var(--color-border); }
	.framework-hub dt { font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--color-muted); text-transform: uppercase; letter-spacing: var(--tracking-wide); }
	.framework-hub dd { margin-top: var(--spacing-2); font-family: var(--font-serif); font-size: clamp(3rem, 7vw, 6rem); line-height: .9; color: var(--color-accent); }
	:global(:lang(th)) .framework-hub dt { font-family: var(--font-sans); font-size: .875rem; text-transform: none; letter-spacing: 0; }
	:global(:lang(th)) .framework-hub dd { font-family: var(--font-sans); font-weight: 300; }
	@media (max-width: 700px) { .framework-hub header { grid-template-columns: 1fr; } .framework-hub dl { padding: var(--spacing-5) 0 0; border: 0; border-top: 1px solid var(--color-border-subtle); } }
</style>
