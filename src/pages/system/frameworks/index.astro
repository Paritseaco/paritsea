---
import { getEmDashCollection } from "emdash";
import Base from "../../../layouts/Base.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import PageRoleHeader from "../../../components/PageRoleHeader.astro";
import { getAstroLocale, localizeEntry, localizedPath } from "../../../utils/i18n";

const locale = getAstroLocale(Astro);
const { entries, cacheHint } = await getEmDashCollection("posts", { where: { framework_page: "the-doctrine" } });
Astro.cache.set(cacheHint);
const works = entries.map((entry) => localizeEntry(entry, "posts", locale));
const title = locale === "th" ? "Frameworks" : "Frameworks";
const intro = locale === "th"
	? "ศูนย์รวมเอกสารที่จัดระเบียบแนวคิดและข้อจำกัดที่เกี่ยวข้อง Framework ไม่ใช่คำตอบสำเร็จรูป และแต่ละฉบับต้องระบุ scope, version และสิ่งที่ยังไม่ยืนยัน"
	: "The hub for documents that organise related concepts and constraints. A Framework is not a universal answer; each one names its scope, version, and what it does not establish.";
---

<Base title={title} description={intro} locale={locale}>
	<div class="archive-shell">
		<Breadcrumb crumbs={[{ label: "System", href: localizedPath("/system", locale) }, { label: "Frameworks" }]} />
		<PageRoleHeader role="Hub" eyebrow="System" title={title} intro={intro} count={works.length} statusLabel={locale === "th" ? "เอกสารฉบับเต็มอยู่ในหน้ารายละเอียด" : "Full documents open on detail pages"} />
		<section class="archive-list" aria-label={title}>
			{works.length > 0 ? works.map((work) => (
				<a class="archive-row" href={localizedPath("/system/frameworks/paritsea-framework", locale)}>
					<span class="archive-type">Framework · v1.0 · current</span>
					<h2>{work.data.title}</h2>
					<p>{work.data.excerpt}</p>
					<span class="archive-open">{locale === "th" ? "เปิดเอกสารฉบับเต็ม →" : "Open full document →"}</span>
				</a>
			)) : <p class="empty">{locale === "th" ? "ยังไม่มี Framework ที่เผยแพร่" : "No published Frameworks yet."}</p>}
		</section>
	</div>
</Base>

<style>
	.archive-shell { width: var(--wide-width); margin: 0 auto; padding: var(--spacing-8) 0 var(--spacing-24); }
	.archive-list { margin-top: var(--spacing-12); border-top: 1px solid var(--color-border); }
	.archive-row { display: grid; grid-template-columns: 190px minmax(0, 1fr) 220px; gap: var(--spacing-8); padding: var(--spacing-8) 0; border-bottom: 1px solid var(--color-border-subtle); }
	.archive-row h2 { font-size: clamp(1.6rem, 3vw, 2.4rem); font-weight: 500; }
	.archive-row p { grid-column: 2; max-width: 62ch; color: var(--color-text-secondary); }
	.archive-type, .archive-open { font-family: var(--font-mono); font-size: var(--font-size-sm); color: var(--color-muted); }
	.archive-open { color: var(--color-accent); text-align: right; }
	.empty { padding: var(--spacing-8) 0; color: var(--color-muted); }
	:global(:lang(th)) .archive-type, :global(:lang(th)) .archive-open { font-family: var(--font-sans); font-size: var(--font-size-sm); letter-spacing: 0; line-height: 1.55; }
	:global(:lang(th)) .archive-row p { font-size: 1.0625rem; line-height: 1.85; }
	@media (max-width: 820px) { .archive-row { grid-template-columns: 1fr; } .archive-row p { grid-column: auto; } .archive-open { text-align: left; } }
</style>
