---
export const prerender = false;

import { getEmDashCollection, getEntryTerms } from "emdash";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import {
	isFrameworkPageSlug,
	resolveFrameworkPage,
	resolvePostPath,
} from "../utils/public-paths";
import { getReadingTime, extractText } from "../utils/reading-time";
import { getAstroLocale, localizeEntry, localizedPath } from "../utils/i18n";

const query = Astro.url.searchParams.get("q")?.trim() || "";
const locale = getAstroLocale(Astro);

const { entries: allPosts } = await getEmDashCollection("posts");

// Simple search: match query against title, excerpt, and content
function matchesQuery(post: (typeof allPosts)[0], q: string): boolean {
	if (!q) return false;
	const lower = q.toLowerCase();
	const title = (post.data.title || "").toLowerCase();
	const excerpt = (post.data.excerpt || "").toLowerCase();
	// Extract plain text from portable text blocks (avoids matching on _type, _key, etc.)
	const content = extractText(post.data.content).toLowerCase();
	return (
		title.includes(lower) || excerpt.includes(lower) || content.includes(lower)
	);
}

const localizedPosts = allPosts.map((post) => localizeEntry(post, "posts", locale));
const results = query ? localizedPosts.filter((p) => matchesQuery(p, query)) : [];
const resultsWithHref = await Promise.all(
	results.map(async (post) => {
		const legacyTerms = await getEntryTerms("posts", post.data.id, "category");
		const frameworkPage = resolveFrameworkPage(
			post.data.framework_page,
			legacyTerms.find((term) => isFrameworkPageSlug(term.slug))?.slug,
		);
		return {
			post,
			href:
				localizedPath(resolvePostPath(post.id, frameworkPage, null) ??
				`/the-method/${post.id}`, locale),
		};
	}),
);
const copy = locale === "th"
	? {
			title: "ค้นหา",
			description: "ค้นหาในคลังอ้างอิงสาธารณะของ Paritsea",
			placeholder: "ค้นหา entry...",
			button: "ค้นหา",
			noResults: (q: string) => `ไม่พบผลลัพธ์สำหรับ "${q}"`,
			results: (count: number, q: string) => `${count} ผลลัพธ์สำหรับ "${q}"`,
			hint: "พิมพ์คำค้นเพื่อค้นหา entry",
		}
	: {
			title: "Search",
			description: "Search the Paritsea public archive.",
			placeholder: "Search posts...",
			button: "Search",
			noResults: (q: string) => `No results for "${q}"`,
			results: (count: number, q: string) => `${count} result${count === 1 ? "" : "s"} for "${q}"`,
			hint: "Enter a search term to find posts.",
		};
---

<Base
	title={query ? `${copy.title}: ${query}` : copy.title}
	description={copy.description}
	robots="noindex, follow"
	locale={locale}
>
	<section class="search-page">
		<h1 class="search-title">{copy.title}</h1>

		<form method="get" action={localizedPath("/search", locale)} class="search-form">
			<input
				type="search"
				name="q"
				value={query}
				placeholder={copy.placeholder}
				class="search-input"
				autofocus
			/>
			<button type="submit" class="search-button">{copy.button}</button>
		</form>

		{
			query && (
				<p class="search-summary">
					{results.length === 0
						? copy.noResults(query)
						: copy.results(results.length, query)}
				</p>
			)
		}

		{
			resultsWithHref.length > 0 && (
				<div class="search-results">
					{resultsWithHref.map(({ post, href }) => (
						<PostCard
							title={post.data.title}
							excerpt={post.data.excerpt}
							featuredImage={post.data.featured_image}
							href={href}
							date={post.data.publishedAt ?? undefined}
							readingTime={getReadingTime(post.data.content)}
							locale={locale}
						/>
					))}
				</div>
			)
		}

		{!query && <p class="search-hint">{copy.hint}</p>}
	</section>
</Base>

<style>
	.search-page {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: var(--spacing-8) var(--spacing-6) var(--spacing-16);
	}

	.search-title {
		font-size: var(--font-size-2xl);
		margin-bottom: var(--spacing-6);
	}

	.search-form {
		display: flex;
		gap: var(--spacing-2);
		margin-bottom: var(--spacing-8);
	}

	.search-input {
		flex: 1;
		padding: var(--spacing-2) var(--spacing-4);
		font-size: var(--font-size-base);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-bg);
		color: var(--color-text);
	}

	.search-input:focus {
		outline: none;
		border-color: var(--color-accent);
	}

	.search-button {
		padding: var(--spacing-2) var(--spacing-6);
		font-size: var(--font-size-base);
		background: var(--color-accent);
		color: var(--color-on-accent);
		border: none;
		border-radius: var(--radius);
		cursor: pointer;
		font-weight: 500;
	}

	.search-button:hover {
		opacity: 0.9;
	}

	.search-summary {
		color: var(--color-muted);
		margin-bottom: var(--spacing-6);
	}

	.search-hint {
		color: var(--color-muted);
	}

	.search-results {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-8);
	}
</style>
