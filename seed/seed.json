  "content": {
    "pages": [
      {
        "id": "licensing",
        "slug": "licensing",
        "status": "published",
        "data": {
          "title": "Licensing & Use",
          "content": [
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "marks": [
                    "strong"
                  ],
                  "text": "Authorship and stewardship"
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Paritsea is an author-led intellectual practice. Parit Ritchai is the author and change authority; Paritsea is the publisher and public steward of the canonical record."
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Published Frameworks, Protocols, and Standards remain publicly traceable so their provenance, version, scope, and revisions can be inspected."
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Licensing and use boundaries protect attribution and canonical integrity; they do not restrict legitimate reading, reference, or critique."
                }
              ]
            },
            {
              "_type": "block",
              "style": "h2",
              "children": [
                {
                  "_type": "span",
                  "text": "Open Licence (Non-Commercial Use)"
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Unless a specific work states otherwise, published Paritsea Frameworks, Protocols, and Standards are available for non-commercial reference under the Creative Commons Attribution–NonCommercial 4.0 International Licence (CC BY-NC 4.0)."
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Full legal terms are available at: creativecommons.org/licenses/by-nc/4.0/"
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Non-commercial use is permitted with proper attribution."
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "This licence applies to: The Paritsea Doctrine — All published Standards — All published Protocols — Public explanatory texts — Official diagrams and structural models"
                }
              ]
            },
            {
              "_type": "block",
              "style": "h2",
              "children": [
                {
                  "_type": "span",
                  "text": "Attribution Requirements"
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Attribution must clearly include: The name \"Paritsea\" — Author: Parit Ritchai — Reference to the original source — A link to the official Paritsea website"
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Attribution must not imply endorsement, partnership, certification, or institutional affiliation unless explicitly authorised."
                }
              ]
            },
            {
              "_type": "block",
              "style": "h2",
              "children": [
                {
                  "_type": "span",
                  "text": "Commercial Implementation"
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Commercial implementation of any Paritsea Protocol or Standard requires a separate commercial licence agreement."
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Commercial implementation includes, but is not limited to: Platform enforcement — Revenue-generating services — Certification systems — Institutional integration — Proprietary deployment within commercial entities"
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Enquiries: hello@paritsea.co"
                }
              ]
            },
            {
              "_type": "block",
              "style": "h2",
              "children": [
                {
                  "_type": "span",
                  "text": "Dual Licensing Framework"
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Paritsea may grant: Standard commercial licences — Dual licences (open + commercial usage rights) — Exclusive commercial licences within defined domains"
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Licensing cannot silently alter canonical content. Canonical meaning may change only through an explicit, attributable, versioned revision published by Paritsea."
                }
              ]
            },
            {
              "_type": "block",
              "style": "h2",
              "children": [
                {
                  "_type": "span",
                  "text": "Canonical Integrity Clause"
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "marks": [
                    "strong"
                  ],
                  "text": "Canonical change must be explicit and versioned."
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Frameworks, Protocols, and Standards may evolve through documented revision. No commercial agreement or applied adaptation may silently change the canonical source. Permission to use does not grant authority to publish a new canonical version."
                }
              ]
            },
            {
              "_type": "block",
              "style": "h2",
              "children": [
                {
                  "_type": "span",
                  "text": "Prohibited Representations"
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "The following are prohibited without explicit written agreement: Claiming certification by Paritsea — Presenting compliance as endorsement — Modifying Protocol or Standard criteria while retaining the Paritsea name — Using Paritsea branding to imply regulatory authority"
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Paritsea is a reference framework, not a regulator."
                }
              ]
            },
            {
              "_type": "block",
              "style": "h2",
              "children": [
                {
                  "_type": "span",
                  "text": "Version Sovereignty"
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "marks": [
                    "strong"
                  ],
                  "text": "Protocols and Standards are versioned."
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Each commercial licence is contract-specific and version-specific."
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Adoption of newer versions is not automatic. Previously licensed versions may continue under their granted terms. Parit Ritchai retains authorial change authority and Paritsea preserves the record across versions. Licensees retain implementation autonomy within the bounds of their licensed version but may not present an adaptation as canonical."
                }
              ]
            },
            {
              "_type": "block",
              "style": "h2",
              "children": [
                {
                  "_type": "span",
                  "text": "Summary"
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Paritsea is open for reference under the terms stated for each work. Non-commercial use is permitted with attribution where CC BY-NC 4.0 applies. Commercial implementation may require agreement. Canonical works are version-governed, and permission to implement does not grant authority to redefine the source."
                }
              ]
            }
          ]
        }
